<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.AdvancedPasteModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" Spacing="14">

            <!--  Header  -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="22" Glyph="&#xE77F;" VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="ResultBar" IsClosable="True" IsOpen="False" />

            <!--  Hotkey / enable card  -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="HotkeyTitle" FontWeight="SemiBold" FontSize="15" />
                            <TextBlock x:Name="HotkeyStatus" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="HotkeySwitch" Grid.Column="1" Toggled="Hotkey_Toggled" VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="HotkeyLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="HotkeyCombo" SelectionChanged="Hotkey_ComboChanged" MinWidth="220" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="DefaultLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="DefaultCombo" SelectionChanged="Default_Changed" MinWidth="260" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  AI provider note  -->
            <InfoBar x:Name="AiBar" IsClosable="False" IsOpen="True" />

            <!--  Try-it-now card (run an action on the current clipboard with preview)  -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="TryTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="TryBlurb" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ComboBox x:Name="TryCombo" MinWidth="260" />
                        <Button x:Name="PreviewBtn" Click="Preview_Click" />
                        <Button x:Name="CopyResultBtn" Click="CopyResult_Click" />
                    </StackPanel>
                    <TextBox x:Name="AiInstruction" PlaceholderText="" Visibility="Collapsed" />
                    <TextBox x:Name="PreviewBox" AcceptsReturn="True" IsReadOnly="True" TextWrapping="Wrap"
                             MinHeight="120" MaxHeight="260" Visibility="Collapsed"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" FontFamily="Consolas" />
                </StackPanel>
            </Border>

            <!--  Enabled-actions checklist  -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="ActionsTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="ActionsBlurb" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <StackPanel x:Name="ActionsList" Spacing="6" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
