<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.TextWrapModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8A5;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="InputLabel" FontWeight="SemiBold" />
                    <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="150"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" FontFamily="Consolas"
                             TextChanged="Input_Changed" />

                    <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock x:Name="WidthLabel" VerticalAlignment="Center" />
                            <NumberBox x:Name="WidthBox" Value="72" Minimum="1" Maximum="2000" SpinButtonPlacementMode="Inline" MinWidth="130" ValueChanged="Width_Changed" />
                        </StackPanel>
                        <TextBlock x:Name="ReadoutText" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                    </StackPanel>

                    <CheckBox x:Name="BreakLongChk" />

                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock x:Name="PrefixLabel" VerticalAlignment="Center" />
                        <TextBox x:Name="PrefixBox" MinWidth="120" Text="&gt; " />
                        <TextBlock x:Name="IndentLabel" VerticalAlignment="Center" Margin="12,0,0,0" />
                        <NumberBox x:Name="IndentBox" Value="4" Minimum="0" Maximum="200" SpinButtonPlacementMode="Inline" MinWidth="120" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="WrapBtn" Click="Wrap_Click" />
                        <Button x:Name="UnwrapBtn" Click="Unwrap_Click" />
                        <Button x:Name="ReflowBtn" Click="Reflow_Click" />
                        <Button x:Name="PrefixBtn" Click="Prefix_Click" />
                        <Button x:Name="IndentBtn" Click="Indent_Click" />
                    </StackPanel>

                    <TextBlock x:Name="OutputLabel" FontWeight="SemiBold" />
                    <TextBox x:Name="OutputBox" AcceptsReturn="True" TextWrapping="NoWrap" IsReadOnly="True" MinHeight="150"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" />

                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button x:Name="CopyBtn" Click="Copy_Click" />
                        <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
