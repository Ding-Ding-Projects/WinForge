<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.WiresharkModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:svc="using:WinForge.Services"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- One packet row, drawn as a tab-aligned grid line. -->
        <DataTemplate x:Key="PacketRowTemplate" x:DataType="svc:PacketRow">
            <Grid ColumnSpacing="8" Padding="0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{x:Bind No}" FontFamily="Consolas" FontSize="12" />
                <TextBlock Grid.Column="1" Text="{x:Bind Time}" FontFamily="Consolas" FontSize="12" />
                <TextBlock Grid.Column="2" Text="{x:Bind Source}" FontFamily="Consolas" FontSize="12" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="3" Text="{x:Bind Destination}" FontFamily="Consolas" FontSize="12" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="4" Text="{x:Bind Protocol}" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                <TextBlock Grid.Column="5" Text="{x:Bind Length}" FontFamily="Consolas" FontSize="12" />
                <TextBlock Grid.Column="6" Text="{x:Bind Info}" FontFamily="Consolas" FontSize="12" TextTrimming="CharacterEllipsis" />
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid Style="{StaticResource WinForgePageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <controls:ModuleHeader x:Name="Header" Grid.Row="0" Glyph="&#xEDA3;" />
        <TextBlock x:Name="HeaderBlurb" Grid.Row="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

        <InfoBar x:Name="EngineBar" Grid.Row="2" IsClosable="False" IsOpen="False" Margin="0,2,0,0" />
        <InfoBar x:Name="NpcapBar" Grid.Row="3" IsClosable="False" IsOpen="False" />
        <InfoBar x:Name="AdminBar" Grid.Row="4" IsClosable="True" IsOpen="False" Severity="Warning" />

        <InfoBar x:Name="ResultBar" Grid.Row="5" IsClosable="True" IsOpen="False" Margin="0,2,0,0" />

        <Pivot Grid.Row="6" Margin="0,2,0,0">

            <!-- ════════ Live capture ════════ -->
            <PivotItem x:Name="CaptureTab">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- interface picker -->
                    <Grid Grid.Row="0" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="RefreshBtn" Grid.Column="0" Click="Refresh_Click"><FontIcon Glyph="&#xE72C;" FontSize="14" /></Button>
                        <ComboBox x:Name="InterfaceBox" Grid.Column="1" HorizontalAlignment="Stretch" PlaceholderText="Interface · 介面" />
                        <ProgressRing x:Name="Busy" Grid.Column="2" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
                    </Grid>

                    <!-- capture / display filters -->
                    <Grid Grid.Row="1" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="CaptureFilterBox" Grid.Column="0" FontFamily="Consolas"
                                 PlaceholderText="Capture filter (BPF) e.g. tcp port 443" />
                        <TextBox x:Name="DisplayFilterBox" Grid.Column="1" FontFamily="Consolas"
                                 PlaceholderText="Display filter e.g. http || dns" />
                    </Grid>

                    <!-- output file + options -->
                    <Grid Grid.Row="2" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="OutputFileBox" Grid.Column="0" FontFamily="Consolas" IsReadOnly="True" />
                        <Button x:Name="ChooseFileBtn" Grid.Column="1" Click="ChooseFile_Click" />
                    </Grid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="14">
                        <CheckBox x:Name="PromiscuousCheck" IsChecked="True" VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock x:Name="StopSecCap" VerticalAlignment="Center" />
                            <NumberBox x:Name="StopSecBox" Value="0" Minimum="0" SpinButtonPlacementMode="Compact" Width="110" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock x:Name="StopPktCap" VerticalAlignment="Center" />
                            <NumberBox x:Name="StopPktBox" Value="0" Minimum="0" SpinButtonPlacementMode="Compact" Width="110" />
                        </StackPanel>
                        <CheckBox x:Name="RingCheck" VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock x:Name="RingFilesCap" VerticalAlignment="Center" />
                            <NumberBox x:Name="RingFilesBox" Value="4" Minimum="2" SpinButtonPlacementMode="Compact" Width="90" />
                            <TextBlock x:Name="RingSizeCap" VerticalAlignment="Center" />
                            <NumberBox x:Name="RingSizeBox" Value="2048" Minimum="64" SpinButtonPlacementMode="Compact" Width="110" />
                        </StackPanel>
                    </StackPanel>

                    <!-- start / stop / counters -->
                    <Grid Grid.Row="4" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="StartBtn" Grid.Column="0" Click="Start_Click" Style="{StaticResource AccentButtonStyle}" />
                        <Button x:Name="StopBtn" Grid.Column="1" Click="Stop_Click" IsEnabled="False" />
                        <Button x:Name="ClearBtn" Grid.Column="2" Click="Clear_Click" />
                        <Button x:Name="OpenWiresharkBtn" Grid.Column="3" Click="OpenWireshark_Click" />
                        <TextBlock x:Name="CounterText" Grid.Column="5" VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>

                    <!-- column header + live grid -->
                    <Border Grid.Row="5" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <Grid RowSpacing="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" ColumnSpacing="8" Padding="12,6"
                                  Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="ColNo" Grid.Column="0" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock x:Name="ColTime" Grid.Column="1" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock x:Name="ColSrc" Grid.Column="2" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock x:Name="ColDst" Grid.Column="3" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock x:Name="ColProto" Grid.Column="4" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock x:Name="ColLen" Grid.Column="5" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock x:Name="ColInfo" Grid.Column="6" FontWeight="SemiBold" FontSize="12" />
                            </Grid>
                            <ListView x:Name="PacketList" Grid.Row="1"
                                      ItemTemplate="{StaticResource PacketRowTemplate}"
                                      SelectionChanged="PacketList_SelectionChanged"
                                      Padding="12,2,12,2">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="MinHeight" Value="0" />
                                        <Setter Property="Padding" Value="0,1" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                            </ListView>
                        </Grid>
                    </Border>

                    <!-- packet detail pane -->
                    <Expander x:Name="DetailExpander" Grid.Row="6" HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch" IsExpanded="False">
                        <ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <TextBox x:Name="DetailText" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                                     FontFamily="Consolas" FontSize="12" BorderThickness="0" Background="Transparent" />
                        </ScrollViewer>
                    </Expander>
                </Grid>
            </PivotItem>

            <!-- ════════ Open file ════════ -->
            <PivotItem x:Name="FileTab">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="OpenFileBtn" Grid.Column="0" Click="OpenFile_Click" />
                        <TextBox x:Name="OpenedFileBox" Grid.Column="1" FontFamily="Consolas" IsReadOnly="True" />
                    </Grid>

                    <Grid Grid.Row="1" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="FileFilterBox" Grid.Column="0" FontFamily="Consolas"
                                 PlaceholderText="Display filter e.g. tcp.port==443" KeyDown="FileFilter_KeyDown" />
                        <Button x:Name="ApplyFilterBtn" Grid.Column="1" Click="ApplyFilter_Click" Style="{StaticResource AccentButtonStyle}" />
                        <Button x:Name="ExportBtn" Grid.Column="2" Click="Export_Click" />
                    </Grid>

                    <TextBlock x:Name="FileCounterText" Grid.Row="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <Border Grid.Row="3" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" ColumnSpacing="8" Padding="12,6"
                                  Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="FColNo" Grid.Column="0" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock x:Name="FColTime" Grid.Column="1" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock x:Name="FColSrc" Grid.Column="2" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock x:Name="FColDst" Grid.Column="3" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock x:Name="FColProto" Grid.Column="4" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock x:Name="FColLen" Grid.Column="5" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock x:Name="FColInfo" Grid.Column="6" FontWeight="SemiBold" FontSize="12" />
                            </Grid>
                            <ListView x:Name="FilePacketList" Grid.Row="1"
                                      ItemTemplate="{StaticResource PacketRowTemplate}"
                                      SelectionChanged="FilePacketList_SelectionChanged"
                                      Padding="12,2,12,2">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="MinHeight" Value="0" />
                                        <Setter Property="Padding" Value="0,1" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </PivotItem>

            <!-- ════════ Packet detail (offline) ════════ -->
            <PivotItem x:Name="DetailTab">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                        <TextBlock x:Name="FrameNoCap" VerticalAlignment="Center" />
                        <NumberBox x:Name="FrameNoBox" Value="1" Minimum="1" SpinButtonPlacementMode="Compact" Width="120" />
                        <Button x:Name="LoadDetailBtn" Click="LoadDetail_Click" Style="{StaticResource AccentButtonStyle}" />
                        <TextBlock x:Name="StreamNoCap" VerticalAlignment="Center" Margin="16,0,0,0" />
                        <NumberBox x:Name="StreamNoBox" Value="0" Minimum="0" SpinButtonPlacementMode="Compact" Width="100" />
                        <Button x:Name="FollowStreamBtn" Click="FollowStream_Click" />
                    </StackPanel>
                    <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <TextBox x:Name="OfflineDetailText" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                                     FontFamily="Consolas" FontSize="12" BorderThickness="0" Background="Transparent" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </PivotItem>

            <!-- ════════ Statistics ════════ -->
            <PivotItem x:Name="StatsTab">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                        <Button x:Name="ProtoStatsBtn" Click="ProtoStats_Click" />
                        <Button x:Name="ConvStatsBtn" Click="ConvStats_Click" />
                        <Button x:Name="EndpointStatsBtn" Click="EndpointStats_Click" />
                    </StackPanel>
                    <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <TextBox x:Name="StatsText" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                                     FontFamily="Consolas" FontSize="12" BorderThickness="0" Background="Transparent" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </PivotItem>

            <!-- ════════ Operations ════════ -->
            <PivotItem x:Name="OpsTab">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="8">
                        <AutoSuggestBox x:Name="OpsFilter" TextChanged="OpsFilter_TextChanged" />
                        <StackPanel x:Name="OpsPanel" Spacing="8" />
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

        </Pivot>
    </Grid>
</Page>
