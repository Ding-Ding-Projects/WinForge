<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.Ascii85Module"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE943;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="Status" IsOpen="True" IsClosable="False" Severity="Informational" />

            <!-- Options -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="18" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock x:Name="VariantLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="VariantBox" SelectionChanged="Variant_Changed" HorizontalAlignment="Stretch" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock x:Name="InputLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="InputBox" SelectionChanged="Input_Changed" HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Grid>

                    <StackPanel x:Name="AdobeOptions" Orientation="Horizontal" Spacing="20">
                        <CheckBox x:Name="WrapChk" Checked="Adobe_Changed" Unchecked="Adobe_Changed" />
                        <CheckBox x:Name="ZChk" Checked="Adobe_Changed" Unchecked="Adobe_Changed" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Encode -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="EncodeTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="PlainBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="90"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" TextChanged="Plain_Changed" />
                    <TextBlock x:Name="EncodeInfo" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBox x:Name="EncodedBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="90"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="EncodeBtn" Click="Encode_Click" Style="{ThemeResource AccentButtonStyle}" />
                        <Button x:Name="CopyEncodedBtn" Click="CopyEncoded_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Decode -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="DecodeTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="CipherBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="90"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    <TextBlock x:Name="DecodeTextLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBox x:Name="DecodedTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    <TextBlock x:Name="DecodeHexLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBox x:Name="DecodedHexBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                             FontFamily="Consolas" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    <TextBlock x:Name="DecodeInfo" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="DecodeBtn" Click="Decode_Click" Style="{ThemeResource AccentButtonStyle}" />
                        <Button x:Name="CopyTextBtn" Click="CopyText_Click" />
                        <Button x:Name="CopyHexBtn" Click="CopyHex_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
