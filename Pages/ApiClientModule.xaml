<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.ApiClientModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Style="{StaticResource WinForgePageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="6">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xEB41;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Environment bar -->
        <Border Grid.Row="1" Padding="12,8,12,8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <FontIcon Grid.Column="0" Glyph="&#xE945;" FontSize="16" VerticalAlignment="Center" />
                <ComboBox x:Name="EnvBox" Grid.Column="1" HorizontalAlignment="Stretch" SelectionChanged="Env_Changed" />
                <Button x:Name="ManageEnvBtn" Grid.Column="2" Click="ManageEnv_Click">
                    <FontIcon FontSize="14" Glyph="&#xE713;" />
                </Button>
                <Button x:Name="NewEnvBtn" Grid.Column="3" Click="NewEnv_Click">
                    <FontIcon FontSize="14" Glyph="&#xE710;" />
                </Button>
                <TextBlock x:Name="StoreHint" Grid.Column="5" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            </Grid>
        </Border>

        <!-- Main split: sidebar | builder -->
        <Grid Grid.Row="2" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar: collections tree -->
            <Border Grid.Column="0" Padding="10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="CollectionsTitle" Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" />
                        <Button x:Name="NewCollectionBtn" Grid.Column="1" Click="NewCollection_Click" ToolTipService.ToolTip="New collection · 新集合">
                            <FontIcon FontSize="14" Glyph="&#xE710;" />
                        </Button>
                    </Grid>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <TreeView x:Name="CollTree" SelectionMode="Single" ItemInvoked="CollTree_ItemInvoked">
                            <TreeView.ItemTemplate>
                                <DataTemplate>
                                    <TreeViewItem ItemsSource="{Binding Children}" IsExpanded="True">
                                        <TreeViewItem.Content>
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Badge}" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Label}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                            </Grid>
                                        </TreeViewItem.Content>
                                    </TreeViewItem>
                                </DataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Builder + response -->
            <Grid Grid.Column="1" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Method + URL + Send -->
                <Grid Grid.Row="0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="MethodBox" Grid.Column="0" HorizontalAlignment="Stretch" />
                    <TextBox x:Name="UrlBox" Grid.Column="1" FontFamily="Consolas" PlaceholderText="https://api.example.com/v1/users  ·  use {{var}} for env vars" />
                    <Button x:Name="SendBtn" Grid.Column="2" Click="Send_Click" Style="{StaticResource AccentButtonStyle}" MinWidth="84" />
                    <Button x:Name="SaveBtn" Grid.Column="3" Click="SaveRequest_Click" ToolTipService.ToolTip="Save to collection · 儲存到集合">
                        <FontIcon FontSize="15" Glyph="&#xE74E;" />
                    </Button>
                </Grid>

                <ProgressBar Grid.Row="1" x:Name="SendBar" IsIndeterminate="True" Visibility="Collapsed" />

                <!-- Request tabs (top) + Response (bottom) split -->
                <Grid Grid.Row="2" RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="220" />
                        <RowDefinition Height="*" MinHeight="200" />
                    </Grid.RowDefinitions>

                    <!-- Request editor tabs -->
                    <Pivot Grid.Row="0" x:Name="ReqTabs">
                        <PivotItem x:Name="TabParams">
                            <Grid RowSpacing="8" Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Button x:Name="AddParamBtn" Grid.Row="0" HorizontalAlignment="Left" Click="AddParam_Click" />
                                <ListView x:Name="ParamsList" Grid.Row="1" SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnSpacing="8" Padding="0,2,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0" IsChecked="{Binding Enabled, Mode=TwoWay}" MinWidth="0" />
                                                <TextBox Grid.Column="1" Text="{Binding Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="key" FontFamily="Consolas" />
                                                <TextBox Grid.Column="2" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="value" FontFamily="Consolas" />
                                                <Button Grid.Column="3" Tag="{Binding}" Click="RemoveParam_Click" Background="Transparent" BorderThickness="0">
                                                    <FontIcon FontSize="13" Glyph="&#xE74D;" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </PivotItem>

                        <PivotItem x:Name="TabHeaders">
                            <Grid RowSpacing="8" Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Button x:Name="AddHeaderBtn" Grid.Row="0" HorizontalAlignment="Left" Click="AddHeader_Click" />
                                <ListView x:Name="HeadersList" Grid.Row="1" SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnSpacing="8" Padding="0,2,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0" IsChecked="{Binding Enabled, Mode=TwoWay}" MinWidth="0" />
                                                <TextBox Grid.Column="1" Text="{Binding Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Header-Name" FontFamily="Consolas" />
                                                <TextBox Grid.Column="2" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="value" FontFamily="Consolas" />
                                                <Button Grid.Column="3" Tag="{Binding}" Click="RemoveHeader_Click" Background="Transparent" BorderThickness="0">
                                                    <FontIcon FontSize="13" Glyph="&#xE74D;" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </PivotItem>

                        <PivotItem x:Name="TabBody">
                            <Grid RowSpacing="8" Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                                    <ComboBox x:Name="BodyModeBox" SelectionChanged="BodyMode_Changed" MinWidth="220" />
                                    <Button x:Name="BeautifyBtn" Click="Beautify_Click" />
                                    <Button x:Name="AddFormBtn" Click="AddForm_Click" Visibility="Collapsed" />
                                </StackPanel>
                                <TextBox x:Name="BodyBox" Grid.Row="1" AcceptsReturn="True" TextWrapping="NoWrap"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Consolas" PlaceholderText="{}{ &quot;key&quot;: &quot;value&quot; }" />
                                <ListView x:Name="FormList" Grid.Row="1" SelectionMode="None" Visibility="Collapsed">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnSpacing="8" Padding="0,2,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0" IsChecked="{Binding Enabled, Mode=TwoWay}" MinWidth="0" />
                                                <TextBox Grid.Column="1" Text="{Binding Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="field" FontFamily="Consolas" />
                                                <TextBox Grid.Column="2" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="value" FontFamily="Consolas" />
                                                <Button Grid.Column="3" Tag="{Binding}" Click="RemoveForm_Click" Background="Transparent" BorderThickness="0">
                                                    <FontIcon FontSize="13" Glyph="&#xE74D;" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </PivotItem>

                        <PivotItem x:Name="TabAuth">
                            <StackPanel Spacing="10" Margin="0,8,0,0">
                                <ComboBox x:Name="AuthKindBox" SelectionChanged="AuthKind_Changed" MinWidth="220" />
                                <StackPanel x:Name="BearerPanel" Spacing="6" Visibility="Collapsed">
                                    <TextBlock x:Name="BearerLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBox x:Name="BearerBox" FontFamily="Consolas" PlaceholderText="token  ·  {{token}}" />
                                </StackPanel>
                                <StackPanel x:Name="BasicPanel" Spacing="6" Visibility="Collapsed">
                                    <TextBlock x:Name="BasicLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBox x:Name="BasicUserBox" PlaceholderText="username" />
                                    <PasswordBox x:Name="BasicPassBox" PlaceholderText="password" />
                                </StackPanel>
                            </StackPanel>
                        </PivotItem>
                    </Pivot>

                    <!-- Response -->
                    <Border Grid.Row="1" Padding="12" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
                                <Border x:Name="StatusPill" CornerRadius="10" Padding="10,3" VerticalAlignment="Center" Visibility="Collapsed" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                    <TextBlock x:Name="StatusText" FontWeight="SemiBold" FontSize="13" />
                                </Border>
                                <TextBlock x:Name="TimeText" VerticalAlignment="Center" FontSize="12" FontFamily="Consolas" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock x:Name="SizeText" VerticalAlignment="Center" FontSize="12" FontFamily="Consolas" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock x:Name="RespHint" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                            <Pivot Grid.Row="1" x:Name="RespTabs">
                                <PivotItem x:Name="TabRespBody">
                                    <Grid RowSpacing="6" Margin="0,6,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                                            <ToggleSwitch x:Name="PrettyToggle" IsOn="True" Toggled="Pretty_Toggled" OnContent="Pretty" OffContent="Raw" MinWidth="0" />
                                            <Button x:Name="CopyBtn" Click="Copy_Click">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon FontSize="13" Glyph="&#xE8C8;" />
                                                    <TextBlock x:Name="CopyLabel" />
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="SaveRespBtn" Click="SaveResponse_Click">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon FontSize="13" Glyph="&#xE74E;" />
                                                    <TextBlock x:Name="SaveRespLabel" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                            <TextBox x:Name="RespBodyBox" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                                     TextWrapping="NoWrap" FontFamily="Consolas" FontSize="13" IsSpellCheckEnabled="False" />
                                        </ScrollViewer>
                                    </Grid>
                                </PivotItem>
                                <PivotItem x:Name="TabRespHeaders">
                                    <ListView x:Name="RespHeadersList" SelectionMode="None" Margin="0,6,0,0">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnSpacing="12" Padding="0,3,0,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="200" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Key}" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" IsTextSelectionEnabled="True" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </PivotItem>
                            </Pivot>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
