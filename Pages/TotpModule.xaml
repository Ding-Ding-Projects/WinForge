<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.TotpModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE72E;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Live code card -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                        <TextBlock x:Name="CodeLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="CodeText" Text="— — —" FontFamily="Consolas" FontSize="40" FontWeight="SemiBold" />
                        <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Grid Width="72" Height="72">
                            <muxc:ProgressRing x:Name="CountRing" IsIndeterminate="False" Value="100" Maximum="100" Width="72" Height="72" />
                            <TextBlock x:Name="CountText" Text="—" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" FontWeight="SemiBold" />
                        </Grid>
                        <Button x:Name="CopyBtn" Click="Copy_Click" HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Configuration card -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="SecretLabel" FontWeight="SemiBold" />
                        <TextBox x:Name="SecretBox" TextChanged="Config_Changed" PlaceholderText="JBSWY3DPEHPK3PXP" FontFamily="Consolas" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="UriLabel" FontWeight="SemiBold" />
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="UriBox" Grid.Column="0" PlaceholderText="otpauth://totp/Example?secret=JBSWY3DPEHPK3PXP&amp;issuer=Example" />
                            <Button x:Name="ImportBtn" Grid.Column="1" Click="Import_Click" VerticalAlignment="Bottom" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="18">
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="DigitsLabel" />
                            <NumberBox x:Name="DigitsBox" Value="6" Minimum="6" Maximum="10" SpinButtonPlacementMode="Inline" MinWidth="120" ValueChanged="Number_Changed" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="PeriodLabel" />
                            <NumberBox x:Name="PeriodBox" Value="30" Minimum="1" Maximum="600" SpinButtonPlacementMode="Inline" MinWidth="120" ValueChanged="Number_Changed" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="AlgoLabel" />
                            <ComboBox x:Name="AlgoBox" MinWidth="140" SelectionChanged="Algo_Changed">
                                <ComboBoxItem Content="SHA1" />
                                <ComboBoxItem Content="SHA256" />
                                <ComboBoxItem Content="SHA512" />
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
