<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.CronBuilderModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE787;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Expression card -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="ExprLabel" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="ExprHint" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ExprBox" Grid.Column="0" FontFamily="Consolas" Text="* * * * *" TextChanged="Expr_TextChanged" VerticalAlignment="Center" />
                        <Button x:Name="CopyBtn" Grid.Column="1" Click="Copy_Click" VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="PresetLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="PresetBox" MinWidth="240" SelectionChanged="Preset_SelectionChanged" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Description card -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="MeaningLabel" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="StatusText" FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Next fire times card -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="NextLabel" FontWeight="SemiBold" FontSize="15" />
                    <ListView x:Name="NextList" SelectionMode="None" IsItemClickEnabled="False" MaxHeight="360" />
                    <TextBlock x:Name="NextEmpty" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Visibility="Collapsed" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
