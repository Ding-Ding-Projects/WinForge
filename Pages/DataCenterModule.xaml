<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.DataCenterModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="840" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE968;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Empty state: reactor not generating -->
            <InfoBar x:Name="NeedPowerBar" IsClosable="False" IsOpen="False" Severity="Warning" />

            <!-- Live reactor output -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ReactorTitle" Grid.Column="0" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                        <TextBlock x:Name="ReactorModeText" Grid.Column="1" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                    </Grid>
                    <ProgressBar x:Name="OutputBar" Minimum="0" Maximum="1150" Value="0" Height="10" />
                    <TextBlock x:Name="OutputValue" FontSize="20" FontWeight="SemiBold" />
                </StackPanel>
            </Border>

            <!-- IT load controls -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="LoadTitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Spacing="2">
                        <TextBlock x:Name="LoadLabel" />
                        <Slider x:Name="LoadSlider" Minimum="0" Maximum="500" Value="0" StepFrequency="5" ValueChanged="LoadSlider_ValueChanged" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="ScaleUpButton" Click="ScaleUp_Click" Style="{ThemeResource AccentButtonStyle}" />
                        <Button x:Name="ScaleDownButton" Click="ScaleDown_Click" />
                        <Button x:Name="ResetSlaButton" Click="ResetSla_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Facility readouts -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="FacilityTitle" FontWeight="SemiBold" FontSize="15" />

                    <StackPanel Spacing="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="DrawCaption" Grid.Column="0" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="DrawValue" Grid.Column="1" FontSize="13" FontWeight="SemiBold" />
                        </Grid>
                        <ProgressBar x:Name="DrawBar" Minimum="0" Maximum="1150" Value="0" Height="8" />
                    </StackPanel>

                    <Grid ColumnSpacing="18" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="1">
                            <TextBlock x:Name="ItCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="ItValue" FontSize="18" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="1">
                            <TextBlock x:Name="PueCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="PueValue" FontSize="18" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="1">
                            <TextBlock x:Name="ReqCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="ReqValue" FontSize="18" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="1">
                            <TextBlock x:Name="UptimeCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="UptimeValue" FontSize="18" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Spacing="1">
                            <TextBlock x:Name="RackCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="RackValue" FontSize="18" FontWeight="SemiBold" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
