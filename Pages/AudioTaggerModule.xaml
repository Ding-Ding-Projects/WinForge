<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.AudioTaggerModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,0" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="6">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="22" Glyph="&#xEC4F;" VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Toolbar -->
        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="OpenFolderBtn" Grid.Column="0" Click="OpenFolder_Click" Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE8B7;" />
                    <TextBlock x:Name="OpenFolderLbl" />
                </StackPanel>
            </Button>
            <Button x:Name="OpenFilesBtn" Grid.Column="1" Click="OpenFiles_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE8E5;" />
                    <TextBlock x:Name="OpenFilesLbl" />
                </StackPanel>
            </Button>
            <TextBlock x:Name="FolderPathText" Grid.Column="2" VerticalAlignment="Center" Margin="6,0,0,0"
                       TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
            <CheckBox x:Name="RecurseChk" Grid.Column="3" Click="Recurse_Click" />
            <Button x:Name="ReloadBtn" Grid.Column="4" Click="Reload_Click">
                <FontIcon FontSize="14" Glyph="&#xE72C;" />
            </Button>
        </Grid>

        <!-- Main split: file list (left) + editor (right) -->
        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.6*" MinWidth="360" />
                <ColumnDefinition Width="*" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <!-- File list -->
            <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- column headers -->
                    <Grid Grid.Row="0" Padding="12,8,12,8" ColumnSpacing="10" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="160" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="56" />
                            <ColumnDefinition Width="56" />
                            <ColumnDefinition Width="64" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ColTitle" Grid.Column="0" FontWeight="SemiBold" FontSize="12" />
                        <TextBlock x:Name="ColArtist" Grid.Column="1" FontWeight="SemiBold" FontSize="12" />
                        <TextBlock x:Name="ColAlbum" Grid.Column="2" FontWeight="SemiBold" FontSize="12" />
                        <TextBlock x:Name="ColTrack" Grid.Column="3" FontWeight="SemiBold" FontSize="12" />
                        <TextBlock x:Name="ColYear" Grid.Column="4" FontWeight="SemiBold" FontSize="12" />
                        <TextBlock x:Name="ColDur" Grid.Column="5" FontWeight="SemiBold" FontSize="12" />
                    </Grid>

                    <ListView x:Name="FileList" Grid.Row="1" SelectionMode="Extended"
                              SelectionChanged="FileList_SelectionChanged"
                              ScrollViewer.HorizontalScrollMode="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="12,6,12,6" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="160" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="56" />
                                        <ColumnDefinition Width="56" />
                                        <ColumnDefinition Width="64" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" FontWeight="SemiBold" ToolTipService.ToolTip="{Binding FileName}" />
                                        <TextBlock Text="{Binding FileName}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding Artist}" VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{Binding Album}" VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="3" Text="{Binding TrackText}" VerticalAlignment="Center" FontSize="12" />
                                    <TextBlock Grid.Column="4" Text="{Binding YearText}" VerticalAlignment="Center" FontSize="12" />
                                    <TextBlock Grid.Column="5" Text="{Binding DurationText}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel x:Name="EmptyState" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                        <FontIcon FontSize="40" Glyph="&#xEC4F;" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="EmptyText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="320" TextAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Editor panel -->
            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
                    <StackPanel x:Name="EditorPanel" Spacing="10">
                        <TextBlock x:Name="EditorHeader" FontWeight="SemiBold" />
                        <TextBlock x:Name="SelectionInfo" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

                        <!-- Cover art -->
                        <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="6" Padding="10">
                            <StackPanel Spacing="8">
                                <TextBlock x:Name="CoverLbl" FontSize="12" FontWeight="SemiBold" />
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="96" Height="96" CornerRadius="4"
                                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                        <Grid>
                                            <FontIcon x:Name="CoverPlaceholder" FontSize="28" Glyph="&#xEB9F;" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <Image x:Name="CoverImage" Stretch="UniformToFill" Visibility="Collapsed" />
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                        <Button x:Name="LoadCoverBtn" Click="LoadCover_Click" HorizontalAlignment="Stretch" />
                                        <Button x:Name="RemoveCoverBtn" Click="RemoveCover_Click" HorizontalAlignment="Stretch" />
                                        <TextBlock x:Name="CoverInfo" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBox x:Name="TitleBox" />
                        <TextBox x:Name="ArtistBox" />
                        <TextBox x:Name="AlbumBox" />
                        <TextBox x:Name="AlbumArtistBox" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TrackBox" Grid.Column="0" />
                            <TextBox x:Name="DiscBox" Grid.Column="1" />
                            <TextBox x:Name="YearBox" Grid.Column="2" />
                        </Grid>
                        <TextBox x:Name="GenreBox" />
                        <TextBox x:Name="ComposerBox" />
                        <TextBox x:Name="CommentBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" />

                        <TextBlock x:Name="TechInfo" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="SaveBtn" Click="Save_Click" Style="{StaticResource AccentButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="14" Glyph="&#xE74E;" />
                                    <TextBlock x:Name="SaveLbl" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="RevertBtn" Click="Revert_Click" />
                            <ProgressRing x:Name="SaveBusy" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Tools -->
                        <Expander x:Name="ToolsExpander" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="0,4,0,0">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="15" Glyph="&#xE90F;" VerticalAlignment="Center" />
                                    <TextBlock x:Name="ToolsHeader" FontWeight="SemiBold" VerticalAlignment="Center" />
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Spacing="14" Margin="0,4,0,0">
                                <!-- Tag from filename -->
                                <StackPanel Spacing="6">
                                    <TextBlock x:Name="FromNameLbl" FontWeight="SemiBold" FontSize="12" />
                                    <TextBox x:Name="FromNamePattern" Text="%artist% - %title%" />
                                    <TextBlock x:Name="FromNameHint" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="FromNamePreviewBtn" Click="FromNamePreview_Click" />
                                        <Button x:Name="FromNameApplyBtn" Click="FromNameApply_Click" />
                                    </StackPanel>
                                    <TextBlock x:Name="FromNamePreview" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                </StackPanel>

                                <!-- Rename from tags -->
                                <StackPanel Spacing="6">
                                    <TextBlock x:Name="ToNameLbl" FontWeight="SemiBold" FontSize="12" />
                                    <TextBox x:Name="ToNamePattern" Text="%track% - %artist% - %title%" />
                                    <TextBlock x:Name="ToNameHint" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="ToNamePreviewBtn" Click="ToNamePreview_Click" />
                                        <Button x:Name="ToNameApplyBtn" Click="ToNameApply_Click" />
                                    </StackPanel>
                                    <TextBlock x:Name="ToNamePreview" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Result bar -->
        <InfoBar x:Name="ResultBar" Grid.Row="3" IsClosable="True" IsOpen="False" Margin="0,0,0,12" />
    </Grid>
</Page>
