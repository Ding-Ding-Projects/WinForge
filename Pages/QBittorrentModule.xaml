<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.QBittorrentModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Style="{StaticResource WinForgePageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="6">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE896;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
            <InfoBar x:Name="EngineBar" IsClosable="False" IsOpen="False" Severity="Warning" />
        </StackPanel>

        <!-- Connection -->
        <Expander x:Name="ConnExpander" Grid.Row="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="True">
            <Expander.Header>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon FontSize="16" Glyph="&#xE968;" VerticalAlignment="Center" />
                    <TextBlock x:Name="ConnHeader" VerticalAlignment="Center" FontWeight="SemiBold" />
                    <Border x:Name="ConnPill" CornerRadius="10" Padding="8,2,8,2" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <TextBlock x:Name="ConnState" FontSize="12" />
                    </Border>
                </StackPanel>
            </Expander.Header>
            <StackPanel Spacing="10" Margin="0,4,0,0">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="HostBox" Grid.Column="0" Header="Host · 主機" Text="localhost" />
                    <NumberBox x:Name="PortBox" Grid.Column="1" Header="Port · 連接埠" Value="8080" SpinButtonPlacementMode="Compact" Minimum="1" Maximum="65535" />
                    <TextBox x:Name="UserBox" Grid.Column="2" Header="Username · 帳號" Text="admin" />
                </Grid>
                <PasswordBox x:Name="PassBox" Header="Password · 密碼" PlaceholderText="WebUI password · WebUI 密碼" />
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <CheckBox x:Name="RememberChk" Content="Remember password · 記住密碼" />
                    <Button x:Name="ConnectBtn" Click="Connect_Click" Style="{StaticResource AccentButtonStyle}" />
                    <Button x:Name="DisconnectBtn" Click="Disconnect_Click" />
                    <Button x:Name="OpenWebUiBtn" Click="OpenWebUi_Click" />
                    <Button x:Name="LaunchAppBtn" Click="LaunchApp_Click" />
                    <ProgressRing x:Name="ConnBusy" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
                </StackPanel>
                <InfoBar x:Name="ConnResult" IsClosable="True" IsOpen="False" />
            </StackPanel>
        </Expander>

        <!-- Toolbar / add bar -->
        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="AddMagnetBtn" Grid.Column="0" Click="AddMagnet_Click" Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE71B;" />
                    <TextBlock x:Name="AddMagnetLbl" />
                </StackPanel>
            </Button>
            <Button x:Name="AddFileBtn" Grid.Column="1" Click="AddFile_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE8E5;" />
                    <TextBlock x:Name="AddFileLbl" />
                </StackPanel>
            </Button>
            <AutoSuggestBox x:Name="SearchBox" Grid.Column="2" QueryIcon="Find" PlaceholderText="Filter by name · 按名稱篩選" TextChanged="Search_Changed" MinWidth="160" />
            <ComboBox x:Name="FilterBox" Grid.Column="3" SelectionChanged="Filter_Changed" MinWidth="120" />
            <ComboBox x:Name="CatFilterBox" Grid.Column="4" SelectionChanged="Filter_Changed" MinWidth="120" />
            <Button x:Name="RefreshBtn" Grid.Column="5" Click="Refresh_Click">
                <FontIcon FontSize="14" Glyph="&#xE72C;" />
            </Button>
        </Grid>

        <!-- Torrent list -->
        <Grid Grid.Row="3">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Bulk action toolbar -->
                    <Grid Grid.Row="0" Padding="10,8,10,8" ColumnSpacing="6" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="ResumeBtn" Grid.Column="0" Click="Resume_Click"><FontIcon FontSize="14" Glyph="&#xE768;" /></Button>
                        <Button x:Name="PauseBtn" Grid.Column="1" Click="Pause_Click"><FontIcon FontSize="14" Glyph="&#xE769;" /></Button>
                        <Button x:Name="DeleteBtn" Grid.Column="2" Click="Delete_Click"><FontIcon FontSize="14" Glyph="&#xE74D;" /></Button>
                        <Button x:Name="RecheckBtn" Grid.Column="3" Click="Recheck_Click"><FontIcon FontSize="14" Glyph="&#xE72C;" /></Button>
                        <Button x:Name="CategoryBtn" Grid.Column="4" Click="AssignCategory_Click"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon FontSize="14" Glyph="&#xE8EC;" /><TextBlock x:Name="CategoryBtnLbl" /></StackPanel></Button>
                        <Button x:Name="TagBtn" Grid.Column="5" Click="AssignTag_Click"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon FontSize="14" Glyph="&#xE8EC;" /><TextBlock x:Name="TagBtnLbl" /></StackPanel></Button>
                        <TextBlock x:Name="SelectionInfo" Grid.Column="6" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <Button x:Name="ManageCatsBtn" Grid.Column="7" Click="ManageCats_Click"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon FontSize="14" Glyph="&#xE713;" /><TextBlock x:Name="ManageCatsLbl" /></StackPanel></Button>
                    </Grid>

                    <ListView x:Name="TorrentList" Grid.Row="1" SelectionMode="Extended"
                              SelectionChanged="TorrentList_SelectionChanged"
                              DoubleTapped="TorrentList_DoubleTapped"
                              ScrollViewer.HorizontalScrollMode="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="10,8,10,8" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="220" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="80" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Name + category/tags -->
                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" FontWeight="SemiBold" ToolTipService.ToolTip="{Binding Name}" />
                                        <TextBlock Text="{Binding SubLine}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <!-- Progress -->
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <ProgressBar Value="{Binding ProgressPct}" Maximum="100" />
                                        <TextBlock Text="{Binding ProgressText}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>

                                    <!-- State -->
                                    <TextBlock Grid.Column="2" Text="{Binding StateText}" VerticalAlignment="Center" FontSize="12" Foreground="{Binding StateBrush}" />

                                    <!-- Speeds -->
                                    <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DlText}" FontSize="12" />
                                        <TextBlock Text="{Binding UlText}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>

                                    <!-- ETA -->
                                    <TextBlock Grid.Column="4" Text="{Binding EtaText}" VerticalAlignment="Center" FontSize="12" />

                                    <!-- Size -->
                                    <TextBlock Grid.Column="5" Text="{Binding SizeText}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Empty / placeholder -->
                    <StackPanel x:Name="EmptyState" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8" Visibility="Collapsed">
                        <FontIcon FontSize="40" Glyph="&#xE896;" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="EmptyText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Status footer -->
        <Border Grid.Row="4" Padding="14,8,14,8" Margin="0,0,0,12" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="8">
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="13" Glyph="&#xE896;" />
                    <TextBlock x:Name="FooterDl" FontSize="12" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="13" Glyph="&#xE898;" />
                    <TextBlock x:Name="FooterUl" FontSize="12" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock x:Name="FooterConn" Grid.Column="2" FontSize="12" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:Name="FooterCount" Grid.Column="4" FontSize="12" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="8">
                    <ToggleSwitch x:Name="AltSpeedToggle" Toggled="AltSpeed_Toggled" OnContent="" OffContent="" MinWidth="0" />
                    <TextBlock x:Name="AltSpeedLbl" FontSize="12" VerticalAlignment="Center" />
                    <Button x:Name="SpeedLimitsBtn" Click="SpeedLimits_Click"><FontIcon FontSize="13" Glyph="&#xEC4A;" /></Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
