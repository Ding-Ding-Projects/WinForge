<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.LineToolsModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8A5;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="InputLabel" FontWeight="SemiBold" />
                    <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="150" MaxHeight="240"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" TextChanged="Input_TextChanged" />
                    <TextBlock x:Name="CountText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="PrefixLabel" FontSize="12" />
                            <TextBox x:Name="PrefixBox" MinWidth="120" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="SuffixLabel" FontSize="12" />
                            <TextBox x:Name="SuffixBox" MinWidth="120" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="DelimLabel" FontSize="12" />
                            <TextBox x:Name="DelimBox" Text=", " MinWidth="120" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="BtnNumberDot" Click="NumberDot_Click" />
                            <Button x:Name="BtnNumberParen" Click="NumberParen_Click" />
                            <Button x:Name="BtnRemoveNums" Click="RemoveNums_Click" />
                            <Button x:Name="BtnQuotes" Click="Quotes_Click" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="BtnPrefix" Click="Prefix_Click" />
                            <Button x:Name="BtnSuffix" Click="Suffix_Click" />
                            <Button x:Name="BtnJoin" Click="Join_Click" />
                            <Button x:Name="BtnSplit" Click="Split_Click" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="BtnReverseChars" Click="ReverseChars_Click" />
                            <Button x:Name="BtnSort" Click="Sort_Click" />
                            <Button x:Name="BtnReverseOrder" Click="ReverseOrder_Click" />
                            <Button x:Name="BtnShuffle" Click="Shuffle_Click" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="BtnDedupe" Click="Dedupe_Click" />
                            <Button x:Name="BtnRemoveEmpty" Click="RemoveEmpty_Click" />
                            <Button x:Name="BtnTrim" Click="Trim_Click" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="OutputLabel" Grid.Column="0" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button x:Name="CopyBtn" Grid.Column="1" Click="Copy_Click" />
                    </Grid>
                    <TextBox x:Name="OutputBox" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" MinHeight="150" MaxHeight="240"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
