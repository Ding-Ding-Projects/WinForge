<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.HeaderScoreModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xEB41;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="InputLabel" FontWeight="SemiBold" />
                    <TextBox x:Name="InputBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="150"
                             FontFamily="Consolas"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="AnalyzeBtn" Style="{ThemeResource AccentButtonStyle}" Click="Analyze_Click" />
                        <Button x:Name="SampleBtn" Click="Sample_Click" />
                        <Button x:Name="CopyBtn" Click="Copy_Click" IsEnabled="False" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border x:Name="ResultCard"
                    Visibility="Collapsed"
                    Padding="16,14,16,14"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="GradeBadge" Grid.Column="0"
                                Width="76" Height="76" CornerRadius="10"
                                VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock x:Name="GradeText" FontSize="34" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="4" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="ScoreText" FontSize="18" FontWeight="SemiBold" />
                            <ProgressBar x:Name="ScoreBar" Minimum="0" Maximum="100" Height="6" />
                            <TextBlock x:Name="SummaryText" TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        </StackPanel>
                    </Grid>

                    <ListView x:Name="ResultsList"
                              SelectionMode="None"
                              IsItemClickEnabled="False"
                              MaxHeight="520">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="6,8,6,8" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Background="{Binding BadgeBrush}"
                                            CornerRadius="4" Padding="8,3,8,3"
                                            VerticalAlignment="Top" MinWidth="64"
                                            Margin="0,2,12,0">
                                        <TextBlock Text="{Binding Status}"
                                                   Foreground="White" FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="{Binding Header}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Value}"
                                                   FontFamily="Consolas" FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding Note}" FontSize="12" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Advice}" FontSize="12" TextWrapping="Wrap"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
