<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.DicewareModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE72E;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="WordsLabel" VerticalAlignment="Center" MinWidth="160" />
                        <NumberBox x:Name="WordsBox" Value="6" Minimum="3" Maximum="12" SpinButtonPlacementMode="Inline" MinWidth="140" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="SepLabel" VerticalAlignment="Center" MinWidth="160" />
                        <ComboBox x:Name="SepBox" MinWidth="180" SelectedIndex="1" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="PhrasesLabel" VerticalAlignment="Center" MinWidth="160" />
                        <NumberBox x:Name="PhrasesBox" Value="5" Minimum="1" Maximum="50" SpinButtonPlacementMode="Inline" MinWidth="140" />
                    </StackPanel>

                    <ToggleSwitch x:Name="CapSwitch" />
                    <ToggleSwitch x:Name="NumSwitch" />

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="GenBtn" Click="Gen_Click" Style="{ThemeResource AccentButtonStyle}" />
                        <Button x:Name="CopyBtn" Click="Copy_Click" />
                    </StackPanel>

                    <TextBlock x:Name="EntropyText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="ResultsLabel" FontWeight="SemiBold" />
                    <TextBox x:Name="ResultsBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                             FontFamily="Consolas" MinHeight="160"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
