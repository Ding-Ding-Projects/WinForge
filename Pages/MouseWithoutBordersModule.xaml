<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.MouseWithoutBordersModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1000" Spacing="14">

            <!-- Header -->
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE962;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="StatusBar" IsClosable="False" IsOpen="True" Severity="Informational" />

            <!-- Master enable + toggles -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock x:Name="EnableTitle" FontWeight="SemiBold" FontSize="16" />
                            <TextBlock x:Name="EnableSub" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="EnableSwitch" Grid.Column="1" VerticalAlignment="Center" Toggled="EnableSwitch_Toggled" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="24">
                        <CheckBox x:Name="ClipboardChk" Click="ClipboardChk_Click" />
                        <CheckBox x:Name="WrapChk" Click="WrapChk_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- This PC: name, key, IP -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="ThisPcTitle" FontWeight="SemiBold" FontSize="16" />

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="NameLbl" Grid.Column="0" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBox x:Name="NameBox" Grid.Column="1" />
                        <Button x:Name="SaveNameBtn" Grid.Column="2" Click="SaveName_Click" />
                    </Grid>

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="KeyLbl" Grid.Column="0" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBox x:Name="KeyValue" Grid.Column="1" IsReadOnly="True" FontFamily="Consolas" FontSize="18" Text="—" />
                        <Button x:Name="CopyKeyBtn" Grid.Column="2" Click="CopyKey_Click">
                            <FontIcon FontSize="15" Glyph="&#xE8C8;" />
                        </Button>
                        <Button x:Name="RegenKeyBtn" Grid.Column="3" Click="RegenKey_Click">
                            <FontIcon FontSize="15" Glyph="&#xE72C;" />
                        </Button>
                    </Grid>

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="IpLbl" Grid.Column="0" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBox x:Name="IpValue" Grid.Column="1" IsReadOnly="True" FontFamily="Consolas" Text="—" />
                        <TextBox x:Name="PortValue" Grid.Column="2" Width="90" PlaceholderText="Port" />
                    </Grid>
                    <TextBlock x:Name="KeyHint" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Pair a new machine -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="PairTitle" FontWeight="SemiBold" FontSize="16" />
                    <TextBlock x:Name="PairBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" TextWrapping="Wrap" />
                    <Grid ColumnSpacing="10" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBox x:Name="PairNameBox" Grid.Row="0" Grid.Column="0" PlaceholderText="Name · 機器名" />
                        <TextBox x:Name="PairIpBox" Grid.Row="0" Grid.Column="1" PlaceholderText="IP · 位址（例如 192.168.1.20）" FontFamily="Consolas" />
                        <TextBox x:Name="PairPortBox" Grid.Row="0" Grid.Column="2" Width="90" PlaceholderText="Port" />
                        <TextBox x:Name="PairKeyBox" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" PlaceholderText="Security key · 安全密鑰" FontFamily="Consolas" />
                        <Button x:Name="PairAddBtn" Grid.Row="1" Grid.Column="2" Click="PairAdd_Click" Style="{StaticResource AccentButtonStyle}" />
                    </Grid>
                    <InfoBar x:Name="PairResult" IsClosable="True" IsOpen="False" />
                </StackPanel>
            </Border>

            <!-- Layout editor (1x4 left/right) -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="LayoutTitle" FontWeight="SemiBold" FontSize="16" />
                    <TextBlock x:Name="LayoutBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" TextWrapping="Wrap" />
                    <Grid x:Name="LayoutGrid" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Paired machines list -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="MachinesTitle" FontWeight="SemiBold" FontSize="16" />
                    <TextBlock x:Name="MachinesEmpty" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13" Visibility="Collapsed" />
                    <StackPanel x:Name="MachinesHost" Spacing="8" />
                </StackPanel>
            </Border>

            <!-- Activity log -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="LogTitle" FontWeight="SemiBold" FontSize="16" />
                    <TextBox x:Name="LogBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                             Height="140" FontFamily="Consolas" FontSize="12"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>

            <TextBlock x:Name="Disclaimer" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</Page>
