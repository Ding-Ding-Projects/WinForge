<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.SemverRangeModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE943;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="Status" IsOpen="False" IsClosable="False" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="RangeLabel" FontWeight="SemiBold" />
                        <TextBox x:Name="RangeBox" PlaceholderText="^1.2.3 || &gt;=2.0.0 &lt;3.0.0" TextChanged="Input_Changed" />
                        <TextBlock x:Name="NormalizedText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="VersionsLabel" FontWeight="SemiBold" />
                        <TextBox x:Name="VersionsBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 PlaceholderText="1.2.3&#x0a;2.0.0-rc.1&#x0a;3.1.4" TextChanged="Input_Changed" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="TestBtn" Style="{ThemeResource AccentButtonStyle}" Click="Test_Click" />
                        <Button x:Name="SortBtn" Click="Sort_Click" />
                        <Button x:Name="CopyBtn" Click="Copy_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border x:Name="HighestCard" Padding="16,12,16,12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="2">
                    <TextBlock x:Name="HighestLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="HighestValue" FontWeight="SemiBold" FontSize="16" IsTextSelectionEnabled="True" />
                </StackPanel>
            </Border>

            <ListView x:Name="Results" SelectionMode="None" IsItemClickEnabled="False">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="8,6,8,6" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{Binding BadgeBrush}" CornerRadius="10" Padding="8,2,8,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Badge}" Foreground="White" FontWeight="SemiBold" FontSize="12" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding Title}" FontWeight="SemiBold" VerticalAlignment="Center" IsTextSelectionEnabled="True" />
                            <TextBlock Grid.Column="2" Text="{Binding Reason}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </ScrollViewer>
</Page>
