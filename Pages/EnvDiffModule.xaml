<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.EnvDiffModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="880" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8F7;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
            <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Capture -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="CaptureTitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="TargetLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="TargetBox" MinWidth="160" SelectedIndex="0">
                            <ComboBoxItem>Process</ComboBoxItem>
                            <ComboBoxItem>User</ComboBoxItem>
                            <ComboBoxItem>Machine</ComboBoxItem>
                        </ComboBox>
                        <TextBox x:Name="NameBox" MinWidth="200" PlaceholderText="name" />
                        <Button x:Name="CaptureBtn" Click="Capture_Click" Style="{ThemeResource AccentButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Saved snapshots -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="SavedTitle" FontWeight="SemiBold" FontSize="15" />
                    <ListView x:Name="SnapshotsList" SelectionMode="None" MaxHeight="260">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="0,6,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                            <Run Text="{Binding Target}" /><Run Text=" · " /><Run Text="{Binding LocalTime}" /><Run Text=" · " /><Run Text="{Binding Count}" /><Run Text=" vars" />
                                        </TextBlock>
                                    </StackPanel>
                                    <Button Grid.Column="1" Margin="0,0,8,0" Content="&#xE71B;" FontFamily="{ThemeResource SymbolThemeFontFamily}" Tag="{Binding FileName}" Click="Export_Click" />
                                    <Button Grid.Column="2" Content="&#xE74D;" FontFamily="{ThemeResource SymbolThemeFontFamily}" Tag="{Binding FileName}" Click="Delete_Click" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock x:Name="EmptyText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <!-- Diff -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="DiffTitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="OldLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="OldBox" MinWidth="220" DisplayMemberPath="Label" />
                        <TextBlock x:Name="NewLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="NewBox" MinWidth="220" DisplayMemberPath="Label" />
                        <Button x:Name="DiffBtn" Click="Diff_Click" />
                        <Button x:Name="DiffExportBtn" Click="DiffExport_Click" Content="&#xE71B;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                            <TextBlock x:Name="AddedHdr" FontWeight="SemiBold" />
                            <ListView x:Name="AddedList" SelectionMode="None" MaxHeight="240">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Padding="0,3,0,3" Spacing="1">
                                            <TextBlock Text="{Binding Key}" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Display}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,8,0">
                            <TextBlock x:Name="RemovedHdr" FontWeight="SemiBold" />
                            <ListView x:Name="RemovedList" SelectionMode="None" MaxHeight="240">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Padding="0,3,0,3" Spacing="1">
                                            <TextBlock Text="{Binding Key}" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Display}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock x:Name="ChangedHdr" FontWeight="SemiBold" />
                            <ListView x:Name="ChangedList" SelectionMode="None" MaxHeight="240">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Padding="0,3,0,3" Spacing="1">
                                            <TextBlock Text="{Binding Key}" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Display}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
