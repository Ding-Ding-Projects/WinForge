<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="WinForge.Pages.AddSourceDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    PrimaryButtonClick="Primary_Click">

    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="520">
        <StackPanel Spacing="12" Width="440">
            <InfoBar x:Name="AdminBar" IsClosable="False" IsOpen="False" Severity="Warning" />

            <ComboBox x:Name="KnownBox" HorizontalAlignment="Stretch"
                      SelectionChanged="Known_Changed" />

            <TextBox x:Name="NameBox" />
            <TextBox x:Name="UrlBox" />

            <InfoBar x:Name="Bar" IsClosable="True" IsOpen="False" Severity="Error" />
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
