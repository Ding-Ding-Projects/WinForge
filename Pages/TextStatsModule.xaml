<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.TextStatsModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8A5;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="InputLabel" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="InputBox"
                             TextChanged="Input_TextChanged"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="200"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                        <CheckBox x:Name="StopChk" Checked="Stop_Changed" Unchecked="Stop_Changed" />
                        <TextBlock x:Name="StatusText" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="StatsTitle" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,6" />
                    <Grid ColumnSpacing="18" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="RowChars" Grid.Row="0" Grid.Column="0" TextWrapping="Wrap" />
                        <TextBlock x:Name="RowCharsNoSpace" Grid.Row="0" Grid.Column="1" TextWrapping="Wrap" />
                        <TextBlock x:Name="RowWords" Grid.Row="1" Grid.Column="0" TextWrapping="Wrap" />
                        <TextBlock x:Name="RowUnique" Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" />
                        <TextBlock x:Name="RowSentences" Grid.Row="2" Grid.Column="0" TextWrapping="Wrap" />
                        <TextBlock x:Name="RowParagraphs" Grid.Row="2" Grid.Column="1" TextWrapping="Wrap" />
                        <TextBlock x:Name="RowAvgWord" Grid.Row="3" Grid.Column="0" TextWrapping="Wrap" />
                        <TextBlock x:Name="RowAvgSentence" Grid.Row="3" Grid.Column="1" TextWrapping="Wrap" />
                        <TextBlock x:Name="RowReading" Grid.Row="4" Grid.Column="0" TextWrapping="Wrap" />
                        <TextBlock x:Name="RowSpeaking" Grid.Row="4" Grid.Column="1" TextWrapping="Wrap" />
                        <TextBlock x:Name="RowEase" Grid.Row="5" Grid.Column="0" TextWrapping="Wrap" />
                        <TextBlock x:Name="RowGrade" Grid.Row="5" Grid.Column="1" TextWrapping="Wrap" />
                        <TextBlock x:Name="RowEaseHint" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" TextWrapping="Wrap"
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="FreqTitle" FontWeight="SemiBold" FontSize="15" />
                    <ListView x:Name="FreqList" SelectionMode="None" MaxHeight="320">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="0,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Word}" TextWrapping="Wrap" />
                                    <TextBlock Grid.Column="1" Text="{Binding Count}" FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock x:Name="FreqEmpty" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
