<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.BitwardenModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="6">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="24" Glyph="&#xE72E;" VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>
            <TextBlock
                x:Name="HeaderBlurb"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />
        </StackPanel>

        <!-- Tabbed shell: a "Servers" tab + unlimited independent connection tabs -->
        <TabView
            x:Name="Tabs"
            Grid.Row="1"
            CanReorderTabs="True"
            CanDragTabs="False"
            IsAddTabButtonVisible="True"
            AddTabButtonClick="Tabs_AddTabButtonClick"
            TabCloseRequested="Tabs_TabCloseRequested"
            VerticalAlignment="Stretch">
            <TabView.TabItems>

                <!-- ===== Self-hosted servers (Vaultwarden via Docker) ===== -->
                <TabViewItem x:Name="ServersTab" IsClosable="False">
                    <TabViewItem.IconSource>
                        <FontIconSource Glyph="&#xE753;" />
                    </TabViewItem.IconSource>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,8,0">
                        <StackPanel MaxWidth="1000" Spacing="14">

                            <TextBlock x:Name="ServersTitle" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock
                                x:Name="ServersBlurb"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap" />

                            <!-- Docker engine banner -->
                            <InfoBar x:Name="DockerBar" IsClosable="False" IsOpen="False" />

                            <!-- New-instance controls -->
                            <Border
                                Padding="16"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Spacing="10">
                                    <TextBlock x:Name="NewServerTitle" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBox x:Name="NewNameBox" MaxWidth="420" HorizontalAlignment="Left" />
                                    <CheckBox x:Name="SignupsToggle" IsChecked="True" />
                                    <CheckBox x:Name="WebsocketToggle" IsChecked="False" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="CreateServerBtn" Style="{StaticResource AccentButtonStyle}" Click="CreateServer_Click" />
                                        <Button x:Name="RefreshServersBtn" Click="RefreshServers_Click" />
                                        <ProgressRing x:Name="ServerBusy" Width="22" Height="22" IsActive="False" VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Instances list -->
                            <TextBlock x:Name="InstancesHeader" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <StackPanel x:Name="InstancesPanel" Spacing="8" />
                            <TextBlock
                                x:Name="NoInstancesHint"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap"
                                Visibility="Collapsed" />

                            <!-- Live log -->
                            <TextBlock x:Name="LogHeader" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <Border
                                MinHeight="120"
                                MaxHeight="220"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto" Padding="10">
                                    <TextBlock x:Name="LogText" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                                </ScrollViewer>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabViewItem>

            </TabView.TabItems>
        </TabView>
    </Grid>
</Page>
