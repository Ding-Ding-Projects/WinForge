<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.KeePassModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Style="{StaticResource WinForgePageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="6">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE192;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Open / create bar (shown when locked) -->
        <Expander x:Name="VaultExpander" Grid.Row="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="True">
            <Expander.Header>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon FontSize="16" Glyph="&#xE1A2;" VerticalAlignment="Center" />
                    <TextBlock x:Name="VaultHeader" VerticalAlignment="Center" FontWeight="SemiBold" />
                    <Border x:Name="LockPill" CornerRadius="10" Padding="8,2,8,2" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <TextBlock x:Name="LockState" FontSize="12" />
                    </Border>
                </StackPanel>
            </Expander.Header>
            <StackPanel Spacing="10" Margin="0,4,0,0">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PathBox" Grid.Column="0" Header="Database file (.kdbx) · 資料庫檔案" IsReadOnly="True" PlaceholderText="No file chosen · 未揀檔案" />
                    <Button x:Name="BrowseBtn" Grid.Column="1" Click="Browse_Click" VerticalAlignment="Bottom" />
                </Grid>
                <PasswordBox x:Name="MasterBox" Header="Master password · 主密碼" PlaceholderText="Master password · 主密碼" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="KeyFileBox" Grid.Column="0" Header="Key file (optional) · 鎖匙檔（可選）" IsReadOnly="True" PlaceholderText="None · 無" />
                    <Button x:Name="KeyFileBtn" Grid.Column="1" Click="PickKeyFile_Click" VerticalAlignment="Bottom" />
                    <Button x:Name="KeyFileClearBtn" Grid.Column="2" Click="ClearKeyFile_Click" VerticalAlignment="Bottom" />
                </Grid>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button x:Name="OpenBtn" Click="Open_Click" Style="{StaticResource AccentButtonStyle}" />
                    <Button x:Name="CreateBtn" Click="Create_Click" />
                    <ProgressRing x:Name="OpenBusy" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
                </StackPanel>
                <InfoBar x:Name="OpenResult" IsClosable="True" IsOpen="False" />
            </StackPanel>
        </Expander>

        <!-- Toolbar (shown when unlocked) -->
        <Grid x:Name="Toolbar" Grid.Row="2" ColumnSpacing="8" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="AddEntryBtn" Grid.Column="0" Click="AddEntry_Click" Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE710;" />
                    <TextBlock x:Name="AddEntryLbl" />
                </StackPanel>
            </Button>
            <Button x:Name="AddGroupBtn" Grid.Column="1" Click="AddGroup_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE8F4;" />
                    <TextBlock x:Name="AddGroupLbl" />
                </StackPanel>
            </Button>
            <Button x:Name="GenBtn" Grid.Column="2" Click="Generator_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE8D7;" />
                    <TextBlock x:Name="GenLbl" />
                </StackPanel>
            </Button>
            <AutoSuggestBox x:Name="SearchBox" Grid.Column="3" QueryIcon="Find" TextChanged="Search_Changed" MinWidth="160" />
            <Button x:Name="SaveBtn" Grid.Column="4" Click="Save_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE74E;" />
                    <TextBlock x:Name="SaveLbl" />
                </StackPanel>
            </Button>
            <Button x:Name="SaveAsBtn" Grid.Column="5" Click="SaveAs_Click">
                <TextBlock x:Name="SaveAsLbl" />
            </Button>
            <Button x:Name="LockBtn" Grid.Column="6" Click="Lock_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE72E;" />
                    <TextBlock x:Name="LockLbl" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Main split: groups tree | entry list | detail -->
        <Grid x:Name="MainArea" Grid.Row="3" ColumnSpacing="12" Margin="0,0,0,12" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="1.2*" MinWidth="240" />
                <ColumnDefinition Width="1.4*" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <!-- Groups -->
            <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="12,8,12,8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <TextBlock x:Name="GroupsHeader" FontWeight="SemiBold" />
                    </Border>
                    <TreeView x:Name="GroupsTree" Grid.Row="1" SelectionMode="Single"
                              ItemInvoked="GroupsTree_ItemInvoked">
                        <TreeView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="14" Glyph="&#xE8B7;" />
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <!-- Entry list -->
            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="12,8,12,8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <TextBlock x:Name="EntriesHeader" FontWeight="SemiBold" />
                    </Border>
                    <ListView x:Name="EntryList" Grid.Row="1" SelectionMode="Single" SelectionChanged="EntryList_SelectionChanged">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="12,8,12,8" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding UserName}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel x:Name="EmptyEntries" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8" Visibility="Collapsed">
                        <FontIcon FontSize="32" Glyph="&#xE192;" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="EmptyEntriesText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" TextAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Detail -->
            <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Padding="12,8,12,8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="DetailHeader" Grid.Column="0" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button x:Name="EditBtn" Grid.Column="1" Click="EditEntry_Click" IsEnabled="False"><TextBlock x:Name="EditLbl" /></Button>
                        <Button x:Name="DeleteEntryBtn" Grid.Column="2" Click="DeleteEntry_Click" IsEnabled="False"><FontIcon FontSize="14" Glyph="&#xE74D;" /></Button>
                    </Grid>
                    <ScrollViewer Grid.Row="1">
                        <StackPanel x:Name="DetailPanel" Padding="16" Spacing="12" />
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
