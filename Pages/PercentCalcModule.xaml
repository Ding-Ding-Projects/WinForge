<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.PercentCalcModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8EF;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- X% of Y -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="C1Title" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox x:Name="C1X" TextChanged="Recalc" MinWidth="120" />
                        <TextBox x:Name="C1Y" TextChanged="Recalc" MinWidth="120" />
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="C1Out" Grid.Column="0" FontSize="14" VerticalAlignment="Center" TextWrapping="Wrap" />
                        <Button x:Name="C1Copy" Grid.Column="1" Click="Copy1" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- X is what % of Y -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="C2Title" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox x:Name="C2X" TextChanged="Recalc" MinWidth="120" />
                        <TextBox x:Name="C2Y" TextChanged="Recalc" MinWidth="120" />
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="C2Out" Grid.Column="0" FontSize="14" VerticalAlignment="Center" TextWrapping="Wrap" />
                        <Button x:Name="C2Copy" Grid.Column="1" Click="Copy2" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- % change from A to B -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="C3Title" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox x:Name="C3A" TextChanged="Recalc" MinWidth="120" />
                        <TextBox x:Name="C3B" TextChanged="Recalc" MinWidth="120" />
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="C3Out" Grid.Column="0" FontSize="14" VerticalAlignment="Center" TextWrapping="Wrap" />
                        <Button x:Name="C3Copy" Grid.Column="1" Click="Copy3" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- increase / decrease Y by X% -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="C4Title" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox x:Name="C4Y" TextChanged="Recalc" MinWidth="120" />
                        <TextBox x:Name="C4X" TextChanged="Recalc" MinWidth="120" />
                        <RadioButton x:Name="C4Inc" GroupName="C4Dir" IsChecked="True" Checked="Recalc" VerticalAlignment="Center" />
                        <RadioButton x:Name="C4Dec" GroupName="C4Dir" Checked="Recalc" VerticalAlignment="Center" />
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="C4Out" Grid.Column="0" FontSize="14" VerticalAlignment="Center" TextWrapping="Wrap" />
                        <Button x:Name="C4Copy" Grid.Column="1" Click="Copy4" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- tip calculator -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="C5Title" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox x:Name="C5Bill" TextChanged="Recalc" MinWidth="110" />
                        <TextBox x:Name="C5Tip" TextChanged="Recalc" MinWidth="110" />
                        <TextBox x:Name="C5Split" Text="1" TextChanged="Recalc" MinWidth="110" />
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="C5Out" Grid.Column="0" FontSize="14" VerticalAlignment="Center" TextWrapping="Wrap" />
                        <Button x:Name="C5Copy" Grid.Column="1" Click="Copy5" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ratio simplify -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="C6Title" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox x:Name="C6A" TextChanged="Recalc" MinWidth="120" />
                        <TextBlock Text=":" VerticalAlignment="Center" FontSize="16" />
                        <TextBox x:Name="C6B" TextChanged="Recalc" MinWidth="120" />
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="C6Out" Grid.Column="0" FontSize="14" VerticalAlignment="Center" TextWrapping="Wrap" />
                        <Button x:Name="C6Copy" Grid.Column="1" Click="Copy6" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
