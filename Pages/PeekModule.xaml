<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.PeekModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:winforgecontrols="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:WinForge.Pages"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    AllowDrop="True"
    DragOver="Page_DragOver"
    Drop="Page_Drop"
    mc:Ignorable="d">

    <Grid Style="{StaticResource WinForgePageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===================== Header ===================== -->
        <StackPanel Grid.Row="0" Spacing="8">
            <winforgecontrols:ModuleHeader x:Name="Header" Glyph="&#xE7B3;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
            <InfoBar x:Name="HotkeyBar" IsClosable="True" IsOpen="False" Severity="Informational" />
        </StackPanel>

        <!-- ===================== Toolbar: pick / hotkey ===================== -->
        <Border Grid.Row="1" Padding="12,10,12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <Button x:Name="PickBtn" Click="Pick_Click" Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="14" Glyph="&#xE8E5;" />
                            <TextBlock x:Name="PickText" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="PickFolderBtn" Click="PickFolder_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="14" Glyph="&#xED25;" />
                            <TextBlock x:Name="PickFolderText" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ExplorerBtn" Click="PeekExplorer_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="14" Glyph="&#xEC50;" />
                            <TextBlock x:Name="ExplorerText" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <TextBlock x:Name="DropHint" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="12" />

                <Button x:Name="HotkeyCfgBtn" Grid.Column="2" Click="HotkeyConfig_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE765;" />
                        <TextBlock x:Name="HotkeyCfgText" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ===================== File info header ===================== -->
        <Border Grid.Row="2" x:Name="InfoCard" Visibility="Collapsed" Padding="14,10,14,10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Image x:Name="FileIcon" Grid.Column="0" Width="40" Height="40" VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock x:Name="FileNameText" FontWeight="SemiBold" FontSize="15" TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="FileMetaText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock x:Name="CounterText" VerticalAlignment="Center" FontSize="12"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="0,0,4,0" />
                    <Button x:Name="PrevBtn" Click="Prev_Click" ToolTipService.ToolTip="Previous">
                        <FontIcon FontSize="14" Glyph="&#xE76B;" />
                    </Button>
                    <Button x:Name="NextBtn" Click="Next_Click" ToolTipService.ToolTip="Next">
                        <FontIcon FontSize="14" Glyph="&#xE76C;" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===================== Preview surface ===================== -->
        <Border Grid.Row="3" Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
            <Grid>
                <!-- Empty / hint state -->
                <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10" MaxWidth="420">
                    <FontIcon FontSize="46" Glyph="&#xE7B3;" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock x:Name="EmptyTitle" HorizontalAlignment="Center" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock x:Name="EmptyBlurb" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <!-- Image previewer -->
                <ScrollViewer x:Name="ImageHost" Visibility="Collapsed" ZoomMode="Enabled"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              MinZoomFactor="0.1" MaxZoomFactor="10">
                    <Image x:Name="PreviewImage" Stretch="Uniform" />
                </ScrollViewer>

                <!-- Text / code previewer -->
                <Grid x:Name="TextHost" Visibility="Collapsed">
                    <TextBox x:Name="TextView" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                             FontFamily="Cascadia Mono, Consolas, monospace" FontSize="13"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             BorderThickness="0" Background="Transparent" Padding="12" />
                </Grid>

                <!-- WebView2 previewer (markdown / pdf / html / svg) -->
                <controls:WebView2 x:Name="WebHost" Visibility="Collapsed" />

                <!-- Media previewer (audio / video) -->
                <Grid x:Name="MediaHost" Visibility="Collapsed" Background="Black">
                    <MediaPlayerElement x:Name="MediaView" AreTransportControlsEnabled="True"
                                        AutoPlay="False" Stretch="Uniform" />
                </Grid>

                <!-- Archive previewer -->
                <Grid x:Name="ArchiveHost" Visibility="Collapsed" RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="ArchiveSummary" Grid.Row="0" Margin="12,10,12,6" FontWeight="SemiBold" />
                    <ListView x:Name="ArchiveList" Grid.Row="1" SelectionMode="None" Padding="6,0,6,8">
                        <ListView.HeaderTemplate>
                            <DataTemplate />
                        </ListView.HeaderTemplate>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="12" Padding="6,4,6,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                                               FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12" />
                                    <TextBlock Grid.Column="1" Text="{Binding SizeText}" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" MinWidth="80"
                                               TextAlignment="Right" />
                                    <TextBlock Grid.Column="2" Text="{Binding Modified}" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" MinWidth="140"
                                               TextAlignment="Right" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <!-- Metadata previewer (unknown / binary) -->
                <ScrollViewer x:Name="MetaHost" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="MetaPanel" MaxWidth="560" Spacing="10" Padding="20" HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                </ScrollViewer>

                <!-- Busy ring -->
                <ProgressRing x:Name="Busy" IsActive="False" Width="40" Height="40"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- ===================== Action bar ===================== -->
        <Border Grid.Row="4" x:Name="ActionBar" Visibility="Collapsed" Padding="12,8,12,8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="OpenBtn" Click="Open_Click" Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE8A7;" />
                        <TextBlock x:Name="OpenText" />
                    </StackPanel>
                </Button>
                <Button x:Name="OpenWithBtn" Click="OpenWith_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE7AC;" />
                        <TextBlock x:Name="OpenWithText" />
                    </StackPanel>
                </Button>
                <Button x:Name="OpenFolderBtn" Click="OpenFolder_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xED25;" />
                        <TextBlock x:Name="OpenFolderText" />
                    </StackPanel>
                </Button>
                <Button x:Name="CopyPathBtn" Click="CopyPath_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE8C8;" />
                        <TextBlock x:Name="CopyPathText" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>
