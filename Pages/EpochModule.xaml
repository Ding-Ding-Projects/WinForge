<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.EpochModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xEC92;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Live "now" card -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="NowTitle" FontWeight="SemiBold" FontSize="15" />
                    <Grid ColumnSpacing="12" RowSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="NowSecLabel" Grid.Row="0" Grid.Column="0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="NowSecValue" Grid.Row="0" Grid.Column="1" FontFamily="Consolas" IsTextSelectionEnabled="True" />
                        <TextBlock x:Name="NowMsLabel" Grid.Row="1" Grid.Column="0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="NowMsValue" Grid.Row="1" Grid.Column="1" FontFamily="Consolas" IsTextSelectionEnabled="True" />
                        <TextBlock x:Name="NowLocalLabel" Grid.Row="2" Grid.Column="0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="NowLocalValue" Grid.Row="2" Grid.Column="1" IsTextSelectionEnabled="True" />
                        <TextBlock x:Name="NowUtcLabel" Grid.Row="3" Grid.Column="0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="NowUtcValue" Grid.Row="3" Grid.Column="1" FontFamily="Consolas" IsTextSelectionEnabled="True" />
                    </Grid>
                    <Button x:Name="CopyNowBtn" Click="CopyNow_Click" />
                </StackPanel>
            </Border>

            <!-- Epoch -> human -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="E2HTitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBox x:Name="EpochInput" MinWidth="240" InputScope="Number" TextChanged="EpochInput_Changed" />
                        <ComboBox x:Name="EpochUnit" SelectedIndex="0" SelectionChanged="EpochUnit_Changed" MinWidth="150" />
                        <Button x:Name="ConvertBtn" Click="Convert_Click" />
                    </StackPanel>
                    <TextBlock x:Name="E2HError" Foreground="{ThemeResource SystemFillColorCriticalBrush}" TextWrapping="Wrap" Visibility="Collapsed" />
                    <Grid x:Name="E2HResults" ColumnSpacing="12" RowSpacing="4" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="RLocalLabel" Grid.Row="0" Grid.Column="0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="RLocalValue" Grid.Row="0" Grid.Column="1" IsTextSelectionEnabled="True" />
                        <TextBlock x:Name="RUtcLabel" Grid.Row="1" Grid.Column="0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="RUtcValue" Grid.Row="1" Grid.Column="1" IsTextSelectionEnabled="True" />
                        <TextBlock x:Name="RIsoLabel" Grid.Row="2" Grid.Column="0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="RIsoValue" Grid.Row="2" Grid.Column="1" FontFamily="Consolas" IsTextSelectionEnabled="True" />
                        <TextBlock x:Name="RDowLabel" Grid.Row="3" Grid.Column="0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="RDowValue" Grid.Row="3" Grid.Column="1" IsTextSelectionEnabled="True" />
                        <TextBlock x:Name="RRelLabel" Grid.Row="4" Grid.Column="0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="RRelValue" Grid.Row="4" Grid.Column="1" IsTextSelectionEnabled="True" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Human -> epoch -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="H2ETitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <CalendarDatePicker x:Name="DatePick" DateChanged="HumanInput_Changed" MinWidth="200" />
                        <TimePicker x:Name="TimePick" ClockIdentifier="24HourClock" SelectedTimeChanged="HumanTime_Changed" MinWidth="140" />
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="UtcToggleTitle" FontWeight="SemiBold" />
                            <TextBlock x:Name="UtcToggleHint" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="UtcSwitch" Grid.Column="1" Toggled="Utc_Toggled" VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock x:Name="H2EError" Foreground="{ThemeResource SystemFillColorCriticalBrush}" TextWrapping="Wrap" Visibility="Collapsed" />
                    <Grid x:Name="H2EResults" ColumnSpacing="12" RowSpacing="4" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="OutSecLabel" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="OutSecValue" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" FontFamily="Consolas" IsTextSelectionEnabled="True" />
                        <Button x:Name="CopySecBtn" Grid.Row="0" Grid.Column="2" Click="CopySec_Click" />
                        <TextBlock x:Name="OutMsLabel" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="OutMsValue" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" FontFamily="Consolas" IsTextSelectionEnabled="True" />
                        <Button x:Name="CopyMsBtn" Grid.Row="1" Grid.Column="2" Click="CopyMs_Click" />
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</Page>
