<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.NewPlusModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Style="{StaticResource WinForgePageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <controls:ModuleHeader x:Name="Header" Grid.Row="0" Glyph="&#xE710;" />
        <TextBlock x:Name="HeaderBlurb" Grid.Row="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

        <!-- Toolbar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,4,0,0" >
            <Button x:Name="AddBtn" Click="Add_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE710;" />
                    <TextBlock x:Name="AddBtnText" />
                </StackPanel>
            </Button>
            <Button x:Name="NewBlankBtn" Click="NewBlank_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE7C3;" />
                    <TextBlock x:Name="NewBlankBtnText" />
                </StackPanel>
            </Button>
            <Button x:Name="RenameBtn" Click="Rename_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE8AC;" />
                    <TextBlock x:Name="RenameBtnText" />
                </StackPanel>
            </Button>
            <Button x:Name="DeleteBtn" Click="Delete_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                    <TextBlock x:Name="DeleteBtnText" />
                </StackPanel>
            </Button>
            <AppBarSeparator />
            <Button x:Name="OpenFolderBtn" Click="OpenFolder_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE838;" />
                    <TextBlock x:Name="OpenFolderBtnText" />
                </StackPanel>
            </Button>
            <Button x:Name="RefreshBtn" Click="Refresh_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE72C;" />
                    <TextBlock x:Name="RefreshBtnText" />
                </StackPanel>
            </Button>
            <Button x:Name="SettingsBtn" Click="Settings_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE713;" />
                    <TextBlock x:Name="SettingsBtnText" />
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Main content: templates list (left) + create-from-template (right) -->
        <Grid Grid.Row="3" ColumnSpacing="14" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- Templates list -->
            <Border
                Grid.Column="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid>
                    <ListView
                        x:Name="TemplatesList"
                        SelectionMode="Single"
                        SelectionChanged="TemplatesList_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="12" Padding="4,6,4,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" FontSize="18" Glyph="{Binding Glyph}" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding SubTitle}" FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding KindLabel}" FontSize="11"
                                               VerticalAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock
                        x:Name="EmptyHint"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap"
                        TextAlignment="Center"
                        MaxWidth="320"
                        Visibility="Collapsed" />
                </Grid>
            </Border>

            <!-- Create from template -->
            <Border
                Grid.Column="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14">
                <ScrollViewer>
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="CreateTitle" Style="{StaticResource BodyStrongTextBlockStyle}" />

                        <TextBlock x:Name="SelectedCap" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="SelectedName" TextWrapping="Wrap" />

                        <TextBlock x:Name="DestCap" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,6,0,0" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="DestBox" Grid.Column="0" IsReadOnly="True" />
                            <Button x:Name="DestBtn" Grid.Column="1" Click="BrowseDest_Click" />
                        </Grid>

                        <TextBlock x:Name="NameCap" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,6,0,0" />
                        <TextBox x:Name="NameBox" TextChanged="NameBox_Changed" />
                        <TextBlock x:Name="PreviewText" FontSize="12" TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <CheckBox x:Name="VarsCheck" Click="Vars_Click" Margin="0,4,0,0" />

                        <Button x:Name="CreateBtn" Click="Create_Click" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" />

                        <Button x:Name="VarsHelpBtn" Click="VarsHelp_Click" HorizontalAlignment="Stretch" />

                        <TextBlock x:Name="ExplorerCap" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,10,0,0" />
                        <TextBlock x:Name="ExplorerBlurb" FontSize="12" TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Button x:Name="RegisterBtn" Click="Register_Click" HorizontalAlignment="Stretch" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <InfoBar x:Name="ResultBar" Grid.Row="4" IsClosable="True" IsOpen="False" />
    </Grid>
</Page>
