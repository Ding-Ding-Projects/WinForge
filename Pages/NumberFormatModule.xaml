<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.NumberFormatModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8EF;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="InputLabel" FontWeight="SemiBold" />
                        <TextBox x:Name="InputBox" PlaceholderText="1234567.89" TextChanged="Input_Changed" />
                        <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>

                    <Grid ColumnSpacing="14" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                            <TextBlock x:Name="DecimalsLabel" />
                            <NumberBox x:Name="DecimalsBox" Value="2" Minimum="0" Maximum="10" SpinButtonPlacementMode="Inline" ValueChanged="Options_Changed" />
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                            <TextBlock x:Name="PadLabel" />
                            <NumberBox x:Name="PadBox" Value="8" Minimum="0" Maximum="40" SpinButtonPlacementMode="Inline" ValueChanged="Options_Changed" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="4">
                            <TextBlock x:Name="CurrencyLabel" />
                            <ComboBox x:Name="CurrencyCombo" HorizontalAlignment="Stretch" SelectionChanged="Options_Changed" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock x:Name="ResultsLabel" FontWeight="SemiBold" />
            <ListView x:Name="ResultsList" SelectionMode="None" IsItemClickEnabled="False">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="4,6,4,6" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                            <TextBlock Grid.Column="1" Text="{Binding Value}" VerticalAlignment="Center" FontFamily="Consolas" IsTextSelectionEnabled="True" TextWrapping="Wrap" />
                            <Button Grid.Column="2" Content="&#xE8C8;" FontFamily="Segoe Fluent Icons" Tag="{Binding Value}" Click="Copy_Click" VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </ScrollViewer>
</Page>
