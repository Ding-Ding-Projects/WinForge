<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.ColorToolsModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE790;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Input + swatch -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBox x:Name="InputBox" MinWidth="240" TextChanged="Input_TextChanged" />
                        <Button x:Name="RandomBtn" Click="Random_Click" />
                    </StackPanel>
                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

                    <Border x:Name="Swatch" Height="96" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" />

                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock x:Name="RLabel" Width="24" VerticalAlignment="Center" />
                            <Slider x:Name="RSlider" Minimum="0" Maximum="255" Width="360" ValueChanged="Slider_Changed" />
                            <TextBlock x:Name="RVal" VerticalAlignment="Center" Width="36" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock x:Name="GLabel" Width="24" VerticalAlignment="Center" />
                            <Slider x:Name="GSlider" Minimum="0" Maximum="255" Width="360" ValueChanged="Slider_Changed" />
                            <TextBlock x:Name="GVal" VerticalAlignment="Center" Width="36" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock x:Name="BLabel" Width="24" VerticalAlignment="Center" />
                            <Slider x:Name="BSlider" Minimum="0" Maximum="255" Width="360" ValueChanged="Slider_Changed" />
                            <TextBlock x:Name="BVal" VerticalAlignment="Center" Width="36" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Output rows -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="OutputsTitle" FontWeight="SemiBold" FontSize="15" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="HEX" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="HexOut" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" FontFamily="Consolas" IsTextSelectionEnabled="True" />
                        <Button x:Name="CopyHex" Grid.Row="0" Grid.Column="2" Click="CopyHex_Click" Margin="0,2,0,2" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="RGB" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="RgbOut" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" FontFamily="Consolas" IsTextSelectionEnabled="True" />
                        <Button x:Name="CopyRgb" Grid.Row="1" Grid.Column="2" Click="CopyRgb_Click" Margin="0,2,0,2" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="HSL" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="HslOut" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" FontFamily="Consolas" IsTextSelectionEnabled="True" />
                        <Button x:Name="CopyHsl" Grid.Row="2" Grid.Column="2" Click="CopyHsl_Click" Margin="0,2,0,2" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="HSV" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="HsvOut" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" FontFamily="Consolas" IsTextSelectionEnabled="True" />
                        <Button x:Name="CopyHsv" Grid.Row="3" Grid.Column="2" Click="CopyHsv_Click" Margin="0,2,0,2" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="CMYK" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="CmykOut" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" FontFamily="Consolas" IsTextSelectionEnabled="True" />
                        <Button x:Name="CopyCmyk" Grid.Row="4" Grid.Column="2" Click="CopyCmyk_Click" Margin="0,2,0,2" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Palette -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="PaletteTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="PaletteHint" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <StackPanel x:Name="PaletteRow" Orientation="Horizontal" Spacing="10" />
                </StackPanel>
            </Border>

            <!-- WCAG contrast -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <TextBlock x:Name="ContrastTitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock x:Name="BgLabel" VerticalAlignment="Center" Width="150" />
                        <TextBox x:Name="BgBox" MinWidth="200" TextChanged="Bg_TextChanged" />
                        <Button x:Name="SwapBtn" Click="Swap_Click" />
                    </StackPanel>
                    <Border x:Name="PreviewBorder" Height="72" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="12">
                        <TextBlock x:Name="PreviewText" FontSize="18" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock x:Name="RatioText" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel x:Name="BadgeRow" Orientation="Horizontal" Spacing="8" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
