<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.EncodingConvModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8C8;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="LoadBtn" Click="Load_Click" />
                        <TextBlock x:Name="DetectText" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>

                    <TextBlock x:Name="SourceLabel" FontWeight="SemiBold" />
                    <TextBox x:Name="SourceBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120" MaxHeight="220" ScrollViewer.VerticalScrollBarVisibility="Auto" TextChanged="Source_Changed" />
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <StackPanel Spacing="1">
                            <TextBlock x:Name="EncLabel" FontSize="12" />
                            <ComboBox x:Name="EncCombo" MinWidth="180" SelectionChanged="Options_Changed" />
                        </StackPanel>
                        <StackPanel Spacing="1">
                            <TextBlock x:Name="EolLabel" FontSize="12" />
                            <ComboBox x:Name="EolCombo" MinWidth="130" SelectionChanged="Options_Changed" />
                        </StackPanel>
                    </StackPanel>

                    <Button x:Name="ConvertBtn" Click="Convert_Click" />

                    <TextBlock x:Name="ResultLabel" FontWeight="SemiBold" />
                    <TextBox x:Name="ResultBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120" MaxHeight="220" ScrollViewer.VerticalScrollBarVisibility="Auto" />

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="SaveBtn" Click="Save_Click" />
                        <Button x:Name="CopyBtn" Click="Copy_Click" />
                    </StackPanel>

                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
