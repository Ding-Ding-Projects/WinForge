<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.ViaProxyModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,16" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
            <FontIcon FontSize="22" Glyph="&#xE990;" VerticalAlignment="Center" />
            <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
        </StackPanel>
        <TextBlock x:Name="HeaderBlurb" Grid.Row="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

        <!-- Engine / status bars -->
        <StackPanel Grid.Row="2" Spacing="8">
            <InfoBar x:Name="JavaBar" IsClosable="False" IsOpen="False" />
            <InfoBar x:Name="JarBar" IsClosable="False" IsOpen="False" />
            <InfoBar x:Name="StatusBar" IsClosable="False" IsOpen="False" />
        </StackPanel>

        <!-- Toolbar -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
            <Button x:Name="DownloadBtn" Click="Download_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE896;" FontSize="14" />
                    <TextBlock x:Name="DownloadText" />
                </StackPanel>
            </Button>
            <Button x:Name="PickJarBtn" Click="PickJar_Click" />
            <ProgressRing x:Name="Busy" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
            <Button x:Name="SourceBtn" Click="Source_Click" />
        </StackPanel>

        <!-- Body: config form (left) + log pane (right) -->
        <Grid Grid.Row="4" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Config form -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                          CornerRadius="8" Padding="14">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="ConfigHeader" FontWeight="SemiBold" />

                    <TextBox x:Name="TargetHostBox" />
                    <NumberBox x:Name="TargetPortBox" Value="25565" Minimum="1" Maximum="65535"
                               SpinButtonPlacementMode="Compact" />
                    <ComboBox x:Name="VersionBox" HorizontalAlignment="Stretch" />

                    <ComboBox x:Name="AuthBox" HorizontalAlignment="Stretch" />
                    <ToggleSwitch x:Name="OnlineModeToggle" />

                    <TextBlock x:Name="AdvancedHeader" FontWeight="SemiBold" Margin="0,6,0,0" />
                    <TextBox x:Name="BindHostBox" Text="127.0.0.1" />
                    <NumberBox x:Name="BindPortBox" Value="25568" Minimum="1" Maximum="65535"
                               SpinButtonPlacementMode="Compact" />
                    <TextBox x:Name="BackendProxyBox" />
                    <ToggleSwitch x:Name="AllowBetaPingToggle" />
                    <ToggleSwitch x:Name="BetacraftToggle" />

                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button x:Name="StartBtn" Click="Start_Click" Style="{StaticResource AccentButtonStyle}" />
                        <Button x:Name="StopBtn" Click="Stop_Click" IsEnabled="False" />
                    </StackPanel>

                    <Border x:Name="HintCard" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="6" Padding="10" Margin="0,6,0,0" Visibility="Collapsed">
                        <StackPanel Spacing="6">
                            <TextBlock x:Name="HintText" TextWrapping="Wrap" FontSize="12" />
                            <Button x:Name="CopyAddrBtn" Click="CopyAddr_Click" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Log pane -->
            <Grid Grid.Column="1" RowSpacing="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                    <TextBlock x:Name="LogHeader" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button x:Name="ClearLogBtn" Click="ClearLog_Click" />
                    <Button x:Name="CopyLogBtn" Click="CopyLog_Click" />
                    <Ellipse x:Name="RunDot" Width="10" Height="10" Fill="Gray" VerticalAlignment="Center" />
                    <TextBlock x:Name="RunState" VerticalAlignment="Center" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <ScrollViewer x:Name="LogScroller" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                              CornerRadius="8" Padding="10">
                    <TextBlock x:Name="LogText" FontFamily="Consolas" FontSize="12" IsTextSelectionEnabled="True"
                               TextWrapping="Wrap" />
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>
