<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.UnicodeInspectModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="920" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE943;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="InputLabel" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80" MaxHeight="200"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             TextChanged="Input_TextChanged" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="SampleBtn" Click="Sample_Click" />
                        <Button x:Name="ClearBtn" Click="Clear_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <InfoBar x:Name="Info" IsClosable="False" IsOpen="False" Severity="Informational" />

            <Border Padding="16,12,16,12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="SummaryTitle" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock x:Name="SummaryText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <TextBlock x:Name="HintText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <ListView x:Name="RowsList" SelectionMode="None" IsItemClickEnabled="True" ItemClick="Rows_ItemClick"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="1" CornerRadius="8">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="4,6,4,6" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="6"
                                    Background="{ThemeResource ControlFillColorDefaultBrush}" VerticalAlignment="Top">
                                <TextBlock Text="{Binding Glyph}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="1">
                                <TextBlock Text="{Binding CodePoint}" FontWeight="SemiBold" FontFamily="Consolas" />
                                <TextBlock Text="{Binding Decimal}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="2">
                                <TextBlock Text="{Binding Name}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Category}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{Binding Flags}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                <TextBlock FontSize="11" FontFamily="Consolas" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap">
                                    <Run Text="UTF-8:" /><Run Text=" " /><Run Text="{Binding Utf8}" /><Run Text="    UTF-16:" /><Run Text=" " /><Run Text="{Binding Utf16}" />
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </ScrollViewer>
</Page>
