<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.ColorPaletteModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE790;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Border x:Name="BasePreview" Width="40" Height="40" CornerRadius="6" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" />
                        <StackPanel Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="BaseLabel" FontWeight="SemiBold" FontSize="14" />
                            <TextBox x:Name="BaseBox" MinWidth="200" Text="#3EB489" TextChanged="Base_Changed" />
                        </StackPanel>
                        <Button x:Name="RandomBtn" Content="Random" Click="Random_Click" VerticalAlignment="Bottom" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock x:Name="RLabel" Width="20" VerticalAlignment="Center" />
                            <Slider x:Name="RSlider" Minimum="0" Maximum="255" Width="260" ValueChanged="Slider_Changed" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock x:Name="GLabel" Width="20" VerticalAlignment="Center" />
                            <Slider x:Name="GSlider" Minimum="0" Maximum="255" Width="260" ValueChanged="Slider_Changed" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock x:Name="BLabel" Width="20" VerticalAlignment="Center" />
                            <Slider x:Name="BSlider" Minimum="0" Maximum="255" Width="260" ValueChanged="Slider_Changed" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="SchemeLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="SchemeBox" MinWidth="220" SelectionChanged="Scheme_Changed" />
                    </StackPanel>

                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

                    <StackPanel x:Name="SwatchRow" Orientation="Horizontal" Spacing="8" />

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="CopyCssBtn" Content="Copy CSS" Click="CopyCss_Click" />
                        <Button x:Name="CopyJsonBtn" Content="Copy JSON" Click="CopyJson_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
