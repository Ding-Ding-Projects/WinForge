<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.SubnetCalcModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE968;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Inputs -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="InputTitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="IpLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBox x:Name="IpBox" MinWidth="180" Text="192.168.1.10" TextChanged="Input_Changed" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="CidrLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <NumberBox x:Name="CidrBox" Value="24" Minimum="0" Maximum="32" SpinButtonPlacementMode="Inline" MinWidth="120" ValueChanged="Cidr_Changed" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="MaskLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBox x:Name="MaskBox" MinWidth="160" Text="255.255.255.0" TextChanged="Mask_Changed" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="StatusText" FontSize="12" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Results -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="ResultTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="ResultBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" FontFamily="Consolas" MinHeight="240"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>

            <!-- Split helper -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="SplitTitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="NewPrefixLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <NumberBox x:Name="NewPrefixBox" Value="26" Minimum="0" Maximum="32" SpinButtonPlacementMode="Inline" MinWidth="120" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="CountLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <NumberBox x:Name="CountBox" Value="0" Minimum="0" Maximum="65536" SpinButtonPlacementMode="Inline" MinWidth="140" />
                        </StackPanel>
                        <Button x:Name="SplitBtn" Click="Split_Click" VerticalAlignment="Bottom" />
                    </StackPanel>
                    <TextBox x:Name="SplitBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" FontFamily="Consolas" MinHeight="160"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
