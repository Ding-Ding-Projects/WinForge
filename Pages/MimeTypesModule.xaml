<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.MimeTypesModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8A5;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Search / filter card -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="SearchTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="SearchBox" TextChanged="Search_Changed" />
                    <TextBlock x:Name="ResultCount" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ListView x:Name="ResultsList" MaxHeight="360" SelectionMode="Single"
                              IsItemClickEnabled="True" ItemClick="Results_ItemClick"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="4,6,4,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Ext}" FontFamily="Consolas" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Mime}" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock x:Name="CopyHint" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Detect-from-filename card -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="DetectTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="DetectBox" TextChanged="Detect_Changed" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="DetectResult" Grid.Column="0" FontFamily="Consolas" FontSize="14" VerticalAlignment="Center" TextWrapping="Wrap" />
                        <Button x:Name="DetectCopyBtn" Grid.Column="1" Click="DetectCopy_Click" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
