<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.WolModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE839;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="MacLabel" FontWeight="SemiBold" />
                        <TextBox x:Name="MacBox" PlaceholderText="AA:BB:CC:DD:EE:FF" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="BroadcastLabel" FontWeight="SemiBold" />
                        <TextBox x:Name="BroadcastBox" Text="255.255.255.255" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="PortLabel" VerticalAlignment="Center" />
                        <NumberBox x:Name="PortBox" Value="9" Minimum="1" Maximum="65535" SpinButtonPlacementMode="Inline" MinWidth="140" />
                    </StackPanel>

                    <Button x:Name="SendButton" Click="Send_Click" Style="{ThemeResource AccentButtonStyle}" />

                    <TextBlock x:Name="StatusText" FontSize="12" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <Border x:Name="RecentCard" Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="RecentLabel" FontWeight="SemiBold" />
                    <ItemsControl x:Name="RecentList" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
