<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.TableFormatModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="880" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE9F9;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="InputLabel" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="150"
                             FontFamily="Consolas" TextChanged="Input_Changed"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />

                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="DelimLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="DelimBox" MinWidth="140" SelectionChanged="Option_Changed" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="FormatLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="FormatBox" MinWidth="140" SelectionChanged="Option_Changed" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="AlignLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="AlignBox" MinWidth="140" SelectionChanged="Option_Changed" />
                        </StackPanel>
                    </StackPanel>

                    <CheckBox x:Name="HeaderChk" Checked="Option_Changed" Unchecked="Option_Changed" />
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="OutputLabel" FontWeight="SemiBold" FontSize="15" />
                            <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <Button x:Name="CopyBtn" Grid.Column="1" Click="Copy_Click" VerticalAlignment="Center" />
                    </Grid>
                    <TextBox x:Name="OutputBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                             MinHeight="180" FontFamily="Consolas"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
