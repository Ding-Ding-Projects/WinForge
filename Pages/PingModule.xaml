<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.PingModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xEB41;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Pivot x:Name="Tabs">
                <!-- Ping -->
                <PivotItem x:Name="PingTab">
                    <StackPanel Spacing="14">
                        <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <TextBlock x:Name="PingHostLabel" VerticalAlignment="Center" />
                                    <TextBox x:Name="PingHostBox" MinWidth="240" Text="8.8.8.8" />
                                    <TextBlock x:Name="PingCountLabel" VerticalAlignment="Center" />
                                    <NumberBox x:Name="PingCountBox" Value="4" Minimum="1" Maximum="1000" SpinButtonPlacementMode="Inline" MinWidth="120" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button x:Name="PingStartBtn" Click="PingStart_Click" Style="{ThemeResource AccentButtonStyle}" />
                                    <Button x:Name="PingStopBtn" Click="PingStop_Click" IsEnabled="False" />
                                </StackPanel>
                                <TextBlock x:Name="PingStatusText" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock x:Name="PingStatsText" FontWeight="SemiBold" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <ListView x:Name="PingList" SelectionMode="None" MaxHeight="360">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="12" Padding="4,6,4,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48" />
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Sequence}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Address}" />
                                        <TextBlock Grid.Column="2" Text="{Binding Rtt}" />
                                        <TextBlock Grid.Column="3" Text="{Binding Ttl}" />
                                        <TextBlock Grid.Column="4" Text="{Binding Status}" TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </PivotItem>

                <!-- Traceroute -->
                <PivotItem x:Name="TraceTab">
                    <StackPanel Spacing="14">
                        <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <TextBlock x:Name="TraceHostLabel" VerticalAlignment="Center" />
                                    <TextBox x:Name="TraceHostBox" MinWidth="240" Text="8.8.8.8" />
                                    <TextBlock x:Name="TraceHopsLabel" VerticalAlignment="Center" />
                                    <NumberBox x:Name="TraceHopsBox" Value="30" Minimum="1" Maximum="64" SpinButtonPlacementMode="Inline" MinWidth="120" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button x:Name="TraceStartBtn" Click="TraceStart_Click" Style="{ThemeResource AccentButtonStyle}" />
                                    <Button x:Name="TraceStopBtn" Click="TraceStop_Click" IsEnabled="False" />
                                </StackPanel>
                                <TextBlock x:Name="TraceStatusText" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                        <ListView x:Name="TraceList" SelectionMode="None" MaxHeight="420">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="12" Padding="4,6,4,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48" />
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Sequence}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Address}" />
                                        <TextBlock Grid.Column="2" Text="{Binding Rtt}" />
                                        <TextBlock Grid.Column="3" Text="{Binding Status}" TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </PivotItem>
            </Pivot>
        </StackPanel>
    </ScrollViewer>
</Page>
