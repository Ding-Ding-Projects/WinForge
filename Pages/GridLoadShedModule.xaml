<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.GridLoadShedModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE945;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Reactor-power empty-state -->
            <InfoBar x:Name="NeedPowerBar" IsOpen="False" IsClosable="False" Severity="Warning" />

            <!-- Live available reactor output -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ReactorTitle" Grid.Column="0" FontWeight="SemiBold" FontSize="15" TextWrapping="Wrap" VerticalAlignment="Center" />
                        <TextBlock x:Name="OutputValue" Grid.Column="1" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                    </Grid>
                    <ProgressBar x:Name="OutputBar" Minimum="0" Maximum="1150" Value="0" Height="8" />
                    <TextBlock x:Name="ReactorModeText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Dispatch controls -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="DispatchTitle" FontWeight="SemiBold" FontSize="15" />
                            <TextBlock x:Name="DispatchStatus" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <Button x:Name="ResetButton" Grid.Column="1" MinHeight="44" Click="Reset_Click" VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Spacing="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ReserveLabel" Grid.Column="0" FontSize="13" TextWrapping="Wrap" />
                            <TextBlock x:Name="ReserveValue" Grid.Column="1" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </Grid>
                        <Slider x:Name="ReserveSlider" MinHeight="44" Minimum="0" Maximum="30" Value="10" StepFrequency="1" ValueChanged="Reserve_ValueChanged" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Feeder board (rows are built in code-behind) -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="BoardTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="BoardHint" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <StackPanel x:Name="FeederBoard" Spacing="6" />
                </StackPanel>
            </Border>

            <!-- Grid telemetry -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="TelemetryTitle" FontWeight="SemiBold" FontSize="15" />

                    <!-- Served vs usable budget -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="BudgetCaption" Grid.Column="0" TextWrapping="Wrap" VerticalAlignment="Center" />
                        <TextBlock x:Name="BudgetValue" Grid.Column="1" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Grid>
                    <ProgressBar x:Name="BudgetBar" Minimum="0" Maximum="990" Value="0" Height="8" />

                    <Grid ColumnSpacing="12" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="1">
                            <TextBlock x:Name="ShedCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                            <TextBlock x:Name="ShedValue" FontWeight="SemiBold" FontSize="16" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="1">
                            <TextBlock x:Name="ReserveHeldCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                            <TextBlock x:Name="ReserveHeldValue" FontWeight="SemiBold" FontSize="16" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="1">
                            <TextBlock x:Name="UnservedCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                            <TextBlock x:Name="UnservedValue" FontWeight="SemiBold" FontSize="16" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="1">
                            <TextBlock x:Name="EventsCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                            <TextBlock x:Name="EventsValue" FontWeight="SemiBold" FontSize="16" />
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="BoardNote" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
