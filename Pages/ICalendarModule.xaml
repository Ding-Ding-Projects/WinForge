<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.ICalendarModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE787;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="Status" IsOpen="False" IsClosable="False" Severity="Informational" />

            <!-- Event details -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="DetailsTitle" FontWeight="SemiBold" FontSize="15" />

                    <TextBox x:Name="SummaryBox" TextChanged="AnyChanged" />
                    <TextBox x:Name="LocationBox" TextChanged="AnyChanged" />
                    <TextBox x:Name="DescBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="72"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" TextChanged="AnyChanged" />

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <CalendarDatePicker x:Name="StartDate" MinWidth="180" DateChanged="Start_DateChanged" />
                        <TimePicker x:Name="StartTime" ClockIdentifier="24HourClock" MinWidth="140" TimeChanged="Start_TimeChanged" />
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="AllDayTitle" FontWeight="SemiBold" />
                            <TextBlock x:Name="AllDayHint" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="AllDaySwitch" Grid.Column="1" VerticalAlignment="Center" Toggled="AllDay_Toggled" />
                    </Grid>

                    <StackPanel x:Name="DurationPanel" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="DurationLabel" VerticalAlignment="Center" />
                        <NumberBox x:Name="DurationBox" Value="60" Minimum="1" Maximum="100000" SpinButtonPlacementMode="Inline" MinWidth="150" ValueChanged="AnyChanged" />
                        <ComboBox x:Name="DurationUnit" SelectionChanged="AnyChanged" MinWidth="120" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Recurrence + reminder -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="RepeatTitle" FontWeight="SemiBold" FontSize="15" />

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="RecurLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="RecurCombo" SelectionChanged="AnyChanged" MinWidth="160" />
                    </StackPanel>

                    <StackPanel x:Name="RecurDetail" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="IntervalLabel" VerticalAlignment="Center" />
                        <NumberBox x:Name="IntervalBox" Value="1" Minimum="1" Maximum="1000" SpinButtonPlacementMode="Inline" MinWidth="120" ValueChanged="AnyChanged" />
                        <TextBlock x:Name="CountLabel" VerticalAlignment="Center" />
                        <NumberBox x:Name="CountBox" Value="0" Minimum="0" Maximum="100000" SpinButtonPlacementMode="Inline" MinWidth="120" ValueChanged="AnyChanged" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="ReminderLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="ReminderCombo" SelectionChanged="AnyChanged" MinWidth="200" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Output -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="OutputTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="OutputBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" MinHeight="180"
                             FontFamily="Consolas"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="CopyBtn" Click="Copy_Click" />
                        <Button x:Name="SaveBtn" Click="Save_Click" Style="{ThemeResource AccentButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Parser -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="ParseTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="ParseInput" AcceptsReturn="True" TextWrapping="NoWrap" MinHeight="120"
                             FontFamily="Consolas"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="ParseBtn" Click="Parse_Click" />
                        <Button x:Name="PasteBtn" Click="Paste_Click" />
                    </StackPanel>
                    <ListView x:Name="ParseList" SelectionMode="None" MaxHeight="260"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="1" Padding="0,4,0,4">
                                    <TextBlock Text="{Binding Summary}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Start}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
