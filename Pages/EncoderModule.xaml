<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.EncoderModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8C8;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock x:Name="ModeLabel" FontWeight="SemiBold" FontSize="13" />
                            <ComboBox x:Name="ModeBox" HorizontalAlignment="Stretch" SelectionChanged="Mode_Changed" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock x:Name="EncodingLabel" FontWeight="SemiBold" FontSize="13" />
                            <ComboBox x:Name="EncodingBox" HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="InputLabel" FontWeight="SemiBold" FontSize="13" />
                        <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" IsSpellCheckEnabled="False" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="EncodeBtn" Click="Encode_Click" Style="{ThemeResource AccentButtonStyle}" />
                        <Button x:Name="DecodeBtn" Click="Decode_Click" />
                        <Button x:Name="SwapBtn" Click="Swap_Click" />
                    </StackPanel>

                    <TextBlock x:Name="StatusText" FontSize="12" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <StackPanel Spacing="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="OutputLabel" Grid.Column="0" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                            <Button x:Name="CopyBtn" Grid.Column="1" Click="Copy_Click" />
                        </Grid>
                        <TextBox x:Name="OutputBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120" IsReadOnly="True"
                                 FontFamily="Consolas" ScrollViewer.VerticalScrollBarVisibility="Auto" IsSpellCheckEnabled="False" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
