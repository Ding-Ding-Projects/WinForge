<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.ReactorDependencyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,18,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="860" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xEBC0;" />

            <InfoBar x:Name="StatusBar" IsClosable="False" IsOpen="True" />

            <Border
                Padding="18"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="RequirementTitle" FontWeight="SemiBold" FontSize="16" />
                    <TextBlock x:Name="RequirementText" TextWrapping="Wrap" />
                    <TextBlock x:Name="ReasonText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <TextBlock x:Name="SnapshotText" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="OpenReactorButton" Click="OpenReactor_Click" />
                <Button x:Name="RetryButton" Click="Retry_Click" />
                <Button x:Name="EnableApiButton" Click="EnableApi_Click" />
                <Button x:Name="SettingsButton" Click="Settings_Click" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
