<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.LoremTextModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8A5;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <Grid ColumnSpacing="16" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                            <TextBlock x:Name="UnitLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="UnitCombo" HorizontalAlignment="Stretch" SelectionChanged="Any_Changed" />
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                            <TextBlock x:Name="CountLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <NumberBox x:Name="CountBox" Value="5" Minimum="1" Maximum="5000" SpinButtonPlacementMode="Inline" HorizontalAlignment="Stretch" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                            <TextBlock x:Name="PoolLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="PoolCombo" HorizontalAlignment="Stretch" SelectionChanged="Any_Changed" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                            <TextBlock x:Name="RangeLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <NumberBox x:Name="MinSentBox" Value="3" Minimum="1" Maximum="40" SpinButtonPlacementMode="Inline" MinWidth="110" />
                                <TextBlock Text="–" VerticalAlignment="Center" />
                                <NumberBox x:Name="MaxSentBox" Value="7" Minimum="1" Maximum="40" SpinButtonPlacementMode="Inline" MinWidth="110" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <ToggleSwitch x:Name="ClassicSwitch" />
                    <ToggleSwitch x:Name="HtmlSwitch" />

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="GenerateBtn" Style="{ThemeResource AccentButtonStyle}" Click="Generate_Click" />
                        <Button x:Name="CopyBtn" Click="Copy_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="OutputLabel" Grid.Column="0" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock x:Name="CountText" Grid.Column="1" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                    </Grid>
                    <TextBox x:Name="OutputBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="260" FontFamily="Consolas"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
