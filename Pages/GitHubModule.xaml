<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.GitHubModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="6">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="24" Glyph="&#xE8AB;" VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>
            <TextBlock
                x:Name="HeaderBlurb"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />
        </StackPanel>

        <!-- Body: repo list (left) + content (right) -->
        <Grid Grid.Row="1" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: repository list -->
            <Border
                Grid.Column="0"
                Padding="14,12,14,12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="ReposLabel" Grid.Row="0" FontWeight="SemiBold" />

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6">
                        <Button x:Name="AddRepoBtn" Click="AddRepo_Click" />
                        <Button x:Name="ScanReposBtn" Click="ScanRepos_Click" />
                    </StackPanel>

                    <Grid Grid.Row="2" ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="CloneUrlBox" Grid.Column="0" />
                        <Button x:Name="CloneRepoBtn" Grid.Column="1" Click="CloneRepo_Click" />
                    </Grid>

                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="RepoListPanel" Spacing="6" />
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- RIGHT: scrollable content -->
            <ScrollViewer Grid.Column="1" Padding="0,0,8,0" VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="1000" Spacing="14">

                    <!-- Active repo status -->
                    <Border
                        Padding="16,12,16,12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="10">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="RepoPathBox" Grid.Column="0" IsReadOnly="True" />
                                <Button x:Name="VsCodeBtn" Grid.Column="1" Click="VsCode_Click" />
                                <Button x:Name="TerminalBtn" Grid.Column="2" Click="Terminal_Click" />
                                <Button x:Name="BrowserBtn" Grid.Column="3" Click="Browser_Click" />
                            </Grid>
                            <TextBlock
                                x:Name="RepoStatus"
                                FontSize="13"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap" />
                            <StackPanel
                                x:Name="QuickActions"
                                Orientation="Horizontal"
                                Spacing="8" />
                        </StackPanel>
                    </Border>

                    <!-- Commit -->
                    <Border
                        Padding="16,14,16,14"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="10">
                            <TextBlock x:Name="CommitLabel" FontWeight="SemiBold" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="CommitMessageBox" Grid.Column="0" />
                                <Button x:Name="CommitBtn" Grid.Column="1" Click="Commit_Click" Style="{StaticResource AccentButtonStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Branch bar -->
                    <Border
                        Padding="16,14,16,14"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="10">
                            <TextBlock x:Name="BranchLabel" FontWeight="SemiBold" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="BranchCombo" Grid.Column="0" HorizontalAlignment="Stretch" />
                                <Button x:Name="SwitchBtn" Grid.Column="1" Click="Switch_Click" />
                                <TextBox x:Name="NewBranchBox" Grid.Column="2" />
                                <Button x:Name="CreateBranchBtn" Grid.Column="3" Click="CreateBranch_Click" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Gitty workflows -->
                    <Expander
                        x:Name="WorkflowsExpander"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        IsExpanded="True">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon FontSize="16" Glyph="&#xE945;" />
                                <TextBlock x:Name="WorkflowsHeader" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>
                        </Expander.Header>
                        <StackPanel Spacing="14">
                            <TextBlock
                                x:Name="WorkflowsBlurb"
                                FontSize="13"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap" />

                            <!-- gh engine bar (shown only when gh is missing) -->
                            <StackPanel x:Name="GhEngineBar" Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
                                <FontIcon
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                    Glyph="&#xE7BA;" />
                                <TextBlock
                                    x:Name="GhEngineLabel"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextWrapping="Wrap" />
                            </StackPanel>

                            <!-- Up -->
                            <StackPanel Spacing="6">
                                <TextBlock x:Name="UpLabel" FontWeight="SemiBold" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="UpMessageBox" Grid.Column="0" />
                                    <Button x:Name="UpBtn" Grid.Column="1" Click="Up_Click" Style="{StaticResource AccentButtonStyle}" />
                                </Grid>
                            </StackPanel>

                            <!-- Undo + Share row -->
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="UndoBtn" Click="Undo_Click" />
                                <Button x:Name="ShareBtn" Click="Share_Click" />
                                <Button x:Name="PrShareBtn" Click="PrShare_Click" />
                            </StackPanel>

                            <!-- Checkpoint / Restore -->
                            <StackPanel Spacing="6">
                                <TextBlock x:Name="CheckpointLabel" FontWeight="SemiBold" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="CheckpointNameBox" Grid.Column="0" />
                                    <ComboBox x:Name="CheckpointBranchCombo" Grid.Column="1" MinWidth="120" />
                                    <Button x:Name="CheckpointBtn" Grid.Column="2" Click="Checkpoint_Click" />
                                    <Button x:Name="RestoreBtn" Grid.Column="3" Click="Restore_Click" />
                                </Grid>
                                <TextBlock
                                    x:Name="RestoreWarn"
                                    FontSize="12"
                                    Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                    TextWrapping="Wrap" />
                            </StackPanel>

                            <!-- Alias store -->
                            <StackPanel Spacing="8">
                                <TextBlock x:Name="AliasLabel" FontWeight="SemiBold" />
                                <TextBlock
                                    x:Name="AliasBlurb"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextWrapping="Wrap" />
                                <StackPanel x:Name="AliasButtonsPanel" Spacing="6" />

                                <Border
                                    Padding="12"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    CornerRadius="6">
                                    <StackPanel Spacing="8">
                                        <TextBlock x:Name="AliasEditorLabel" FontWeight="SemiBold" FontSize="13" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="AliasNameLabel" Grid.Column="0" VerticalAlignment="Center" FontSize="13" />
                                            <TextBox x:Name="AliasNameBox" Grid.Column="1" />
                                        </Grid>
                                        <TextBox
                                            x:Name="AliasStepsBox"
                                            AcceptsReturn="True"
                                            Height="92"
                                            TextWrapping="Wrap"
                                            FontFamily="Consolas"
                                            FontSize="12" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button x:Name="AliasSaveBtn" Click="AliasSave_Click" Style="{StaticResource AccentButtonStyle}" />
                                            <Button x:Name="AliasClearBtn" Click="AliasClear_Click" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <!-- Chunked uploader -->
                    <Border
                        Padding="16,14,16,14"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="10">
                            <TextBlock x:Name="ChunkLabel" FontWeight="SemiBold" />
                            <TextBlock
                                x:Name="ChunkBlurb"
                                FontSize="13"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <NumberBox
                                    x:Name="ChunkSizeBox"
                                    Grid.Column="0"
                                    MinWidth="140"
                                    Maximum="9000"
                                    Minimum="1"
                                    SpinButtonPlacementMode="Inline"
                                    Value="25" />
                                <TextBox x:Name="ChunkMessageBox" Grid.Column="1" />
                                <Button x:Name="ChunkUploadBtn" Grid.Column="2" Click="ChunkUpload_Click" Style="{StaticResource AccentButtonStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Command runner -->
                    <Border
                        Padding="16,14,16,14"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="10">
                            <TextBlock x:Name="RunnerLabel" FontWeight="SemiBold" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="RunnerTool" Grid.Column="0" SelectedIndex="0">
                                    <ComboBoxItem Content="git" />
                                    <ComboBoxItem Content="gh" />
                                </ComboBox>
                                <TextBox x:Name="RunnerArgs" Grid.Column="1" PlaceholderText="status --short" />
                                <Button x:Name="RunnerBtn" Grid.Column="2" Click="Runner_Click" />
                            </Grid>
                            <Border
                                x:Name="ConsoleBorder"
                                Padding="12"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                CornerRadius="6"
                                Visibility="Collapsed">
                                <ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto">
                                    <TextBlock
                                        x:Name="ConsoleLog"
                                        FontFamily="Consolas"
                                        FontSize="12"
                                        IsTextSelectionEnabled="True"
                                        TextWrapping="Wrap" />
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Operations library -->
                    <TextBlock x:Name="AdvancedHeader" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="ScopeCombo" Grid.Column="0" SelectionChanged="Scope_Changed" />
                        <AutoSuggestBox
                            x:Name="OpsFilter"
                            Grid.Column="1"
                            QueryIcon="Find"
                            TextChanged="OpsFilter_TextChanged" />
                    </Grid>
                    <StackPanel x:Name="OpsPanel" Spacing="2" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
