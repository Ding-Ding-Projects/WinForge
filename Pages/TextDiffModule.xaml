<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.TextDiffModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8A5;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="6">
                        <TextBlock x:Name="LabelA" FontWeight="SemiBold" />
                        <TextBox x:Name="InputA" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="180" MaxHeight="320"
                                 FontFamily="Consolas" ScrollViewer.VerticalScrollBarVisibility="Auto" TextChanged="Input_TextChanged" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="6">
                        <TextBlock x:Name="LabelB" FontWeight="SemiBold" />
                        <TextBox x:Name="InputB" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="180" MaxHeight="320"
                                 FontFamily="Consolas" ScrollViewer.VerticalScrollBarVisibility="Auto" TextChanged="Input_TextChanged" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="24">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock x:Name="WsLabel" VerticalAlignment="Center" />
                            <ToggleSwitch x:Name="WsSwitch" Toggled="Option_Toggled" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock x:Name="CaseLabel" VerticalAlignment="Center" />
                            <ToggleSwitch x:Name="CaseSwitch" Toggled="Option_Toggled" />
                        </StackPanel>
                        <Button x:Name="CopyButton" Click="Copy_Click" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock x:Name="CountsText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <Border Padding="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <ListView x:Name="DiffList" SelectionMode="None" MaxHeight="420"
                          ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="Padding" Value="8,1,8,1" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding Prefix}" FontFamily="Consolas" Foreground="{Binding Foreground}" Width="14" />
                                <TextBlock Text="{Binding Text}" FontFamily="Consolas" Foreground="{Binding Foreground}" TextWrapping="NoWrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
