<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.CsvJsonModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE9F9;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="DirectionLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="DirectionBox" MinWidth="180" SelectionChanged="Option_Changed" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="DelimiterLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="DelimiterBox" MinWidth="160" SelectionChanged="Option_Changed" />
                        </StackPanel>
                        <StackPanel Spacing="2" VerticalAlignment="Bottom">
                            <TextBlock x:Name="HeaderToggleLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ToggleSwitch x:Name="HeaderSwitch" IsOn="True" Toggled="Option_Changed" />
                        </StackPanel>
                        <Button x:Name="ConvertBtn" Click="Convert_Click" VerticalAlignment="Bottom" Style="{ThemeResource AccentButtonStyle}" />
                    </StackPanel>

                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock x:Name="InputLabel" FontWeight="SemiBold" FontSize="13" />
                            <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="260"
                                     FontFamily="Consolas" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     TextChanged="Input_Changed" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="OutputLabel" Grid.Column="0" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                                <Button x:Name="CopyBtn" Grid.Column="1" Click="Copy_Click" Padding="10,2,10,2" />
                            </Grid>
                            <TextBox x:Name="OutputBox" AcceptsReturn="True" TextWrapping="NoWrap" IsReadOnly="True" MinHeight="260"
                                     FontFamily="Consolas" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
