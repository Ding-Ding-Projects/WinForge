<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.UuidV5Module"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE943;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="NamespaceLabel" FontWeight="SemiBold" />
                        <ComboBox x:Name="NamespaceCombo" SelectionChanged="Namespace_Changed" MinWidth="360" />
                        <TextBox x:Name="CustomGuidBox" TextChanged="Inputs_Changed" PlaceholderText="00000000-0000-0000-0000-000000000000" Visibility="Collapsed" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock x:Name="VersionLabel" FontWeight="SemiBold" />
                        <ComboBox x:Name="VersionCombo" SelectionChanged="Inputs_Changed" MinWidth="240" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock x:Name="NameLabel" FontWeight="SemiBold" />
                        <TextBox x:Name="NameBox" TextChanged="Inputs_Changed" />
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ResultBox" Grid.Column="0" IsReadOnly="True" FontFamily="Consolas" VerticalAlignment="Center" />
                        <Button x:Name="CopyBtn" Grid.Column="1" Margin="10,0,0,0" Click="Copy_Click" VerticalAlignment="Center" />
                    </Grid>

                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="BulkTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="BulkBlurb" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <TextBox x:Name="BulkInput" AcceptsReturn="True" TextWrapping="Wrap" Height="120" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="BulkRunBtn" Click="BulkRun_Click" />
                        <Button x:Name="BulkCopyBtn" Click="BulkCopy_Click" />
                    </StackPanel>
                    <ListView x:Name="BulkList" IsItemClickEnabled="False" SelectionMode="Single" MaxHeight="260"
                              ItemsSource="{Binding}" FontFamily="Consolas" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
