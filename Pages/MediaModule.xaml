<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.MediaModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1000" Spacing="14">

            <controls:ModuleHeader x:Name="Header" Glyph="&#xE714;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="EngineBar" IsClosable="False" IsOpen="False" Severity="Warning" />

            <!-- One persistent result / status area for action results & errors -->
            <InfoBar x:Name="ResultBar" IsClosable="True" IsOpen="False" />

            <!-- Files (chrome-free) -->
            <StackPanel Spacing="10">
                <TextBlock x:Name="SelLabel" FontWeight="SemiBold" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="InCap" Grid.Column="0" VerticalAlignment="Center" Width="70" />
                    <TextBox x:Name="InputBox" Grid.Column="1" IsReadOnly="True" />
                    <Button x:Name="InputBtn" Grid.Column="2" Click="PickInput_Click" />
                </Grid>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="OutCap" Grid.Column="0" VerticalAlignment="Center" Width="70" />
                    <TextBox x:Name="OutputBox" Grid.Column="1" IsReadOnly="True" />
                    <Button x:Name="OutputBtn" Grid.Column="2" Click="PickOutput_Click" />
                </Grid>
                <Border x:Name="InfoBorder" Padding="10" Background="{ThemeResource LayerFillColorDefaultBrush}"
                        CornerRadius="6" Visibility="Collapsed">
                    <TextBlock x:Name="InfoText" FontFamily="Consolas" FontSize="11"
                               IsTextSelectionEnabled="True" TextWrapping="Wrap" />
                </Border>
            </StackPanel>

            <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Opacity="0.6" />

            <!-- Quick conversions -->
            <TextBlock x:Name="QuickLabel" FontWeight="SemiBold" />
            <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Auto" VerticalScrollMode="Disabled">
                <StackPanel x:Name="QuickOps" Orientation="Horizontal" Spacing="8" />
            </ScrollViewer>

            <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Opacity="0.6" />

            <!-- Trim + GIF / frame (chrome-free) -->
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="10">
                    <TextBlock x:Name="TrimLabel" FontWeight="SemiBold" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TrimStart" Grid.Column="0" PlaceholderText="00:00:00" />
                        <TextBox x:Name="TrimDuration" Grid.Column="1" PlaceholderText="00:00:10" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="TrimCopyBtn" Click="TrimCopy_Click" />
                        <Button x:Name="TrimEncodeBtn" Click="TrimEncode_Click" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="10">
                    <TextBlock x:Name="GifLabel" FontWeight="SemiBold" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <NumberBox x:Name="GifFps" Grid.Column="0" Minimum="1" Maximum="60" Value="12" SpinButtonPlacementMode="Inline" />
                        <NumberBox x:Name="GifWidth" Grid.Column="1" Minimum="80" Maximum="3840" Value="480" SpinButtonPlacementMode="Inline" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="GifBtn" Click="MakeGif_Click" />
                        <Button x:Name="FrameBtn" Click="GrabFrame_Click" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Border x:Name="OutBorder" Padding="12" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="6" Visibility="Collapsed">
                <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="OutText" FontFamily="Consolas" FontSize="12" IsTextSelectionEnabled="True" TextWrapping="Wrap" />
                </ScrollViewer>
            </Border>

            <TextBlock x:Name="AdvancedHeader" Style="{StaticResource SubtitleTextBlockStyle}" />
            <AutoSuggestBox x:Name="OpsFilter" MaxWidth="420" HorizontalAlignment="Left" QueryIcon="Find" TextChanged="OpsFilter_TextChanged" />

            <!-- Hand-built control rows with a subtle Fluent entrance animation. -->
            <StackPanel x:Name="OpsPanel" Spacing="0">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="24" IsStaggeringEnabled="True" />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
