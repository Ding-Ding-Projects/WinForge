<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.JsonFlattenModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE943;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                        <StackPanel Spacing="1">
                            <TextBlock x:Name="DirectionLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="DirectionBox" SelectionChanged="Direction_Changed" MinWidth="200" SelectedIndex="0" />
                        </StackPanel>
                        <StackPanel Spacing="1">
                            <TextBlock x:Name="SeparatorLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBox x:Name="SeparatorBox" Text="." MaxLength="8" TextChanged="Separator_Changed" MinWidth="90" />
                        </StackPanel>
                    </StackPanel>

                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock x:Name="InputLabel" FontWeight="SemiBold" FontSize="13" />
                            <TextBox x:Name="InputBox"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     FontFamily="Consolas"
                                     Height="320"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     TextChanged="Input_Changed" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="OutputLabel" Grid.Column="0" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                                <Button x:Name="CopyButton" Grid.Column="1" Click="Copy_Click" />
                            </Grid>
                            <TextBox x:Name="OutputBox"
                                     AcceptsReturn="True"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     FontFamily="Consolas"
                                     Height="320"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="StatusText" FontSize="12" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
