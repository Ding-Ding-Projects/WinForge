<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.MouseModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="780" Spacing="12">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE962;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
            <StackPanel x:Name="Root" Spacing="10" Margin="0,4,0,0" />
        </StackPanel>
    </ScrollViewer>
</Page>
