<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.WebClonerModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1000" Spacing="14">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="24" Glyph="&#xE774;" VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>
            <TextBlock
                x:Name="HeaderBlurb"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />

            <!-- Legal / ToS disclaimer -->
            <InfoBar
                x:Name="DisclaimerBar"
                IsClosable="False"
                IsOpen="True"
                Severity="Warning" />

            <!-- URL input -->
            <Border
                Padding="14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="UrlLabel" FontWeight="SemiBold" />
                    <TextBox x:Name="UrlBox" PlaceholderText="https://example.com" />

                    <TextBlock x:Name="FolderLabel" FontWeight="SemiBold" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="FolderBox" Grid.Column="0" IsReadOnly="True" />
                        <Button x:Name="FolderBtn" Grid.Column="1" Click="Folder_Click" />
                    </Grid>

                    <!-- Options -->
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="OptionsLabel" FontWeight="SemiBold" />
                        <CheckBox x:Name="AssetsCheck" IsChecked="True" />
                        <CheckBox x:Name="RenderedCheck" />
                        <RadioButtons x:Name="ModeRadios" />
                    </StackPanel>

                    <!-- AI agent picker (only relevant in AI mode) -->
                    <Grid x:Name="AgentRow" ColumnSpacing="8" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="AgentLabel" Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" />
                        <ComboBox x:Name="AgentCombo" Grid.Column="1" HorizontalAlignment="Stretch" />
                    </Grid>

                    <InfoBar x:Name="AgentBar" IsClosable="False" IsOpen="False" Severity="Informational" />

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="CloneBtn" Style="{StaticResource AccentButtonStyle}" Click="Clone_Click" />
                        <Button x:Name="CancelBtn" Click="Cancel_Click" IsEnabled="False" />
                        <Button x:Name="OpenFolderBtn" Click="OpenFolder_Click" IsEnabled="False" />
                        <Button x:Name="OpenBrowserBtn" Click="OpenBrowser_Click" IsEnabled="False" />
                    </StackPanel>

                    <ProgressBar x:Name="Progress" IsIndeterminate="True" Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <!-- Result -->
            <InfoBar x:Name="ResultBar" IsClosable="True" IsOpen="False" />

            <!-- Design-token summary -->
            <Border
                x:Name="TokenCard"
                Padding="14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="Collapsed">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="TokenTitle" FontWeight="SemiBold" />
                    <TextBlock x:Name="TokenText" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Progress log -->
            <Border
                Padding="14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="LogTitle" FontWeight="SemiBold" />
                    <ScrollViewer x:Name="LogScroller" Height="200" VerticalScrollBarVisibility="Auto"
                                  Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="6" Padding="10">
                        <StackPanel x:Name="LogPanel" Spacing="2" />
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- Hidden WebView2 used to capture the JS-rendered DOM -->
            <controls:WebView2 x:Name="HiddenWeb" Width="0" Height="0" Visibility="Collapsed" />

        </StackPanel>
    </ScrollViewer>
</Page>
