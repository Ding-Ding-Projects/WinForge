<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.HttpHeadersModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xEB41;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
            <InfoBar x:Name="NetworkNotice" IsOpen="True" IsClosable="False" Severity="Informational" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="UrlLabel" FontWeight="SemiBold" />
                        <TextBox x:Name="UrlBox" PlaceholderText="https://example.com" />
                    </StackPanel>

                    <Grid ColumnSpacing="16" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock x:Name="MethodLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="MethodBox" MinWidth="120" SelectedIndex="0">
                                <ComboBoxItem Content="GET" />
                                <ComboBoxItem Content="HEAD" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Bottom">
                            <TextBlock x:Name="RedirectLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ToggleSwitch x:Name="RedirectSwitch" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="6">
                        <TextBlock x:Name="CustomLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Grid ColumnSpacing="10" RowSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBox x:Name="H1Key" Grid.Row="0" Grid.Column="0" PlaceholderText="Header" />
                            <TextBox x:Name="H1Val" Grid.Row="0" Grid.Column="1" PlaceholderText="Value" />
                            <TextBox x:Name="H2Key" Grid.Row="1" Grid.Column="0" PlaceholderText="Header" />
                            <TextBox x:Name="H2Val" Grid.Row="1" Grid.Column="1" PlaceholderText="Value" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="SendButton" Style="{ThemeResource AccentButtonStyle}" Click="Send_Click" />
                        <ProgressRing x:Name="Busy" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock x:Name="StatusText" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <Border x:Name="SummaryCard" Visibility="Collapsed" Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="StatusLine" FontWeight="SemiBold" FontSize="15" TextWrapping="Wrap" />
                    <TextBlock x:Name="ContentTypeLine" TextWrapping="Wrap" />
                    <TextBlock x:Name="ContentLengthLine" TextWrapping="Wrap" />
                    <TextBlock x:Name="LocationLine" TextWrapping="Wrap" Visibility="Collapsed" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="FinalUrlLine" TextWrapping="Wrap" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <Border x:Name="HeadersCard" Visibility="Collapsed" Padding="4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <ListView x:Name="HeadersList" SelectionMode="None" MaxHeight="420">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnSpacing="12" Padding="8,6,8,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Key}" FontWeight="SemiBold" TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                                <TextBlock Grid.Column="1" Text="{Binding Value}" TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
