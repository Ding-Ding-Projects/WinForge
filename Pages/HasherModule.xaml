<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.HasherModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE9A9;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Text input card -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="TextCardTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="96"
                             TextChanged="Input_Changed" ScrollViewer.VerticalScrollBarVisibility="Auto" />

                    <Grid ColumnSpacing="10" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="EncodingLabel" Grid.Column="0" VerticalAlignment="Center" />
                        <ComboBox x:Name="EncodingBox" Grid.Column="1" HorizontalAlignment="Left" MinWidth="180"
                                  SelectedIndex="0" SelectionChanged="Options_Changed">
                            <ComboBoxItem>UTF-8</ComboBoxItem>
                            <ComboBoxItem>UTF-16</ComboBoxItem>
                            <ComboBoxItem>ASCII</ComboBoxItem>
                        </ComboBox>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="HmacTitle" VerticalAlignment="Center" />
                        <ToggleSwitch x:Name="HmacSwitch" Toggled="Options_Changed" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBox x:Name="HmacKeyBox" PlaceholderText="" TextChanged="Options_Changed" Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <!-- File card -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="FileCardTitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Button x:Name="PickFileBtn" Click="PickFile_Click" />
                        <ProgressRing x:Name="Working" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock x:Name="FileInfoText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <!-- Verify card -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="VerifyTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="ExpectedBox" PlaceholderText="" TextChanged="Options_Changed" />
                    <TextBlock x:Name="VerifyStatus" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Results card -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="ResultsTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <StackPanel x:Name="ResultsPanel" Spacing="8" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
