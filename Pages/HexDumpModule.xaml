<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.HexDumpModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE7C3;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="SourceLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="SourceCombo" MinWidth="220" SelectionChanged="Source_Changed" />
                    </StackPanel>

                    <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="120" MaxHeight="220" FontFamily="Consolas"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             TextChanged="Input_Changed" />

                    <StackPanel x:Name="FilePanel" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Visibility="Collapsed">
                        <Button x:Name="BrowseBtn" Click="Browse_Click" />
                        <TextBlock x:Name="FilePathText" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="18" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock x:Name="PerRowLabel" VerticalAlignment="Center" />
                            <ComboBox x:Name="PerRowCombo" MinWidth="80" SelectionChanged="Options_Changed">
                                <ComboBoxItem Content="8" />
                                <ComboBoxItem Content="16" IsSelected="True" />
                                <ComboBoxItem Content="32" />
                            </ComboBox>
                        </StackPanel>
                        <ToggleSwitch x:Name="UpperSwitch" Toggled="Options_Changed" />
                        <ToggleSwitch x:Name="OffsetSwitch" IsOn="True" Toggled="Options_Changed" />
                    </StackPanel>

                    <TextBlock x:Name="CountText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="OutputLabel" Grid.Column="0" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button x:Name="CopyBtn" Grid.Column="1" Click="Copy_Click" />
            </Grid>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <TextBox x:Name="OutputBox" IsReadOnly="True" IsSpellCheckEnabled="False"
                         FontFamily="Consolas" FontSize="13" MinHeight="260" MaxHeight="480"
                         BorderThickness="0" TextWrapping="NoWrap"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto" />
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
