<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.DockerSshModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,0" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="6">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="22" Glyph="&#xEA86;" VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
            <InfoBar x:Name="DockerBar" IsClosable="False" IsOpen="False" Severity="Warning" />
        </StackPanel>

        <!-- Connection -->
        <Expander x:Name="ConnExpander" Grid.Row="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="True">
            <Expander.Header>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon FontSize="16" Glyph="&#xE968;" VerticalAlignment="Center" />
                    <TextBlock x:Name="ConnHeader" VerticalAlignment="Center" FontWeight="SemiBold" />
                    <Border x:Name="ConnPill" CornerRadius="10" Padding="8,2,8,2" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <TextBlock x:Name="ConnState" FontSize="12" />
                    </Border>
                </StackPanel>
            </Expander.Header>
            <StackPanel Spacing="10" Margin="0,4,0,0">
                <!-- Saved profile picker -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="ProfileBox" Grid.Column="0" HorizontalAlignment="Stretch"
                              SelectionChanged="Profile_Changed" />
                    <Button x:Name="ReloadProfilesBtn" Grid.Column="1" Click="ReloadProfiles_Click" VerticalAlignment="Bottom">
                        <FontIcon FontSize="14" Glyph="&#xE72C;" />
                    </Button>
                </Grid>

                <!-- Manual entry -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="HostBox" Grid.Column="0" Header="Host · 主機" PlaceholderText="192.168.1.10 / docker.example.com" />
                    <NumberBox x:Name="PortBox" Grid.Column="1" Header="Port · 連接埠" Value="22" SpinButtonPlacementMode="Compact" Minimum="1" Maximum="65535" />
                    <TextBox x:Name="UserBox" Grid.Column="2" Header="Username · 帳號" PlaceholderText="root / ubuntu" />
                </Grid>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="AuthBox" Grid.Column="0" Header="Auth · 認證" SelectionChanged="Auth_Changed" MinWidth="160" />
                    <PasswordBox x:Name="PassBox" Grid.Column="1" Header="Password · 密碼" PlaceholderText="SSH password · SSH 密碼" />
                </Grid>
                <Grid x:Name="KeyRow" ColumnSpacing="8" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="KeyPathBox" Grid.Column="0" Header="Private key file · 私鑰檔" PlaceholderText="C:\Users\me\.ssh\id_ed25519" />
                    <Button x:Name="BrowseKeyBtn" Grid.Column="1" Click="BrowseKey_Click" VerticalAlignment="Bottom" />
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <CheckBox x:Name="RememberChk" Content="Save as SSH profile · 儲存做 SSH 設定檔" />
                    <Button x:Name="ConnectBtn" Click="Connect_Click" Style="{StaticResource AccentButtonStyle}" />
                    <Button x:Name="DisconnectBtn" Click="Disconnect_Click" />
                    <ProgressRing x:Name="ConnBusy" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
                </StackPanel>
                <InfoBar x:Name="ConnResult" IsClosable="True" IsOpen="False" />
            </StackPanel>
        </Expander>

        <!-- Toolbar -->
        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <AutoSuggestBox x:Name="SearchBox" Grid.Column="0" QueryIcon="Find" PlaceholderText="Filter by name/image · 按名稱／鏡像篩選" TextChanged="Search_Changed" MinWidth="160" />
            <ToggleSwitch x:Name="AutoRefreshToggle" Grid.Column="1" OnContent="" OffContent="" MinWidth="0" Toggled="AutoRefresh_Toggled" VerticalAlignment="Center" />
            <TextBlock x:Name="AutoRefreshLbl" Grid.Column="2" FontSize="12" VerticalAlignment="Center" />
            <Button x:Name="RefreshBtn" Grid.Column="3" Click="Refresh_Click">
                <FontIcon FontSize="14" Glyph="&#xE72C;" />
            </Button>
        </Grid>

        <!-- Container list + detail/log pane -->
        <Grid Grid.Row="3" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- List -->
            <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Power-action toolbar -->
                    <Grid Grid.Row="0" Padding="10,8,10,8" ColumnSpacing="6" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="StartBtn" Grid.Column="0" Click="Start_Click" ToolTipService.ToolTip="Start · 啟動"><FontIcon FontSize="14" Glyph="&#xE768;" /></Button>
                        <Button x:Name="StopBtn" Grid.Column="1" Click="Stop_Click" ToolTipService.ToolTip="Stop · 停止"><FontIcon FontSize="14" Glyph="&#xE71A;" /></Button>
                        <Button x:Name="RestartBtn" Grid.Column="2" Click="Restart_Click" ToolTipService.ToolTip="Restart · 重啟"><FontIcon FontSize="14" Glyph="&#xE72C;" /></Button>
                        <Button x:Name="PauseBtn" Grid.Column="3" Click="Pause_Click" ToolTipService.ToolTip="Pause / Unpause · 暫停／繼續"><FontIcon FontSize="14" Glyph="&#xE769;" /></Button>
                        <Button x:Name="RemoveBtn" Grid.Column="4" Click="Remove_Click" ToolTipService.ToolTip="Remove · 移除"><FontIcon FontSize="14" Glyph="&#xE74D;" /></Button>
                        <Button x:Name="LogsBtn" Grid.Column="6" Click="Logs_Click"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon FontSize="14" Glyph="&#xE9D9;" /><TextBlock x:Name="LogsBtnLbl" /></StackPanel></Button>
                    </Grid>

                    <ListView x:Name="ContainerList" Grid.Row="1" SelectionMode="Single"
                              SelectionChanged="ContainerList_SelectionChanged"
                              ScrollViewer.HorizontalScrollMode="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="10,8,10,8" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="160" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="150" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" FontWeight="SemiBold" ToolTipService.ToolTip="{Binding Name}" />
                                        <TextBlock Text="{Binding SubLine}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding SubLine}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding StateText}" VerticalAlignment="Center" FontSize="12" Foreground="{Binding StateBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding StatusText}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding StatusText}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel x:Name="EmptyState" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8" Visibility="Collapsed">
                        <FontIcon FontSize="40" Glyph="&#xEA86;" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="EmptyText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="320" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Detail / logs -->
            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <Grid Padding="12" RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="DetailTitle" Grid.Row="0" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                        <TextBlock x:Name="DetailSub" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="6">
                        <ScrollViewer x:Name="LogScroller" HorizontalScrollMode="Auto" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Padding="10">
                            <TextBlock x:Name="LogText" FontFamily="Consolas" FontSize="12" IsTextSelectionEnabled="True" TextWrapping="NoWrap" />
                        </ScrollViewer>
                    </Border>
                    <Grid Grid.Row="3" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <NumberBox x:Name="TailBox" Grid.Column="0" Value="200" Minimum="10" Maximum="5000" SpinButtonPlacementMode="Compact" Width="120" />
                        <TextBox x:Name="ExecBox" Grid.Column="1" PlaceholderText="exec: ls -la /  ·  喺容器入面執行" />
                        <Button x:Name="ExecBtn" Grid.Column="2" Click="Exec_Click" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Status footer -->
        <Border Grid.Row="4" Padding="14,8,14,8" Margin="0,0,0,12" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="8">
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="FooterHost" Grid.Column="0" FontSize="12" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:Name="FooterVersion" Grid.Column="1" FontSize="12" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:Name="FooterCount" Grid.Column="2" FontSize="12" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Grid>
        </Border>
    </Grid>
</Page>
