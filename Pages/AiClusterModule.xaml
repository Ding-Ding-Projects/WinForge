<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.AiClusterModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="780" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE99A;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Needs-power empty-state -->
            <InfoBar x:Name="NeedPowerBar" IsOpen="False" IsClosable="False" Severity="Warning" />

            <!-- Live reactor output -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="ReactorTitle" FontWeight="SemiBold" FontSize="15" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar x:Name="OutputBar" Grid.Column="0" Minimum="0" Maximum="1150" Value="0" Height="10" VerticalAlignment="Center" />
                        <TextBlock x:Name="OutputValue" Grid.Column="1" Margin="12,0,0,0" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock x:Name="ReactorModeText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Cluster control -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <TextBlock x:Name="ClusterTitle" FontWeight="SemiBold" FontSize="15" />

                    <StackPanel Spacing="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="DrawLabel" Grid.Column="0" VerticalAlignment="Center" />
                            <TextBlock x:Name="DrawValue" Grid.Column="1" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </Grid>
                        <Slider x:Name="DrawSlider" Minimum="0" Maximum="900" Value="0" StepFrequency="10" ValueChanged="DrawSlider_ValueChanged" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock x:Name="ModelLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="ModelCombo" MinWidth="200" SelectionChanged="ModelCombo_SelectionChanged" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="RunButton" Click="Run_Click" Style="{ThemeResource AccentButtonStyle}" />
                        <Button x:Name="NewRunButton" Click="NewRun_Click" />
                        <Button x:Name="ResetButton" Click="Reset_Click" />
                    </StackPanel>

                    <TextBlock x:Name="OverclockNote" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Training progress + telemetry -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="ProgressTitle" FontWeight="SemiBold" FontSize="15" />

                    <StackPanel Spacing="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ProgressCaption" Grid.Column="0" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBlock x:Name="ProgressValue" Grid.Column="1" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </Grid>
                        <ProgressBar x:Name="ProgressBarRun" Minimum="0" Maximum="100" Value="0" Height="10" />
                    </StackPanel>

                    <Grid ColumnSpacing="16" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="1">
                            <TextBlock x:Name="ThroughputCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="ThroughputValue" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="1">
                            <TextBlock x:Name="ComputeCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="ComputeValue" FontWeight="SemiBold" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="GpuCaption" Grid.Column="0" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                <TextBlock x:Name="GpuValue" Grid.Column="1" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </Grid>
                            <ProgressBar x:Name="GpuBar" Minimum="0" Maximum="100" Value="0" Height="8" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="TempCaption" Grid.Column="0" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                <TextBlock x:Name="TempValue" Grid.Column="1" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </Grid>
                            <ProgressBar x:Name="TempBar" Minimum="20" Maximum="95" Value="24" Height="8" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Spacing="1">
                            <TextBlock x:Name="DrawnCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="DrawnValue" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Spacing="1">
                            <TextBlock x:Name="CheckpointCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="CheckpointValue" FontWeight="SemiBold" />
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="0" Spacing="1">
                            <TextBlock x:Name="EarnCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="EarnValue" FontWeight="SemiBold" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
