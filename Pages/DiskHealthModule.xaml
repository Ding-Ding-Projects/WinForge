<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.DiskHealthModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,16" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="22" Glyph="&#xEDA8;" VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <ProgressRing x:Name="Busy" Width="20" Height="20" IsActive="False" />
                <Button x:Name="RefreshBtn" Click="Refresh_Click" />
            </StackPanel>
        </Grid>
        <TextBlock x:Name="HeaderBlurb" Grid.Row="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

        <InfoBar x:Name="AdminBar" Grid.Row="2" IsClosable="True" IsOpen="False" Severity="Informational" />
        <InfoBar x:Name="EmptyBar" Grid.Row="3" IsClosable="False" IsOpen="False" Severity="Warning" />

        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
            <ItemsControl x:Name="Cards">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0,0,0,12"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="10">

                                <!--  Title row: model + health pill  -->
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="{Binding Glyph}" FontSize="24" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Model}" FontWeight="SemiBold" FontSize="16" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding SubLine}" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Border Grid.Column="2" VerticalAlignment="Center" CornerRadius="12" Padding="12,4" Background="{Binding HealthBrush}">
                                        <TextBlock Text="{Binding HealthLabel}" Foreground="White" FontWeight="SemiBold" FontSize="13" />
                                    </Border>
                                </Grid>

                                <!--  Headline stats  -->
                                <Grid ColumnSpacing="20" RowSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Text="{Binding TempCaption}" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                        <TextBlock Text="{Binding TempValue}" FontSize="18" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1">
                                        <TextBlock Text="{Binding HoursCaption}" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                        <TextBlock Text="{Binding HoursValue}" FontSize="18" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="2">
                                        <TextBlock Text="{Binding CyclesCaption}" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                        <TextBlock Text="{Binding CyclesValue}" FontSize="18" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="3">
                                        <TextBlock Text="{Binding ExtraCaption}" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                        <TextBlock Text="{Binding ExtraValue}" FontSize="18" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Grid>

                                <!--  Per-drive error note  -->
                                <InfoBar
                                    IsOpen="{Binding HasError}"
                                    IsClosable="False"
                                    Severity="Warning"
                                    Message="{Binding ErrorMessage}" />

                                <!--  SMART attribute table (expander)  -->
                                <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Visibility="{Binding AttrVisibility}">
                                    <Expander.Header>
                                        <TextBlock Text="{Binding AttrHeader}" FontWeight="SemiBold" />
                                    </Expander.Header>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!--  Column headers  -->
                                        <Grid Grid.Row="0" Padding="6,4" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="64" />
                                                <ColumnDefinition Width="64" />
                                                <ColumnDefinition Width="78" />
                                                <ColumnDefinition Width="130" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding ColId}" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                            <TextBlock Grid.Column="1" Text="{Binding ColName}" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                            <TextBlock Grid.Column="2" Text="{Binding ColCur}" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorTertiaryBrush}" HorizontalTextAlignment="Right" />
                                            <TextBlock Grid.Column="3" Text="{Binding ColWorst}" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorTertiaryBrush}" HorizontalTextAlignment="Right" />
                                            <TextBlock Grid.Column="4" Text="{Binding ColThr}" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorTertiaryBrush}" HorizontalTextAlignment="Right" />
                                            <TextBlock Grid.Column="5" Text="{Binding ColRaw}" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorTertiaryBrush}" HorizontalTextAlignment="Right" />
                                        </Grid>

                                        <ItemsControl Grid.Row="1" ItemsSource="{Binding Rows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Padding="6,4" ColumnSpacing="10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="44" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="64" />
                                                            <ColumnDefinition Width="64" />
                                                            <ColumnDefinition Width="78" />
                                                            <ColumnDefinition Width="130" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Id}" FontFamily="Consolas" FontSize="12" />
                                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Column="2" Text="{Binding Current}" FontSize="12" HorizontalTextAlignment="Right" />
                                                        <TextBlock Grid.Column="3" Text="{Binding Worst}" FontSize="12" HorizontalTextAlignment="Right" />
                                                        <TextBlock Grid.Column="4" Text="{Binding Threshold}" FontSize="12" HorizontalTextAlignment="Right" />
                                                        <TextBlock Grid.Column="5" Text="{Binding Raw}" FontFamily="Consolas" FontSize="12" HorizontalTextAlignment="Right" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Expander>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
