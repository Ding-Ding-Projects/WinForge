<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.JsonSortModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE943;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="Info" IsOpen="False" IsClosable="False" Severity="Informational" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="InputLabel" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="150" MaxHeight="300"
                             FontFamily="Consolas" IsSpellCheckEnabled="False"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <TextBlock x:Name="OptionsTitle" FontWeight="SemiBold" FontSize="15" />

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="OrderLabel" VerticalAlignment="Center" MinWidth="120" />
                        <ComboBox x:Name="OrderCombo" MinWidth="200" SelectedIndex="0">
                            <ComboBoxItem x:Name="OrderAsc" />
                            <ComboBoxItem x:Name="OrderDesc" />
                        </ComboBox>
                    </StackPanel>

                    <CheckBox x:Name="CaseChk" IsChecked="True" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="MinifyTitle" FontWeight="SemiBold" />
                            <TextBlock x:Name="MinifyHint" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="MinifySwitch" Grid.Column="1" Toggled="Minify_Toggled" VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel x:Name="IndentPanel" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="IndentLabel" VerticalAlignment="Center" MinWidth="120" />
                        <ComboBox x:Name="IndentCombo" MinWidth="200" SelectedIndex="0">
                            <ComboBoxItem x:Name="Indent2" />
                            <ComboBoxItem x:Name="Indent4" />
                            <ComboBoxItem x:Name="IndentTab" />
                        </ComboBox>
                    </StackPanel>

                    <CheckBox x:Name="SortArraysChk" />
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="SortBtn" Style="{ThemeResource AccentButtonStyle}" Click="Sort_Click" />
                <Button x:Name="CopyBtn" Click="Copy_Click" IsEnabled="False" />
            </StackPanel>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="OutputLabel" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="OutputBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" MinHeight="150" MaxHeight="360"
                             FontFamily="Consolas" IsSpellCheckEnabled="False"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
