<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.FancyZonesModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1000" Spacing="14">

            <!-- Header -->
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE737;" />
            <TextBlock
                x:Name="HeaderBlurb"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />

            <!-- Engine (install) bar -->
            <InfoBar x:Name="EngineBar" IsClosable="False" IsOpen="False" Severity="Warning" />

            <!-- Status card -->
            <Border
                Padding="16,14,16,14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="StatusTitle" FontWeight="SemiBold" FontSize="15" />
                            <TextBlock
                                x:Name="StatusText"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <Button
                            x:Name="RefreshBtn"
                            Grid.Column="1"
                            Click="Refresh_Click"
                            VerticalAlignment="Center" />
                    </Grid>

                    <!-- Module enable toggle -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="ModuleToggleTitle" FontWeight="SemiBold" />
                            <TextBlock
                                x:Name="ModuleToggleSub"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <ToggleSwitch
                            x:Name="ModuleSwitch"
                            Grid.Column="1"
                            Toggled="ModuleSwitch_Toggled"
                            VerticalAlignment="Center" />
                    </Grid>

                    <!-- Primary actions -->
                    <StackPanel
                        x:Name="ActionsPanel"
                        Orientation="Horizontal"
                        Spacing="8"
                        Padding="0,2,0,0" />

                    <!-- Action result -->
                    <InfoBar x:Name="ResultBar" IsClosable="True" IsOpen="False" />
                </StackPanel>
            </Border>

            <!-- Built-in layouts reference -->
            <TextBlock x:Name="LayoutsHeader" Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock
                x:Name="LayoutsHint"
                FontSize="13"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />
            <ItemsControl x:Name="LayoutsRepeater">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <!-- Snap hotkeys reference -->
            <TextBlock x:Name="HotkeysHeader" Style="{StaticResource SubtitleTextBlockStyle}" />
            <Border
                Padding="14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel x:Name="HotkeysPanel" Spacing="8" />
            </Border>

            <!-- Saved custom layouts -->
            <TextBlock x:Name="CustomHeader" Style="{StaticResource SubtitleTextBlockStyle}" />
            <Border
                Padding="14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock
                        x:Name="CustomText"
                        TextWrapping="Wrap"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <StackPanel x:Name="CustomList" Spacing="2" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="ImportBtn" Click="Import_Click" />
                        <Button x:Name="ExportBtn" Click="Export_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Data-driven behaviour toggles -->
            <TextBlock x:Name="OpsHeader" Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock
                x:Name="OpsHint"
                FontSize="13"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />
            <AutoSuggestBox
                x:Name="OpsFilter"
                MaxWidth="420"
                HorizontalAlignment="Left"
                QueryIcon="Find"
                TextChanged="OpsFilter_TextChanged" />
            <StackPanel x:Name="OpsPanel" Spacing="2" />
        </StackPanel>
    </ScrollViewer>
</Page>
