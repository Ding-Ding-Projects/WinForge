<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.TextToolsModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8A5;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Input -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="InputLabel" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" TextChanged="Input_TextChanged" />
                </StackPanel>
            </Border>

            <!-- Live stats -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="StatsTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="StatsText" FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Transforms -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="TransformsTitle" FontWeight="SemiBold" FontSize="15" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="BtnUpper" Click="Upper_Click" />
                        <Button x:Name="BtnLower" Click="Lower_Click" />
                        <Button x:Name="BtnTitle" Click="Title_Click" />
                        <Button x:Name="BtnToggle" Click="Toggle_Click" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="BtnTrim" Click="Trim_Click" />
                        <Button x:Name="BtnBlank" Click="Blank_Click" />
                        <Button x:Name="BtnCollapse" Click="Collapse_Click" />
                        <Button x:Name="BtnDedup" Click="Dedup_Click" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="BtnSortAsc" Click="SortAsc_Click" />
                        <Button x:Name="BtnSortDesc" Click="SortDesc_Click" />
                        <Button x:Name="BtnSortNum" Click="SortNum_Click" />
                        <Button x:Name="BtnReverseLines" Click="ReverseLines_Click" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="BtnShuffle" Click="Shuffle_Click" />
                        <Button x:Name="BtnReverseChars" Click="ReverseChars_Click" />
                        <Button x:Name="BtnSlug" Click="Slug_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Output -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="OutputLabel" Grid.Column="0" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button x:Name="BtnCopy" Click="Copy_Click" />
                            <Button x:Name="BtnToInput" Click="ToInput_Click" />
                        </StackPanel>
                    </Grid>
                    <TextBox x:Name="OutputBox" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" MinHeight="120"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
