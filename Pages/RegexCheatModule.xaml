<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.RegexCheatModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE943;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="Info" IsOpen="False" IsClosable="True" Severity="Success" />

            <!-- Search + category filter -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SearchBox" Grid.Column="0" TextChanged="Search_Changed" />
                        <ComboBox x:Name="CategoryBox" Grid.Column="1" MinWidth="200" SelectionChanged="Category_Changed" />
                    </Grid>
                    <TextBlock x:Name="HintText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Reference entries -->
            <Border Padding="8,8,8,8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="RefTitle" FontWeight="SemiBold" FontSize="15" Margin="8,6,8,0" />
                    <ListView x:Name="EntryList" SelectionMode="None" IsItemClickEnabled="True" ItemClick="Entry_Click"
                              MaxHeight="520" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="6,8,6,8" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{Binding Token}" FontFamily="Consolas" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding CategoryLabel}" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="{Binding Desc}" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Example}" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock x:Name="EmptyText" Margin="8,4,8,6" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <!-- Ready-made patterns -->
            <Border Padding="8,8,8,8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="RecipeTitle" FontWeight="SemiBold" FontSize="15" Margin="8,6,8,0" />
                    <TextBlock x:Name="RecipeHint" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="8,0,8,0" TextWrapping="Wrap" />
                    <ListView x:Name="RecipeList" SelectionMode="None" IsItemClickEnabled="True" ItemClick="Recipe_Click">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Padding="6,8,6,8" Spacing="2">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Pattern}" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
