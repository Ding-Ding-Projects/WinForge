<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.CommandPaletteModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE773;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" />

            <!-- Enable + open -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="EnableTitle" FontWeight="SemiBold" FontSize="15" />
                            <TextBlock x:Name="EnableStatus" FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="EnableSwitch" Grid.Column="1" Toggled="Enable_Toggled" VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock x:Name="HotkeyLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="HotkeyCombo" MinWidth="200" SelectionChanged="Hotkey_Changed" />
                        <Button x:Name="OpenNowButton" Click="OpenNow_Click" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock x:Name="MaxLabel" VerticalAlignment="Center" />
                        <NumberBox x:Name="MaxBox" Value="8" Minimum="3" Maximum="25" SpinButtonPlacementMode="Inline" MinWidth="140" ValueChanged="Max_Changed" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Appearance -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="AppearanceTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="AppearanceBlurb" FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock x:Name="BackdropLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="BackdropCombo" MinWidth="190" SelectionChanged="Backdrop_Changed" />
                    </StackPanel>
                    <TextBlock x:Name="BackgroundImageLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="BackgroundImageBox" IsReadOnly="True" />
                        <Button x:Name="BackgroundImageBrowseButton" Grid.Column="1" Click="BackgroundImageBrowse_Click" />
                        <Button x:Name="BackgroundImageClearButton" Grid.Column="2" Click="BackgroundImageClear_Click" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Providers -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="ProvidersTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="ProvidersBlurb" FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" />
                    <StackPanel x:Name="ProvidersPanel" Spacing="6" />
                </StackPanel>
            </Border>

            <!-- Declarative extension packs -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="ExtensionPacksTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="ExtensionPacksBlurb" FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" />
                    <InfoBar x:Name="ExtensionPacksInfo" IsOpen="False" IsClosable="False" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="ExtensionImportButton" Click="ExtensionImport_Click" />
                        <Button x:Name="ExtensionTemplateButton" Click="ExtensionTemplate_Click" />
                    </StackPanel>
                    <TextBlock x:Name="ExtensionPacksEmptyText" FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" />
                    <StackPanel x:Name="ExtensionPacksPanel" Spacing="8" />
                </StackPanel>
            </Border>

            <!-- Bookmarks -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="BookmarksTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="BookmarksBlurb" FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" />
                    <InfoBar x:Name="BookmarkInfo" IsOpen="False" IsClosable="False" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="BookmarkNameBox" />
                        <TextBox x:Name="BookmarkUrlBox" Grid.Column="1" />
                        <Button x:Name="BookmarkAddButton" Grid.Column="2" Click="BookmarkAdd_Click" />
                    </Grid>
                    <StackPanel x:Name="BookmarksPanel" Spacing="6" />
                </StackPanel>
            </Border>

            <!-- Remote Desktop profiles -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="RemoteDesktopTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="RemoteDesktopBlurb" FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" />
                    <InfoBar x:Name="RemoteDesktopInfo" IsOpen="False" IsClosable="False" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="RemoteDesktopNameBox" />
                        <TextBox x:Name="RemoteDesktopHostBox" Grid.Column="1" />
                        <Button x:Name="RemoteDesktopAddButton" Grid.Column="2" Click="RemoteDesktopAdd_Click" />
                    </Grid>
                    <StackPanel x:Name="RemoteDesktopPanel" Spacing="6" />
                </StackPanel>
            </Border>

            <!-- Persistent Dock -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="DockTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="DockBlurb" FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="DockStatus" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center" />
                        <ToggleSwitch x:Name="DockSwitch" Grid.Column="1" Toggled="Dock_Toggled" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock x:Name="DockSideLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="DockSideCombo" MinWidth="180" SelectionChanged="DockSide_Changed" />
                        <Button x:Name="DockOpenButton" Click="DockOpen_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
