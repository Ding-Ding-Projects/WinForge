<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.DateCalcModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE787;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Difference -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="DiffTitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <CalendarDatePicker x:Name="DiffFrom" MinWidth="180" DateChanged="AnyChanged" />
                        <CalendarDatePicker x:Name="DiffTo" MinWidth="180" DateChanged="AnyChanged" />
                    </StackPanel>
                    <TextBlock x:Name="DiffResult" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Button x:Name="DiffCopy" Click="DiffCopy_Click" />
                </StackPanel>
            </Border>

            <!-- Add / subtract -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="AddTitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <CalendarDatePicker x:Name="AddBase" MinWidth="180" DateChanged="AnyChanged" />
                        <ToggleSwitch x:Name="AddMode" Toggled="AnyToggled" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <NumberBox x:Name="AddYears" Header="Y" Value="0" SpinButtonPlacementMode="Compact" MinWidth="110" ValueChanged="AnyNum" />
                        <NumberBox x:Name="AddMonths" Header="M" Value="0" SpinButtonPlacementMode="Compact" MinWidth="110" ValueChanged="AnyNum" />
                        <NumberBox x:Name="AddWeeks" Header="W" Value="0" SpinButtonPlacementMode="Compact" MinWidth="110" ValueChanged="AnyNum" />
                        <NumberBox x:Name="AddDays" Header="D" Value="0" SpinButtonPlacementMode="Compact" MinWidth="110" ValueChanged="AnyNum" />
                    </StackPanel>
                    <TextBlock x:Name="AddResult" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Button x:Name="AddCopy" Click="AddCopy_Click" />
                </StackPanel>
            </Border>

            <!-- Age -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="AgeTitle" FontWeight="SemiBold" FontSize="15" />
                    <CalendarDatePicker x:Name="AgeBirth" MinWidth="180" DateChanged="AnyChanged" />
                    <TextBlock x:Name="AgeResult" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Button x:Name="AgeCopy" Click="AgeCopy_Click" />
                </StackPanel>
            </Border>

            <!-- Info -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="InfoTitle" FontWeight="SemiBold" FontSize="15" />
                    <CalendarDatePicker x:Name="InfoDate" MinWidth="180" DateChanged="AnyChanged" />
                    <TextBlock x:Name="InfoResult" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Button x:Name="InfoCopy" Click="InfoCopy_Click" />
                </StackPanel>
            </Border>

            <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</Page>
