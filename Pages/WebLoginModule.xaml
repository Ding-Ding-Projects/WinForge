<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.WebLoginModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:wfcontrols="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Style="{StaticResource WinForgePageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="6">
            <wfcontrols:ModuleHeader x:Name="Header" Glyph="&#xE77B;" />
            <TextBlock
                x:Name="HeaderBlurb"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />
        </StackPanel>

        <InfoBar
            x:Name="EngineBar"
            Grid.Row="1"
            IsClosable="False"
            IsOpen="False"
            Severity="Warning" />

        <!-- Toolbar: nav + address + go -->
        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="BackBtn" Grid.Column="0" Width="36" Padding="0" Click="Back_Click">
                <FontIcon FontSize="14" Glyph="&#xE72B;" />
            </Button>
            <Button x:Name="FwdBtn" Grid.Column="1" Width="36" Padding="0" Click="Forward_Click">
                <FontIcon FontSize="14" Glyph="&#xE72A;" />
            </Button>
            <Button x:Name="ReloadBtn" Grid.Column="2" Width="36" Padding="0" Click="Reload_Click">
                <FontIcon FontSize="14" Glyph="&#xE72C;" />
            </Button>
            <TextBox
                x:Name="AddressBox"
                Grid.Column="3"
                VerticalAlignment="Center"
                IsSpellCheckEnabled="False"
                KeyDown="Address_KeyDown" />
            <Button
                x:Name="GoBtn"
                Grid.Column="4"
                Click="Go_Click"
                Style="{ThemeResource AccentButtonStyle}" />
        </Grid>

        <!-- Capture / profile controls -->
        <Grid Grid.Row="3" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock x:Name="ProviderLabel" VerticalAlignment="Center" FontWeight="SemiBold" />
                <ComboBox x:Name="ProviderCombo" MinWidth="180" SelectionChanged="Provider_Changed" />
                <Button x:Name="CaptureBtn" Click="Capture_Click" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock x:Name="ProfileLabel" VerticalAlignment="Center" FontWeight="SemiBold" />
                <ComboBox x:Name="ProfileCombo" MinWidth="140" IsEditable="True" />
                <Button x:Name="ClearBtn" Click="Clear_Click" />
            </StackPanel>
        </Grid>

        <!-- Embedded browser -->
        <Grid Grid.Row="4" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6">
                <Grid>
                    <controls:WebView2 x:Name="Web" />
                    <ProgressRing
                        x:Name="Spinner"
                        Width="36"
                        Height="36"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsActive="False" />
                </Grid>
            </Border>

            <InfoBar
                x:Name="ResultBar"
                Grid.Row="1"
                IsClosable="True"
                IsOpen="False"
                Severity="Success" />
        </Grid>
    </Grid>
</Page>
