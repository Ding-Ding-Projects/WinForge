<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.TimeLensModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="980" Spacing="14">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="22" Glyph="&#xE823;" VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Privacy notice -->
            <InfoBar x:Name="PrivacyBar" IsOpen="True" IsClosable="False" Severity="Informational" />

            <!-- Controls: tracking toggle, pause, status, settings -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock x:Name="TrackingLabel" FontWeight="SemiBold" />
                            <TextBlock x:Name="StatusText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <ToggleSwitch x:Name="TrackToggle" Toggled="Track_Toggled" />
                            <Button x:Name="PauseBtn" Click="Pause_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon x:Name="PauseIcon" FontSize="14" Glyph="&#xE769;" />
                                    <TextBlock x:Name="PauseText" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock x:Name="IdleLabel" FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Slider x:Name="IdleSlider" Width="180" Minimum="1" Maximum="30" StepFrequency="1" />
                                <TextBlock x:Name="IdleValue" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock x:Name="PollLabel" FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Slider x:Name="PollSlider" Width="180" Minimum="1" Maximum="30" StepFrequency="1" />
                                <TextBlock x:Name="PollValue" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Date picker + actions -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <CalendarDatePicker x:Name="DatePicker" Grid.Column="0" DateChanged="Date_Changed" MinWidth="180" />
                <Button x:Name="TodayBtn" Grid.Column="1" Click="Today_Click" />
                <Button x:Name="RefreshBtn" Grid.Column="3" Click="Refresh_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE72C;" />
                        <TextBlock x:Name="RefreshText" />
                    </StackPanel>
                </Button>
                <Button x:Name="ExportBtn" Grid.Column="4" Click="Export_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xEDE1;" />
                        <TextBlock x:Name="ExportText" />
                    </StackPanel>
                </Button>
                <Button x:Name="ClearBtn" Grid.Column="5" Click="Clear_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE74D;" />
                        <TextBlock x:Name="ClearText" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Summary -->
            <TextBlock x:Name="SummaryText" FontWeight="SemiBold" />

            <!-- Empty state -->
            <Border x:Name="EmptyCard" Visibility="Collapsed" Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="6" HorizontalAlignment="Center">
                    <FontIcon FontSize="26" Glyph="&#xE9D9;" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="EmptyText" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Timeline (24 hour rows, stacked colour segments) -->
            <Border x:Name="TimelineCard" Padding="14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="TimelineTitle" FontWeight="SemiBold" />
                    <StackPanel x:Name="TimelineHost" Spacing="3" />
                </StackPanel>
            </Border>

            <!-- Per-app totals -->
            <Border x:Name="TotalsCard" Padding="14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="TotalsTitle" FontWeight="SemiBold" />
                    <StackPanel x:Name="TotalsHost" Spacing="8" />
                </StackPanel>
            </Border>

            <InfoBar x:Name="ResultBar" IsOpen="False" />
        </StackPanel>
    </ScrollViewer>
</Page>
