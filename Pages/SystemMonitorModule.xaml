<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.SystemMonitorModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WinForge.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="22" Glyph="&#xE9D9;" VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock x:Name="IntervalLabel" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <ComboBox x:Name="IntervalBox" SelectionChanged="Interval_Changed" SelectedIndex="1" MinWidth="92" />
            </StackPanel>
        </Grid>
        <TextBlock x:Name="HeaderBlurb" Grid.Row="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

        <!--  btop-style meter dashboard  -->
        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <!--  CPU box: overall %, sparkline, per-core bars  -->
            <Border
                Grid.Column="0"
                Padding="16,12,16,12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="CpuLabel" Grid.Column="0" FontWeight="SemiBold" VerticalAlignment="Bottom" />
                        <TextBlock x:Name="CpuTemp" Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Bottom" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="CpuValue" Grid.Column="2" FontSize="28" FontWeight="Bold" Text="—" />
                    </Grid>
                    <controls:SparklineGraph x:Name="CpuGraph" Height="56" Max="100" />
                    <controls:CoreBars x:Name="CoreBarsCtl" Margin="0,2,0,0" />
                </StackPanel>
            </Border>

            <!--  Memory + Swap meters  -->
            <Border
                Grid.Column="1"
                Padding="16,12,16,12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="RamLabel" Grid.Column="0" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock x:Name="RamValue" Grid.Column="1" FontSize="20" FontWeight="Bold" Text="—" />
                    </Grid>
                    <Grid>
                        <Border x:Name="RamTrackBg" Height="10" CornerRadius="3" HorizontalAlignment="Stretch" Background="{ThemeResource ControlStrongFillColorDefaultBrush}" Opacity="0.25" />
                        <Border x:Name="RamBar" Width="0" Height="10" CornerRadius="3" HorizontalAlignment="Left" />
                    </Grid>
                    <TextBlock x:Name="RamSub" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SwapLabel" Grid.Column="0" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock x:Name="SwapValue" Grid.Column="1" FontSize="14" FontWeight="SemiBold" Text="—" />
                    </Grid>
                    <Grid>
                        <Border Height="8" CornerRadius="3" HorizontalAlignment="Stretch" Background="{ThemeResource ControlStrongFillColorDefaultBrush}" Opacity="0.25" />
                        <Border x:Name="SwapBar" Width="0" Height="8" CornerRadius="3" HorizontalAlignment="Left" />
                    </Grid>
                    <TextBlock x:Name="SwapSub" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>
        </Grid>

        <!--  Network sparklines + Uptime  -->
        <Grid Grid.Row="3" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="16,10,16,10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock x:Name="NetDown" FontFamily="Consolas" FontSize="13" Text="&#x2193; —" />
                        <controls:SparklineGraph x:Name="DownGraph" Height="40" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock x:Name="NetUp" FontFamily="Consolas" FontSize="13" Text="&#x2191; —" />
                        <controls:SparklineGraph x:Name="UpGraph" Height="40" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border
                Grid.Column="1"
                Padding="16,10,16,10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="6" VerticalAlignment="Center">
                    <TextBlock x:Name="NetLabel" FontWeight="SemiBold" />
                    <TextBlock x:Name="UpLabel" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="UpValue" FontFamily="Consolas" FontSize="16" FontWeight="SemiBold" Text="—" />
                </StackPanel>
            </Border>
        </Grid>

        <!--  Process grid header (sortable)  -->
        <Grid Grid.Row="4" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="ProcTitle" Grid.Column="0" FontWeight="SemiBold" VerticalAlignment="Center" />
            <AutoSuggestBox
                x:Name="SearchBox"
                Grid.Column="1"
                MaxWidth="280"
                HorizontalAlignment="Right"
                QueryIcon="Find"
                TextChanged="Search_Changed" />
        </Grid>

        <Border
            Grid.Row="5"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  Column headers (clickable sort)  -->
                <Grid Grid.Row="0" Padding="12,8,12,8" ColumnSpacing="10" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="206" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="HdrPid" Grid.Column="0" Click="SortHeader_Click" Tag="pid" Background="Transparent" BorderThickness="0" Padding="2" HorizontalAlignment="Left" />
                    <Button x:Name="HdrName" Grid.Column="1" Click="SortHeader_Click" Tag="name" Background="Transparent" BorderThickness="0" Padding="2" HorizontalAlignment="Left" />
                    <Button x:Name="HdrCpu" Grid.Column="2" Click="SortHeader_Click" Tag="cpu" Background="Transparent" BorderThickness="0" Padding="2" HorizontalAlignment="Right" />
                    <Button x:Name="HdrMem" Grid.Column="3" Click="SortHeader_Click" Tag="mem" Background="Transparent" BorderThickness="0" Padding="2" HorizontalAlignment="Right" />
                    <TextBlock x:Name="HdrActions" Grid.Column="4" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Grid>

                <ListView x:Name="ProcList" Grid.Row="1" SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="12,5,12,5" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="206" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding PidText}" VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                <Grid Grid.Column="2">
                                    <Border Height="14" CornerRadius="2" HorizontalAlignment="Stretch" Background="{ThemeResource ControlStrongFillColorDefaultBrush}" Opacity="0.18" />
                                    <Border Width="{Binding CpuBarWidth}" Height="14" CornerRadius="2" HorizontalAlignment="Left" Background="{Binding CpuBrush}" Opacity="0.55" />
                                    <TextBlock Text="{Binding CpuText}" VerticalAlignment="Center" HorizontalTextAlignment="Right" Margin="0,0,4,0" FontFamily="Consolas" FontSize="11" />
                                </Grid>
                                <TextBlock Grid.Column="3" Text="{Binding MemText}" VerticalAlignment="Center" HorizontalTextAlignment="Right" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                    <Button Click="Priority_Click" Padding="8,3,8,3" FontSize="12" Content="Priority &#xB7; &#x512A;&#x5148;&#x6B0A;" ToolTipService.ToolTip="Set priority / efficiency / affinity &#xB7; &#x8A2D;&#x5B9A;&#x512A;&#x5148;&#x6B0A;／&#x6548;&#x7387;／&#x89AA;&#x548C;&#x6027;" />
                                    <Button Click="Kill_Click" Padding="8,3,8,3" ToolTipService.ToolTip="End task &#xB7; &#x7D50;&#x675F;&#x5DE5;&#x4F5C;">
                                        <FontIcon Glyph="&#xE711;" FontSize="12" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
