<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.MacToolsModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE839;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="InputLabel" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBox x:Name="MacBox" MinWidth="320" TextChanged="Mac_Changed" PlaceholderText="00:1A:2B:3C:4D:5E" />
                        <Button x:Name="RandomBtn" Click="Random_Click" />
                    </StackPanel>
                    <TextBlock x:Name="StatusText" FontSize="12" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <Border x:Name="ResultCard" Visibility="Collapsed" Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="AnalysisTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="AnalysisText" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <TextBlock x:Name="FormatsTitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel x:Name="FormatsPanel" Spacing="6" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
