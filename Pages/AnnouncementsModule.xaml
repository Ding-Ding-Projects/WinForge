<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.AnnouncementsModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="860" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xEC42;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="VoiceBar" IsOpen="False" IsClosable="False" Severity="Warning" />

            <!-- Settings card -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <TextBlock x:Name="SettingsHeader" FontWeight="SemiBold" />

                    <StackPanel Spacing="6">
                        <TextBlock x:Name="VoiceLabel" FontWeight="SemiBold" />
                        <ComboBox x:Name="VoiceCombo" HorizontalAlignment="Stretch" SelectionChanged="VoiceCombo_SelectionChanged" />
                    </StackPanel>

                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock x:Name="VolumeLabel" FontWeight="SemiBold" />
                            <Slider x:Name="VolumeSlider" Minimum="0" Maximum="100" StepFrequency="1" TickFrequency="25" TickPlacement="Outside" ValueChanged="VolumeSlider_ValueChanged" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock x:Name="RateLabel" FontWeight="SemiBold" />
                            <Slider x:Name="RateSlider" Minimum="-10" Maximum="10" StepFrequency="1" TickFrequency="5" TickPlacement="Outside" ValueChanged="RateSlider_ValueChanged" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="28">
                        <ToggleSwitch x:Name="ChimeToggle" Toggled="ChimeToggle_Toggled" />
                        <ToggleSwitch x:Name="MuteToggle" Toggled="MuteToggle_Toggled" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="ChimeTestBtn" Click="ChimeTest_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="14" Glyph="&#xE767;" />
                                <TextBlock x:Name="ChimeTestText" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Test announcement card -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <TextBlock x:Name="TestHeader" FontWeight="SemiBold" />
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="TextLabel" FontWeight="SemiBold" />
                        <TextBox x:Name="TextBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="90" PlaceholderText="" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <CheckBox x:Name="UrgentCheck" />
                        <CheckBox x:Name="BothLangCheck" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="AnnounceBtn" Click="Announce_Click" Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="14" Glyph="&#xEC42;" />
                                <TextBlock x:Name="AnnounceText" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="StopBtn" Click="Stop_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="14" Glyph="&#xE71A;" />
                                <TextBlock x:Name="StopText" />
                            </StackPanel>
                        </Button>
                        <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Preset PA announcements card -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <TextBlock x:Name="PresetHeader" FontWeight="SemiBold" />
                    <TextBlock x:Name="PresetBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <StackPanel x:Name="PresetPanel" Orientation="Horizontal" Spacing="10" />
                    <StackPanel x:Name="PresetPanel2" Orientation="Horizontal" Spacing="10" />
                </StackPanel>
            </Border>

            <InfoBar x:Name="ResultBar" IsOpen="False" />
        </StackPanel>
    </ScrollViewer>
</Page>
