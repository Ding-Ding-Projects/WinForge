<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.AsciiTableModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,24" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" MaxWidth="900" HorizontalAlignment="Left" Spacing="8">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8D2;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1" MaxWidth="900" HorizontalAlignment="Stretch" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox" Grid.Column="0" TextChanged="Search_Changed" VerticalAlignment="Center" />
            <CheckBox x:Name="Latin1Chk" Grid.Column="1" Checked="Latin1_Changed" Unchecked="Latin1_Changed" VerticalAlignment="Center" />
        </Grid>

        <TextBlock x:Name="StatusText" Grid.Row="2" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

        <Border Grid.Row="3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Padding="16,10,16,10" ColumnSpacing="8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52" />
                        <ColumnDefinition Width="56" />
                        <ColumnDefinition Width="72" />
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="52" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ColDec" Grid.Column="0" FontWeight="SemiBold" FontSize="12" />
                    <TextBlock x:Name="ColHex" Grid.Column="1" FontWeight="SemiBold" FontSize="12" />
                    <TextBlock x:Name="ColOct" Grid.Column="2" FontWeight="SemiBold" FontSize="12" />
                    <TextBlock x:Name="ColBin" Grid.Column="3" FontWeight="SemiBold" FontSize="12" />
                    <TextBlock x:Name="ColChar" Grid.Column="4" FontWeight="SemiBold" FontSize="12" />
                    <TextBlock x:Name="ColName" Grid.Column="5" FontWeight="SemiBold" FontSize="12" />
                </Grid>

                <ListView x:Name="RowsList" Grid.Row="1" SelectionMode="Single"
                          SelectionChanged="Rows_SelectionChanged"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="MinHeight" Value="34" />
                            <Setter Property="Padding" Value="16,2,16,2" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52" />
                                    <ColumnDefinition Width="56" />
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="96" />
                                    <ColumnDefinition Width="52" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Dec}" FontFamily="Consolas" FontSize="13" />
                                <TextBlock Grid.Column="1" Text="{Binding Hex}" FontFamily="Consolas" FontSize="13" />
                                <TextBlock Grid.Column="2" Text="{Binding Oct}" FontFamily="Consolas" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Column="3" Text="{Binding Bin}" FontFamily="Consolas" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Column="4" Text="{Binding Char}" FontFamily="Consolas" FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="5" Text="{Binding Name}" FontSize="13" TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
