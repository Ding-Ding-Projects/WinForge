<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.TaskbarTweakerModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
        工作列調校 · Taskbar Tweaker. 每個調校用手砌嘅控件列渲染（唔再用 Controls/TweakCard）：
        左邊雙語標題／說明，右邊對應控件；結果／錯誤集中喺一個常駐 InfoBar。
        Each tweak is rendered as a hand-built control row (no Controls/TweakCard): bilingual
        title/description on the left, matching WinUI control on the right; results & errors go to
        one persistent InfoBar.
    -->
    <Grid Style="{StaticResource WinForgePageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <controls:ModuleHeader x:Name="Header" Grid.Row="0" Glyph="&#xE71D;" />
        <TextBlock x:Name="HeaderBlurb" Grid.Row="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

        <!-- Detection InfoBars (7+TT / Windhawk) -->
        <InfoBar x:Name="SevenTtBar" Grid.Row="2" IsClosable="False" IsOpen="False" Margin="0,2,0,0" />
        <InfoBar x:Name="WindhawkBar" Grid.Row="3" IsClosable="False" IsOpen="False" />

        <!-- Deep-behaviour explainer card (cross-links handoff 29 / Windhawk) -->
        <Border Grid.Row="4" Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
            <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="16" Glyph="&#xE946;" VerticalAlignment="Center" Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                    <TextBlock x:Name="DeepTitle" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>
                <TextBlock x:Name="DeepBody" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13" TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                    <Button x:Name="RestartExplorerBtn" Click="RestartExplorer_Click" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- One persistent result / status area for tweak results & errors -->
        <InfoBar x:Name="ResultBar" Grid.Row="5" IsClosable="True" IsOpen="False" Margin="0,2,0,0" />

        <!-- Filter -->
        <AutoSuggestBox x:Name="FilterBox" Grid.Row="6" QueryIcon="Find" TextChanged="FilterBox_TextChanged" Margin="0,2,0,0" />

        <!-- Hand-built control rows (no TweakCard) with a subtle Fluent entrance animation -->
        <ScrollViewer Grid.Row="7" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Auto" Padding="0,0,4,0">
            <StackPanel x:Name="RowsPanel" Spacing="0">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="24" IsStaggeringEnabled="True" />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
