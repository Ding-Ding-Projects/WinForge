<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.HtmlFormatModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE943;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="InputLabel" FontWeight="SemiBold" FontSize="14" />
                    <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="150"
                             FontFamily="Consolas" ScrollViewer.VerticalScrollBarVisibility="Auto"
                             PlaceholderText="&lt;div&gt;&lt;p&gt;Hello&lt;/p&gt;&lt;/div&gt;" />

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="IndentLabel" VerticalAlignment="Center" />
                        <NumberBox x:Name="IndentBox" Value="2" Minimum="0" Maximum="16" SpinButtonPlacementMode="Inline" MinWidth="130" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="FormatBtn" Click="Format_Click" Style="{ThemeResource AccentButtonStyle}" />
                        <Button x:Name="MinifyBtn" Click="Minify_Click" />
                        <Button x:Name="CopyBtn" Click="Copy_Click" />
                    </StackPanel>

                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <TextBlock x:Name="OutputLabel" FontWeight="SemiBold" FontSize="14" />
                    <TextBox x:Name="OutputBox" AcceptsReturn="True" TextWrapping="NoWrap" IsReadOnly="True" MinHeight="180"
                             FontFamily="Consolas" ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
