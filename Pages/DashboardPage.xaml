<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="40,28,40,40" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1120" Spacing="18">

            <!-- Hero (WinForge.dc.html design) -->
            <StackPanel Spacing="3">
                <StackPanel Orientation="Horizontal" Spacing="14">
                    <TextBlock x:Name="HeroNameEn" Text="WinForge" FontSize="48" FontWeight="Bold" />
                    <TextBlock
                        x:Name="HeroNameZh"
                        Text="視窗調校"
                        FontSize="32"
                        FontWeight="SemiBold"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,6"
                        Foreground="{ThemeResource WinForgeBrandBrush}" />
                </StackPanel>
                <TextBlock
                    x:Name="HeroSubEn"
                    Margin="0,12,0,0"
                    FontSize="16"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="HeroSubZh"
                    FontSize="13"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    TextWrapping="Wrap" />

                <!-- Stat row: features · categories · modules -->
                <StackPanel Orientation="Horizontal" Spacing="28" Margin="0,18,0,0">
                    <StackPanel>
                        <TextBlock x:Name="StatFeatures" FontFamily="{StaticResource WinForgeMonoFont}" FontSize="24" FontWeight="Bold" Foreground="{ThemeResource WinForgeBrandBrush}" />
                        <TextBlock Text="FEATURES · 功能" FontSize="10.5" FontFamily="{StaticResource WinForgeMonoFont}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                    <Border Width="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />
                    <StackPanel>
                        <TextBlock x:Name="StatCategories" FontFamily="{StaticResource WinForgeMonoFont}" FontSize="24" FontWeight="Bold" />
                        <TextBlock Text="CATEGORIES · 分類" FontSize="10.5" FontFamily="{StaticResource WinForgeMonoFont}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                    <Border Width="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />
                    <StackPanel>
                        <TextBlock x:Name="StatModules" FontFamily="{StaticResource WinForgeMonoFont}" FontSize="24" FontWeight="Bold" />
                        <TextBlock Text="MODULES · 模組" FontSize="10.5" FontFamily="{StaticResource WinForgeMonoFont}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <InfoBar
                x:Name="AdminBar"
                IsClosable="False"
                IsOpen="True" />

            <AutoSuggestBox
                x:Name="SearchBox"
                QueryIcon="Find"
                TextChanged="SearchBox_TextChanged" />

            <StackPanel x:Name="SearchResults" Visibility="Collapsed" />

            <StackPanel x:Name="BrowseSection" Spacing="10">
                <TextBlock
                    x:Name="ModulesHeader"
                    Style="{StaticResource SubtitleTextBlockStyle}" />
                <ItemsRepeater x:Name="ModuleRepeater" />

                <TextBlock
                    x:Name="StatsHeader"
                    Margin="0,8,0,0"
                    Style="{StaticResource SubtitleTextBlockStyle}" />
                <StackPanel x:Name="StatsPanel" Spacing="6" />

                <TextBlock
                    x:Name="BrowseHeader"
                    Margin="0,8,0,0"
                    Style="{StaticResource SubtitleTextBlockStyle}" />
                <ItemsRepeater x:Name="CategoryRepeater" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
