<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.CropAndLockModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" Spacing="14">

            <!-- Header -->
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE7A8;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" />

            <!-- Result feedback -->
            <InfoBar x:Name="ResultBar" IsClosable="True" IsOpen="False" />

            <!-- ===== Enable + hotkeys ===== -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="EnableTitle" FontWeight="SemiBold" FontSize="15" />
                            <TextBlock x:Name="EnableBlurb" FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="EnableSwitch" Grid.Column="1" Toggled="Enable_Toggled" VerticalAlignment="Center" />
                    </Grid>

                    <!-- Thumbnail hotkey -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ThumbHkLabel" Grid.Column="0" VerticalAlignment="Center" MinWidth="170" />
                        <Border Grid.Column="1" Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="10,4" VerticalAlignment="Center">
                            <TextBlock x:Name="ThumbHkText" FontFamily="Consolas" />
                        </Border>
                        <Button x:Name="ThumbHkBtn" Grid.Column="3" Click="ThumbHk_Click" VerticalAlignment="Center" />
                    </Grid>

                    <!-- Crop hotkey -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="CropHkLabel" Grid.Column="0" VerticalAlignment="Center" MinWidth="170" />
                        <Border Grid.Column="1" Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="10,4" VerticalAlignment="Center">
                            <TextBlock x:Name="CropHkText" FontFamily="Consolas" />
                        </Border>
                        <Button x:Name="CropHkBtn" Grid.Column="3" Click="CropHk_Click" VerticalAlignment="Center" />
                    </Grid>

                    <!-- Screenshot hotkey -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ScreenshotHkLabel" Grid.Column="0" VerticalAlignment="Center" MinWidth="170" />
                        <Border Grid.Column="1" Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="10,4" VerticalAlignment="Center">
                            <TextBlock x:Name="ScreenshotHkText" FontFamily="Consolas" />
                        </Border>
                        <Button x:Name="ScreenshotHkBtn" Grid.Column="3" Click="ScreenshotHk_Click" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Pick window & region ===== -->
            <TextBlock x:Name="PickHeader" FontWeight="SemiBold" FontSize="15" Margin="2,4,0,0" />
            <TextBlock x:Name="PickBlurb" FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" Margin="2,0,0,0" />

            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Window list -->
                <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="6">
                    <StackPanel Spacing="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="CountText" Grid.Column="0" VerticalAlignment="Center" Margin="6,0,0,0" FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                            <Button x:Name="RefreshBtn" Grid.Column="1" Click="Refresh_Click" />
                        </Grid>
                        <ListView x:Name="WinList" Height="260" SelectionMode="Single">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="0" Padding="2,4">
                                        <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Process}" FontSize="11" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- Mode buttons -->
                <StackPanel Grid.Column="1" Spacing="10" Width="240" VerticalAlignment="Top">
                    <Button x:Name="ThumbBtn" Click="Thumb_Click" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" />
                    <TextBlock x:Name="ThumbDesc" FontSize="11" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" />
                    <Button x:Name="CropBtn" Click="Crop_Click" HorizontalAlignment="Stretch" />
                    <TextBlock x:Name="CropDesc" FontSize="11" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" />
                    <Button x:Name="ScreenshotBtn" Click="Screenshot_Click" HorizontalAlignment="Stretch" />
                    <TextBlock x:Name="ScreenshotDesc" FontSize="11" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <!-- ===== Active cropped windows ===== -->
            <Grid Margin="2,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="1">
                    <TextBlock x:Name="ActiveHeader" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="ActiveBlurb" FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
                <Button x:Name="CloseAllBtn" Grid.Column="1" Click="CloseAll_Click" VerticalAlignment="Center" />
            </Grid>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="6">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="EmptyActive" FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Margin="6,8" Visibility="Collapsed" />
                    <ItemsControl x:Name="ActiveList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="6,6" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" FontSize="16" Glyph="&#xE7A8;" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Spacing="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SourceTitle}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Button Grid.Column="2" Tag="{Binding}" Click="CloseOne_Click" VerticalAlignment="Center">
                                        <FontIcon FontSize="14" Glyph="&#xE711;" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Limitations note -->
            <InfoBar x:Name="LimitBar" IsClosable="False" IsOpen="True" Severity="Informational" />

        </StackPanel>
    </ScrollViewer>
</Page>
