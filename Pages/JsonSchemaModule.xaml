<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.JsonSchemaModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE943;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="ValidateBtn" Style="{ThemeResource AccentButtonStyle}" Click="Validate_Click" />
                <Button x:Name="SampleBtn" Click="Sample_Click" />
                <Button x:Name="ClearBtn" Click="Clear_Click" />
                <Button x:Name="CopyBtn" Click="Copy_Click" />
            </StackPanel>

            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock x:Name="SchemaLabel" FontWeight="SemiBold" />
                    <TextBox x:Name="SchemaBox"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             FontFamily="Consolas" MinHeight="280"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock x:Name="DocLabel" FontWeight="SemiBold" />
                    <TextBox x:Name="DocBox"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             FontFamily="Consolas" MinHeight="280"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                </StackPanel>
            </Grid>

            <Border x:Name="VerdictBorder" Padding="16,12,16,12" CornerRadius="8"
                    BorderThickness="1" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <StackPanel Spacing="2">
                    <TextBlock x:Name="VerdictText" FontWeight="Bold" FontSize="18" />
                    <TextBlock x:Name="VerdictSub" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <TextBlock x:Name="FindingsLabel" FontWeight="SemiBold" />
            <ListView x:Name="FindingsList" SelectionMode="None" MaxHeight="360"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="1" CornerRadius="8">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="4,8,4,8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="4" Padding="8,2,8,2"
                                    VerticalAlignment="Top" Background="{Binding BadgeBrush}">
                                <TextBlock Text="{Binding Badge}" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding Path}" FontFamily="Consolas"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Top" />
                            <TextBlock Grid.Column="2" Text="{Binding Message}" TextWrapping="Wrap" VerticalAlignment="Top" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </ScrollViewer>
</Page>
