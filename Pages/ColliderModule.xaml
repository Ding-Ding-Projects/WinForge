<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.ColliderModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xEA86;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Needs-power empty-state -->
            <InfoBar x:Name="NeedPowerBar" IsOpen="False" IsClosable="False" Severity="Warning" />

            <!-- Available reactor output -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="ReactorTitle" FontWeight="SemiBold" FontSize="15" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar x:Name="OutputBar" Grid.Column="0" Minimum="0" Maximum="1150" Value="0" VerticalAlignment="Center" />
                        <TextBlock x:Name="OutputValue" Grid.Column="1" Margin="12,0,0,0" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock x:Name="ReactorModeText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Beam controls -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="BeamTitle" FontWeight="SemiBold" FontSize="15" />
                            <TextBlock x:Name="BeamStatus" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button x:Name="RampButton" Click="Ramp_Click" />
                            <Button x:Name="ResetButton" Click="Reset_Click" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="TargetLabel" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="TargetSlider" Grid.Column="0" Minimum="0" Maximum="14" StepFrequency="0.1" Value="0" ValueChanged="Target_ValueChanged" VerticalAlignment="Center" />
                            <TextBlock x:Name="TargetValue" Grid.Column="1" Margin="12,0,0,0" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Beam energy meter -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="EnergyTitle" FontWeight="SemiBold" FontSize="15" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar x:Name="EnergyBar" Grid.Column="0" Minimum="0" Maximum="14" Value="0" VerticalAlignment="Center" />
                        <TextBlock x:Name="EnergyValue" Grid.Column="1" Margin="12,0,0,0" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock x:Name="PowerCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar x:Name="MagnetBar" Grid.Column="0" Minimum="0" Maximum="800" Value="0" VerticalAlignment="Center" />
                        <TextBlock x:Name="MagnetValue" Grid.Column="1" Margin="12,0,0,0" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Physics readouts -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="PhysicsTitle" FontWeight="SemiBold" FontSize="15" />
                    <Grid ColumnSpacing="16" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="1">
                            <TextBlock x:Name="LumiCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="LumiValue" FontWeight="SemiBold" FontSize="18" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="1">
                            <TextBlock x:Name="EventsCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="EventsValue" FontWeight="SemiBold" FontSize="18" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="1">
                            <TextBlock x:Name="DiscoveriesCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="DiscoveriesValue" FontWeight="SemiBold" FontSize="18" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="1">
                            <TextBlock x:Name="LastDiscoveryCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="LastDiscoveryValue" FontWeight="SemiBold" FontSize="15" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
