<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.CsvLintModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="960" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE9F9;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Bottom">
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="DelimiterLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="DelimiterBox" MinWidth="180" SelectionChanged="Option_Changed" />
                        </StackPanel>
                        <Button x:Name="LintBtn" Click="Lint_Click" VerticalAlignment="Bottom" Style="{ThemeResource AccentButtonStyle}" />
                        <Button x:Name="RepairBtn" Click="Repair_Click" VerticalAlignment="Bottom" />
                    </StackPanel>

                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="InputLabel" FontWeight="SemiBold" FontSize="13" />
                        <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="NoWrap" MinHeight="180"
                                 FontFamily="Consolas" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="IssuesLabel" FontWeight="SemiBold" FontSize="13" />
                        <ListView x:Name="IssuesList" MinHeight="140" MaxHeight="280"
                                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6"
                                  SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="12" Padding="4,6,4,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="82" />
                                            <ColumnDefinition Width="52" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding LevelText}" FontWeight="SemiBold" FontSize="12" />
                                        <TextBlock Grid.Column="1" Text="{Binding LineText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontFamily="Consolas" FontSize="12" />
                                        <TextBlock Grid.Column="2" Text="{Binding Message}" TextWrapping="Wrap" FontSize="12" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="OutputLabel" Grid.Column="0" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                            <Button x:Name="CopyBtn" Grid.Column="1" Click="Copy_Click" Padding="10,2,10,2" />
                        </Grid>
                        <TextBox x:Name="OutputBox" AcceptsReturn="True" TextWrapping="NoWrap" IsReadOnly="True" MinHeight="160"
                                 FontFamily="Consolas" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
