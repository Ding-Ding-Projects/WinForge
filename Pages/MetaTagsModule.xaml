<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.MetaTagsModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE12B;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="BasicHeading" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="TitleBox" TextChanged="Field_Changed" />
                    <TextBox x:Name="DescBox" TextChanged="Field_Changed" TextWrapping="Wrap" AcceptsReturn="True" Height="64" />
                    <TextBox x:Name="KeywordsBox" TextChanged="Field_Changed" />
                    <TextBox x:Name="AuthorBox" TextChanged="Field_Changed" />
                    <TextBox x:Name="CanonicalBox" TextChanged="Field_Changed" />
                    <TextBox x:Name="ViewportBox" TextChanged="Field_Changed" />
                    <TextBox x:Name="ThemeColorBox" TextChanged="Field_Changed" />
                    <TextBox x:Name="CharsetBox" TextChanged="Field_Changed" />
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="OgHeading" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="OgTitleBox" TextChanged="Field_Changed" />
                    <TextBox x:Name="OgDescBox" TextChanged="Field_Changed" TextWrapping="Wrap" AcceptsReturn="True" Height="64" />
                    <TextBox x:Name="OgImageBox" TextChanged="Field_Changed" />
                    <TextBox x:Name="OgUrlBox" TextChanged="Field_Changed" />
                    <TextBox x:Name="OgTypeBox" TextChanged="Field_Changed" />
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="TwHeading" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="TwCardBox" TextChanged="Field_Changed" />
                    <TextBox x:Name="TwSiteBox" TextChanged="Field_Changed" />
                    <TextBox x:Name="TwCreatorBox" TextChanged="Field_Changed" />
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="OutHeading" FontWeight="SemiBold" FontSize="15" />
                            <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <Button x:Name="CopyButton" Grid.Column="1" Click="Copy_Click" VerticalAlignment="Center" />
                    </Grid>
                    <TextBox x:Name="OutputBox" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="140" FontFamily="Consolas" IsSpellCheckEnabled="False" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
