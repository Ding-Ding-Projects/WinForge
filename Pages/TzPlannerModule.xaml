<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.TzPlannerModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE774;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Reference instant -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="RefTitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="RefZoneLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ComboBox x:Name="RefZoneCombo" MinWidth="360" SelectionChanged="Ref_Changed" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="RefDateLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <CalendarDatePicker x:Name="RefDate" DateChanged="Ref_DateChanged" MinWidth="180" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="RefTimeLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TimePicker x:Name="RefTime" ClockIdentifier="24HourClock" TimeChanged="Ref_TimeChanged" MinWidth="140" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="StartLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <NumberBox x:Name="StartBox" Value="9" Minimum="0" Maximum="23" SpinButtonPlacementMode="Inline" MinWidth="120" ValueChanged="Hours_Changed" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="EndLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <NumberBox x:Name="EndBox" Value="17" Minimum="1" Maximum="24" SpinButtonPlacementMode="Inline" MinWidth="120" ValueChanged="Hours_Changed" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Add participant -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="AddTitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ComboBox x:Name="AddZoneCombo" MinWidth="360" />
                        <Button x:Name="AddButton" Click="Add_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Participant zone rows -->
            <Border Padding="8,8,8,8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="EmptyText" Margin="8,6,8,6" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <ListView x:Name="RowsList" SelectionMode="None" IsItemClickEnabled="False">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="4" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="10,8,10,8" CornerRadius="6" Background="{Binding RowBrush}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Width="6" RadiusX="3" RadiusY="3" VerticalAlignment="Stretch" Margin="0,0,8,0" Fill="{Binding AccentBrush}" />
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ZoneName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding LocalTime}" FontSize="13" />
                                        <TextBlock Text="{Binding OffsetAndState}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <Button Grid.Column="3" Click="Remove_Click" Tag="{Binding ZoneId}" VerticalAlignment="Center"
                                            Content="&#xE738;" FontFamily="Segoe Fluent Icons" Background="Transparent" BorderThickness="0" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
