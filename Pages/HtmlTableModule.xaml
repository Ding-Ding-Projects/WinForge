<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.HtmlTableModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE943;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock x:Name="DirLabel" VerticalAlignment="Center" />
                <ComboBox x:Name="DirCombo" MinWidth="240" SelectionChanged="Dir_Changed" />
            </StackPanel>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <TextBlock x:Name="InputTitle" FontWeight="SemiBold" FontSize="15" />

                    <!-- Data → HTML options -->
                    <StackPanel x:Name="DataOptions" Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock x:Name="DelimLabel" VerticalAlignment="Center" />
                            <ComboBox x:Name="DelimCombo" MinWidth="160" SelectionChanged="Opt_Changed" />
                        </StackPanel>
                        <ToggleSwitch x:Name="HeaderSwitch" Toggled="Opt_Changed" />
                        <ToggleSwitch x:Name="EscapeSwitch" Toggled="Opt_Changed" />
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock x:Name="ClassLabel" VerticalAlignment="Center" />
                            <TextBox x:Name="ClassBox" MinWidth="220" TextChanged="Opt_Changed" />
                        </StackPanel>
                    </StackPanel>

                    <!-- HTML → Data options -->
                    <StackPanel x:Name="HtmlOptions" Spacing="10" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock x:Name="OutFmtLabel" VerticalAlignment="Center" />
                            <ComboBox x:Name="OutFmtCombo" MinWidth="200" SelectionChanged="Opt_Changed" />
                        </StackPanel>
                    </StackPanel>

                    <TextBox x:Name="InputBox"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             MinHeight="150"
                             TextChanged="Input_Changed"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="OutputTitle" FontWeight="SemiBold" FontSize="15" />
                            <TextBlock x:Name="StatsText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <Button x:Name="CopyButton" Grid.Column="1" Click="Copy_Click" VerticalAlignment="Center" />
                    </Grid>

                    <TextBox x:Name="OutputBox"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             MinHeight="180"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
