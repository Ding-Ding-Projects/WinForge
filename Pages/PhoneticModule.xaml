<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.PhoneticModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8D6;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <TextBox x:Name="InputBox" AcceptsReturn="False" TextChanged="Input_Changed" />

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="AlphabetLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="AlphabetBox" MinWidth="200" SelectionChanged="Options_Changed" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="18">
                        <CheckBox x:Name="UpperChk" Checked="Options_Changed" Unchecked="Options_Changed" />
                        <CheckBox x:Name="PunctChk" Checked="Options_Changed" Unchecked="Options_Changed" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SpokenTitle" Grid.Column="0" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                        <Button x:Name="CopyButton" Grid.Column="1" Click="Copy_Click" />
                    </Grid>
                    <TextBlock x:Name="SpokenText" TextWrapping="Wrap" IsTextSelectionEnabled="True" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <ListView x:Name="CharList" SelectionMode="None" MaxHeight="360">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="0,6,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Character}" FontWeight="SemiBold" FontSize="16" />
                                    <TextBlock Grid.Column="1" Text="{Binding Code}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
