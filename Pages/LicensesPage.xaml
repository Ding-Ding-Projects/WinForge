<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.LicensesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    mc:Ignorable="d">

    <ScrollViewer
        x:Name="RootScroll"
        Padding="24,16,24,24"
        HorizontalScrollBarVisibility="Disabled"
        HorizontalScrollMode="Disabled"
        SizeChanged="RootScroll_SizeChanged"
        VerticalScrollBarVisibility="Auto">
        <StackPanel
            x:Name="RootStack"
            HorizontalAlignment="Left"
            MaxWidth="560"
            Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8D7;" />

            <TextBlock
                x:Name="HeaderBlurb"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />

            <Border
                Padding="14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <AutoSuggestBox
                        x:Name="SearchBox"
                        QueryIcon="Find"
                        TextChanged="SearchBox_TextChanged"
                        QuerySubmitted="SearchBox_QuerySubmitted"
                        automation:AutomationProperties.Name="Search license notices · 搜尋授權聲明" />

                    <ComboBox
                        x:Name="CategoryBox"
                        HorizontalAlignment="Left"
                        MinWidth="230"
                        SelectionChanged="CategoryBox_Changed"
                        automation:AutomationProperties.Name="Filter license category · 篩選授權分類" />

                    <ToggleSwitch
                        x:Name="CopyleftOnlySwitch"
                        HorizontalAlignment="Left"
                        Toggled="CopyleftOnly_Toggled"
                        automation:AutomationProperties.Name="Show GPL AGPL source-available only · 只顯示 GPL AGPL source-available" />

                    <Button
                        x:Name="ClearBtn"
                        HorizontalAlignment="Left"
                        Click="Clear_Click"
                        automation:AutomationProperties.Name="Clear license filters · 清除授權篩選">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="14" Glyph="&#xE894;" />
                            <TextBlock x:Name="ClearLabel" />
                        </StackPanel>
                    </Button>

                    <TextBlock
                        x:Name="SummaryText"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <StackPanel x:Name="NoticesPanel" Spacing="8" />
        </StackPanel>
    </ScrollViewer>
</Page>
