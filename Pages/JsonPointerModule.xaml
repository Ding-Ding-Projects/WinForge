<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.JsonPointerModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE943;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="DocLabel" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="DocBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             FontFamily="Consolas"
                             MinHeight="150"
                             MaxHeight="300"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="SampleBtn" Click="Sample_Click" />
                        <Button x:Name="ListBtn" Click="List_Click" Style="{ThemeResource AccentButtonStyle}" />
                    </StackPanel>

                    <TextBlock x:Name="PointerLabel" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="PointerBox" FontFamily="Consolas" TextChanged="Pointer_Changed" PlaceholderText="/a/b/0" />
                </StackPanel>
            </Border>

            <Border x:Name="ResultCard" Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="ResultTitle" FontWeight="SemiBold" FontSize="15" />
                            <TextBlock x:Name="ResultType" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <Button x:Name="CopyValueBtn" Grid.Column="1" Click="CopyValue_Click" VerticalAlignment="Center" />
                    </Grid>
                    <InfoBar x:Name="ResultBar" IsOpen="False" IsClosable="False" Severity="Informational" />
                    <TextBox x:Name="ResultBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                             FontFamily="Consolas" MinHeight="90" MaxHeight="260"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>

            <Border x:Name="ListCard" Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="ListTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="ListHint" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <ListView x:Name="PointerList"
                              SelectionMode="Single"
                              ItemClick="PointerList_ItemClick"
                              IsItemClickEnabled="True"
                              MaxHeight="360"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="0,4,0,4" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="1">
                                        <TextBlock Text="{Binding Pointer}" FontFamily="Consolas" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Preview}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Border Grid.Column="1" VerticalAlignment="Center" Padding="8,2,8,2" CornerRadius="4" Background="{ThemeResource ControlFillColorSecondaryBrush}">
                                        <TextBlock Text="{Binding ValueType}" FontSize="11" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
