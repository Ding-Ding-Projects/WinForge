<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.PortScanModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE968;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="EthicsBar" IsOpen="True" IsClosable="False" Severity="Warning" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="HostLabel" />
                        <TextBox x:Name="HostBox" Text="127.0.0.1" />
                    </StackPanel>

                    <Grid ColumnSpacing="12" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock x:Name="StartLabel" />
                            <NumberBox x:Name="StartBox" Value="1" Minimum="1" Maximum="65535" SpinButtonPlacementMode="Inline" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock x:Name="EndLabel" />
                            <NumberBox x:Name="EndBox" Value="1024" Minimum="1" Maximum="65535" SpinButtonPlacementMode="Inline" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="TimeoutLabel" />
                        <NumberBox x:Name="TimeoutBox" Value="300" Minimum="25" Maximum="10000" SpinButtonPlacementMode="Inline" MinWidth="160" HorizontalAlignment="Left" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="StartBtn" Click="Start_Click" Style="{ThemeResource AccentButtonStyle}" />
                        <Button x:Name="StopBtn" Click="Stop_Click" IsEnabled="False" />
                    </StackPanel>

                    <ProgressBar x:Name="Progress" Minimum="0" Maximum="1" Value="0" />
                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="OpenTitle" FontWeight="SemiBold" FontSize="15" />
                    <ListView x:Name="OpenList" SelectionMode="None" MaxHeight="320">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Display}" FontFamily="Consolas" Padding="0,4,0,4" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock x:Name="EmptyText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
