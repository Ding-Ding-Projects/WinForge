<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.PumpedHydroModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE945;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="NeedPowerBar" IsOpen="False" IsClosable="False" Severity="Informational" />

            <!-- Reactor tie-in -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="ReactorTitle" FontWeight="SemiBold" FontSize="15" />
                    <ProgressBar x:Name="ReactorBar" Minimum="0" Maximum="1150" Value="0" Height="10" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ReactorModeText" Grid.Column="0" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBlock x:Name="ReactorValue" Grid.Column="1" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Upper reservoir + storage -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="ReservoirTitle" FontWeight="SemiBold" FontSize="15" />
                    <ProgressBar x:Name="ReservoirBar" Minimum="0" Maximum="100" Value="0" Height="16" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="StoredCaption" Grid.Column="0" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBlock x:Name="StoredValue" Grid.Column="1" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock x:Name="EfficiencyText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Controls -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <TextBlock x:Name="ControlsTitle" FontWeight="SemiBold" FontSize="15" />

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="ModeLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="ModeCombo" MinWidth="200" SelectionChanged="Mode_Changed" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="PumpLabel" VerticalAlignment="Center" />
                        <Slider x:Name="PumpSlider" Minimum="0" Maximum="400" Value="200" StepFrequency="10" MinWidth="240" ValueChanged="Pump_Changed" />
                        <TextBlock x:Name="PumpValue" VerticalAlignment="Center" MinWidth="80" />
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="AutoTitle" FontWeight="SemiBold" />
                            <TextBlock x:Name="AutoHint" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="AutoSwitch" Grid.Column="1" Toggled="Auto_Toggled" VerticalAlignment="Center" />
                    </Grid>

                    <Button x:Name="ResetButton" Click="Reset_Click" />
                </StackPanel>
            </Border>

            <!-- Flows / earnings -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="FlowTitle" FontWeight="SemiBold" FontSize="15" />
                    <Grid ColumnSpacing="12" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="InCaption" Grid.Row="0" Grid.Column="0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="InValue" Grid.Row="0" Grid.Column="1" FontWeight="SemiBold" />
                        <TextBlock x:Name="OutCaption" Grid.Row="1" Grid.Column="0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="OutValue" Grid.Row="1" Grid.Column="1" FontWeight="SemiBold" />
                        <TextBlock x:Name="EarnedCaption" Grid.Row="2" Grid.Column="0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="EarnedValue" Grid.Row="2" Grid.Column="1" FontWeight="SemiBold" />
                    </Grid>
                    <TextBlock x:Name="StatusNote" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
