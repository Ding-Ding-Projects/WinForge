<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.LightSwitchModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="780" Spacing="14">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="22" Glyph="&#xE793;" VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Current theme status -->
            <Border Padding="16,12,16,12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                        <TextBlock x:Name="StatusTitle" FontWeight="SemiBold" FontSize="15" />
                        <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button x:Name="LightNowBtn" Click="LightNow_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="14" Glyph="&#xE706;" />
                                <TextBlock x:Name="LightNowLabel" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="DarkNowBtn" Click="DarkNow_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="14" Glyph="&#xE708;" />
                                <TextBlock x:Name="DarkNowLabel" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Enable + scope -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="EnableTitle" FontWeight="SemiBold" FontSize="15" />
                            <TextBlock x:Name="EnableSub" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="EnableSwitch" Grid.Column="1" Toggled="Enable_Toggled" VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Spacing="6">
                        <TextBlock x:Name="ScopeLabel" FontWeight="SemiBold" />
                        <RadioButtons x:Name="ScopeRadios" SelectionChanged="Scope_Changed">
                            <RadioButton x:Name="ScopeBoth" />
                            <RadioButton x:Name="ScopeApps" />
                            <RadioButton x:Name="ScopeSystem" />
                        </RadioButtons>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Schedule mode -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <TextBlock x:Name="ModeLabel" FontWeight="SemiBold" FontSize="15" />
                    <RadioButtons x:Name="ModeRadios" SelectionChanged="Mode_Changed">
                        <RadioButton x:Name="ModeOff" />
                        <RadioButton x:Name="ModeFixed" />
                        <RadioButton x:Name="ModeSun" />
                    </RadioButtons>

                    <!-- Fixed-hours panel -->
                    <StackPanel x:Name="FixedPanel" Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="14">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="LightTimeLabel" FontSize="13" />
                                <TimePicker x:Name="LightTimePicker" ClockIdentifier="24HourClock" MinuteIncrement="5" TimeChanged="LightTime_Changed" MinWidth="150" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="DarkTimeLabel" FontSize="13" />
                                <TimePicker x:Name="DarkTimePicker" ClockIdentifier="24HourClock" MinuteIncrement="5" TimeChanged="DarkTime_Changed" MinWidth="150" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Sunrise/sunset panel -->
                    <StackPanel x:Name="SunPanel" Spacing="12">
                        <TextBlock x:Name="SunHelp" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="14">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="LatLabel" FontSize="13" />
                                <TextBox x:Name="LatBox" MinWidth="150" PlaceholderText="22.3193" TextChanged="Coords_Changed" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="LonLabel" FontSize="13" />
                                <TextBox x:Name="LonBox" MinWidth="150" PlaceholderText="114.1694" TextChanged="Coords_Changed" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="14">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="SunriseOffLabel" FontSize="13" />
                                <NumberBox x:Name="SunriseOffBox" Value="0" Minimum="-720" Maximum="720" SpinButtonPlacementMode="Inline" MinWidth="140" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="SunsetOffLabel" FontSize="13" />
                                <NumberBox x:Name="SunsetOffBox" Value="0" Minimum="-720" Maximum="720" SpinButtonPlacementMode="Inline" MinWidth="140" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button x:Name="DetectBtn" Click="Detect_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="14" Glyph="&#xE81D;" />
                                    <TextBlock x:Name="DetectLabel" />
                                </StackPanel>
                            </Button>
                            <ProgressRing x:Name="DetectRing" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
                        </StackPanel>
                        <Border Padding="12,8,12,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="6">
                            <TextBlock x:Name="SunPreview" FontSize="13" TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Background job -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                        <TextBlock x:Name="BgTitle" FontWeight="SemiBold" FontSize="15" />
                        <TextBlock x:Name="BgSub" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleSwitch x:Name="BgSwitch" Grid.Column="1" Toggled="Bg_Toggled" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <InfoBar x:Name="ResultBar" IsOpen="False" IsClosable="True" />
        </StackPanel>
    </ScrollViewer>
</Page>
