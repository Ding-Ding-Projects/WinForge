<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.NumWordsXModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE7BF;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="InputLabel" FontWeight="SemiBold" />
                        <TextBox x:Name="InputBox" PlaceholderText="123.45" TextChanged="OnInputChanged" />
                    </StackPanel>

                    <Grid ColumnSpacing="14" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock x:Name="ModeLabel" FontWeight="SemiBold" />
                            <ComboBox x:Name="ModeCombo" HorizontalAlignment="Stretch" SelectionChanged="OnModeChanged" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock x:Name="CurrencyLabel" FontWeight="SemiBold" />
                            <ComboBox x:Name="CurrencyCombo" HorizontalAlignment="Stretch" SelectionChanged="OnCurrencyChanged" />
                        </StackPanel>
                    </Grid>

                    <InfoBar x:Name="Status" IsOpen="False" IsClosable="False" />
                </StackPanel>
            </Border>

            <StackPanel x:Name="ResultsPanel" Spacing="12" />
        </StackPanel>
    </ScrollViewer>
</Page>
