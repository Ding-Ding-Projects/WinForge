<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.ExpenseSplitModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8EF;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Currency -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock x:Name="CurrencyLabel" VerticalAlignment="Center" />
                    <TextBox x:Name="CurrencyBox" Text="$" MaxLength="4" Width="80" TextChanged="Currency_Changed" />
                </StackPanel>
            </Border>

            <!-- People -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="PeopleTitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBox x:Name="NewPersonBox" MinWidth="240" KeyDown="NewPerson_KeyDown" />
                        <Button x:Name="AddPersonBtn" Click="AddPerson_Click" />
                    </StackPanel>
                    <ListView x:Name="PeopleList" SelectionMode="None" MaxHeight="220">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="0,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" />
                                    <Button Grid.Column="1" Content="&#xE711;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                            Tag="{Binding Name}" Click="RemovePerson_Click" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- Expenses -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="ExpensesTitle" FontWeight="SemiBold" FontSize="15" />
                    <Button x:Name="AddExpenseBtn" Click="AddExpense_Click" />
                    <ListView x:Name="ExpensesList" SelectionMode="None" MaxHeight="360">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="0,6,0,6" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="{Binding DescPlaceholder}" MinWidth="140" VerticalAlignment="Center" />
                                    <ComboBox Grid.Column="1" ItemsSource="{Binding People}" SelectedItem="{Binding Payer, Mode=TwoWay}"
                                              MinWidth="130" VerticalAlignment="Center" />
                                    <NumberBox Grid.Column="2" Value="{Binding Amount, Mode=TwoWay}" Minimum="0" SmallChange="1"
                                               SpinButtonPlacementMode="Compact" MinWidth="130" VerticalAlignment="Center" />
                                    <Button Grid.Column="3" Content="&#xE711;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                            Tag="{Binding Id}" Click="RemoveExpense_Click" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- Summary + transfers -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SummaryTitle" Grid.Column="0" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                        <Button x:Name="CopyBtn" Grid.Column="1" Click="Copy_Click" />
                    </Grid>
                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <TextBlock x:Name="SummaryBody" TextWrapping="Wrap" FontFamily="Consolas" IsTextSelectionEnabled="True" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
