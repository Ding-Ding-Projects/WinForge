<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.H2PlantModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE945;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Empty state: no nuclear power -->
            <InfoBar x:Name="IdleBar" IsClosable="False" IsOpen="False" Severity="Warning" />

            <!-- Reactor output available -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ReactorTitle" Grid.Column="0" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                        <TextBlock x:Name="ReactorModeText" Grid.Column="1" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                    </Grid>
                    <ProgressBar x:Name="AvailableBar" Minimum="0" Maximum="1150" Height="8" />
                    <TextBlock x:Name="AvailableText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Plant controls -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="RunTitle" FontWeight="SemiBold" FontSize="15" />
                            <TextBlock x:Name="RunStatus" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="RunSwitch" Grid.Column="1" Toggled="Run_Toggled" VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="LoadLabel" />
                        <Slider x:Name="LoadSlider" Minimum="0" Maximum="500" StepFrequency="10" ValueChanged="Load_Changed" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="VentButton" Click="Vent_Click" />
                        <Button x:Name="ResetButton" Click="Reset_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Live readouts -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="ReadoutTitle" FontWeight="SemiBold" FontSize="15" />

                    <Grid ColumnSpacing="16" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="DrawnValue" Grid.Row="0" Grid.Column="0" />
                        <TextBlock x:Name="RateValue" Grid.Row="0" Grid.Column="1" />
                        <TextBlock x:Name="StackValue" Grid.Row="1" Grid.Column="0" />
                        <TextBlock x:Name="EffValue" Grid.Row="1" Grid.Column="1" />
                    </Grid>

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="StackTempLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ProgressBar x:Name="WarmthBar" Minimum="0" Maximum="100" Height="8" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="TankLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ProgressBar x:Name="TankBar" Minimum="0" Maximum="100" Height="10" />
                    </StackPanel>

                    <TextBlock x:Name="TotalValue" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
