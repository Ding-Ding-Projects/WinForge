<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.EmulatorModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Style="{StaticResource WinForgePageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <controls:ModuleHeader x:Name="Header" Grid.Row="0" Glyph="&#xE8EA;" />
        <TextBlock x:Name="HeaderBlurb" Grid.Row="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

        <InfoBar x:Name="EngineBar" Grid.Row="2" IsClosable="False" IsOpen="False" Margin="0,2,0,0" />

        <Pivot Grid.Row="3" x:Name="Tabs" SelectionChanged="Tabs_SelectionChanged">

            <!-- ===================== AVD tab ===================== -->
            <PivotItem x:Name="AvdTab">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                        <Button x:Name="RefreshBtn" Click="Refresh_Click"><FontIcon Glyph="&#xE72C;" FontSize="14" /></Button>
                        <Button x:Name="CreateBtn" Click="Create_Click" Style="{StaticResource AccentButtonStyle}" />
                        <CheckBox x:Name="ColdBootCheck" VerticalAlignment="Center" />
                        <ProgressRing x:Name="Busy" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
                    </StackPanel>

                    <ListView x:Name="AvdList" Grid.Row="1"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="12" Padding="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Target}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
                        <Button x:Name="LaunchBtn" Click="Launch_Click" Style="{StaticResource AccentButtonStyle}" />
                        <Button x:Name="StopBtn" Click="Stop_Click" />
                        <Button x:Name="WipeBtn" Click="Wipe_Click" />
                        <Button x:Name="DeleteBtn" Click="Delete_Click" />
                    </StackPanel>
                </Grid>
            </PivotItem>

            <!-- ===================== SDK Packages tab ===================== -->
            <PivotItem x:Name="SdkTab">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- SDK root indicator -->
                    <Border Grid.Row="0" Margin="0,4,0,0" Padding="12,8,12,8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE8B7;" FontSize="16" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="SdkRootLabel" FontSize="12" FontWeight="SemiBold" />
                                <TextBlock x:Name="SdkRootPath" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                            </StackPanel>
                            <Button x:Name="OpenSdkBtn" Grid.Column="2" Click="OpenSdk_Click" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Action row: channel, accept licenses, update all, refresh -->
                    <Grid Grid.Row="1" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ChannelLabel" Grid.Column="0" VerticalAlignment="Center" FontSize="12" />
                        <ComboBox x:Name="ChannelBox" Grid.Column="1" SelectionChanged="Channel_Changed" MinWidth="130" />
                        <ProgressRing x:Name="SdkBusy" Grid.Column="2" IsActive="False" Width="20" Height="20" HorizontalAlignment="Left" Margin="8,0,0,0" />
                        <Button x:Name="SdkRefreshBtn" Grid.Column="3" Click="SdkRefresh_Click"><FontIcon Glyph="&#xE72C;" FontSize="14" /></Button>
                    </Grid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                        <Button x:Name="AcceptLicensesBtn" Click="AcceptLicenses_Click" Style="{StaticResource AccentButtonStyle}" />
                        <Button x:Name="UpdateAllBtn" Click="UpdateAll_Click" />
                        <ComboBox x:Name="QuickInstallBox" MinWidth="240" />
                        <Button x:Name="QuickInstallBtn" Click="QuickInstall_Click" />
                    </StackPanel>

                    <!-- Filter + install/uninstall by id -->
                    <Grid Grid.Row="3" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="FilterBox" Grid.Column="0" TextChanged="Filter_Changed" />
                        <ToggleButton x:Name="InstalledOnlyToggle" Grid.Column="1" Click="InstalledOnly_Click" />
                        <Button x:Name="InstallSelBtn" Grid.Column="2" Click="InstallSelected_Click" Style="{StaticResource AccentButtonStyle}" />
                        <Button x:Name="UninstallSelBtn" Grid.Column="3" Click="UninstallSelected_Click" />
                    </Grid>

                    <!-- Package list -->
                    <ListView x:Name="PkgList" Grid.Row="4" SelectionMode="Single"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="12" Padding="2,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Status}" FontWeight="Bold"
                                               Foreground="{ThemeResource SystemFillColorSuccessBrush}" Width="16" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Path}" FontWeight="SemiBold" FontFamily="Consolas" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding Version}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Output console -->
                    <Border Grid.Row="5" Margin="0,2,0,0" Padding="10"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="160">
                            <TextBox x:Name="SdkConsole" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                                     FontFamily="Consolas" FontSize="12" BorderThickness="0" Background="Transparent" MinHeight="80"
                                     IsSpellCheckEnabled="False" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
