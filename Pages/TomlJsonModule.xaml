<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.TomlJsonModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="960" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE943;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="DirectionLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="DirectionBox" MinWidth="200" SelectionChanged="Direction_Changed" />
                        <Button x:Name="ConvertButton" Click="Convert_Click" Style="{ThemeResource AccentButtonStyle}" />
                        <Button x:Name="SwapButton" Click="Swap_Click" />
                        <Button x:Name="CopyButton" Click="Copy_Click" />
                    </StackPanel>

                    <InfoBar x:Name="Status" IsOpen="False" IsClosable="False" />

                    <Grid ColumnSpacing="14" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="InputLabel" Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" />
                        <TextBlock x:Name="OutputLabel" Grid.Row="0" Grid.Column="1" FontWeight="SemiBold" />

                        <TextBox x:Name="InputBox" Grid.Row="1" Grid.Column="0"
                                 AcceptsReturn="True" TextWrapping="NoWrap" MinHeight="320"
                                 FontFamily="Consolas"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 TextChanged="Input_Changed" />
                        <TextBox x:Name="OutputBox" Grid.Row="1" Grid.Column="1"
                                 AcceptsReturn="True" TextWrapping="NoWrap" MinHeight="320"
                                 IsReadOnly="True" FontFamily="Consolas"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                    </Grid>

                    <TextBlock x:Name="NotesText" FontSize="12" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
