<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.MediaPlayerModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:lvs="using:LibVLCSharp.Platforms.Windows"
    mc:Ignorable="d">

    <Grid Style="{StaticResource WinForgePageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header + engine bar -->
        <StackPanel Grid.Row="0" Spacing="10">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE714;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
            <InfoBar x:Name="EngineBar" IsClosable="False" IsOpen="False" Severity="Informational" />
            <InfoBar x:Name="ResultBar" IsClosable="True" IsOpen="False" />
        </StackPanel>

        <!-- Main: player (left) + playlist (right) -->
        <Grid Grid.Row="1" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <!-- ===================== Player column ===================== -->
            <Grid Grid.Column="0" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Open file / URL -->
                <Border Grid.Row="0" Padding="14,12,14,12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="OpenFileBtn" Click="OpenFile_Click" Style="{StaticResource AccentButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="14" Glyph="&#xE8E5;" />
                                    <TextBlock x:Name="OpenFileText" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="AddToListBtn" Click="AddFiles_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="14" Glyph="&#xE710;" />
                                    <TextBlock x:Name="AddToListText" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="UrlBox" Grid.Column="0" PlaceholderText="https://… / rtsp://… / mms://…" />
                            <Button x:Name="OpenUrlBtn" Grid.Column="1" Click="OpenUrl_Click" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Video surface -->
                <Border Grid.Row="1" MinHeight="280" Background="Black" CornerRadius="8">
                    <Grid>
                        <lvs:VideoView x:Name="VideoView" />
                        <TextBlock x:Name="NoMediaHint" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#80FFFFFF" TextWrapping="Wrap" TextAlignment="Center" />
                    </Grid>
                </Border>

                <!-- Seek bar + time -->
                <Grid Grid.Row="2" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="CurTime" Grid.Column="0" VerticalAlignment="Center" FontFamily="Consolas" Text="00:00" />
                    <Slider x:Name="SeekSlider" Grid.Column="1" Minimum="0" Maximum="1000" Value="0"
                            VerticalAlignment="Center"
                            ManipulationMode="All"
                            PointerPressed="Seek_PointerPressed"
                            PointerReleased="Seek_PointerReleased"
                            ValueChanged="Seek_ValueChanged" />
                    <TextBlock x:Name="TotTime" Grid.Column="2" VerticalAlignment="Center" FontFamily="Consolas" Text="00:00" />
                </Grid>

                <!-- Transport controls -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button x:Name="PrevBtn" Click="Prev_Click" ToolTipService.ToolTip="Previous · 上一個">
                        <FontIcon FontSize="14" Glyph="&#xE892;" />
                    </Button>
                    <Button x:Name="PlayPauseBtn" Click="PlayPause_Click" Style="{StaticResource AccentButtonStyle}"
                            ToolTipService.ToolTip="Play / Pause · 播放／暫停">
                        <FontIcon x:Name="PlayPauseIcon" FontSize="16" Glyph="&#xE768;" />
                    </Button>
                    <Button x:Name="StopBtn" Click="Stop_Click" ToolTipService.ToolTip="Stop · 停止">
                        <FontIcon FontSize="14" Glyph="&#xE71A;" />
                    </Button>
                    <Button x:Name="NextBtn" Click="Next_Click" ToolTipService.ToolTip="Next · 下一個">
                        <FontIcon FontSize="14" Glyph="&#xE893;" />
                    </Button>

                    <AppBarSeparator />

                    <Button x:Name="MuteBtn" Click="Mute_Click" ToolTipService.ToolTip="Mute · 靜音">
                        <FontIcon x:Name="MuteIcon" FontSize="14" Glyph="&#xE767;" />
                    </Button>
                    <Slider x:Name="VolumeSlider" Minimum="0" Maximum="100" Value="100" Width="110"
                            VerticalAlignment="Center" ValueChanged="Volume_ValueChanged"
                            ToolTipService.ToolTip="Volume · 音量" />

                    <AppBarSeparator />

                    <TextBlock x:Name="SpeedCap" VerticalAlignment="Center" />
                    <ComboBox x:Name="SpeedBox" SelectionChanged="Speed_SelectionChanged" MinWidth="84" VerticalAlignment="Center">
                        <ComboBoxItem Content="0.5×" Tag="0.5" />
                        <ComboBoxItem Content="0.75×" Tag="0.75" />
                        <ComboBoxItem Content="1.0×" Tag="1.0" IsSelected="True" />
                        <ComboBoxItem Content="1.25×" Tag="1.25" />
                        <ComboBoxItem Content="1.5×" Tag="1.5" />
                        <ComboBoxItem Content="2.0×" Tag="2.0" />
                    </ComboBox>

                    <AppBarSeparator />

                    <Button x:Name="SnapshotBtn" Click="Snapshot_Click" ToolTipService.ToolTip="Snapshot (PNG) · 截圖">
                        <FontIcon FontSize="14" Glyph="&#xE722;" />
                    </Button>
                    <Button x:Name="FullscreenBtn" Click="Fullscreen_Click" ToolTipService.ToolTip="Fullscreen · 全螢幕">
                        <FontIcon FontSize="14" Glyph="&#xE740;" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ===================== Right column: tracks + playlist + transcode ===================== -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                <StackPanel Spacing="12">

                    <!-- Tracks -->
                    <Border Padding="12,10,12,12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="TracksTitle" FontWeight="SemiBold" />
                            <TextBlock x:Name="AudioCap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                            <ComboBox x:Name="AudioTrackBox" HorizontalAlignment="Stretch" SelectionChanged="AudioTrack_Changed" />
                            <TextBlock x:Name="SubCap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0" />
                            <ComboBox x:Name="SubTrackBox" HorizontalAlignment="Stretch" SelectionChanged="SubTrack_Changed" />
                            <Button x:Name="LoadSubBtn" Click="LoadSub_Click" HorizontalAlignment="Stretch" Margin="0,4,0,0" />
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <TextBlock x:Name="SubDelayCap" VerticalAlignment="Center" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <NumberBox x:Name="SubDelayBox" Value="0" SpinButtonPlacementMode="Inline"
                                           SmallChange="0.1" LargeChange="0.5" MinWidth="120"
                                           ValueChanged="SubDelay_Changed" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Playlist -->
                    <Border Padding="12,10,12,12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="8">
                            <Grid>
                                <TextBlock x:Name="PlaylistTitle" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Button x:Name="ClearListBtn" Click="ClearList_Click" HorizontalAlignment="Right"
                                        Padding="6,2,6,2">
                                    <FontIcon FontSize="12" Glyph="&#xE74D;" />
                                </Button>
                            </Grid>
                            <ListView x:Name="PlaylistView" MaxHeight="240" SelectionMode="Single"
                                      DoubleTapped="Playlist_DoubleTapped"
                                      SelectionChanged="Playlist_SelectionChanged">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <TextBlock x:Name="EmptyList" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="12" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="PlaySelBtn" Click="PlaySel_Click" />
                                <Button x:Name="RemoveSelBtn" Click="RemoveSel_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Transcode / convert -->
                    <Border Padding="12,10,12,12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="ConvertTitle" FontWeight="SemiBold" />
                            <TextBlock x:Name="ConvertBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="12" TextWrapping="Wrap" />
                            <ComboBox x:Name="PresetBox" HorizontalAlignment="Stretch" />
                            <Button x:Name="ConvertBtn" Click="Convert_Click" HorizontalAlignment="Stretch" />
                            <ProgressBar x:Name="ConvertProgress" IsIndeterminate="True" Visibility="Collapsed" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
