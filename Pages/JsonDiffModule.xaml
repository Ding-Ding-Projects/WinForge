<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.JsonDiffModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="980" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8A5;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock x:Name="LabelA" FontWeight="SemiBold" />
                    <TextBox x:Name="InputA" AcceptsReturn="True" TextWrapping="Wrap" Height="220"
                             FontFamily="Consolas" ScrollViewer.VerticalScrollBarVisibility="Auto"
                             TextChanged="Input_TextChanged" />
                    <TextBlock x:Name="ErrorA" Foreground="#E0483B" TextWrapping="Wrap" FontSize="12" Visibility="Collapsed" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock x:Name="LabelB" FontWeight="SemiBold" />
                    <TextBox x:Name="InputB" AcceptsReturn="True" TextWrapping="Wrap" Height="220"
                             FontFamily="Consolas" ScrollViewer.VerticalScrollBarVisibility="Auto"
                             TextChanged="Input_TextChanged" />
                    <TextBlock x:Name="ErrorB" Foreground="#E0483B" TextWrapping="Wrap" FontSize="12" Visibility="Collapsed" />
                </StackPanel>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                    <TextBlock x:Name="ToggleTitle" FontWeight="SemiBold" />
                    <TextBlock x:Name="ToggleSub" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <ToggleSwitch x:Name="IgnoreOrderSwitch" Grid.Column="1" Toggled="IgnoreOrder_Toggled" VerticalAlignment="Center" />
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock x:Name="SummaryText" VerticalAlignment="Center" FontWeight="SemiBold" />
                <Button x:Name="CopyButton" Click="Copy_Click" />
            </StackPanel>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <ListView x:Name="DiffList" SelectionMode="None" MaxHeight="420"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="4,6,4,6" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="3*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Path}" FontFamily="Consolas"
                                           TextWrapping="Wrap" Foreground="{Binding Brush}" />
                                <TextBlock Grid.Column="1" Text="{Binding Status}" Foreground="{Binding Brush}"
                                           FontWeight="SemiBold" VerticalAlignment="Top" />
                                <TextBlock Grid.Column="2" Text="{Binding Detail}" FontFamily="Consolas"
                                           TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <TextBlock x:Name="EmptyHint" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</Page>
