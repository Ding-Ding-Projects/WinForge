<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.FileSplitModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8A5;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Split -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="SplitTitle" FontWeight="SemiBold" FontSize="15" />

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="PickSourceBtn" Click="PickSource_Click" />
                        <TextBlock x:Name="SourceText" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="PartSizeLabel" VerticalAlignment="Center" />
                        <NumberBox x:Name="PartSizeBox" Value="100" Minimum="1" Maximum="1048576" SpinButtonPlacementMode="Inline" MinWidth="150" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="PickOutFolderBtn" Click="PickOutFolder_Click" />
                        <TextBlock x:Name="OutFolderText" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <Button x:Name="SplitBtn" Click="Split_Click" Style="{ThemeResource AccentButtonStyle}" />
                    <ProgressBar x:Name="SplitProgress" Minimum="0" Maximum="1" Value="0" />
                    <TextBlock x:Name="SplitStatus" FontSize="12" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Join -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="JoinTitle" FontWeight="SemiBold" FontSize="15" />

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="PickFirstPartBtn" Click="PickFirstPart_Click" />
                        <TextBlock x:Name="FirstPartText" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <CheckBox x:Name="HashChk" IsChecked="True" />

                    <Button x:Name="JoinBtn" Click="Join_Click" Style="{ThemeResource AccentButtonStyle}" />
                    <ProgressBar x:Name="JoinProgress" Minimum="0" Maximum="1" Value="0" />
                    <TextBlock x:Name="JoinStatus" FontSize="12" TextWrapping="Wrap" IsTextSelectionEnabled="True" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
