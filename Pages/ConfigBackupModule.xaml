<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.ConfigBackupModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Style="{StaticResource WinForgePageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <controls:ModuleHeader x:Name="Header" Grid.Row="0" Glyph="&#xE8F7;" />
        <TextBlock x:Name="HeaderBlurb" Grid.Row="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

        <InfoBar x:Name="ResultBar" Grid.Row="2" IsClosable="True" IsOpen="False" Margin="0,2,0,0" />

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="14">

                <!-- Portable bundle -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16,14,16,14">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="BundleTitle" FontWeight="SemiBold" />
                        <TextBlock x:Name="BundleDesc" FontSize="12" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <!-- Include secrets (encrypted) -->
                        <Border Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10,12,10">
                            <StackPanel Spacing="10">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock x:Name="SecretsToggleLabel" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                                        <TextBlock x:Name="SecretsToggleDesc" FontSize="11" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ToggleSwitch x:Name="SecretsToggle" Grid.Column="1" VerticalAlignment="Center" Toggled="SecretsToggle_Toggled" />
                                </Grid>

                                <StackPanel x:Name="SecretsPanel" Spacing="10" Visibility="Collapsed">
                                    <InfoBar x:Name="SecretsWarnBar" Severity="Error" IsOpen="True" IsClosable="False" />

                                    <StackPanel Spacing="8">
                                        <CheckBox x:Name="SecretApiKeysCheck" IsChecked="True" />
                                        <CheckBox x:Name="SecretSettingsCheck" IsChecked="True" />
                                        <CheckBox x:Name="SecretEnvCheck" IsChecked="True" />
                                        <CheckBox x:Name="SecretSshCheck" IsChecked="False" />
                                    </StackPanel>

                                    <Grid ColumnSpacing="10" RowSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <PasswordBox x:Name="SecretPwdBox" Grid.Column="0" PasswordChanged="SecretPwd_Changed" />
                                        <PasswordBox x:Name="SecretPwdConfirmBox" Grid.Column="1" PasswordChanged="SecretPwd_Changed" />
                                    </Grid>
                                    <TextBlock x:Name="SecretPwdHint" FontSize="11" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="ExportBundleBtn" Style="{StaticResource AccentButtonStyle}" Click="ExportBundle_Click" />
                            <Button x:Name="ImportBundleBtn" Click="ImportBundle_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Config snapshots (git) -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16,14,16,14">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="SnapTitle" FontWeight="SemiBold" />
                        <TextBlock x:Name="SnapDesc" FontSize="12" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBox x:Name="SnapMessageBox" MinWidth="240" />
                            <Button x:Name="TakeSnapshotBtn" Style="{StaticResource AccentButtonStyle}" Click="TakeSnapshot_Click" />
                            <Button x:Name="RefreshSnapsBtn" Click="RefreshSnaps_Click" />
                            <Button x:Name="VerifyBtn" Click="Verify_Click" />
                            <Button x:Name="PruneBtn" Click="Prune_Click" />
                            <Button x:Name="BundleFileBtn" Click="BundleFile_Click" />
                        </StackPanel>

                        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Height="220">
                            <Grid>
                                <ListView x:Name="SnapList" SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="6,6,6,6" ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="78" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding ShortHash}" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Subject}" FontSize="13" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding Date}" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                </StackPanel>
                                                <Button Grid.Column="2" Click="SnapActions_Click" Padding="12,5,12,5" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="Actions · 操作" FontSize="12" />
                                                        <FontIcon Glyph="&#xE70D;" FontSize="10" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <TextBlock x:Name="SnapEmpty" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Visibility="Collapsed" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Capture & export -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16,14,16,14">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="CaptureTitle" FontWeight="SemiBold" />
                        <TextBlock x:Name="CaptureDesc" FontSize="12" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8" >
                            <Button x:Name="ExportRegBtn" Click="ExportReg_Click" />
                            <Button x:Name="ExportWingetBtn" Click="ExportWinget_Click" />
                            <Button x:Name="BackupTaskbarBtn" Click="BackupTaskbar_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Auto-sync schedule (interval timer + git + optional remote) -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16,14,16,14">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="SyncTitle" FontWeight="SemiBold" />
                        <TextBlock x:Name="SyncDesc" FontSize="12" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <InfoBar x:Name="GitMissingBar" Severity="Warning" IsClosable="False" IsOpen="False" />

                        <!-- interval row: every [count] [unit] + enable toggle -->
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock x:Name="EveryLabel" VerticalAlignment="Center" FontSize="13" />
                            <NumberBox x:Name="IntervalCount" Value="15" Minimum="1" Maximum="9999" SpinButtonPlacementMode="Compact" Width="120" />
                            <ComboBox x:Name="IntervalUnit" MinWidth="130" SelectedIndex="0" />
                            <ToggleSwitch x:Name="AutoSyncToggle" Toggled="AutoSyncToggle_Toggled" />
                        </StackPanel>

                        <!-- optional remote URL -->
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock x:Name="RemoteLabel" VerticalAlignment="Center" FontSize="13" Width="150" TextWrapping="Wrap" />
                            <TextBox x:Name="RemoteUrlBox" MinWidth="320" />
                            <Button x:Name="PushNowBtn" Click="PushNow_Click" />
                        </StackPanel>

                        <!-- actions + status -->
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button x:Name="SyncNowBtn" Style="{StaticResource AccentButtonStyle}" Click="SyncNow_Click" />
                            <CheckBox x:Name="BackgroundTaskCheck" Checked="BackgroundTask_Changed" Unchecked="BackgroundTask_Changed" />
                        </StackPanel>
                        <TextBlock x:Name="LastSyncStatus" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Schedule & mirror -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16,14,16,14">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="AutoTitle" FontWeight="SemiBold" />
                        <TextBlock x:Name="AutoDesc" FontSize="12" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock x:Name="TimeLabel" VerticalAlignment="Center" FontSize="12" />
                            <TextBox x:Name="TimeBox" Text="03:00" Width="80" />
                            <Button x:Name="ScheduleBtn" Click="Schedule_Click" />
                            <Button x:Name="UnscheduleBtn" Click="Unschedule_Click" />
                            <TextBlock x:Name="ScheduleStatus" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button x:Name="MirrorBtn" Click="Mirror_Click" />
                            <TextBlock x:Name="MirrorDest" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextTrimming="CharacterEllipsis" MaxWidth="420" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Output pane -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16,14,16,14">
                    <StackPanel Spacing="8">
                        <Grid>
                            <TextBlock x:Name="OutputTitle" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <Button x:Name="CopyOutputBtn" HorizontalAlignment="Right" Padding="10,4,10,4" Click="CopyOutput_Click" />
                        </Grid>
                        <ScrollViewer Height="180" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="6" Padding="10,8,10,8">
                            <TextBlock x:Name="OutputText" FontFamily="Consolas" FontSize="12" IsTextSelectionEnabled="True" TextWrapping="NoWrap" />
                        </ScrollViewer>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
