<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.BarcodeModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE91B;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="SymLabel" FontWeight="SemiBold" />
                        <ComboBox x:Name="SymBox" MinWidth="260" SelectionChanged="OnAnyChanged" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock x:Name="InputLabel" FontWeight="SemiBold" />
                        <TextBox x:Name="InputBox" TextChanged="OnAnyChanged" />
                        <TextBlock x:Name="HintText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>

                    <CheckBox x:Name="TextChk" Checked="OnAnyChanged" Unchecked="OnAnyChanged" IsChecked="True" />

                    <InfoBar x:Name="ErrorBar" IsOpen="False" Severity="Error" IsClosable="False" />
                </StackPanel>
            </Border>

            <Border x:Name="PreviewCard" Padding="16" Background="#FFFFFFFF" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" HorizontalAlignment="Stretch">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" HorizontalScrollMode="Auto">
                    <Grid x:Name="BarsHost" HorizontalAlignment="Center" />
                </ScrollViewer>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="CopySvgBtn" Click="CopySvg_Click" />
                <Button x:Name="SaveSvgBtn" Click="SaveSvg_Click" Style="{ThemeResource AccentButtonStyle}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
