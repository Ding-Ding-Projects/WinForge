<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.UlidModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE943;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="Status" IsOpen="False" IsClosable="False" Severity="Informational" />

            <!-- 1. Generate ULIDs -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="GenTitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock x:Name="CountLabel" VerticalAlignment="Center" />
                            <NumberBox x:Name="CountBox" Value="1" Minimum="1" Maximum="10000" SpinButtonPlacementMode="Inline" MinWidth="130" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock x:Name="MonoLabel" VerticalAlignment="Center" />
                            <ToggleSwitch x:Name="MonoSwitch" MinWidth="0" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="GenButton" Click="Generate_Click" Style="{ThemeResource AccentButtonStyle}" />
                        <Button x:Name="GenCopyButton" Click="GenCopy_Click" />
                    </StackPanel>
                    <TextBox x:Name="GenOutput" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" FontFamily="Consolas" MinHeight="120" MaxHeight="220"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>

            <!-- 2. Decode ULID -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="DecUlidTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="UlidInput" FontFamily="Consolas" PlaceholderText="01ARZ3NDEKTSV4RRFFQ69G5FAV" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="DecUlidButton" Click="DecodeUlid_Click" Style="{ThemeResource AccentButtonStyle}" />
                        <Button x:Name="UlidTsCopyButton" Click="UlidTsCopy_Click" />
                        <Button x:Name="UlidRandCopyButton" Click="UlidRandCopy_Click" />
                    </StackPanel>
                    <TextBlock x:Name="UlidTsUtc" IsTextSelectionEnabled="True" FontFamily="Consolas" TextWrapping="Wrap" />
                    <TextBlock x:Name="UlidTsLocal" IsTextSelectionEnabled="True" FontFamily="Consolas" TextWrapping="Wrap" />
                    <TextBlock x:Name="UlidRand" IsTextSelectionEnabled="True" FontFamily="Consolas" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- 3. Decode Snowflake -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="DecSnowTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="SnowInput" FontFamily="Consolas" PlaceholderText="175928847299117063" />
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock x:Name="EpochLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="EpochBox" MinWidth="260" SelectedIndex="0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="DecSnowButton" Click="DecodeSnowflake_Click" Style="{ThemeResource AccentButtonStyle}" />
                        <Button x:Name="SnowTsCopyButton" Click="SnowTsCopy_Click" />
                    </StackPanel>
                    <TextBlock x:Name="SnowTsUtc" IsTextSelectionEnabled="True" FontFamily="Consolas" TextWrapping="Wrap" />
                    <TextBlock x:Name="SnowTsLocal" IsTextSelectionEnabled="True" FontFamily="Consolas" TextWrapping="Wrap" />
                    <TextBlock x:Name="SnowWorker" IsTextSelectionEnabled="True" FontFamily="Consolas" TextWrapping="Wrap" />
                    <TextBlock x:Name="SnowSeq" IsTextSelectionEnabled="True" FontFamily="Consolas" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
