<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.VertFarmModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE945;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Empty-state: reactor not generating -->
            <InfoBar x:Name="IdleBar" IsClosable="False" IsOpen="False" />

            <!-- Reactor availability -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ReactorTitle" Grid.Column="0" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                        <TextBlock x:Name="ReactorModeText" Grid.Column="1" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                    </Grid>
                    <ProgressBar x:Name="AvailableBar" Minimum="0" Maximum="1150" Value="0" Height="8" />
                    <TextBlock x:Name="AvailableText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Operator controls -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="RunTitle" FontWeight="SemiBold" FontSize="15" />
                            <TextBlock x:Name="RunStatus" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="RunSwitch" Grid.Column="1" Toggled="Run_Toggled" VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="DrawLabel" />
                        <Slider x:Name="DrawSlider" Minimum="0" Maximum="200" StepFrequency="5" ValueChanged="Draw_Changed" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="RunButton" Click="RunToggle_Click" />
                        <Button x:Name="HarvestButton" Click="Harvest_Click" />
                        <Button x:Name="ResetButton" Click="Reset_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Readouts -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="ReadoutTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="DrawValue" />
                    <TextBlock x:Name="LightsValue" />
                    <TextBlock x:Name="CanopyValue" />

                    <TextBlock x:Name="GrowthLabel" Margin="0,4,0,0" />
                    <ProgressBar x:Name="GrowthBar" Minimum="0" Maximum="100" Value="0" Height="8" />

                    <InfoBar x:Name="LightsOutBar" IsClosable="False" IsOpen="False" />

                    <TextBlock x:Name="HarvestsValue" Margin="0,4,0,0" />
                    <TextBlock x:Name="YieldValue" />
                    <TextBlock x:Name="EarnedValue" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
