<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.FileZillaModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16,12,16,12" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- header -->
            <RowDefinition Height="Auto" />
            <!-- quickconnect + status -->
            <RowDefinition Height="*" />
            <!-- panes -->
            <RowDefinition Height="Auto" />
            <!-- transfer queue -->
        </Grid.RowDefinitions>

        <!-- ===================== Header ===================== -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
            <FontIcon FontSize="22" Glyph="&#xE8B7;" VerticalAlignment="Center" />
            <StackPanel>
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock
                    x:Name="HeaderBlurb"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </StackPanel>

        <!-- About / operations help (reachable, collapsible) -->
        <Expander
            Grid.Row="0"
            Margin="0,2,0,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top">
            <Expander.Header>
                <TextBlock x:Name="HelpHeader" />
            </Expander.Header>
            <StackPanel
                x:Name="OpsPanel"
                MinWidth="360"
                Spacing="2" />
        </Expander>

        <!-- ===================== Quickconnect bar ===================== -->
        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="2*" MinWidth="140" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="110" />
                <ColumnDefinition Width="*" MinWidth="110" />
                <ColumnDefinition Width="*" MinWidth="110" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ComboBox
                x:Name="QcProtocol"
                Grid.Column="0"
                MinWidth="90"
                VerticalAlignment="Center" />
            <TextBox
                x:Name="QcHost"
                Grid.Column="1"
                VerticalAlignment="Center"
                PlaceholderText="host · 主機" />
            <TextBox
                x:Name="QcPort"
                Grid.Column="2"
                Width="64"
                VerticalAlignment="Center"
                PlaceholderText="port" />
            <TextBox
                x:Name="QcUser"
                Grid.Column="3"
                VerticalAlignment="Center"
                PlaceholderText="user · 使用者" />
            <PasswordBox
                x:Name="QcPass"
                Grid.Column="4"
                VerticalAlignment="Center"
                PlaceholderText="password · 密碼" />
            <Button
                x:Name="QcConnectBtn"
                Grid.Column="6"
                VerticalAlignment="Center"
                Click="QuickConnect_Click"
                Style="{StaticResource AccentButtonStyle}" />
            <Button
                x:Name="DisconnectBtn"
                Grid.Column="7"
                VerticalAlignment="Center"
                Click="Disconnect_Click"
                IsEnabled="False" />
        </Grid>

        <InfoBar
            x:Name="StatusBar"
            Grid.Row="1"
            Margin="0,52,0,0"
            IsClosable="True"
            IsOpen="False" />

        <!-- ===================== Three panes ===================== -->
        <Grid Grid.Row="2" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="200" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="280" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <!-- Site Manager · 站台管理 -->
            <Border
                Grid.Column="0"
                Padding="10"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        x:Name="SiteMgrHeader"
                        Grid.Row="0"
                        Style="{StaticResource BodyStrongTextBlockStyle}" />

                    <ListView
                        x:Name="SitesList"
                        Grid.Row="1"
                        SelectionChanged="SitesList_SelectionChanged"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Padding="0,4">
                                    <TextBlock Text="{Binding Name}" />
                                    <TextBlock
                                        FontSize="11"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding Summary}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel
                        Grid.Row="2"
                        Orientation="Horizontal"
                        Spacing="6">
                        <Button x:Name="NewSiteBtn" Click="NewSite_Click" ToolTipService.ToolTip="New site · 新增站台">
                            <FontIcon FontSize="14" Glyph="&#xE710;" />
                        </Button>
                        <Button x:Name="EditSiteBtn" Click="EditSite_Click" ToolTipService.ToolTip="Edit site · 編輯站台">
                            <FontIcon FontSize="14" Glyph="&#xE70F;" />
                        </Button>
                        <Button x:Name="DeleteSiteBtn" Click="DeleteSite_Click" ToolTipService.ToolTip="Delete site · 刪除站台">
                            <FontIcon FontSize="14" Glyph="&#xE74D;" />
                        </Button>
                        <Button x:Name="ConnectSiteBtn" Click="ConnectSite_Click" ToolTipService.ToolTip="Connect · 連線">
                            <FontIcon FontSize="14" Glyph="&#xE768;" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Local pane · 本機窗 -->
            <Border
                Grid.Column="2"
                Padding="10"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        x:Name="LocalHeader"
                        Grid.Row="0"
                        Style="{StaticResource BodyStrongTextBlockStyle}" />

                    <Grid Grid.Row="1" ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button
                            Grid.Column="0"
                            Click="LocalUp_Click"
                            ToolTipService.ToolTip="Up · 上層">
                            <FontIcon FontSize="13" Glyph="&#xE74A;" />
                        </Button>
                        <TextBox
                            x:Name="LocalPath"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            KeyDown="LocalPath_KeyDown" />
                        <Button
                            Grid.Column="2"
                            Click="LocalBrowse_Click"
                            ToolTipService.ToolTip="Browse… · 瀏覽…">
                            <FontIcon FontSize="13" Glyph="&#xE838;" />
                        </Button>
                        <Button
                            Grid.Column="3"
                            Click="LocalMkdir_Click"
                            ToolTipService.ToolTip="New folder · 新資料夾">
                            <FontIcon FontSize="13" Glyph="&#xE8F4;" />
                        </Button>
                        <Button
                            Grid.Column="4"
                            Click="LocalRefresh_Click"
                            ToolTipService.ToolTip="Refresh · 重新整理">
                            <FontIcon FontSize="13" Glyph="&#xE72C;" />
                        </Button>
                    </Grid>

                    <ListView
                        x:Name="LocalList"
                        Grid.Row="2"
                        DoubleTapped="LocalList_DoubleTapped"
                        SelectionMode="Extended">
                        <ListView.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem x:Name="LocalUploadMenu" Click="Upload_Click" Text="Upload · 上載">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74B;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem x:Name="LocalRenameMenu" Click="LocalRename_Click" Text="Rename · 重新命名">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8AC;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem x:Name="LocalDeleteMenu" Click="LocalDelete_Click" Text="Delete · 刪除">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74D;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </ListView.ContextFlyout>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="8" Padding="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon
                                        Grid.Column="0"
                                        FontSize="14"
                                        Glyph="{Binding Glyph}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{Binding Name}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Grid.Column="2"
                                        MinWidth="70"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding SizeText}"
                                        TextAlignment="Right" />
                                    <TextBlock
                                        Grid.Column="3"
                                        MinWidth="120"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding ModifiedText}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- transfer arrows between local and remote -->
            <StackPanel
                Grid.Column="3"
                VerticalAlignment="Center"
                Spacing="8">
                <Button
                    x:Name="UploadBtn"
                    Click="Upload_Click"
                    IsEnabled="False"
                    ToolTipService.ToolTip="Upload selected · 上載所選">
                    <FontIcon FontSize="16" Glyph="&#xE74B;" />
                </Button>
                <Button
                    x:Name="DownloadBtn"
                    Click="Download_Click"
                    IsEnabled="False"
                    ToolTipService.ToolTip="Download selected · 下載所選">
                    <FontIcon FontSize="16" Glyph="&#xE74A;" />
                </Button>
            </StackPanel>

            <!-- Remote pane · 遠端窗 -->
            <Border
                Grid.Column="4"
                Padding="10"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        x:Name="RemoteHeader"
                        Grid.Row="0"
                        Style="{StaticResource BodyStrongTextBlockStyle}" />

                    <Grid Grid.Row="1" ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button
                            Grid.Column="0"
                            Click="RemoteUp_Click"
                            ToolTipService.ToolTip="Up · 上層">
                            <FontIcon FontSize="13" Glyph="&#xE74A;" />
                        </Button>
                        <TextBox
                            x:Name="RemotePath"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            IsEnabled="False"
                            KeyDown="RemotePath_KeyDown" />
                        <Button
                            Grid.Column="2"
                            Click="RemoteMkdir_Click"
                            ToolTipService.ToolTip="New folder · 新資料夾">
                            <FontIcon FontSize="13" Glyph="&#xE8F4;" />
                        </Button>
                        <Button
                            Grid.Column="3"
                            Click="RemoteRefresh_Click"
                            ToolTipService.ToolTip="Refresh · 重新整理">
                            <FontIcon FontSize="13" Glyph="&#xE72C;" />
                        </Button>
                    </Grid>

                    <ListView
                        x:Name="RemoteList"
                        Grid.Row="2"
                        DoubleTapped="RemoteList_DoubleTapped"
                        SelectionMode="Extended">
                        <ListView.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem x:Name="RemoteDownloadMenu" Click="Download_Click" Text="Download · 下載">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74A;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem x:Name="RemoteRenameMenu" Click="RemoteRename_Click" Text="Rename · 重新命名">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8AC;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem x:Name="RemoteDeleteMenu" Click="RemoteDelete_Click" Text="Delete · 刪除">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74D;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </ListView.ContextFlyout>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="8" Padding="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon
                                        Grid.Column="0"
                                        FontSize="14"
                                        Glyph="{Binding Glyph}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{Binding Name}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Grid.Column="2"
                                        MinWidth="70"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding SizeText}"
                                        TextAlignment="Right" />
                                    <TextBlock
                                        Grid.Column="3"
                                        MinWidth="120"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding ModifiedText}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- ===================== Transfer queue ===================== -->
        <Border
            Grid.Row="3"
            Padding="10"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid RowSpacing="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Name="QueueHeader"
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <CheckBox
                        x:Name="ResumeCheck"
                        Grid.Column="2"
                        IsChecked="True"
                        VerticalAlignment="Center" />
                    <Button
                        x:Name="CancelTransferBtn"
                        Grid.Column="3"
                        Click="CancelTransfer_Click"
                        IsEnabled="False" />
                    <Button
                        x:Name="ClearQueueBtn"
                        Grid.Column="4"
                        Click="ClearQueue_Click" />
                </Grid>

                <ProgressBar
                    x:Name="OverallProgress"
                    Grid.Row="1"
                    Maximum="1"
                    Value="0" />

                <ListView
                    x:Name="QueueList"
                    Grid.Row="2"
                    MaxHeight="150"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnSpacing="10" Padding="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon
                                    Grid.Column="0"
                                    FontSize="13"
                                    Glyph="{Binding DirectionGlyph}" />
                                <TextBlock
                                    Grid.Column="1"
                                    Text="{Binding FileName}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Grid.Column="2"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{Binding PathText}"
                                    TextTrimming="CharacterEllipsis" />
                                <ProgressBar
                                    Grid.Column="3"
                                    VerticalAlignment="Center"
                                    Maximum="1"
                                    Value="{Binding Progress}" />
                                <TextBlock
                                    Grid.Column="4"
                                    MinWidth="80"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{Binding StatusText}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
