<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.SqliteBrowserModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Style="{StaticResource WinForgePageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="6">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xEC0A;" />
            <TextBlock
                x:Name="HeaderBlurb"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />
        </StackPanel>

        <!-- Managed-engine note -->
        <InfoBar
            Grid.Row="1"
            x:Name="EngineBar"
            IsClosable="True"
            IsOpen="True"
            Severity="Informational" />

        <!-- File bar -->
        <Border
            Grid.Row="2"
            Padding="12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="OpenBtn" Click="Open_Click" Style="{StaticResource AccentButtonStyle}" />
                    <Button x:Name="NewBtn" Click="New_Click" />
                    <Button x:Name="CloseBtn" Click="Close_Click" IsEnabled="False" />
                    <Button x:Name="RefreshBtn" Click="Refresh_Click" IsEnabled="False" />
                </StackPanel>
                <TextBlock x:Name="PathLabel" TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Border>

        <!-- Tabs -->
        <Pivot Grid.Row="3" x:Name="MainPivot">

            <!-- ===================== Structure ===================== -->
            <PivotItem x:Name="StructureTab">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" MinWidth="220" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto">
                            <TreeView
                                x:Name="StructureTree"
                                Padding="4,8,4,8"
                                ItemInvoked="StructureTree_ItemInvoked"
                                SelectionMode="Single" />
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Column="1" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="StructureSelLabel" Grid.Row="0"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />

                        <Border
                            Grid.Row="1"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="ColumnsHost" Padding="0" />
                            </ScrollViewer>
                        </Border>

                        <Border
                            Grid.Row="2"
                            Padding="10"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="6">
                                <TextBlock x:Name="DdlLabel" Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBox x:Name="DdlBox" IsReadOnly="True" AcceptsReturn="True"
                                         FontFamily="Consolas" FontSize="12" BorderThickness="0"
                                         MaxHeight="120"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </PivotItem>

            <!-- ===================== Browse Data ===================== -->
            <PivotItem x:Name="BrowseTab">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Table picker + actions -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                        <TextBlock x:Name="BrowseTableLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="BrowseTableCombo" MinWidth="240"
                                  SelectionChanged="BrowseTableCombo_SelectionChanged" />
                        <AppBarSeparator />
                        <Button x:Name="InsertRowBtn" Click="InsertRow_Click" IsEnabled="False" />
                        <Button x:Name="DeleteRowBtn" Click="DeleteRow_Click" IsEnabled="False" />
                        <Button x:Name="SaveCellBtn" Click="SaveCell_Click" IsEnabled="False"
                                Style="{StaticResource AccentButtonStyle}" />
                        <Button x:Name="ExportTableBtn" Click="ExportTable_Click" IsEnabled="False" />
                    </StackPanel>

                    <InfoBar Grid.Row="1" x:Name="BrowseBar" IsClosable="True" IsOpen="False" />

                    <!-- Data grid (custom, editable cells) -->
                    <Border
                        Grid.Row="2"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <ScrollViewer x:Name="BrowseScroller"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollMode="Enabled">
                            <StackPanel x:Name="BrowseGridHost" />
                        </ScrollViewer>
                    </Border>

                    <!-- Paging -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button x:Name="PrevPageBtn" Click="PrevPage_Click" IsEnabled="False">
                            <FontIcon FontSize="14" Glyph="&#xE76B;" />
                        </Button>
                        <Button x:Name="NextPageBtn" Click="NextPage_Click" IsEnabled="False">
                            <FontIcon FontSize="14" Glyph="&#xE76C;" />
                        </Button>
                        <TextBlock x:Name="PageLabel" VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <AppBarSeparator />
                        <TextBlock x:Name="PageSizeLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="PageSizeCombo" SelectionChanged="PageSize_SelectionChanged">
                            <ComboBoxItem Content="25" Tag="25" />
                            <ComboBoxItem Content="50" Tag="50" IsSelected="True" />
                            <ComboBoxItem Content="100" Tag="100" />
                            <ComboBoxItem Content="200" Tag="200" />
                            <ComboBoxItem Content="500" Tag="500" />
                        </ComboBox>
                        <TextBlock x:Name="RowCountLabel" VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Grid>
            </PivotItem>

            <!-- ===================== Execute SQL ===================== -->
            <PivotItem x:Name="SqlTab">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="2*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                        <Button x:Name="RunBtn" Click="Run_Click" Style="{StaticResource AccentButtonStyle}" IsEnabled="False" />
                        <Button x:Name="CancelBtn" Click="Cancel_Click" IsEnabled="False" />
                        <Button x:Name="ClearBtn" Click="Clear_Click" />
                        <Button x:Name="ExportResultBtn" Click="ExportResult_Click" IsEnabled="False" />
                    </StackPanel>

                    <Border
                        Grid.Row="1"
                        MinHeight="120"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <TextBox
                            x:Name="SqlBox"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            FontFamily="Consolas"
                            FontSize="13"
                            BorderThickness="0"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            VerticalAlignment="Stretch"
                            VerticalContentAlignment="Top">
                            <TextBox.KeyboardAccelerators>
                                <KeyboardAccelerator Key="Enter" Modifiers="Control" Invoked="RunAccel_Invoked" />
                            </TextBox.KeyboardAccelerators>
                        </TextBox>
                    </Border>

                    <InfoBar Grid.Row="2" x:Name="ResultBar" IsClosable="True" IsOpen="False" />

                    <Border
                        Grid.Row="3"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid RowSpacing="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border
                                Grid.Row="0"
                                Padding="10,6"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="0,0,0,1"
                                CornerRadius="8,8,0,0">
                                <TextBlock x:Name="ResultSummary" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Border>
                            <ScrollViewer
                                Grid.Row="1"
                                HorizontalScrollBarVisibility="Auto"
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollMode="Enabled">
                                <StackPanel x:Name="ResultsHost" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
