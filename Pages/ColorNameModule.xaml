<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.ColorNameModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE790;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <TextBlock x:Name="InputLabel" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBox x:Name="InputBox" MinWidth="220" TextChanged="Input_Changed" />
                        <Border x:Name="BaseSwatch" Width="46" Height="34" CornerRadius="6" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock x:Name="RLabel" Width="26" VerticalAlignment="Center" />
                            <Slider x:Name="RSlider" Minimum="0" Maximum="255" Width="300" ValueChanged="Slider_Changed" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock x:Name="GLabel" Width="26" VerticalAlignment="Center" />
                            <Slider x:Name="GSlider" Minimum="0" Maximum="255" Width="300" ValueChanged="Slider_Changed" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock x:Name="BLabel" Width="26" VerticalAlignment="Center" />
                            <Slider x:Name="BSlider" Minimum="0" Maximum="255" Width="300" ValueChanged="Slider_Changed" />
                        </StackPanel>
                    </StackPanel>

                    <Border Padding="12,10,12,10" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="6">
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Border x:Name="NearestSwatch" Width="46" Height="46" CornerRadius="6" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" />
                            <StackPanel Spacing="1" VerticalAlignment="Center">
                                <TextBlock x:Name="NearestLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock x:Name="NearestName" FontWeight="SemiBold" FontSize="15" />
                                <TextBlock x:Name="NearestDetail" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="ListTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="FilterBox" TextChanged="Filter_Changed" />
                    <ListView x:Name="ColorList" SelectionChanged="ColorList_SelectionChanged" MaxHeight="360" SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="12" Padding="0,4,0,4">
                                    <Border Width="30" Height="30" CornerRadius="5" Background="{Binding Brush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" />
                                    <StackPanel Spacing="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="14" />
                                        <TextBlock Text="{Binding Hex}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
