<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.AiChatModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===== Sidebar: conversations ===== -->
        <Grid
            Grid.Column="0"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Padding="12,12,12,6" Spacing="8">
                <Button x:Name="NewChatBtn" HorizontalAlignment="Stretch" Click="NewChat_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE710;" />
                        <TextBlock x:Name="NewChatText" />
                    </StackPanel>
                </Button>
                <TextBox
                    x:Name="ChatSearchBox"
                    PlaceholderText="Search… · 搜尋…"
                    TextChanged="ChatSearch_TextChanged" />
            </StackPanel>

            <TextBlock
                x:Name="ChatsHeader"
                Grid.Row="1"
                Margin="14,4,12,4"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}" />

            <ScrollViewer Grid.Row="2" Padding="8,0,8,8">
                <StackPanel x:Name="ConversationList" Spacing="4" />
            </ScrollViewer>
        </Grid>

        <!-- ===== Main chat pane ===== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Top bar: title + provider/model + settings -->
            <Grid Grid.Row="0" Padding="16,12,16,8" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBox
                        x:Name="ChatTitleBox"
                        FontSize="16"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Background="Transparent"
                        LostFocus="ChatTitle_LostFocus"
                        PlaceholderText="Conversation · 對話" />
                </StackPanel>

                <ComboBox
                    x:Name="ProviderPicker"
                    Grid.Column="1"
                    MinWidth="150"
                    VerticalAlignment="Center"
                    SelectionChanged="Provider_SelectionChanged" />
                <ComboBox
                    x:Name="ModelPicker"
                    Grid.Column="2"
                    MinWidth="170"
                    VerticalAlignment="Center"
                    SelectionChanged="Model_SelectionChanged" />
                <Button
                    x:Name="SettingsBtn"
                    Grid.Column="3"
                    VerticalAlignment="Center"
                    ToolTipService.ToolTip="Chat settings · 對話設定">
                    <FontIcon FontSize="16" Glyph="&#xE713;" />
                    <Button.Flyout>
                        <Flyout>
                            <StackPanel Width="320" Spacing="10">
                                <TextBlock x:Name="SettingsTitle" FontWeight="SemiBold" />
                                <TextBlock x:Name="SysPromptLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBox
                                    x:Name="SystemPromptBox"
                                    AcceptsReturn="True"
                                    Height="100"
                                    TextWrapping="Wrap"
                                    LostFocus="SystemPrompt_LostFocus" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="TempLabel" VerticalAlignment="Center" />
                                    <TextBlock x:Name="TempValue" Grid.Column="1" VerticalAlignment="Center" />
                                </Grid>
                                <Slider
                                    x:Name="TempSlider"
                                    Minimum="0"
                                    Maximum="2"
                                    StepFrequency="0.05"
                                    ValueChanged="Temp_ValueChanged" />
                                <TextBlock x:Name="MaxTokLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <NumberBox
                                    x:Name="MaxTokBox"
                                    Minimum="0"
                                    Maximum="131072"
                                    SpinButtonPlacementMode="Compact"
                                    ValueChanged="MaxTok_ValueChanged" />
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Button
                    x:Name="ManageBtn"
                    Grid.Column="4"
                    VerticalAlignment="Center"
                    Click="Manage_Click"
                    ToolTipService.ToolTip="Providers &amp; Ollama models · 供應商與 Ollama 模型">
                    <FontIcon FontSize="16" Glyph="&#xE9F5;" />
                </Button>
            </Grid>

            <InfoBar
                x:Name="StatusBar"
                Grid.Row="1"
                Margin="16,0,16,4"
                IsClosable="True"
                IsOpen="False" />

            <!-- Messages -->
            <ScrollViewer
                x:Name="MessagesScroll"
                Grid.Row="2"
                Padding="0,4,0,4"
                VerticalScrollBarVisibility="Auto">
                <StackPanel
                    x:Name="MessagesPanel"
                    MaxWidth="820"
                    Margin="16,0,16,0"
                    HorizontalAlignment="Stretch"
                    Spacing="14" />
            </ScrollViewer>

            <!-- Composer -->
            <Grid Grid.Row="3" Padding="16,8,16,16">
                <Border
                    MaxWidth="820"
                    HorizontalAlignment="Stretch"
                    Padding="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                    <Grid ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button
                            x:Name="AttachBtn"
                            Grid.Column="0"
                            VerticalAlignment="Bottom"
                            Click="Attach_Click"
                            ToolTipService.ToolTip="Attach a text file · 附加文字檔">
                            <FontIcon FontSize="16" Glyph="&#xE723;" />
                        </Button>
                        <TextBox
                            x:Name="InputBox"
                            Grid.Column="1"
                            MaxHeight="160"
                            AcceptsReturn="True"
                            BorderThickness="0"
                            Background="Transparent"
                            TextWrapping="Wrap"
                            VerticalAlignment="Center"
                            PlaceholderText="Message… (Enter to send, Shift+Enter for newline) · 輸入訊息…"
                            KeyDown="Input_KeyDown" />
                        <Button
                            x:Name="SendBtn"
                            Grid.Column="2"
                            VerticalAlignment="Bottom"
                            Style="{ThemeResource AccentButtonStyle}"
                            Click="Send_Click">
                            <FontIcon FontSize="16" Glyph="&#xE724;" />
                        </Button>
                        <Button
                            x:Name="StopBtn"
                            Grid.Column="2"
                            VerticalAlignment="Bottom"
                            Visibility="Collapsed"
                            Click="Stop_Click">
                            <FontIcon FontSize="16" Glyph="&#xE71A;" />
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
