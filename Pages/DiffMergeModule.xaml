<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.DiffMergeModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,0" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="6">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="22" Glyph="&#xE1AD;" VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
        </StackPanel>

        <Pivot x:Name="RootPivot" Grid.Row="1">
            <!-- ============================ TEXT DIFF ============================ -->
            <PivotItem x:Name="TextPivot">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- File pickers -->
                    <Grid Grid.Row="0" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="LeftPathBox" Grid.Column="0" IsReadOnly="True" Header="Left file · 左邊檔案" PlaceholderText="—" />
                            <Button x:Name="PickLeftBtn" Grid.Column="1" Click="PickLeft_Click" VerticalAlignment="Bottom">
                                <FontIcon FontSize="14" Glyph="&#xE8E5;" />
                            </Button>
                        </Grid>
                        <Button x:Name="SwapBtn" Grid.Column="1" Click="Swap_Click" VerticalAlignment="Bottom" ToolTipService.ToolTip="Swap sides · 互換左右">
                            <FontIcon FontSize="14" Glyph="&#xE8AB;" />
                        </Button>
                        <Grid Grid.Column="2" ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="RightPathBox" Grid.Column="0" IsReadOnly="True" Header="Right file · 右邊檔案" PlaceholderText="—" />
                            <Button x:Name="PickRightBtn" Grid.Column="1" Click="PickRight_Click" VerticalAlignment="Bottom">
                                <FontIcon FontSize="14" Glyph="&#xE8E5;" />
                            </Button>
                        </Grid>
                    </Grid>

                    <!-- Toolbar -->
                    <Grid Grid.Row="1" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="RecomputeBtn" Grid.Column="0" Click="Recompute_Click" Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="14" Glyph="&#xE72C;" />
                                <TextBlock x:Name="RecomputeLbl" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="PrevDiffBtn" Grid.Column="1" Click="PrevDiff_Click" ToolTipService.ToolTip="Previous difference · 上一處差異">
                            <FontIcon FontSize="14" Glyph="&#xE74A;" />
                        </Button>
                        <Button x:Name="NextDiffBtn" Grid.Column="2" Click="NextDiff_Click" ToolTipService.ToolTip="Next difference · 下一處差異">
                            <FontIcon FontSize="14" Glyph="&#xE74B;" />
                        </Button>
                        <CheckBox x:Name="IgnoreWsChk" Grid.Column="3" Click="IgnoreWs_Click" VerticalAlignment="Center" />
                        <TextBlock x:Name="DiffSummary" Grid.Column="4" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <Button x:Name="SaveLeftBtn" Grid.Column="5" Click="SaveLeft_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="14" Glyph="&#xE74E;" />
                                <TextBlock x:Name="SaveLeftLbl" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="SaveRightBtn" Grid.Column="6" Click="SaveRight_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="14" Glyph="&#xE74E;" />
                                <TextBlock x:Name="SaveRightLbl" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Side-by-side diff -->
                    <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <!-- Column header row -->
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Padding="10,6,10,6" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" ColumnSpacing="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="LeftColHdr" Grid.Column="0" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="RightColHdr" Grid.Column="2" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis" />
                            </Grid>

                            <ListView x:Name="DiffList" Grid.Row="1"
                                      SelectionMode="Single"
                                      ScrollViewer.HorizontalScrollMode="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="MinHeight" Value="0" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                            </ListView>

                            <StackPanel x:Name="TextEmpty" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                                <FontIcon FontSize="40" Glyph="&#xE1AD;" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock x:Name="TextEmptyLbl" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <InfoBar x:Name="TextInfo" Grid.Row="3" IsClosable="True" IsOpen="False" Margin="0,0,0,12" />
                </Grid>
            </PivotItem>

            <!-- ============================ FOLDER COMPARE ============================ -->
            <PivotItem x:Name="FolderPivot">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Folder pickers -->
                    <Grid Grid.Row="0" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="LeftDirBox" Grid.Column="0" IsReadOnly="True" Header="Left folder · 左邊資料夾" PlaceholderText="—" />
                            <Button x:Name="PickLeftDirBtn" Grid.Column="1" Click="PickLeftDir_Click" VerticalAlignment="Bottom">
                                <FontIcon FontSize="14" Glyph="&#xE8B7;" />
                            </Button>
                        </Grid>
                        <Button x:Name="SwapDirBtn" Grid.Column="1" Click="SwapDir_Click" VerticalAlignment="Bottom" ToolTipService.ToolTip="Swap sides · 互換左右">
                            <FontIcon FontSize="14" Glyph="&#xE8AB;" />
                        </Button>
                        <Grid Grid.Column="2" ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="RightDirBox" Grid.Column="0" IsReadOnly="True" Header="Right folder · 右邊資料夾" PlaceholderText="—" />
                            <Button x:Name="PickRightDirBtn" Grid.Column="1" Click="PickRightDir_Click" VerticalAlignment="Bottom">
                                <FontIcon FontSize="14" Glyph="&#xE8B7;" />
                            </Button>
                        </Grid>
                    </Grid>

                    <!-- Toolbar -->
                    <Grid Grid.Row="1" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="CompareDirBtn" Grid.Column="0" Click="CompareDir_Click" Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="14" Glyph="&#xE72C;" />
                                <TextBlock x:Name="CompareDirLbl" />
                            </StackPanel>
                        </Button>
                        <ComboBox x:Name="DirFilterBox" Grid.Column="1" SelectionChanged="DirFilter_Changed" MinWidth="150" />
                        <ProgressRing x:Name="DirBusy" Grid.Column="2" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
                        <TextBlock x:Name="DirSummary" Grid.Column="3" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" TextTrimming="CharacterEllipsis" />
                    </Grid>

                    <!-- Folder grid -->
                    <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Padding="12,6,12,6" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="220" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="110" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="ColName" Grid.Column="0" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock x:Name="ColStatus" Grid.Column="1" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock x:Name="ColLeftSize" Grid.Column="2" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock x:Name="ColRightSize" Grid.Column="3" FontWeight="SemiBold" FontSize="12" />
                            </Grid>

                            <ListView x:Name="FolderList" Grid.Row="1" SelectionMode="Single"
                                      DoubleTapped="FolderList_DoubleTapped"
                                      ScrollViewer.HorizontalScrollMode="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="12,6,12,6" />
                                        <Setter Property="MinHeight" Value="0" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" MinWidth="220" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="110" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <FontIcon FontSize="14" Glyph="{Binding Glyph}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Text="{Binding Display}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding Display}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding StatusText}" Foreground="{Binding StatusBrush}" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding LeftSizeText}" FontSize="12" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Grid.Column="3" Text="{Binding RightSizeText}" FontSize="12" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <StackPanel x:Name="FolderEmpty" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                                <FontIcon FontSize="40" Glyph="&#xE8B7;" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock x:Name="FolderEmptyLbl" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <InfoBar x:Name="DirInfo" Grid.Row="3" IsClosable="True" IsOpen="False" Margin="0,0,0,12" />
                </Grid>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
