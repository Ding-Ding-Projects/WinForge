<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.ColorBlindModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE790;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="InputLabel" VerticalAlignment="Center" />
                        <TextBox x:Name="InputBox" MinWidth="180" Text="#4CAF50" />
                        <Button x:Name="ApplyBtn" Click="Apply_Click" />
                        <Button x:Name="RandomBtn" Click="Random_Click" />
                    </StackPanel>

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="R" VerticalAlignment="Center" Width="18" />
                        <Slider x:Name="RSlider" Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="255" ValueChanged="Slider_Changed" VerticalAlignment="Center" />
                        <TextBlock x:Name="RVal" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Width="34" TextAlignment="Right" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="G" VerticalAlignment="Center" Width="18" />
                        <Slider x:Name="GSlider" Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255" ValueChanged="Slider_Changed" VerticalAlignment="Center" />
                        <TextBlock x:Name="GVal" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Width="34" TextAlignment="Right" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="B" VerticalAlignment="Center" Width="18" />
                        <Slider x:Name="BSlider" Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255" ValueChanged="Slider_Changed" VerticalAlignment="Center" />
                        <TextBlock x:Name="BVal" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Width="34" TextAlignment="Right" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border x:Name="BaseSwatch" Width="64" Height="64" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" />
                        <StackPanel Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="BaseTitle" FontWeight="SemiBold" />
                            <TextBlock x:Name="BaseHex" FontFamily="Consolas" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <ItemsControl x:Name="SimList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,10" Padding="14,12,14,12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="56" Height="56" CornerRadius="8" Background="{Binding Brush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" />
                                <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Hex}" FontFamily="Consolas" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <Button Grid.Column="2" Content="{Binding CopyLabel}" Tag="{Binding Hex}" Click="Copy_Click" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock x:Name="ApproxNote" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</Page>
