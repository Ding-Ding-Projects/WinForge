<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.AppLauncherModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1160" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8A7;" />

            <TextBlock
                x:Name="HeaderBlurb"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />

            <Border
                Padding="14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid ColumnSpacing="10" RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <AutoSuggestBox
                        x:Name="SearchBox"
                        Grid.Row="0"
                        Grid.Column="0"
                        QueryIcon="Find"
                        TextChanged="SearchBox_TextChanged"
                        QuerySubmitted="SearchBox_QuerySubmitted"
                        automation:AutomationProperties.Name="Search launchable native apps · 搜尋可啟動嘅原生 app" />

                    <ComboBox
                        x:Name="CategoryBox"
                        Grid.Row="0"
                        Grid.Column="1"
                        MinWidth="230"
                        SelectionChanged="CategoryBox_Changed"
                        automation:AutomationProperties.Name="Filter app category · 篩選 app 分類" />

                    <Button
                        x:Name="ClearBtn"
                        Grid.Row="0"
                        Grid.Column="2"
                        Click="Clear_Click"
                        automation:AutomationProperties.Name="Clear filters · 清除篩選">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="14" Glyph="&#xE894;" />
                            <TextBlock x:Name="ClearLabel" />
                        </StackPanel>
                    </Button>

                    <TextBlock
                        x:Name="SummaryText"
                        Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />
                </Grid>
            </Border>

            <StackPanel x:Name="AppsPanel" Spacing="8" />
        </StackPanel>
    </ScrollViewer>
</Page>
