<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.BoxTextModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8A5;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="InputLabel" FontWeight="SemiBold" />
                        <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="120" TextChanged="Input_Changed"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    </StackPanel>

                    <Grid ColumnSpacing="16" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                            <TextBlock x:Name="StyleLabel" />
                            <ComboBox x:Name="StyleBox" HorizontalAlignment="Stretch" SelectionChanged="Options_Changed" />
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                            <TextBlock x:Name="AlignLabel" />
                            <ComboBox x:Name="AlignBox" HorizontalAlignment="Stretch" SelectionChanged="Options_Changed" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                            <TextBlock x:Name="PaddingLabel" />
                            <NumberBox x:Name="PaddingBox" Value="1" Minimum="0" Maximum="40"
                                       SpinButtonPlacementMode="Inline" ValueChanged="Padding_Changed" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                            <TextBlock x:Name="TitleLabel" />
                            <TextBox x:Name="TitleBox" TextChanged="Input_Changed" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="CopyBtn" Click="Copy_Click" />
                    </StackPanel>

                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="OutputLabel" FontWeight="SemiBold" />
                    <TextBox x:Name="OutputBox" IsReadOnly="True" AcceptsReturn="True"
                             FontFamily="Consolas" TextWrapping="NoWrap" MinHeight="180"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
