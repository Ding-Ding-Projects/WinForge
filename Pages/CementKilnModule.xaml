<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.CementKilnModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE945;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Reactor-power empty-state -->
            <InfoBar x:Name="NeedPowerBar" IsOpen="False" IsClosable="False" Severity="Warning" />

            <!-- Live available reactor output -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ReactorTitle" Grid.Column="0" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                        <TextBlock x:Name="OutputValue" Grid.Column="1" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                    </Grid>
                    <ProgressBar x:Name="OutputBar" Minimum="0" Maximum="1150" Value="0" Height="8" />
                    <TextBlock x:Name="ReactorModeText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Kiln controls -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="KilnTitle" FontWeight="SemiBold" FontSize="15" />
                            <TextBlock x:Name="KilnStatus" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button x:Name="FireButton" Click="Fire_Click" Style="{ThemeResource AccentButtonStyle}" />
                            <Button x:Name="ResetButton" Click="Reset_Click" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="PowerLabel" Grid.Column="0" FontSize="13" />
                            <TextBlock x:Name="PowerValue" Grid.Column="1" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </Grid>
                        <Slider x:Name="PowerSlider" Minimum="0" Maximum="400" Value="240" StepFrequency="10" ValueChanged="Power_ValueChanged" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Kiln telemetry -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="TelemetryTitle" FontWeight="SemiBold" FontSize="15" />

                    <!-- Kiln temperature -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TempCaption" Grid.Column="0" VerticalAlignment="Center" />
                        <TextBlock x:Name="TempValue" Grid.Column="1" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Grid>
                    <ProgressBar x:Name="TempBar" Minimum="0" Maximum="1450" Value="0" Height="8" />

                    <Grid ColumnSpacing="12" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="1">
                            <TextBlock x:Name="DrawCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="DrawValue" FontWeight="SemiBold" FontSize="16" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="1">
                            <TextBlock x:Name="RateCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="RateValue" FontWeight="SemiBold" FontSize="16" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="1">
                            <TextBlock x:Name="TotalCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="TotalValue" FontWeight="SemiBold" FontSize="16" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="1">
                            <TextBlock x:Name="Co2Caption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="Co2Value" FontWeight="SemiBold" FontSize="16" />
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="KilnNote" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Reactor-Bank economy: cement sales -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="EconTitle" Grid.Column="0" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                        <TextBlock x:Name="EconBalance" Grid.Column="1" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                    </Grid>
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1">
                            <TextBlock x:Name="SalesCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="SalesValue" FontWeight="SemiBold" FontSize="16" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="1">
                            <TextBlock x:Name="PriceCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="PriceValue" FontWeight="SemiBold" FontSize="16" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
