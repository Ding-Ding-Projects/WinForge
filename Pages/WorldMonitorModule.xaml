<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.WorldMonitorModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="12,10,12,12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10">
            <FontIcon FontSize="20" Glyph="&#xE909;" VerticalAlignment="Center" />
            <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Native toolbar -->
        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Variant picker -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock x:Name="VariantLbl" VerticalAlignment="Center" FontWeight="SemiBold" />
                <ComboBox x:Name="VariantBox" MinWidth="180" SelectionChanged="VariantBox_SelectionChanged" />
            </StackPanel>

            <!-- Navigation buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <Button x:Name="BackBtn" Click="Back_Click" ToolTipService.ToolTip="Back · 返回">
                    <FontIcon FontSize="14" Glyph="&#xE72B;" />
                </Button>
                <Button x:Name="FwdBtn" Click="Fwd_Click" ToolTipService.ToolTip="Forward · 前進">
                    <FontIcon FontSize="14" Glyph="&#xE72A;" />
                </Button>
                <Button x:Name="HomeBtn" Click="Home_Click" ToolTipService.ToolTip="Home · 主頁">
                    <FontIcon FontSize="14" Glyph="&#xE80F;" />
                </Button>
                <Button x:Name="ReloadBtn" Click="Reload_Click" ToolTipService.ToolTip="Reload · 重新載入">
                    <FontIcon FontSize="14" Glyph="&#xE72C;" />
                </Button>
                <ProgressRing x:Name="LoadRing" IsActive="False" Width="18" Height="18" VerticalAlignment="Center" Margin="4,0,0,0" />
            </StackPanel>

            <!-- Zoom + open + advanced -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <Button x:Name="ZoomOutBtn" Click="ZoomOut_Click" ToolTipService.ToolTip="Zoom out · 縮細">
                    <FontIcon FontSize="14" Glyph="&#xE71F;" />
                </Button>
                <TextBlock x:Name="ZoomLbl" VerticalAlignment="Center" MinWidth="48" TextAlignment="Center" FontFamily="Consolas" />
                <Button x:Name="ZoomInBtn" Click="ZoomIn_Click" ToolTipService.ToolTip="Zoom in · 放大">
                    <FontIcon FontSize="14" Glyph="&#xE8A3;" />
                </Button>
                <Button x:Name="CopyUrlBtn" Click="CopyUrl_Click" Margin="6,0,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE774;" />
                        <TextBlock x:Name="CopyUrlTxt" />
                    </StackPanel>
                </Button>
                <Button x:Name="AdvBtn" Click="Adv_Click" ToolTipService.ToolTip="Advanced · 進階">
                    <FontIcon FontSize="14" Glyph="&#xE713;" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Current URL display -->
        <TextBlock Grid.Row="2" x:Name="UrlText" FontFamily="Consolas" FontSize="12"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />

        <!-- WebView2 host -->
        <Border Grid.Row="3" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid>
                <controls:WebView2 x:Name="Web"
                                   NavigationStarting="Web_NavigationStarting"
                                   NavigationCompleted="Web_NavigationCompleted"
                                   CoreWebView2Initialized="Web_CoreWebView2Initialized" />

                <!-- Error / offline overlay -->
                <Grid x:Name="ErrorPanel" Visibility="Collapsed" Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <StackPanel MaxWidth="460" Spacing="14" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <InfoBar x:Name="ErrorBar" Severity="Error" IsClosable="False" IsOpen="True" />
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <Button x:Name="RetryBtn" Click="Retry_Click" Style="{StaticResource AccentButtonStyle}" />
                            <Button x:Name="ErrCopyUrlBtn" Click="CopyUrl_Click" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- WebView2 runtime missing overlay -->
                <Grid x:Name="RuntimePanel" Visibility="Collapsed" Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <StackPanel MaxWidth="460" Spacing="14" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <InfoBar x:Name="RuntimeBar" Severity="Warning" IsClosable="False" IsOpen="True" />
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <Button x:Name="CopyRuntimeBtn" Click="CopyRuntimeUrl_Click" Style="{StaticResource AccentButtonStyle}" />
                            <Button x:Name="RtCopyUrlBtn" Click="CopyUrl_Click" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- AGPL / info footnote -->
        <TextBlock Grid.Row="4" x:Name="FootNote" FontSize="11" TextWrapping="Wrap"
                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
    </Grid>
</Page>
