<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.HttpHeaderRefModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4" MaxWidth="1000" HorizontalAlignment="Left">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xEB41;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox" Grid.Column="0" TextChanged="Filter_Changed" />
            <ComboBox x:Name="CategoryBox" Grid.Column="1" MinWidth="170" SelectionChanged="Filter_Changed" />
            <ComboBox x:Name="DirectionBox" Grid.Column="2" MinWidth="150" SelectionChanged="Filter_Changed" />
        </Grid>

        <TextBlock x:Name="CountText" Grid.Row="2" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

        <ListView x:Name="HeaderList"
                  Grid.Row="3"
                  SelectionMode="Single"
                  IsItemClickEnabled="True"
                  ItemClick="Header_Click"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                  BorderThickness="1"
                  CornerRadius="8">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Spacing="3" Padding="4,8,4,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                            <Border Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="4" Padding="6,1,6,1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DirectionText}" FontSize="11" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                            </Border>
                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="4" Padding="6,1,6,1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CategoryText}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13" />
                        <TextBlock Text="{Binding ExampleText}" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock x:Name="StatusText" Grid.Row="4" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
    </Grid>
</Page>
