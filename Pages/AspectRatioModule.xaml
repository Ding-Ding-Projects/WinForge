<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.AspectRatioModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE799;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Simplify -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="SimplifyTitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="WidthLabel" VerticalAlignment="Center" MinWidth="70" />
                        <NumberBox x:Name="WidthBox" Value="1920" Minimum="0" Maximum="100000" SpinButtonPlacementMode="Inline" MinWidth="150" ValueChanged="Simplify_Changed" />
                        <TextBlock x:Name="HeightLabel" VerticalAlignment="Center" MinWidth="70" />
                        <NumberBox x:Name="HeightBox" Value="1080" Minimum="0" Maximum="100000" SpinButtonPlacementMode="Inline" MinWidth="150" ValueChanged="Simplify_Changed" />
                    </StackPanel>
                    <TextBlock x:Name="RatioText" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock x:Name="DetailText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <Button x:Name="CopyBtn" Click="Copy_Click" />
                </StackPanel>
            </Border>

            <!-- Preset -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="PresetTitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="PresetLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="PresetCombo" MinWidth="160" SelectionChanged="Preset_Changed" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Scale (locked ratio) -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="ScaleTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="ScaleBlurb" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="TargetWidthLabel" VerticalAlignment="Center" MinWidth="120" />
                        <NumberBox x:Name="TargetWidthBox" Value="1280" Minimum="0" Maximum="100000" SpinButtonPlacementMode="Inline" MinWidth="150" ValueChanged="TargetWidth_Changed" />
                        <TextBlock x:Name="ScaledHeightText" VerticalAlignment="Center" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="TargetHeightLabel" VerticalAlignment="Center" MinWidth="120" />
                        <NumberBox x:Name="TargetHeightBox" Value="720" Minimum="0" Maximum="100000" SpinButtonPlacementMode="Inline" MinWidth="150" ValueChanged="TargetHeight_Changed" />
                        <TextBlock x:Name="ScaledWidthText" VerticalAlignment="Center" FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</Page>
