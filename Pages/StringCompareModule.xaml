<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.StringCompareModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8A5;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="LabelA" FontWeight="SemiBold" FontSize="13" />
                        <TextBox x:Name="InputA" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="72" TextChanged="Input_Changed" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="LabelB" FontWeight="SemiBold" FontSize="13" />
                        <TextBox x:Name="InputB" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="72" TextChanged="Input_Changed" />
                    </StackPanel>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ToggleSwitch x:Name="CaseSwitch" Grid.Column="0" Toggled="Option_Changed" />
                        <ToggleSwitch x:Name="WhitespaceSwitch" Grid.Column="1" Toggled="Option_Changed" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="MetricsTitle" Grid.Column="0" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                        <Button x:Name="CopyButton" Grid.Column="1" Click="Copy_Click" />
                    </Grid>

                    <ItemsControl x:Name="MetricsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="0,3,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="SemiBold" FontFamily="Consolas" VerticalAlignment="Center" Margin="12,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
