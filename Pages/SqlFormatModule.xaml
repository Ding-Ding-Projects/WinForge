<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.SqlFormatModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="880" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE943;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock x:Name="UpperTitle" VerticalAlignment="Center" />
                            <ToggleSwitch x:Name="UpperSwitch" Toggled="Options_Changed" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock x:Name="IndentLabel" VerticalAlignment="Center" />
                            <NumberBox x:Name="IndentBox" Value="2" Minimum="0" Maximum="16" SpinButtonPlacementMode="Inline" MinWidth="130" ValueChanged="Indent_Changed" />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock x:Name="InputLabel" FontWeight="SemiBold" />
                    <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap" Height="150"
                             FontFamily="Consolas" ScrollViewer.VerticalScrollBarVisibility="Auto"
                             PlaceholderText="select id, name from users where active=1 order by name" />

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="FormatBtn" Click="Format_Click" Style="{ThemeResource AccentButtonStyle}" />
                        <Button x:Name="MinifyBtn" Click="Minify_Click" />
                        <Button x:Name="SampleBtn" Click="Sample_Click" />
                        <Button x:Name="ClearBtn" Click="Clear_Click" />
                        <Button x:Name="CopyBtn" Click="Copy_Click" />
                    </StackPanel>

                    <TextBlock x:Name="OutputLabel" FontWeight="SemiBold" />
                    <TextBox x:Name="OutputBox" AcceptsReturn="True" TextWrapping="NoWrap" IsReadOnly="True" Height="220"
                             FontFamily="Consolas"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" />

                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="FeaturesLabel" FontWeight="SemiBold" />
                    <ListView x:Name="FeaturesList" SelectionMode="None" IsItemClickEnabled="False">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="10" Padding="0,4,0,4">
                                    <FontIcon Glyph="&#xE73E;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
