<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.HostsEditModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE968;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="Status" IsOpen="True" IsClosable="False" Severity="Informational" />

            <!-- Load + presets -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="LoadTitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="LoadBtn" Click="Load_Click" Style="{ThemeResource AccentButtonStyle}" />
                        <Button x:Name="ClearBtn" Click="Clear_Click" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="PresetLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="PresetBox" MinWidth="220" />
                        <Button x:Name="ApplyPresetBtn" Click="ApplyPreset_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Add entry -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="AddTitle" FontWeight="SemiBold" FontSize="15" />
                    <Grid ColumnSpacing="10" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="IpLabel" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" />
                        <TextBox x:Name="IpBox" Grid.Row="0" Grid.Column="1" PlaceholderText="0.0.0.0" />
                        <TextBlock x:Name="HostLabel" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" />
                        <TextBox x:Name="HostBox" Grid.Row="1" Grid.Column="1" PlaceholderText="example.com" />
                        <TextBlock x:Name="CommentLabel" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" />
                        <TextBox x:Name="CommentBox" Grid.Row="2" Grid.Column="1" />
                    </Grid>
                    <Button x:Name="AddBtn" Click="Add_Click" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <!-- Entries list -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="ListTitle" FontWeight="SemiBold" FontSize="15" />
                    <ListView x:Name="EntriesList" MaxHeight="360" SelectionMode="Single"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="10" Padding="4,6,4,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleSwitch Grid.Column="0" IsOn="{Binding Enabled, Mode=TwoWay}" MinWidth="0" OnContent="" OffContent="" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Display}" TextWrapping="Wrap" VerticalAlignment="Center" FontFamily="Consolas" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="RemoveBtn" Click="Remove_Click" />
                        <Button x:Name="RebuildBtn" Click="Rebuild_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Output -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="OutputTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="OutputBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                             FontFamily="Consolas" MinHeight="200" MaxHeight="320"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="CopyBtn" Click="Copy_Click" />
                        <Button x:Name="SaveAsBtn" Click="SaveAs_Click" />
                        <Button x:Name="WriteBackBtn" Click="WriteBack_Click" Style="{ThemeResource AccentButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
