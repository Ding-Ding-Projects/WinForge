<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.ShortcutGuideModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Fixed header / controls -->
        <ScrollViewer Grid.Row="0" Padding="24,16,24,0" VerticalScrollBarVisibility="Disabled" MaxHeight="430">
            <StackPanel MaxWidth="1000" Spacing="14">

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon FontSize="22" Glyph="&#xE765;" VerticalAlignment="Center" />
                    <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
                </StackPanel>
                <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

                <InfoBar x:Name="ResultBar" IsClosable="True" IsOpen="False" />

                <!-- Enable + preview -->
                <Border Padding="16,12,16,12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="EnableTitle" FontWeight="SemiBold" FontSize="15" />
                            <TextBlock x:Name="EnableStatus" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <Button x:Name="PreviewBtn" Grid.Column="1" Click="Preview_Click" VerticalAlignment="Center" />
                        <ToggleSwitch x:Name="EnableSwitch" Grid.Column="2" Toggled="Enable_Toggled" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- Activation + appearance settings -->
                <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                    <StackPanel Spacing="14">
                        <!-- Hold duration -->
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="HoldLabel" Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <Slider x:Name="HoldSlider" Grid.Column="1" Minimum="200" Maximum="2000" StepFrequency="50"
                                    TickFrequency="300" SnapsTo="StepValues" VerticalAlignment="Center" ValueChanged="Hold_Changed" />
                            <TextBlock x:Name="HoldValue" Grid.Column="2" VerticalAlignment="Center" MinWidth="72" TextAlignment="Right" />
                        </Grid>

                        <!-- Opacity -->
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="OpacityLabel" Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <Slider x:Name="OpacitySlider" Grid.Column="1" Minimum="30" Maximum="100" StepFrequency="5"
                                    TickFrequency="10" SnapsTo="StepValues" VerticalAlignment="Center" ValueChanged="Opacity_Changed" />
                            <TextBlock x:Name="OpacityValue" Grid.Column="2" VerticalAlignment="Center" MinWidth="72" TextAlignment="Right" />
                        </Grid>

                        <!-- Theme -->
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ThemeLabel" Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <ComboBox x:Name="ThemeBox" Grid.Column="1" MinWidth="200" SelectionChanged="Theme_Changed" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Reference table header + search -->
                <Grid ColumnSpacing="12" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ReferenceHeader" Grid.Column="0" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center" />
                    <AutoSuggestBox x:Name="SearchBox" Grid.Column="1" MinWidth="300" QueryIcon="Find" TextChanged="Search_TextChanged" />
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Scrollable reference table -->
        <ScrollViewer Grid.Row="1" Padding="24,8,24,24" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="1000">
                <ItemsControl x:Name="ReferenceHost" />
                <TextBlock x:Name="NoResults" Margin="0,20,0,0" HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" TextAlignment="Center" Visibility="Collapsed" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
