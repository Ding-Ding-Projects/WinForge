<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.PasswordStrengthModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE928;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
            <TextBlock x:Name="PrivacyNote" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="EntryLabel" FontWeight="SemiBold" FontSize="15" />
                    <PasswordBox x:Name="Hidden" PasswordChanged="Hidden_Changed" />
                    <TextBox x:Name="Shown" TextChanged="Shown_Changed" Visibility="Collapsed" IsSpellCheckEnabled="False" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="RevealLabel" Grid.Column="0" VerticalAlignment="Center" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ToggleSwitch x:Name="RevealSwitch" Grid.Column="1" Toggled="Reveal_Toggled" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="StrengthTitle" Grid.Column="0" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                        <TextBlock x:Name="StrengthLabel" Grid.Column="1" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                    </Grid>
                    <ProgressBar x:Name="StrengthBar" Minimum="0" Maximum="1" Value="0" Height="8" />
                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <InfoBar x:Name="CommonWarn" IsOpen="False" Severity="Error" IsClosable="False" />

                    <TextBlock x:Name="MetricsHeader" FontWeight="SemiBold" Margin="0,4,0,0" />
                    <TextBlock x:Name="LengthLine" FontFamily="Consolas" FontSize="13" />
                    <TextBlock x:Name="PoolLine" FontFamily="Consolas" FontSize="13" />
                    <TextBlock x:Name="EntropyLine" FontFamily="Consolas" FontSize="13" />
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="CrackHeader" FontWeight="SemiBold" />
                    <TextBlock x:Name="CrackOnline" FontSize="13" TextWrapping="Wrap" />
                    <TextBlock x:Name="CrackGpu" FontSize="13" TextWrapping="Wrap" />
                    <TextBlock x:Name="CrackFast" FontSize="13" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel x:Name="Checklist" Spacing="6">
                    <TextBlock x:Name="ChecklistHeader" FontWeight="SemiBold" Margin="0,0,0,2" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
