<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.ReactorSettingsModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Padding="24,16,24,32" Spacing="16" MaxWidth="900" HorizontalAlignment="Left">

            <!-- header -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="24" Glyph="&#xE713;" VerticalAlignment="Center" />
                <StackPanel>
                    <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </StackPanel>

            <Button x:Name="BackToReactorButton" Click="BackToReactor_Click" />

            <!-- Keep PC awake -->
            <Border CornerRadius="8" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <ToggleSwitch x:Name="KeepAwakeToggle" Toggled="KeepAwake_Toggled" />
                    <TextBlock x:Name="KeepAwakeNote" TextWrapping="Wrap" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Windows-settings linkage -->
            <Border CornerRadius="8" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <ToggleSwitch x:Name="SysLinkToggle" Toggled="SysLink_Toggled" />
                    <TextBlock x:Name="SysLinkWarn" TextWrapping="Wrap" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- ARM real shutdown on meltdown -->
            <Border CornerRadius="8" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="#55FF6E6E" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="ArmTitle" FontWeight="SemiBold" />
                    <ToggleSwitch x:Name="ArmToggle" Toggled="Arm_Toggled" />
                    <TextBlock x:Name="ArmWarn" TextWrapping="Wrap" Foreground="#FFB300" />
                </StackPanel>
            </Border>

            <!-- Public status API -->
            <Border CornerRadius="8" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="ApiTitle" FontWeight="SemiBold" />
                    <TextBlock x:Name="ApiBlurb" TextWrapping="Wrap" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="ApiNames" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"
                               Foreground="#E690CAF9" />
                    <ToggleSwitch x:Name="ApiToggle" Toggled="Api_Toggled" />
                    <TextBlock x:Name="ApiStateText" FontSize="12" FontWeight="SemiBold" />
                </StackPanel>
            </Border>

            <!-- Crash-safe autosave -->
            <Border CornerRadius="8" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <ToggleSwitch x:Name="AutosaveToggle" Toggled="Autosave_Toggled" />
                    <TextBlock x:Name="AutosaveNote" TextWrapping="Wrap" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Home Assistant mirror -->
            <Border CornerRadius="8" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="HaTitle" FontWeight="SemiBold" />
                    <TextBlock x:Name="HaBlurb" TextWrapping="Wrap" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <!-- shown when HA is not configured -->
                    <Border x:Name="HaNotConfigured" Visibility="Collapsed" CornerRadius="6" Padding="12"
                            Background="#22FFB300">
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="HaNotConfiguredText" TextWrapping="Wrap" Foreground="#FFB300" />
                            <Button x:Name="HaOpenModuleButton" Click="HaOpenModule_Click" />
                        </StackPanel>
                    </Border>

                    <!-- shown when HA IS configured -->
                    <StackPanel x:Name="HaConfigured" Spacing="10" Visibility="Collapsed">
                        <ToggleSwitch x:Name="HaMirrorToggle" Toggled="HaMirror_Toggled" />

                        <StackPanel Spacing="4">
                            <TextBlock x:Name="HaAlarmLabel" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="HaAlarmCombo" MinWidth="360" SelectionChanged="HaAlarmCombo_Changed" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock x:Name="HaGenLabel" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="HaGenCombo" MinWidth="360" SelectionChanged="HaGenCombo_Changed" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button x:Name="HaRefreshButton" Click="HaRefresh_Click" />
                            <TextBlock x:Name="HaStatusText" FontSize="12" VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
