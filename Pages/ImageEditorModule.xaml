<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.ImageEditorModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Padding="20,14,20,8" Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="22" Glyph="&#xE7C5;" VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
            <InfoBar x:Name="Toast" IsOpen="False" IsClosable="True" Severity="Success" />
        </StackPanel>

        <!-- Command bar -->
        <Border Grid.Row="1" Padding="20,0,20,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="NewBtn" Click="New_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6"><FontIcon FontSize="14" Glyph="&#xE7C3;" /><TextBlock x:Name="NewBtnText" /></StackPanel>
                </Button>
                <Button x:Name="OpenBtn" Click="Open_Click" Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6"><FontIcon FontSize="14" Glyph="&#xE8E5;" /><TextBlock x:Name="OpenBtnText" /></StackPanel>
                </Button>
                <Button x:Name="SaveBtn" Click="Save_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6"><FontIcon FontSize="14" Glyph="&#xE74E;" /><TextBlock x:Name="SaveBtnText" /></StackPanel>
                </Button>
                <Button x:Name="SaveAsBtn" Click="SaveAs_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6"><FontIcon FontSize="14" Glyph="&#xE792;" /><TextBlock x:Name="SaveAsBtnText" /></StackPanel>
                </Button>
                <AppBarSeparator />
                <Button x:Name="UndoBtn" Click="Undo_Click" IsEnabled="False">
                    <StackPanel Orientation="Horizontal" Spacing="6"><FontIcon FontSize="14" Glyph="&#xE7A7;" /><TextBlock x:Name="UndoBtnText" /></StackPanel>
                </Button>
                <Button x:Name="RedoBtn" Click="Redo_Click" IsEnabled="False">
                    <StackPanel Orientation="Horizontal" Spacing="6"><FontIcon FontSize="14" Glyph="&#xE7A6;" /><TextBlock x:Name="RedoBtnText" /></StackPanel>
                </Button>
                <AppBarSeparator />
                <TextBlock x:Name="ZoomLabel" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Slider x:Name="ZoomSlider" Width="130" Minimum="5" Maximum="800" Value="100" VerticalAlignment="Center" ValueChanged="Zoom_Changed" />
                <Button x:Name="FitBtn" Click="Fit_Click"><TextBlock x:Name="FitBtnText" /></Button>
                <Button x:Name="Zoom100Btn" Click="Zoom100_Click"><TextBlock Text="1:1" /></Button>
                <AppBarSeparator />
                <TextBlock x:Name="DimText" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
            </StackPanel>
        </Border>

        <!-- Main: tools | canvas | side panel -->
        <Grid Grid.Row="2" Padding="20,0,20,16" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <!-- Tool column -->
            <Border Grid.Column="0" Padding="6" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    VerticalAlignment="Top">
                <StackPanel Spacing="10">
                    <StackPanel x:Name="ToolStack" Spacing="6" />
                    <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" />
                    <!-- Active colour -->
                    <Border x:Name="PrimarySwatch" Width="40" Height="40" CornerRadius="6"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            HorizontalAlignment="Center" />
                    <Button x:Name="ColorBtn" Click="Color_Click" Padding="6,2,6,2" HorizontalAlignment="Stretch">
                        <FontIcon FontSize="13" Glyph="&#xE790;" />
                    </Button>
                    <StackPanel Spacing="2">
                        <TextBlock x:Name="BrushSizeLabel" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                        <Slider x:Name="BrushSizeSlider" Minimum="1" Maximum="80" Value="6" Width="56" ValueChanged="BrushSize_Changed" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Canvas host -->
            <Border Grid.Column="1" CornerRadius="8"
                    Background="{ThemeResource LayerFillColorAltBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid>
                    <ScrollViewer x:Name="CanvasScroll" ZoomMode="Disabled"
                                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollMode="Auto" VerticalScrollMode="Auto"
                                  Padding="24">
                        <Grid x:Name="CanvasWrap" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image x:Name="CheckerImage" Stretch="Fill" HorizontalAlignment="Left" VerticalAlignment="Top" />
                            <Image x:Name="CanvasImage" Stretch="Fill"
                                   HorizontalAlignment="Left" VerticalAlignment="Top"
                                   PointerPressed="Canvas_PointerPressed"
                                   PointerMoved="Canvas_PointerMoved"
                                   PointerReleased="Canvas_PointerReleased" />
                            <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False" />
                        </Grid>
                    </ScrollViewer>
                    <Border x:Name="EmptyHint" Background="Transparent" IsHitTestVisible="False"
                            HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <FontIcon FontSize="40" Glyph="&#xE7C5;" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="EmptyHintText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Side panel -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">

                    <!-- Adjustments -->
                    <Expander x:Name="AdjustExpander" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="True">
                        <Expander.Header><TextBlock x:Name="AdjustHeader" FontWeight="SemiBold" /></Expander.Header>
                        <StackPanel Spacing="6" Margin="0,4,0,0">
                            <TextBlock x:Name="BrightLabel" FontSize="12" />
                            <Slider x:Name="BrightSlider" Minimum="-100" Maximum="100" Value="0" ValueChanged="Adjust_Changed" />
                            <TextBlock x:Name="ContrastLabel" FontSize="12" />
                            <Slider x:Name="ContrastSlider" Minimum="-100" Maximum="100" Value="0" ValueChanged="Adjust_Changed" />
                            <TextBlock x:Name="SatLabel" FontSize="12" />
                            <Slider x:Name="SatSlider" Minimum="-100" Maximum="100" Value="0" ValueChanged="Adjust_Changed" />
                            <TextBlock x:Name="HueLabel" FontSize="12" />
                            <Slider x:Name="HueSlider" Minimum="-180" Maximum="180" Value="0" ValueChanged="Adjust_Changed" />
                            <TextBlock x:Name="GammaLabel" FontSize="12" />
                            <Slider x:Name="GammaSlider" Minimum="10" Maximum="300" Value="100" ValueChanged="Adjust_Changed" />
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <Button x:Name="AdjustApplyBtn" Click="AdjustApply_Click" Style="{StaticResource AccentButtonStyle}" />
                                <Button x:Name="AdjustResetBtn" Click="AdjustReset_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <!-- Filters -->
                    <Expander x:Name="FilterExpander" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="True">
                        <Expander.Header><TextBlock x:Name="FilterHeader" FontWeight="SemiBold" /></Expander.Header>
                        <StackPanel Spacing="6" Margin="0,4,0,0">
                            <Grid ColumnSpacing="6" RowSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Button x:Name="FltGrayBtn" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Stretch" Click="FilterGray_Click" />
                                <Button x:Name="FltInvertBtn" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch" Click="FilterInvert_Click" />
                                <Button x:Name="FltSepiaBtn" Grid.Row="1" Grid.Column="0" HorizontalAlignment="Stretch" Click="FilterSepia_Click" />
                                <Button x:Name="FltBlurBtn" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch" Click="FilterBlur_Click" />
                                <Button x:Name="FltSharpBtn" Grid.Row="2" Grid.Column="0" HorizontalAlignment="Stretch" Click="FilterSharpen_Click" />
                                <Button x:Name="FltEdgeBtn" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Stretch" Click="FilterEdge_Click" />
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:Name="BlurAmtLabel" FontSize="11" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Slider x:Name="BlurAmtSlider" Minimum="1" Maximum="20" Value="4" Width="140" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <!-- Transform -->
                    <Expander x:Name="TransformExpander" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="True">
                        <Expander.Header><TextBlock x:Name="TransformHeader" FontWeight="SemiBold" /></Expander.Header>
                        <StackPanel Spacing="8" Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button x:Name="RotCwBtn" Click="RotateCw_Click"><FontIcon FontSize="14" Glyph="&#xE7AD;" /></Button>
                                <Button x:Name="RotCcwBtn" Click="RotateCcw_Click"><FontIcon FontSize="14" Glyph="&#xE7A7;" /></Button>
                                <Button x:Name="FlipHBtn" Click="FlipH_Click"><TextBlock x:Name="FlipHText" /></Button>
                                <Button x:Name="FlipVBtn" Click="FlipV_Click"><TextBlock x:Name="FlipVText" /></Button>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <NumberBox x:Name="RotDegBox" Width="90" Value="0" Minimum="-360" Maximum="360" SpinButtonPlacementMode="Compact" />
                                <Button x:Name="RotArbBtn" Click="RotateArb_Click"><TextBlock x:Name="RotArbText" /></Button>
                            </StackPanel>
                            <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" />
                            <TextBlock x:Name="ResizeLabel" FontWeight="SemiBold" FontSize="12" />
                            <Grid ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <NumberBox x:Name="ResizeWBox" Grid.Column="0" Header="W" Minimum="1" Maximum="16384" SpinButtonPlacementMode="Compact" ValueChanged="ResizeW_Changed" />
                                <NumberBox x:Name="ResizeHBox" Grid.Column="1" Header="H" Minimum="1" Maximum="16384" SpinButtonPlacementMode="Compact" ValueChanged="ResizeH_Changed" />
                            </Grid>
                            <CheckBox x:Name="AspectLockChk" IsChecked="True" />
                            <Button x:Name="ResizeApplyBtn" Click="ResizeApply_Click" HorizontalAlignment="Stretch" />
                            <TextBlock x:Name="CropHint" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                            <Button x:Name="CropApplyBtn" Click="CropApply_Click" HorizontalAlignment="Stretch" IsEnabled="False" />
                        </StackPanel>
                    </Expander>

                    <!-- Layers -->
                    <Expander x:Name="LayersExpander" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="True">
                        <Expander.Header><TextBlock x:Name="LayersHeader" FontWeight="SemiBold" /></Expander.Header>
                        <StackPanel Spacing="8" Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="2" HorizontalAlignment="Right">
                                <Button x:Name="LayerAddBtn" Click="LayerAdd_Click" Padding="6,2,6,2"><FontIcon FontSize="12" Glyph="&#xE710;" /></Button>
                                <Button x:Name="LayerUpBtn" Click="LayerUp_Click" Padding="6,2,6,2"><FontIcon FontSize="12" Glyph="&#xE70E;" /></Button>
                                <Button x:Name="LayerDownBtn" Click="LayerDown_Click" Padding="6,2,6,2"><FontIcon FontSize="12" Glyph="&#xE70D;" /></Button>
                                <Button x:Name="LayerDelBtn" Click="LayerDel_Click" Padding="6,2,6,2"><FontIcon FontSize="12" Glyph="&#xE74D;" /></Button>
                                <Button x:Name="LayerFlatBtn" Click="LayerFlatten_Click" Padding="6,2,6,2"><FontIcon FontSize="12" Glyph="&#xE8B3;" /></Button>
                            </StackPanel>
                            <ListView x:Name="LayersList" SelectionMode="Single" MaxHeight="200"
                                      SelectionChanged="Layers_SelectionChanged" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock x:Name="OpacityLabel" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Slider x:Name="OpacitySlider" Width="150" Minimum="0" Maximum="100" Value="100"
                                        ValueChanged="Opacity_Changed" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
