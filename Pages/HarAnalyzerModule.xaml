<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.HarAnalyzerModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="980" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xEB41;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="Status" IsOpen="False" IsClosable="False" />

            <!-- Input card -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="InputTitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="OpenBtn" Click="Open_Click" Style="{ThemeResource AccentButtonStyle}" />
                        <Button x:Name="AnalyzePasteBtn" Click="AnalyzePaste_Click" />
                        <Button x:Name="ClearBtn" Click="Clear_Click" />
                    </StackPanel>
                    <TextBox x:Name="PasteBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="90" MaxHeight="180"
                             FontFamily="Consolas" IsSpellCheckEnabled="False"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>

            <!-- Summary card -->
            <Border x:Name="SummaryCard" Visibility="Collapsed" Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="SummaryTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="SummaryLine" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="StatusBreakdown" TextWrapping="Wrap" />
                    <TextBlock x:Name="TypeBreakdown" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="HighlightLine" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Filter + sort row -->
            <Grid x:Name="ToolsRow" Visibility="Collapsed" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FilterBox" Grid.Column="0" VerticalAlignment="Center" TextChanged="Filter_Changed" />
                <ToggleSwitch x:Name="ErrorsToggle" Grid.Column="1" VerticalAlignment="Center" Toggled="Filter_Changed" />
                <ComboBox x:Name="SortBox" Grid.Column="2" VerticalAlignment="Center" MinWidth="150" SelectionChanged="Sort_Changed" />
                <Button x:Name="CopyBtn" Grid.Column="3" Click="Copy_Click" VerticalAlignment="Center" />
            </Grid>

            <!-- Entries list -->
            <Border x:Name="ListCard" Visibility="Collapsed" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <Grid Padding="12,10,12,8" ColumnSpacing="8" Background="{ThemeResource LayerFillColorDefaultBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="86" />
                            <ColumnDefinition Width="86" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ColMethod" Grid.Column="0" FontWeight="SemiBold" FontSize="12" />
                        <TextBlock x:Name="ColStatus" Grid.Column="1" FontWeight="SemiBold" FontSize="12" />
                        <TextBlock x:Name="ColUrl" Grid.Column="2" FontWeight="SemiBold" FontSize="12" />
                        <TextBlock x:Name="ColMime" Grid.Column="3" FontWeight="SemiBold" FontSize="12" />
                        <TextBlock x:Name="ColSize" Grid.Column="4" FontWeight="SemiBold" FontSize="12" TextAlignment="Right" />
                        <TextBlock x:Name="ColTime" Grid.Column="5" FontWeight="SemiBold" FontSize="12" TextAlignment="Right" />
                    </Grid>
                    <ListView x:Name="EntriesList" SelectionMode="None" MaxHeight="460"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="12,6,12,6" />
                                <Setter Property="MinHeight" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="86" />
                                        <ColumnDefinition Width="86" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Method}" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding StatusDisplay}" Foreground="{Binding StatusBrush}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding Url}" TextTrimming="CharacterEllipsis" FontSize="12" VerticalAlignment="Center" ToolTipService.ToolTip="{Binding Url}" />
                                    <TextBlock Grid.Column="3" Text="{Binding MimeDisplay}" TextTrimming="CharacterEllipsis" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="4" Text="{Binding SizeDisplay}" FontSize="12" TextAlignment="Right" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="5" Text="{Binding TimeDisplay}" FontSize="12" TextAlignment="Right" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
