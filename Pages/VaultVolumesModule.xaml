<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.VaultVolumesModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,16" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
            <FontIcon FontSize="22" Glyph="&#xE72E;" VerticalAlignment="Center" />
            <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
        </StackPanel>
        <TextBlock x:Name="HeaderBlurb" Grid.Row="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

        <!-- Engine status / install bar -->
        <InfoBar x:Name="EngineBar" Grid.Row="2" IsClosable="False" IsOpen="False">
            <StackPanel x:Name="EngineActionHost" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8" />
        </InfoBar>

        <!-- Top toolbar with the two wizard cards in expanders -->
        <StackPanel Grid.Row="3" Spacing="10">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="RefreshBtn" Click="Refresh_Click" />
                <Button x:Name="ChangePwdBtn" Click="ChangePwd_Click" />
                <Button x:Name="BenchmarkBtn" Click="Benchmark_Click" />
                <Button x:Name="WipeCacheBtn" Click="WipeCache_Click" />
                <Button x:Name="DismountAllBtn" Click="DismountAll_Click" />
            </StackPanel>

            <!-- Create container wizard -->
            <Expander x:Name="CreateExpander" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <TextBlock x:Name="CreateHeader" FontWeight="SemiBold" />
                </Expander.Header>
                <Grid ColumnSpacing="12" RowSpacing="10" Margin="0,4,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Grid.ColumnSpan="2" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="CreatePathBox" Grid.Column="0" IsReadOnly="True" />
                        <Button x:Name="CreatePathBtn" Grid.Column="1" Click="PickCreatePath_Click" />
                    </Grid>

                    <NumberBox x:Name="CreateSizeBox" Grid.Row="1" Grid.Column="0" Value="256" Minimum="1" Maximum="1048576" SpinButtonPlacementMode="Inline" />
                    <ComboBox x:Name="CreateSizeUnit" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch" SelectedIndex="1" />

                    <ComboBox x:Name="CreateAlgoBox" Grid.Row="2" Grid.Column="0" HorizontalAlignment="Stretch" />
                    <ComboBox x:Name="CreateHashBox" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Stretch" />

                    <ComboBox x:Name="CreateFsBox" Grid.Row="3" Grid.Column="0" HorizontalAlignment="Stretch" />
                    <NumberBox x:Name="CreatePimBox" Grid.Row="3" Grid.Column="1" Value="0" Minimum="0" Maximum="2147483" SpinButtonPlacementMode="Inline" />

                    <Grid Grid.Row="4" Grid.Column="0" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="CreateKeyfileBox" Grid.Column="0" IsReadOnly="True" />
                        <Button x:Name="CreateKeyfileBtn" Grid.Column="1" Click="PickCreateKeyfile_Click" />
                    </Grid>
                    <PasswordBox x:Name="CreatePwdBox" Grid.Row="4" Grid.Column="1" />

                    <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <CheckBox x:Name="CreateDynamicChk" />
                        <CheckBox x:Name="CreateQuickChk" />
                        <Button x:Name="CreateBtn" Click="Create_Click" Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Expander>

            <!-- Mount wizard -->
            <Expander x:Name="MountExpander" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <TextBlock x:Name="MountHeader" FontWeight="SemiBold" />
                </Expander.Header>
                <Grid ColumnSpacing="12" RowSpacing="10" Margin="0,4,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Grid.ColumnSpan="2" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="MountPathBox" Grid.Column="0" IsReadOnly="True" />
                        <Button x:Name="MountPathBtn" Grid.Column="1" Click="PickMountPath_Click" />
                    </Grid>

                    <ComboBox x:Name="MountLetterBox" Grid.Row="1" Grid.Column="0" HorizontalAlignment="Stretch" />
                    <NumberBox x:Name="MountPimBox" Grid.Row="1" Grid.Column="1" Value="0" Minimum="0" Maximum="2147483" SpinButtonPlacementMode="Inline" />

                    <Grid Grid.Row="2" Grid.Column="0" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="MountKeyfileBox" Grid.Column="0" IsReadOnly="True" />
                        <Button x:Name="MountKeyfileBtn" Grid.Column="1" Click="PickKeyfile_Click" />
                    </Grid>
                    <PasswordBox x:Name="MountPwdBox" Grid.Row="2" Grid.Column="1" />

                    <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <CheckBox x:Name="MountReadOnlyChk" />
                        <CheckBox x:Name="MountRemovableChk" />
                        <CheckBox x:Name="MountExploreChk" IsChecked="True" />
                        <Button x:Name="MountBtn" Click="Mount_Click" Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Expander>

            <TextBlock x:Name="MountedHeader" FontWeight="SemiBold" Margin="0,4,0,0" />
        </StackPanel>

        <Border
            Grid.Row="4"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid>
                <TextBlock x:Name="EmptyHint" Margin="16" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" />
                <ListView x:Name="List" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="10,8,10,8" ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE72E;" FontSize="20" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TitleText}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding SubText}" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </StackPanel>
                                <Button Grid.Column="2" Tag="{Binding Letter}" Click="Explore_Click" ToolTipService.ToolTip="Explore · 瀏覽">
                                    <FontIcon Glyph="&#xE838;" FontSize="14" />
                                </Button>
                                <Button Grid.Column="3" Tag="{Binding Letter}" Click="Dismount_Click" ToolTipService.ToolTip="Dismount · 卸載">
                                    <FontIcon Glyph="&#xE8BB;" FontSize="14" />
                                </Button>
                                <Button Grid.Column="4" Tag="{Binding Letter}" Click="ForceDismount_Click" ToolTipService.ToolTip="Force dismount · 強制卸載">
                                    <FontIcon Glyph="&#xE7BA;" FontSize="14" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <InfoBar x:Name="ResultBar" Grid.Row="5" IsClosable="True" IsOpen="False" />
    </Grid>
</Page>
