<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.ReactorBankModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WinForge.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE1D6;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Balance card -->
            <Border Padding="20,18,20,18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="10">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="BalanceCaption" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="&#x26A1;" FontSize="34" VerticalAlignment="Center" />
                        <TextBlock x:Name="BalanceText" FontSize="40" FontWeight="Bold" VerticalAlignment="Center" />
                        <TextBlock x:Name="BalanceUnit" FontSize="18" VerticalAlignment="Bottom" Margin="0,0,0,8" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <TextBlock x:Name="MintRateText" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="ReactorMeterCaption" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <ProgressBar x:Name="ReactorMeter" Minimum="0" Maximum="1150" Value="0" Height="8" />
                    <InfoBar x:Name="OfflineBar" IsClosable="False" IsOpen="False" Severity="Warning" />
                </StackPanel>
            </Border>

            <!-- Store: features that REQUIRE Watts -->
            <TextBlock x:Name="StoreTitle" FontWeight="SemiBold" FontSize="16" Margin="2,4,0,0" />
            <TextBlock x:Name="StoreBlurb" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
            <StackPanel x:Name="StoreHost" Spacing="10" />

            <!-- Ledger -->
            <TextBlock x:Name="LedgerTitle" FontWeight="SemiBold" FontSize="16" Margin="2,8,0,0" />
            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" MinHeight="120">
                <Grid>
                    <ListView x:Name="LedgerList" SelectionMode="None" MaxHeight="320">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="8,6,8,6" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding When}" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    <TextBlock Grid.Column="1" Text="{Binding Reason}" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{Binding AmountText}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock x:Name="LedgerEmpty" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Visibility="Collapsed" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="500" />
                </Grid>
            </Border>

            <TextBlock x:Name="FooterNote" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</Page>
