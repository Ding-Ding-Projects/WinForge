<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.ImgBase64Module"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8B9;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="EncodeTitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="PickButton" Click="Pick_Click" />
                        <Button x:Name="CopyUriButton" Click="CopyUri_Click" IsEnabled="False" />
                    </StackPanel>
                    <TextBlock x:Name="EncodeStats" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <TextBox x:Name="UriBox" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" Height="120" />
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="DecodeTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="InputBox" TextWrapping="Wrap" AcceptsReturn="True" Height="110" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="DecodeButton" Click="Decode_Click" />
                        <Button x:Name="SaveButton" Click="Save_Click" IsEnabled="False" />
                    </StackPanel>
                    <TextBlock x:Name="DecodeStats" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="PreviewTitle" FontWeight="SemiBold" FontSize="15" />
                    <Image x:Name="Preview" Stretch="Uniform" MaxHeight="320" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
