<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.LoremImgModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE91B;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="Info" IsOpen="False" IsClosable="True" />

            <!-- Inputs -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="InputsTitle" FontWeight="SemiBold" FontSize="15" />

                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="WidthLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <NumberBox x:Name="WidthBox" Value="640" Minimum="1" Maximum="10000" SpinButtonPlacementMode="Inline" MinWidth="150" ValueChanged="Input_Changed" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="HeightLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <NumberBox x:Name="HeightBox" Value="480" Minimum="1" Maximum="10000" SpinButtonPlacementMode="Inline" MinWidth="150" ValueChanged="Input_Changed" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="FontLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <NumberBox x:Name="FontBox" Value="0" Minimum="0" Maximum="2000" SpinButtonPlacementMode="Inline" MinWidth="150" ValueChanged="Input_Changed" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="BgLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBox x:Name="BgBox" Text="#DDDDDD" MinWidth="150" TextChanged="Input_Changed" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="FgLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBox x:Name="FgBox" Text="#555555" MinWidth="150" TextChanged="Input_Changed" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="LabelLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBox x:Name="LabelBox" PlaceholderText="WxH" MinWidth="240" TextChanged="Input_Changed" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Live preview -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="PreviewTitle" FontWeight="SemiBold" FontSize="15" />
                    <Border x:Name="PreviewFrame" HorizontalAlignment="Left" CornerRadius="4"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Border x:Name="PreviewBox" Width="320" Height="240">
                            <TextBlock x:Name="PreviewText" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontWeight="SemiBold" TextWrapping="Wrap" TextAlignment="Center" Text="640×480" />
                        </Border>
                    </Border>
                    <TextBlock x:Name="PreviewNote" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Outputs -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="CopySvgBtn" Click="CopySvg_Click" />
                        <Button x:Name="CopyUriBtn" Click="CopyUri_Click" />
                        <Button x:Name="SaveBtn" Click="Save_Click" Style="{ThemeResource AccentButtonStyle}" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="SvgTitle" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBox x:Name="SvgBox" IsReadOnly="True" FontFamily="Consolas" AcceptsReturn="True" TextWrapping="Wrap"
                                 Height="150" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="UriTitle" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBox x:Name="UriBox" IsReadOnly="True" FontFamily="Consolas" AcceptsReturn="True" TextWrapping="Wrap"
                                 Height="90" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="PicsumTitle" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBox x:Name="PicsumBox" IsReadOnly="True" FontFamily="Consolas" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
