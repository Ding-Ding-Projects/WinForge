<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.CiphersModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE72E;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="ModeLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="ModeBox" MinWidth="180" SelectionChanged="Mode_Changed" />
                    </StackPanel>

                    <StackPanel x:Name="ShiftPanel" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Visibility="Collapsed">
                        <TextBlock x:Name="ShiftLabel" VerticalAlignment="Center" />
                        <NumberBox x:Name="ShiftBox" Value="3" Minimum="0" Maximum="25" SpinButtonPlacementMode="Inline" MinWidth="140" />
                    </StackPanel>

                    <StackPanel x:Name="KeyPanel" Spacing="4" Visibility="Collapsed">
                        <TextBlock x:Name="KeyLabel" />
                        <TextBox x:Name="KeyBox" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="InputLabel" />
                        <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="90" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="EncodeBtn" Click="Encode_Click" Style="{ThemeResource AccentButtonStyle}" />
                        <Button x:Name="DecodeBtn" Click="Decode_Click" />
                        <Button x:Name="CopyBtn" Click="Copy_Click" />
                        <Button x:Name="ClearBtn" Click="Clear_Click" />
                    </StackPanel>

                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="OutputLabel" />
                        <TextBox x:Name="OutputBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="90" IsReadOnly="True" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
