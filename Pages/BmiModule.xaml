<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.BmiModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE95E;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Units -->
            <Border Padding="16,12,16,12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                        <TextBlock x:Name="UnitsTitle" FontWeight="SemiBold" FontSize="15" />
                        <TextBlock x:Name="UnitsHint" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <ToggleSwitch x:Name="UnitSwitch" Grid.Column="1" Toggled="Units_Toggled" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- BMI -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="BmiTitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="BmiHeightLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <NumberBox x:Name="BmiHeight" Value="170" Minimum="1" SpinButtonPlacementMode="Compact" MinWidth="150" ValueChanged="Any_Changed" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="BmiWeightLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <NumberBox x:Name="BmiWeight" Value="65" Minimum="1" SpinButtonPlacementMode="Compact" MinWidth="150" ValueChanged="Any_Changed" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="BmiResult" FontSize="14" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- BMR + calories -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="BmrTitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="BmrSexLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="BmrSex" MinWidth="140" SelectionChanged="Sel_Changed" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="BmrAgeLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <NumberBox x:Name="BmrAge" Value="30" Minimum="1" Maximum="130" SpinButtonPlacementMode="Compact" MinWidth="120" ValueChanged="Any_Changed" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="BmrHeightLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <NumberBox x:Name="BmrHeight" Value="170" Minimum="1" SpinButtonPlacementMode="Compact" MinWidth="150" ValueChanged="Any_Changed" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="BmrWeightLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <NumberBox x:Name="BmrWeight" Value="65" Minimum="1" SpinButtonPlacementMode="Compact" MinWidth="150" ValueChanged="Any_Changed" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="ActivityLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ComboBox x:Name="ActivityBox" MinWidth="320" SelectionChanged="Sel_Changed" />
                    </StackPanel>
                    <TextBlock x:Name="BmrResult" FontSize="14" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Body fat (US Navy) -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="BfTitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="BfSexLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="BfSex" MinWidth="140" SelectionChanged="Sel_Changed" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="BfHeightLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <NumberBox x:Name="BfHeight" Value="170" Minimum="1" SpinButtonPlacementMode="Compact" MinWidth="150" ValueChanged="Any_Changed" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="BfNeckLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <NumberBox x:Name="BfNeck" Value="38" Minimum="1" SpinButtonPlacementMode="Compact" MinWidth="120" ValueChanged="Any_Changed" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="BfWaistLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <NumberBox x:Name="BfWaist" Value="85" Minimum="1" SpinButtonPlacementMode="Compact" MinWidth="120" ValueChanged="Any_Changed" />
                        </StackPanel>
                        <StackPanel x:Name="BfHipsPanel" Spacing="4">
                            <TextBlock x:Name="BfHipsLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <NumberBox x:Name="BfHips" Value="95" Minimum="1" SpinButtonPlacementMode="Compact" MinWidth="120" ValueChanged="Any_Changed" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="BfResult" FontSize="14" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <TextBlock x:Name="Disclaimer" FontSize="12" FontStyle="Italic" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</Page>
