<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.SlugifyModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE943;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="InputLabel" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="InputBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="120"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             TextChanged="Input_Changed" />

                    <Grid ColumnSpacing="14" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                            <TextBlock x:Name="SepLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="SepBox" HorizontalAlignment="Stretch" SelectionChanged="Opt_Changed" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                            <TextBlock x:Name="CaseLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="CaseBox" HorizontalAlignment="Stretch" SelectionChanged="Opt_Changed" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2" Spacing="4">
                            <TextBlock x:Name="MaxLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <NumberBox x:Name="MaxBox" Value="0" Minimum="0" Maximum="500" SpinButtonPlacementMode="Inline" HorizontalAlignment="Stretch" ValueChanged="Num_Changed" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="20">
                        <CheckBox x:Name="DiacriticsChk" Checked="Opt_Changed" Unchecked="Opt_Changed" IsChecked="True" />
                        <CheckBox x:Name="CollapseChk" Checked="Opt_Changed" Unchecked="Opt_Changed" IsChecked="True" />
                        <CheckBox x:Name="UnicodeChk" Checked="Opt_Changed" Unchecked="Opt_Changed" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="OutputLabel" Grid.Column="0" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                        <Button x:Name="CopyBtn" Grid.Column="1" Click="Copy_Click" />
                    </Grid>
                    <TextBox x:Name="OutputBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             IsReadOnly="True"
                             MinHeight="120"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" />
                    <TextBlock x:Name="PreviewLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="PreviewText" FontSize="13" TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
