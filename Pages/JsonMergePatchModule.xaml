<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.JsonMergePatchModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE943;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="ModeLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="ModeBox" MinWidth="240" SelectionChanged="Mode_Changed" SelectedIndex="0" />
                    </StackPanel>

                    <TextBlock x:Name="NoteBlock" FontSize="12" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="LeftLabel" FontWeight="SemiBold" />
                        <TextBox x:Name="LeftBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="150" MaxHeight="260"
                                 FontFamily="Consolas" IsSpellCheckEnabled="False"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="RightLabel" FontWeight="SemiBold" />
                        <TextBox x:Name="RightBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="150" MaxHeight="260"
                                 FontFamily="Consolas" IsSpellCheckEnabled="False"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="RunButton" Style="{ThemeResource AccentButtonStyle}" Click="Run_Click" />
                        <Button x:Name="SampleButton" Click="Sample_Click" />
                        <Button x:Name="CopyButton" Click="Copy_Click" IsEnabled="False" />
                    </StackPanel>

                    <InfoBar x:Name="Info" IsOpen="False" IsClosable="False" />

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="OutLabel" FontWeight="SemiBold" />
                        <TextBox x:Name="OutBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="170" MaxHeight="320"
                                 FontFamily="Consolas" IsSpellCheckEnabled="False"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
