<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.ComputeMineModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE945;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Empty state: reactor not generating -->
            <InfoBar x:Name="NeedPowerBar" IsClosable="False" IsOpen="False" Severity="Warning" />

            <!-- Live reactor output the mine feeds on -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ReactorTitle" Grid.Column="0" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                        <TextBlock x:Name="ReactorModeText" Grid.Column="1" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                    </Grid>
                    <ProgressBar x:Name="OutputBar" Minimum="0" Maximum="1150" Value="0" Height="10" />
                    <TextBlock x:Name="OutputValue" FontSize="20" FontWeight="SemiBold" />
                </StackPanel>
            </Border>

            <!-- Mine controls -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="MineTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="MineHint" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <StackPanel Spacing="2">
                        <TextBlock x:Name="DrawLabel" />
                        <Slider x:Name="DrawSlider" Minimum="0" Maximum="600" Value="0" StepFrequency="5" ValueChanged="DrawSlider_ValueChanged" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="MineButton" Click="Mine_Click" Style="{ThemeResource AccentButtonStyle}" />
                        <Button x:Name="SellButton" Click="Sell_Click" />
                        <Button x:Name="ResetButton" Click="Reset_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Mine readouts -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="StatsTitle" FontWeight="SemiBold" FontSize="15" />
                    <Grid ColumnSpacing="18" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="1">
                            <TextBlock x:Name="HashCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="HashValue" FontSize="18" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="1">
                            <TextBlock x:Name="EarnedCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="EarnedValue" FontSize="18" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="1">
                            <TextBlock x:Name="PowerCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="PowerValue" FontSize="18" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="1">
                            <TextBlock x:Name="EffCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="EffValue" FontSize="18" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Spacing="1">
                            <TextBlock x:Name="PriceCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="PriceValue" FontSize="18" FontWeight="SemiBold" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
