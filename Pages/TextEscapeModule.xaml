<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.TextEscapeModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8C8;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="LangLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="LangBox" MinWidth="220" SelectionChanged="Lang_SelectionChanged" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="InputLabel" FontWeight="SemiBold" />
                        <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" IsSpellCheckEnabled="False" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="EscapeBtn" Click="Escape_Click" Style="{ThemeResource AccentButtonStyle}" />
                        <Button x:Name="UnescapeBtn" Click="Unescape_Click" />
                        <Button x:Name="CopyBtn" Click="Copy_Click" />
                        <Button x:Name="ClearBtn" Click="Clear_Click" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="OutputLabel" FontWeight="SemiBold" />
                        <TextBox x:Name="OutputBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120" IsReadOnly="True"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" IsSpellCheckEnabled="False" />
                    </StackPanel>

                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
