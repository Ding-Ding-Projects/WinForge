<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.MdTableModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="920" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8A5;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="Status" IsOpen="True" IsClosable="False" Severity="Informational" />

            <!-- Input -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="InputTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="InputBox"
                             AcceptsReturn="True" TextWrapping="NoWrap"
                             FontFamily="Consolas" MinHeight="150"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             TextChanged="OnInputChanged" />

                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="DelimLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="DelimCombo" MinWidth="150" SelectionChanged="OnOptionChanged" />
                        </StackPanel>
                        <StackPanel Spacing="4" VerticalAlignment="Bottom">
                            <ToggleSwitch x:Name="HeaderSwitch" IsOn="True" Toggled="OnOptionChanged" />
                        </StackPanel>
                        <StackPanel Spacing="4" VerticalAlignment="Bottom">
                            <ToggleSwitch x:Name="PadSwitch" IsOn="True" Toggled="OnOptionChanged" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="ReverseHint" Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
                        <FontIcon Glyph="&#xE946;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBlock x:Name="ReverseHintText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Alignment -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="AlignTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="AlignBlurb" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" HorizontalScrollMode="Auto">
                    <ItemsControl x:Name="AlignHost">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="4" MinWidth="150" Margin="0,0,10,0">
                                    <TextBlock Text="{Binding Name}" FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="150" />
                                    <ComboBox ItemsSource="{Binding Options}" SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}" MinWidth="150" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    </ScrollViewer>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="ApplyAlignBtn" Click="OnApplyAlign" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Output -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="OutputTitle" FontWeight="SemiBold" FontSize="15" />
                            <TextBlock x:Name="CountsText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <ComboBox x:Name="OutFormatCombo" MinWidth="150" SelectionChanged="OnOptionChanged" />
                            <Button x:Name="CopyBtn" Click="OnCopy" />
                        </StackPanel>
                    </Grid>
                    <TextBox x:Name="OutputBox"
                             IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                             FontFamily="Consolas" MinHeight="180"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
