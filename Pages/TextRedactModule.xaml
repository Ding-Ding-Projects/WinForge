<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.TextRedactModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE72E;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="DetectLabel" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Spacing="6">
                        <CheckBox x:Name="EmailChk" IsChecked="True" Checked="Option_Changed" Unchecked="Option_Changed" />
                        <CheckBox x:Name="PhoneChk" IsChecked="True" Checked="Option_Changed" Unchecked="Option_Changed" />
                        <CheckBox x:Name="CardChk" IsChecked="True" Checked="Option_Changed" Unchecked="Option_Changed" />
                        <CheckBox x:Name="IpChk" IsChecked="True" Checked="Option_Changed" Unchecked="Option_Changed" />
                        <CheckBox x:Name="DigitsChk" IsChecked="True" Checked="Option_Changed" Unchecked="Option_Changed" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="StyleLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="StyleCombo" MinWidth="200" SelectionChanged="Style_Changed" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel Spacing="6">
                <TextBlock x:Name="InputLabel" FontWeight="SemiBold" />
                <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="140"
                         ScrollViewer.VerticalScrollBarVisibility="Auto" TextChanged="Input_Changed" />
            </StackPanel>

            <StackPanel Spacing="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="OutputLabel" Grid.Column="0" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button x:Name="CopyButton" Grid.Column="1" Click="Copy_Click" />
                </Grid>
                <TextBox x:Name="OutputBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="140" IsReadOnly="True"
                         ScrollViewer.VerticalScrollBarVisibility="Auto" />
            </StackPanel>

            <TextBlock x:Name="StatusText" FontSize="12" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock x:Name="DisclaimerText" FontSize="12" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
        </StackPanel>
    </ScrollViewer>
</Page>
