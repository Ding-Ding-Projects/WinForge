<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.GradientModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE790;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="TypeLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="TypeBox" MinWidth="160" SelectionChanged="Type_Changed">
                                <ComboBoxItem x:Name="LinearItem" />
                                <ComboBoxItem x:Name="RadialItem" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel x:Name="AnglePanel" Spacing="4">
                            <TextBlock x:Name="AngleLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <NumberBox x:Name="AngleBox" Value="90" Minimum="0" Maximum="360" SpinButtonPlacementMode="Inline" MinWidth="140" ValueChanged="Angle_Changed" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock x:Name="StopsLabel" FontWeight="SemiBold" FontSize="14" />
                        <ItemsControl x:Name="StopsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4,0,4" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="4" Background="{Binding Swatch}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" Text="{Binding Hex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="#rrggbb" VerticalAlignment="Center" />
                                        <NumberBox Grid.Column="2" Value="{Binding Position, Mode=TwoWay}" Minimum="0" Maximum="100" SpinButtonPlacementMode="Inline" MinWidth="120" VerticalAlignment="Center" />
                                        <Button Grid.Column="3" Content="&#xE738;" FontFamily="Segoe Fluent Icons" Tag="{Binding}" Click="RemoveStop_Click" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button x:Name="AddStopButton" Click="AddStop_Click" HorizontalAlignment="Left" />
                    </StackPanel>

                    <Border x:Name="Preview" Height="160" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" />

                    <TextBox x:Name="CssBox" IsReadOnly="True" TextWrapping="Wrap" FontFamily="Consolas" />

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="CopyButton" Click="Copy_Click" />
                        <Button x:Name="RandomButton" Click="Random_Click" />
                    </StackPanel>

                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
