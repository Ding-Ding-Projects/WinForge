<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.SubnetV6Module"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE968;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Input card -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="AddrLabel" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="AddrBox" PlaceholderText="2001:db8::1 / 64" FontFamily="Consolas" TextChanged="Addr_Changed" />
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="PrefixLabel" VerticalAlignment="Center" />
                        <NumberBox x:Name="PrefixBox" Value="64" Minimum="0" Maximum="128" SpinButtonPlacementMode="Inline" MinWidth="140" ValueChanged="Prefix_Changed" />
                    </StackPanel>
                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Results -->
            <Border x:Name="ResultsCard" Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Visibility="Collapsed">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="ResultsTitle" FontWeight="SemiBold" FontSize="15" />

                    <StackPanel Spacing="2">
                        <TextBlock x:Name="ExpandedLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="ExpandedVal" FontFamily="Consolas" IsTextSelectionEnabled="True" VerticalAlignment="Center" TextWrapping="Wrap" />
                            <Button x:Name="ExpandedCopy" Click="Copy_Expanded" Content="&#xE8C8;" FontFamily="Segoe MDL2 Assets" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="2">
                        <TextBlock x:Name="CompressedLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="CompressedVal" FontFamily="Consolas" IsTextSelectionEnabled="True" VerticalAlignment="Center" TextWrapping="Wrap" />
                            <Button x:Name="CompressedCopy" Click="Copy_Compressed" Content="&#xE8C8;" FontFamily="Segoe MDL2 Assets" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="2">
                        <TextBlock x:Name="TypeLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="TypeVal" IsTextSelectionEnabled="True" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Prefix / subnet -->
            <Border x:Name="PrefixCard" Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Visibility="Collapsed">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="PrefixTitle" FontWeight="SemiBold" FontSize="15" />

                    <StackPanel Spacing="2">
                        <TextBlock x:Name="NetLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="NetVal" FontFamily="Consolas" IsTextSelectionEnabled="True" VerticalAlignment="Center" TextWrapping="Wrap" />
                            <Button x:Name="NetCopy" Click="Copy_Net" Content="&#xE8C8;" FontFamily="Segoe MDL2 Assets" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="2">
                        <TextBlock x:Name="MaskLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="MaskVal" FontFamily="Consolas" IsTextSelectionEnabled="True" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="2">
                        <TextBlock x:Name="CountLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="CountVal" IsTextSelectionEnabled="True" VerticalAlignment="Center" TextWrapping="Wrap" />
                            <Button x:Name="CountCopy" Click="Copy_Count" Content="&#xE8C8;" FontFamily="Segoe MDL2 Assets" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="2">
                        <TextBlock x:Name="FirstLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="FirstVal" FontFamily="Consolas" IsTextSelectionEnabled="True" VerticalAlignment="Center" TextWrapping="Wrap" />
                            <Button x:Name="FirstCopy" Click="Copy_First" Content="&#xE8C8;" FontFamily="Segoe MDL2 Assets" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="2">
                        <TextBlock x:Name="LastLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="LastVal" FontFamily="Consolas" IsTextSelectionEnabled="True" VerticalAlignment="Center" TextWrapping="Wrap" />
                            <Button x:Name="LastCopy" Click="Copy_Last" Content="&#xE8C8;" FontFamily="Segoe MDL2 Assets" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- EUI-64 helper -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="EuiTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="EuiBlurb" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <TextBox x:Name="MacBox" PlaceholderText="00:1A:2B:3C:4D:5E" FontFamily="Consolas" TextChanged="Mac_Changed" />
                    <StackPanel Spacing="2">
                        <TextBlock x:Name="EuiLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="EuiVal" FontFamily="Consolas" IsTextSelectionEnabled="True" VerticalAlignment="Center" TextWrapping="Wrap" />
                            <Button x:Name="EuiCopy" Click="Copy_Eui" Content="&#xE8C8;" FontFamily="Segoe MDL2 Assets" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="EuiStatus" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
