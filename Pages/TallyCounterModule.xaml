<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.TallyCounterModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8EF;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBox x:Name="NewNameBox" MinWidth="240" />
                        <Button x:Name="AddBtn" Click="Add_Click" Style="{ThemeResource AccentButtonStyle}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="StepLabel" VerticalAlignment="Center" />
                        <NumberBox x:Name="StepBox" Value="1" Minimum="1" Maximum="1000000" SpinButtonPlacementMode="Inline" MinWidth="120" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <ListView x:Name="CountersList" SelectionMode="None" IsItemClickEnabled="False">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0,4,0,4" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="14,10,14,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" TextWrapping="Wrap" />
                                <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="24" FontWeight="Bold" MinWidth="72" TextAlignment="Center" VerticalAlignment="Center" />
                                <Button Grid.Column="2" Content="&#x2212;" Click="Minus_Click" MinWidth="44" VerticalAlignment="Center" />
                                <Button Grid.Column="3" Content="&#x2b;" Click="Plus_Click" MinWidth="44" VerticalAlignment="Center" />
                                <Button Grid.Column="4" Click="Row_Reset_Click" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                                </Button>
                                <Button Grid.Column="5" Click="Row_Menu_Click" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE712;" FontSize="14" />
                                    <Button.Flyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem x:Name="RenameItem" Click="Rename_Click">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE8AC;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutItem x:Name="DeleteItem" Click="Delete_Click">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE74D;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock x:Name="EmptyText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Visibility="Collapsed" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                        <TextBlock x:Name="TotalLabel" FontWeight="SemiBold" FontSize="15" />
                        <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <TextBlock x:Name="TotalValue" Grid.Column="1" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <Button x:Name="ResetAllBtn" Grid.Column="2" Click="ResetAll_Click" VerticalAlignment="Center" />
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
