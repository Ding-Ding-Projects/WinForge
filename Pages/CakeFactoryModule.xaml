<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.CakeFactoryModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16,12,16,16" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <FontIcon Grid.Column="0" FontSize="22" Glyph="&#xECA5;" VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Spacing="2">
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button x:Name="OpenReactorBtn" Click="OpenReactor_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xEBC0;" />
                        <TextBlock x:Name="OpenReactorText" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <InfoBar
            x:Name="PowerInfo"
            Grid.Row="1"
            IsOpen="True"
            IsClosable="False" />

        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12" Padding="0,0,8,0">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="10">
                        <Viewbox Stretch="Uniform" StretchDirection="DownOnly" HorizontalAlignment="Stretch">
                            <Canvas x:Name="SceneCanvas" Width="1180" Height="520" />
                        </Viewbox>
                    </Border>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                            <StackPanel Spacing="8">
                                <TextBlock x:Name="FarmHeader" FontWeight="SemiBold" />
                                <ProgressBar x:Name="WheatBar" Minimum="0" Maximum="100" />
                                <TextBlock x:Name="WheatText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <ProgressBar x:Name="BeetBar" Minimum="0" Maximum="100" />
                                <TextBlock x:Name="BeetText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <ProgressBar x:Name="VanillaBar" Minimum="0" Maximum="100" />
                                <TextBlock x:Name="VanillaText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                            <StackPanel Spacing="8">
                                <TextBlock x:Name="FactoryHeader" FontWeight="SemiBold" />
                                <TextBlock x:Name="StageText" />
                                <ProgressBar x:Name="StageBar" Minimum="0" Maximum="100" />
                                <TextBlock x:Name="OvenText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock x:Name="GravityText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                            <StackPanel Spacing="8">
                                <TextBlock x:Name="FoodSafetyHeader" FontWeight="SemiBold" />
                                <TextBlock x:Name="HaccpText" />
                                <ProgressBar x:Name="QualityBar" Minimum="0" Maximum="100" />
                                <TextBlock x:Name="QualityText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <ProgressBar x:Name="SanitationBar" Minimum="0" Maximum="100" />
                                <TextBlock x:Name="SanitationText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                        <StackPanel Spacing="10">
                            <TextBlock x:Name="ControlsHeader" FontWeight="SemiBold" />
                            <ComboBox x:Name="RecipeBox" SelectionChanged="RecipeBox_SelectionChanged" />
                            <TextBlock x:Name="FarmSliderLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <Slider x:Name="FarmSlider" Minimum="0" Maximum="100" Value="78" ValueChanged="FarmSlider_ValueChanged" />
                            <TextBlock x:Name="LineSliderLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <Slider x:Name="LineSlider" Minimum="0" Maximum="120" Value="72" ValueChanged="LineSlider_ValueChanged" />
                            <ToggleSwitch x:Name="AutoHarvestSwitch" IsOn="True" Toggled="AutoHarvestSwitch_Toggled" />
                            <ToggleSwitch x:Name="AutoBatchSwitch" IsOn="True" Toggled="AutoBatchSwitch_Toggled" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="StartBatchBtn" Click="StartBatch_Click" Style="{StaticResource AccentButtonStyle}" />
                                <Button x:Name="CleanBtn" Click="Clean_Click" />
                            </StackPanel>
                            <Button x:Name="HarvestBtn" Click="Harvest_Click" />
                        </StackPanel>
                    </Border>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="PowerHeader" FontWeight="SemiBold" />
                            <ProgressBar x:Name="PowerBar" Minimum="0" Maximum="100" />
                            <TextBlock x:Name="PowerText" FontFamily="Consolas" FontSize="12" />
                            <TextBlock x:Name="DemandText" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="InventoryHeader" FontWeight="SemiBold" />
                            <Grid ColumnSpacing="8" RowSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="FlourLbl" Grid.Row="0" Grid.Column="0" />
                                <TextBlock x:Name="FlourVal" Grid.Row="0" Grid.Column="1" FontFamily="Consolas" />
                                <TextBlock x:Name="SugarLbl" Grid.Row="1" Grid.Column="0" />
                                <TextBlock x:Name="SugarVal" Grid.Row="1" Grid.Column="1" FontFamily="Consolas" />
                                <TextBlock x:Name="EggLbl" Grid.Row="2" Grid.Column="0" />
                                <TextBlock x:Name="EggVal" Grid.Row="2" Grid.Column="1" FontFamily="Consolas" />
                                <TextBlock x:Name="MilkLbl" Grid.Row="3" Grid.Column="0" />
                                <TextBlock x:Name="MilkVal" Grid.Row="3" Grid.Column="1" FontFamily="Consolas" />
                                <TextBlock x:Name="ButterLbl" Grid.Row="4" Grid.Column="0" />
                                <TextBlock x:Name="ButterVal" Grid.Row="4" Grid.Column="1" FontFamily="Consolas" />
                                <TextBlock x:Name="VanillaLbl" Grid.Row="5" Grid.Column="0" />
                                <TextBlock x:Name="VanillaVal" Grid.Row="5" Grid.Column="1" FontFamily="Consolas" />
                                <TextBlock x:Name="CocoaLbl" Grid.Row="6" Grid.Column="0" />
                                <TextBlock x:Name="CocoaVal" Grid.Row="6" Grid.Column="1" FontFamily="Consolas" />
                                <TextBlock x:Name="BakingLbl" Grid.Row="7" Grid.Column="0" />
                                <TextBlock x:Name="BakingVal" Grid.Row="7" Grid.Column="1" FontFamily="Consolas" />
                                <TextBlock x:Name="PackedLbl" Grid.Row="8" Grid.Column="0" />
                                <TextBlock x:Name="PackedVal" Grid.Row="8" Grid.Column="1" FontFamily="Consolas" />
                                <TextBlock x:Name="WasteLbl" Grid.Row="9" Grid.Column="0" />
                                <TextBlock x:Name="WasteVal" Grid.Row="9" Grid.Column="1" FontFamily="Consolas" />
                            </Grid>
                            <TextBlock x:Name="MissingText" FontSize="12" Foreground="{ThemeResource SystemFillColorCautionBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <InfoBar x:Name="ActionInfo" IsOpen="False" IsClosable="True" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
