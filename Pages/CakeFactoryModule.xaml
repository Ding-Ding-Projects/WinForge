<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.CakeFactoryModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16,12,16,16" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <FontIcon Grid.Column="0" FontSize="22" Glyph="&#xECA5;" VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Spacing="2">
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock
                    x:Name="HeaderBlurb"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap" />
            </StackPanel>
            <Button x:Name="OpenReactorBtn" Grid.Column="2" VerticalAlignment="Center" Click="OpenReactor_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xEBC0;" />
                    <TextBlock x:Name="OpenReactorText" />
                </StackPanel>
            </Button>
        </Grid>

        <InfoBar
            x:Name="PowerInfo"
            Grid.Row="1"
            IsClosable="False"
            IsOpen="True" />

        <Border
            Grid.Row="2"
            MinHeight="680"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid>
                <controls:WebView2
                    x:Name="CakeWeb"
                    MinHeight="680"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" />
                <ProgressRing
                    x:Name="LoadingRing"
                    Width="38"
                    Height="38"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsActive="True" />
            </Grid>
        </Border>
    </Grid>
</Page>
