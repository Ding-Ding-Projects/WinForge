<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.DiagramEditorModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Style="{StaticResource WinForgePageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="6">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8A3;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Top toolbar: file ops, edit ops, zoom, grid -->
        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                <Button x:Name="NewBtn" Click="New_Click"><StackPanel Orientation="Horizontal" Spacing="6"><FontIcon FontSize="14" Glyph="&#xE8A5;" /><TextBlock x:Name="NewLbl" /></StackPanel></Button>
                <Button x:Name="OpenBtn" Click="Open_Click"><StackPanel Orientation="Horizontal" Spacing="6"><FontIcon FontSize="14" Glyph="&#xE8E5;" /><TextBlock x:Name="OpenLbl" /></StackPanel></Button>
                <Button x:Name="SaveBtn" Click="Save_Click"><StackPanel Orientation="Horizontal" Spacing="6"><FontIcon FontSize="14" Glyph="&#xE74E;" /><TextBlock x:Name="SaveLbl" /></StackPanel></Button>
                <Button x:Name="ExportBtn" Click="Export_Click"><StackPanel Orientation="Horizontal" Spacing="6"><FontIcon FontSize="14" Glyph="&#xEB9F;" /><TextBlock x:Name="ExportLbl" /></StackPanel></Button>
                <AppBarSeparator />
                <Button x:Name="DuplicateBtn" Click="Duplicate_Click" ToolTipService.ToolTip="Duplicate · 複製"><FontIcon FontSize="14" Glyph="&#xE8C8;" /></Button>
                <Button x:Name="DeleteBtn" Click="Delete_Click" ToolTipService.ToolTip="Delete · 刪除"><FontIcon FontSize="14" Glyph="&#xE74D;" /></Button>
                <Button x:Name="FrontBtn" Click="BringFront_Click" ToolTipService.ToolTip="Bring to front · 移到最前"><FontIcon FontSize="14" Glyph="&#xE74A;" /></Button>
                <Button x:Name="BackBtn" Click="SendBack_Click" ToolTipService.ToolTip="Send to back · 移到最後"><FontIcon FontSize="14" Glyph="&#xE74B;" /></Button>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <ToggleButton x:Name="ConnectModeBtn" Click="ConnectMode_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6"><FontIcon FontSize="14" Glyph="&#xE71B;" /><TextBlock x:Name="ConnectLbl" /></StackPanel>
                </ToggleButton>
                <AppBarSeparator />
                <ToggleSwitch x:Name="SnapToggle" OnContent="" OffContent="" MinWidth="0" Toggled="Snap_Toggled" />
                <TextBlock x:Name="SnapLbl" VerticalAlignment="Center" FontSize="12" />
                <AppBarSeparator />
                <Button x:Name="ZoomOutBtn" Click="ZoomOut_Click"><FontIcon FontSize="14" Glyph="&#xE71F;" /></Button>
                <TextBlock x:Name="ZoomText" VerticalAlignment="Center" MinWidth="48" TextAlignment="Center" FontSize="12" />
                <Button x:Name="ZoomInBtn" Click="ZoomIn_Click"><FontIcon FontSize="14" Glyph="&#xE8A3;" /></Button>
                <Button x:Name="ZoomResetBtn" Click="ZoomReset_Click"><FontIcon FontSize="14" Glyph="&#xE9A6;" /></Button>
            </StackPanel>
        </Grid>

        <!-- Body: palette | canvas | properties -->
        <Grid Grid.Row="2" ColumnSpacing="12" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Palette -->
            <Border Grid.Column="0" Width="172" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="PaletteHeader" FontWeight="SemiBold" />
                    <Button x:Name="AddRectBtn" Click="AddRect_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8"><FontIcon FontSize="14" Glyph="&#xE739;" /><TextBlock x:Name="RectLbl" /></StackPanel>
                    </Button>
                    <Button x:Name="AddRoundBtn" Click="AddRound_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8"><FontIcon FontSize="14" Glyph="&#xE7C3;" /><TextBlock x:Name="RoundLbl" /></StackPanel>
                    </Button>
                    <Button x:Name="AddEllipseBtn" Click="AddEllipse_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8"><FontIcon FontSize="14" Glyph="&#xEA3A;" /><TextBlock x:Name="EllipseLbl" /></StackPanel>
                    </Button>
                    <Button x:Name="AddDiamondBtn" Click="AddDiamond_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8"><FontIcon FontSize="14" Glyph="&#xE879;" /><TextBlock x:Name="DiamondLbl" /></StackPanel>
                    </Button>
                    <Button x:Name="AddTextBtn" Click="AddText_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8"><FontIcon FontSize="14" Glyph="&#xE8D2;" /><TextBlock x:Name="TextLbl" /></StackPanel>
                    </Button>
                    <TextBlock x:Name="PaletteHint" FontSize="11" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <!-- Canvas surface -->
            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <ScrollViewer x:Name="CanvasScroller" ZoomMode="Disabled"
                              HorizontalScrollMode="Auto" HorizontalScrollBarVisibility="Auto"
                              VerticalScrollMode="Auto" VerticalScrollBarVisibility="Auto">
                    <Grid x:Name="ZoomHost" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="CanvasScale" ScaleX="1" ScaleY="1" />
                        </Grid.RenderTransform>
                        <Canvas x:Name="DiagramCanvas" Width="2400" Height="1600"
                                Background="Transparent"
                                PointerPressed="Canvas_PointerPressed"
                                PointerMoved="Canvas_PointerMoved"
                                PointerReleased="Canvas_PointerReleased" />
                    </Grid>
                </ScrollViewer>
            </Border>

            <!-- Properties panel -->
            <Border Grid.Column="2" Width="248" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel Spacing="12">
                        <TextBlock x:Name="PropsHeader" FontWeight="SemiBold" />
                        <TextBlock x:Name="PropsEmpty" FontSize="12" TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <StackPanel x:Name="PropsPanel" Spacing="12" Visibility="Collapsed">
                            <TextBox x:Name="LabelBox" Header="Label · 文字" TextChanged="Label_Changed" AcceptsReturn="True" TextWrapping="Wrap" />

                            <StackPanel x:Name="FillRow" Spacing="4">
                                <TextBlock x:Name="FillLbl" FontSize="12" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:Name="FillSwatch" Width="40" Height="28" Padding="0" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                        <Button.Flyout>
                                            <Flyout>
                                                <ColorPicker x:Name="FillPicker" ColorChanged="FillColor_Changed" IsAlphaEnabled="True" IsMoreButtonVisible="True" />
                                            </Flyout>
                                        </Button.Flyout>
                                    </Button>
                                    <TextBlock x:Name="FillHex" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock x:Name="StrokeLbl" FontSize="12" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:Name="StrokeSwatch" Width="40" Height="28" Padding="0" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                        <Button.Flyout>
                                            <Flyout>
                                                <ColorPicker x:Name="StrokePicker" ColorChanged="StrokeColor_Changed" IsAlphaEnabled="True" IsMoreButtonVisible="True" />
                                            </Flyout>
                                        </Button.Flyout>
                                    </Button>
                                    <TextBlock x:Name="StrokeHex" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>

                            <NumberBox x:Name="StrokeWidthBox" Header="Stroke width · 邊框粗幼" Minimum="0" Maximum="20" SmallChange="1" SpinButtonPlacementMode="Compact" ValueChanged="StrokeWidth_Changed" />
                            <NumberBox x:Name="FontSizeBox" Header="Font size · 字體大小" Minimum="6" Maximum="96" SmallChange="1" SpinButtonPlacementMode="Compact" ValueChanged="FontSize_Changed" />

                            <StackPanel x:Name="TextColorRow" Spacing="4">
                                <TextBlock x:Name="TextColorLbl" FontSize="12" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:Name="TextColorSwatch" Width="40" Height="28" Padding="0" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                        <Button.Flyout>
                                            <Flyout>
                                                <ColorPicker x:Name="TextColorPicker" ColorChanged="TextColor_Changed" IsAlphaEnabled="True" IsMoreButtonVisible="True" />
                                            </Flyout>
                                        </Button.Flyout>
                                    </Button>
                                    <TextBlock x:Name="TextColorHex" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>

                            <TextBlock x:Name="SelectionInfo" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <InfoBar x:Name="StatusBar" Grid.Row="0" IsClosable="True" IsOpen="False" VerticalAlignment="Bottom" Margin="0,0,0,0" />
    </Grid>
</Page>
