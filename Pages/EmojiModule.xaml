<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.EmojiModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,24" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" MaxWidth="900" Spacing="6" HorizontalAlignment="Left">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE76E;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="CategoryBox" Grid.Column="0" MinWidth="200" SelectionChanged="Category_Changed" />
            <TextBox x:Name="SearchBox" Grid.Column="1" TextChanged="Search_Changed" />
        </Grid>

        <Border Grid.Row="2" Padding="12,8,12,8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
            <StackPanel Spacing="4">
                <TextBlock x:Name="RecentLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <StackPanel x:Name="RecentStrip" Orientation="Horizontal" Spacing="6" />
            </StackPanel>
        </Border>

        <ListView x:Name="EmojiList" Grid.Row="3" SelectionMode="Single" SelectionChanged="Emoji_Selected"
                  IsItemClickEnabled="True" ItemClick="Emoji_Clicked"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="4,6,4,6" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Emoji}" FontSize="28" VerticalAlignment="Center" Width="44" TextAlignment="Center" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                            <TextBlock Text="{Binding Name}" FontSize="14" TextWrapping="NoWrap" />
                            <TextBlock Text="{Binding Category}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock x:Name="StatusText" Grid.Row="4" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
    </Grid>
</Page>
