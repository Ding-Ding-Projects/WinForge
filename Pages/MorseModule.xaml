<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.MorseModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8D6;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="Info" IsOpen="False" IsClosable="True" Severity="Informational" />

            <!-- Input -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="InputTitle" FontWeight="SemiBold" FontSize="15" />
                            <TextBlock x:Name="InputSub" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock x:Name="ModeText2Morse" VerticalAlignment="Center" FontSize="12" />
                            <ToggleSwitch x:Name="DirectionSwitch" Toggled="Direction_Toggled" VerticalAlignment="Center" MinWidth="0" />
                            <TextBlock x:Name="ModeMorse2Text" VerticalAlignment="Center" FontSize="12" />
                        </StackPanel>
                    </Grid>

                    <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="96" MaxHeight="180"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             TextChanged="Input_Changed" />

                    <StackPanel x:Name="SepPanel" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="SepLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="SepBox" SelectionChanged="Sep_Changed" MinWidth="200" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Output -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="OutputTitle" Grid.Column="0" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                        <Button x:Name="CopyBtn" Grid.Column="1" Click="Copy_Click" />
                    </Grid>

                    <TextBox x:Name="OutputBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="80" MaxHeight="180"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />

                    <TextBlock x:Name="UnknownText" FontSize="12" TextWrapping="Wrap"
                               Foreground="{ThemeResource SystemFillColorCautionBrush}" Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <!-- Flash preview -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="FlashTitle" FontWeight="SemiBold" FontSize="15" />

                    <Border x:Name="Lamp" Height="72" CornerRadius="8"
                            Background="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" />

                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Button x:Name="PlayBtn" Click="Play_Click" Style="{ThemeResource AccentButtonStyle}" />
                        <Button x:Name="StopBtn" Click="Stop_Click" IsEnabled="False" />
                        <TextBlock x:Name="WpmLabel" VerticalAlignment="Center" />
                        <NumberBox x:Name="WpmBox" Value="15" Minimum="1" Maximum="60"
                                   SpinButtonPlacementMode="Inline" MinWidth="130" />
                    </StackPanel>
                    <TextBlock x:Name="FlashStatus" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
