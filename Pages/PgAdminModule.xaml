<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.PgAdminModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20,14,20,14" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="6">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="24" Glyph="&#xE94D;" VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>
            <TextBlock
                x:Name="HeaderBlurb"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />
        </StackPanel>

        <!-- Engine fallback (pgAdmin 4 desktop) bar -->
        <InfoBar
            Grid.Row="1"
            x:Name="EngineBar"
            IsClosable="False"
            IsOpen="False"
            Severity="Informational" />

        <!-- Connection bar -->
        <Border
            Grid.Row="2"
            Padding="12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ComboBox
                        x:Name="SavedCombo"
                        MinWidth="280"
                        SelectionChanged="SavedCombo_SelectionChanged" />
                    <Button x:Name="NewConnBtn" Click="NewConn_Click" />
                    <Button x:Name="DeleteConnBtn" Click="DeleteConn_Click" />
                    <AppBarSeparator />
                    <Button x:Name="ConnectBtn" Click="Connect_Click" Style="{StaticResource AccentButtonStyle}" />
                    <Button x:Name="TestBtn" Click="Test_Click" />
                    <Button x:Name="DisconnectBtn" Click="Disconnect_Click" IsEnabled="False" />
                    <Button x:Name="LaunchPgAdminBtn" Click="LaunchPgAdmin_Click" Visibility="Collapsed" />
                </StackPanel>

                <!-- Editable connection fields -->
                <Grid ColumnSpacing="8" RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox x:Name="NameBox" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4" />

                    <TextBox x:Name="HostBox" Grid.Row="1" Grid.Column="0" />
                    <NumberBox
                        x:Name="PortBox"
                        Grid.Row="1"
                        Grid.Column="1"
                        Minimum="1"
                        Maximum="65535"
                        Value="5432"
                        SpinButtonPlacementMode="Compact" />
                    <TextBox x:Name="DbBox" Grid.Row="1" Grid.Column="2" />
                    <TextBox x:Name="UserBox" Grid.Row="1" Grid.Column="3" />
                </Grid>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="PassBox" Grid.Column="0" />
                    <ComboBox x:Name="SslCombo" Grid.Column="1" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="Prefer" Tag="Prefer" />
                        <ComboBoxItem Content="Require" Tag="Require" />
                        <ComboBoxItem Content="Disable" Tag="Disable" />
                        <ComboBoxItem Content="VerifyCA" Tag="VerifyCA" />
                        <ComboBoxItem Content="VerifyFull" Tag="VerifyFull" />
                    </ComboBox>
                    <CheckBox x:Name="SavePassCheck" Grid.Column="2" VerticalAlignment="Center" IsChecked="True" />
                    <Button x:Name="SaveConnBtn" Grid.Column="3" Click="SaveConn_Click" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Main work area: tree | (SQL editor + results) -->
        <Grid Grid.Row="3" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Object tree -->
            <Border
                Grid.Column="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowSpacing="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Padding="10,8,10,2" Orientation="Horizontal" Spacing="8">
                        <TextBlock x:Name="TreeHeader" VerticalAlignment="Center" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <Button x:Name="RefreshTreeBtn" Click="RefreshTree_Click" Padding="6,2">
                            <FontIcon FontSize="14" Glyph="&#xE72C;" />
                        </Button>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto">
                        <TreeView
                            x:Name="Tree"
                            Padding="4,4,4,8"
                            Expanding="Tree_Expanding"
                            ItemInvoked="Tree_ItemInvoked"
                            SelectionMode="Single" />
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- SQL editor + results -->
            <Grid Grid.Column="1" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                    <Button x:Name="RunBtn" Click="Run_Click" Style="{StaticResource AccentButtonStyle}" IsEnabled="False" />
                    <Button x:Name="CancelBtn" Click="Cancel_Click" IsEnabled="False" />
                    <Button x:Name="ClearBtn" Click="Clear_Click" />
                    <Button x:Name="ExportCsvBtn" Click="ExportCsv_Click" IsEnabled="False" />
                    <TextBlock x:Name="DbContextLabel" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <Border
                    Grid.Row="1"
                    MinHeight="120"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <TextBox
                        x:Name="SqlBox"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        FontFamily="Consolas"
                        FontSize="13"
                        BorderThickness="0"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        VerticalAlignment="Stretch"
                        VerticalContentAlignment="Top">
                        <TextBox.KeyboardAccelerators>
                            <KeyboardAccelerator Key="Enter" Modifiers="Control" Invoked="RunAccel_Invoked" />
                        </TextBox.KeyboardAccelerators>
                    </TextBox>
                </Border>

                <InfoBar
                    Grid.Row="2"
                    x:Name="ResultBar"
                    IsClosable="True"
                    IsOpen="False" />

                <!-- Results grid (custom, since WinUI has no built-in DataGrid here) -->
                <Border
                    Grid.Row="3"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border
                            Grid.Row="0"
                            Padding="10,6"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1"
                            CornerRadius="8,8,0,0">
                            <TextBlock x:Name="ResultSummary" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Border>
                        <ScrollViewer
                            Grid.Row="1"
                            x:Name="GridScroller"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollMode="Enabled">
                            <StackPanel x:Name="ResultsHost" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
