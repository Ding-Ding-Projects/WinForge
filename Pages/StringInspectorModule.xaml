<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.StringInspectorModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8C1;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="InputLabel" FontWeight="SemiBold" />
                    <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120"
                             TextChanged="Input_Changed" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="CopyBtn" Click="Copy_Click" />
                        <Button x:Name="ClearBtn" Click="Clear_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="StatsTitle" FontWeight="SemiBold" />
                    <TextBlock x:Name="StatsText" TextWrapping="Wrap" FontFamily="Consolas"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="TransformTitle" FontWeight="SemiBold" />
                    <StackPanel x:Name="TransformButtons" Orientation="Horizontal" Spacing="8">
                        <Button x:Name="ReverseBtn" Click="Reverse_Click" />
                        <Button x:Name="NfcBtn" Click="Nfc_Click" />
                        <Button x:Name="NfdBtn" Click="Nfd_Click" />
                        <Button x:Name="NfkcBtn" Click="Nfkc_Click" />
                        <Button x:Name="NfkdBtn" Click="Nfkd_Click" />
                        <Button x:Name="EscapeBtn" Click="Escape_Click" />
                        <Button x:Name="UnescapeBtn" Click="Unescape_Click" />
                        <Button x:Name="StripBtn" Click="Strip_Click" />
                        <Button x:Name="AsciiBtn" Click="Ascii_Click" />
                    </StackPanel>
                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="CodePointsTitle" FontWeight="SemiBold" />
                    <ListView x:Name="CodePointList" MaxHeight="360" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="12" Padding="0,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding CodePoint}" FontFamily="Consolas" />
                                    <TextBlock Grid.Column="1" Text="{Binding Display}" />
                                    <TextBlock Grid.Column="2" Text="{Binding Category}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
