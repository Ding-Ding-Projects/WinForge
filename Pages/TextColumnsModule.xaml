<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.TextColumnsModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8A5;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="InputLabel" FontWeight="SemiBold" />
                    <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="NoWrap" MinHeight="120"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" />

                    <StackPanel Orientation="Horizontal" Spacing="18">
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="InDelimLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="InDelimBox" MinWidth="160" SelectedIndex="0" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="OutDelimLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="OutDelimBox" MinWidth="160" SelectedIndex="1" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="IndexLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBox x:Name="IndexBox" MinWidth="180" Text="1" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="ExtractBtn" Click="Extract_Click" />
                        <Button x:Name="DeleteBtn" Click="Delete_Click" />
                        <Button x:Name="ReorderBtn" Click="Reorder_Click" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="AlignBtn" Click="Align_Click" />
                        <Button x:Name="TransposeBtn" Click="Transpose_Click" />
                        <Button x:Name="TrimBtn" Click="Trim_Click" />
                    </StackPanel>

                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="OutputLabel" Grid.Column="0" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button x:Name="CopyBtn" Grid.Column="1" Click="Copy_Click" />
                    </Grid>
                    <TextBox x:Name="OutputBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" MinHeight="140"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
