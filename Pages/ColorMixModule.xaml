<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.ColorMixModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE790;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="Info" IsOpen="False" IsClosable="True" Severity="Success" />

            <!-- Two colour inputs -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <TextBlock x:Name="InputsTitle" FontWeight="SemiBold" FontSize="15" />
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                            <Border x:Name="SwatchA" Width="44" Height="44" CornerRadius="6" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" />
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="LabelA" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBox x:Name="HexA" Text="#3366CC" MinWidth="140" TextChanged="Inputs_Changed" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                            <Border x:Name="SwatchB" Width="44" Height="44" CornerRadius="6" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" />
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="LabelB" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBox x:Name="HexB" Text="#CC3333" MinWidth="140" TextChanged="Inputs_Changed" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="6">
                        <TextBlock x:Name="RatioLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Slider x:Name="RatioSlider" Minimum="0" Maximum="100" Value="50" StepFrequency="1" ValueChanged="Ratio_Changed" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="SpaceLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="SpaceBox" MinWidth="200" SelectionChanged="Space_Changed" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Mixed result -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="MixedTitle" FontWeight="SemiBold" FontSize="15" />
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="MixedSwatch" Grid.Column="0" Width="72" Height="72" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" />
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock x:Name="MixedHex" FontWeight="SemiBold" FontSize="18" FontFamily="Consolas" />
                            <TextBlock x:Name="MixedRgb" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="MixedHsl" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <Button x:Name="CopyMixBtn" Grid.Column="2" VerticalAlignment="Center" Click="CopyMix_Click" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Gradient -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="GradientTitle" Grid.Column="0" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                        <Button x:Name="CopyCssBtn" Grid.Column="1" Click="CopyCss_Click" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="StepsLabel" VerticalAlignment="Center" />
                        <NumberBox x:Name="StepsBox" Value="7" Minimum="3" Maximum="20" SpinButtonPlacementMode="Inline" MinWidth="150" ValueChanged="Steps_Changed" />
                    </StackPanel>

                    <Border x:Name="GradientBar" Height="26" CornerRadius="6" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" />

                    <TextBlock x:Name="GradientHint" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <ListView x:Name="StepsList" SelectionMode="None" IsItemClickEnabled="True" ItemClick="Step_Click" MaxHeight="420">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="12" Padding="0,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="34" Height="34" CornerRadius="6" Background="{Binding Brush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" />
                                    <TextBlock Grid.Column="1" Text="{Binding Hex}" FontFamily="Consolas" FontWeight="SemiBold" VerticalAlignment="Center" MinWidth="90" />
                                    <TextBlock Grid.Column="2" Text="{Binding Detail}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
