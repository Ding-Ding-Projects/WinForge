<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.DockerModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,16" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="6">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="22" Glyph="&#xEC7A;" VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Connection / engine row -->
        <StackPanel Grid.Row="1" Spacing="8">
            <InfoBar x:Name="EngineBar" IsClosable="False" IsOpen="False" Severity="Warning" />
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="EndpointBox" Grid.Column="0" Header="Engine endpoint · 引擎端點" PlaceholderText="npipe://./pipe/docker_engine" />
                <Button x:Name="RefreshBtn" Grid.Column="1" Click="Refresh_Click" VerticalAlignment="Bottom">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE72C;" />
                        <TextBlock x:Name="RefreshLbl" />
                    </StackPanel>
                </Button>
                <Button x:Name="DisconnectBtn" Grid.Column="2" Click="Disconnect_Click" VerticalAlignment="Bottom" />
                <ProgressRing x:Name="Busy" Grid.Column="3" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" Margin="4,0,0,0" />
            </Grid>

            <!-- Summary chips -->
            <Border x:Name="SummaryCard" Padding="14,8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="8" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="24">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="13" Glyph="&#xE950;" />
                        <TextBlock x:Name="SumVersion" FontSize="12" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="13" Glyph="&#xEC7A;" />
                        <TextBlock x:Name="SumContainers" FontSize="12" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="13" Glyph="&#xE8B7;" />
                        <TextBlock x:Name="SumImages" FontSize="12" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <InfoBar x:Name="ResultBar" IsClosable="True" IsOpen="False" />
        </StackPanel>

        <!-- Tabs -->
        <Pivot x:Name="MainPivot" Grid.Row="3">

            <!-- ===================== CONTAINERS ===================== -->
            <PivotItem x:Name="ContainersTab">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- toolbar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6">
                        <Button x:Name="CStartBtn" Click="CStart_Click"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon FontSize="14" Glyph="&#xE768;" /><TextBlock x:Name="CStartLbl" /></StackPanel></Button>
                        <Button x:Name="CStopBtn" Click="CStop_Click"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon FontSize="14" Glyph="&#xE71A;" /><TextBlock x:Name="CStopLbl" /></StackPanel></Button>
                        <Button x:Name="CRestartBtn" Click="CRestart_Click"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon FontSize="14" Glyph="&#xE72C;" /><TextBlock x:Name="CRestartLbl" /></StackPanel></Button>
                        <Button x:Name="CPauseBtn" Click="CPause_Click"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon FontSize="14" Glyph="&#xE769;" /><TextBlock x:Name="CPauseLbl" /></StackPanel></Button>
                        <Button x:Name="CUnpauseBtn" Click="CUnpause_Click"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon FontSize="14" Glyph="&#xE768;" /><TextBlock x:Name="CUnpauseLbl" /></StackPanel></Button>
                        <Button x:Name="CLogsBtn" Click="CLogs_Click"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon FontSize="14" Glyph="&#xE9F9;" /><TextBlock x:Name="CLogsLbl" /></StackPanel></Button>
                        <Button x:Name="CExecBtn" Click="CExec_Click"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon FontSize="14" Glyph="&#xE756;" /><TextBlock x:Name="CExecLbl" /></StackPanel></Button>
                        <Button x:Name="CRemoveBtn" Click="CRemove_Click"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon FontSize="14" Glyph="&#xE74D;" /><TextBlock x:Name="CRemoveLbl" /></StackPanel></Button>
                    </StackPanel>

                    <!-- list -->
                    <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <ListView x:Name="ContainerList" SelectionMode="Single" SelectionChanged="ContainerList_SelectionChanged"
                                      ScrollViewer.HorizontalScrollMode="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="10,8" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" MinWidth="180" />
                                                <ColumnDefinition Width="2*" MinWidth="160" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" VerticalAlignment="Center" Width="10" Height="10" CornerRadius="5" Background="{Binding StateBrush}" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding Name}" />
                                                <TextBlock Text="{Binding ShortId}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Image}" FontSize="12" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding Image}" />
                                                <TextBlock Text="{Binding Ports}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="3" Text="{Binding Status}" VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding Status}" />
                                            <TextBlock Grid.Column="4" Text="{Binding Created}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <StackPanel x:Name="ContainerEmpty" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8" Visibility="Collapsed">
                                <FontIcon FontSize="40" Glyph="&#xEC7A;" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock x:Name="ContainerEmptyTxt" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- detail card -->
                    <Border x:Name="ContainerDetail" Grid.Row="2" Visibility="Collapsed" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="8" Padding="14" MaxHeight="220">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="DetailName" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap" />
                                    <TextBlock x:Name="DetailStats" Grid.Column="1" FontSize="12" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                                <TextBox x:Name="DetailBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" FontFamily="Consolas" FontSize="12" BorderThickness="0" Background="Transparent" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </PivotItem>

            <!-- ===================== IMAGES ===================== -->
            <PivotItem x:Name="ImagesTab">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="PullBox" Grid.Column="0" PlaceholderText="e.g. nginx:latest · 例如 nginx:latest" />
                        <Button x:Name="PullBtn" Grid.Column="1" Click="Pull_Click" Style="{StaticResource AccentButtonStyle}"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon FontSize="14" Glyph="&#xE896;" /><TextBlock x:Name="PullLbl" /></StackPanel></Button>
                        <Button x:Name="ImgRemoveBtn" Grid.Column="2" Click="ImgRemove_Click"><FontIcon FontSize="14" Glyph="&#xE74D;" /></Button>
                        <Button x:Name="ImgPruneBtn" Grid.Column="3" Click="ImgPrune_Click"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon FontSize="14" Glyph="&#xEA99;" /><TextBlock x:Name="ImgPruneLbl" /></StackPanel></Button>
                    </Grid>
                    <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <ListView x:Name="ImageList" SelectionMode="Single">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem"><Setter Property="HorizontalContentAlignment" Value="Stretch" /><Setter Property="Padding" Value="10,8" /></Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" MinWidth="240" />
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Repo}" VerticalAlignment="Center" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding Repo}" />
                                        <TextBlock Grid.Column="1" Text="{Binding ShortId}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Column="2" Text="{Binding Size}" VerticalAlignment="Center" FontSize="12" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Grid>
            </PivotItem>

            <!-- ===================== VOLUMES ===================== -->
            <PivotItem x:Name="VolumesTab">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6">
                        <Button x:Name="VolCreateBtn" Click="VolCreate_Click" Style="{StaticResource AccentButtonStyle}"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon FontSize="14" Glyph="&#xE710;" /><TextBlock x:Name="VolCreateLbl" /></StackPanel></Button>
                        <Button x:Name="VolRemoveBtn" Click="VolRemove_Click"><FontIcon FontSize="14" Glyph="&#xE74D;" /></Button>
                        <Button x:Name="VolPruneBtn" Click="VolPrune_Click"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon FontSize="14" Glyph="&#xEA99;" /><TextBlock x:Name="VolPruneLbl" /></StackPanel></Button>
                    </StackPanel>
                    <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <ListView x:Name="VolumeList" SelectionMode="Single">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem"><Setter Property="HorizontalContentAlignment" Value="Stretch" /><Setter Property="Padding" Value="10,8" /></Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" MinWidth="200" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="2*" MinWidth="180" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding Name}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Driver}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Column="2" Text="{Binding Mountpoint}" VerticalAlignment="Center" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding Mountpoint}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Grid>
            </PivotItem>

            <!-- ===================== NETWORKS ===================== -->
            <PivotItem x:Name="NetworksTab">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6">
                        <Button x:Name="NetCreateBtn" Click="NetCreate_Click" Style="{StaticResource AccentButtonStyle}"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon FontSize="14" Glyph="&#xE710;" /><TextBlock x:Name="NetCreateLbl" /></StackPanel></Button>
                        <Button x:Name="NetRemoveBtn" Click="NetRemove_Click"><FontIcon FontSize="14" Glyph="&#xE74D;" /></Button>
                        <Button x:Name="NetPruneBtn" Click="NetPrune_Click"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon FontSize="14" Glyph="&#xEA99;" /><TextBlock x:Name="NetPruneLbl" /></StackPanel></Button>
                    </StackPanel>
                    <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <ListView x:Name="NetworkList" SelectionMode="Single">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem"><Setter Property="HorizontalContentAlignment" Value="Stretch" /><Setter Property="Padding" Value="10,8" /></Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" MinWidth="200" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="160" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding Name}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Driver}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Column="2" Text="{Binding Scope}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Column="3" Text="{Binding ShortId}" VerticalAlignment="Center" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Grid>
            </PivotItem>

            <!-- ===================== COMPOSE ===================== -->
            <PivotItem x:Name="ComposeTab">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Spacing="8">
                        <TextBlock x:Name="ComposeBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ComposePathBox" Grid.Column="0" Header="docker-compose.yml" IsReadOnly="True" PlaceholderText="Pick a file… · 揀一個檔案…" />
                            <Button x:Name="ComposePickBtn" Grid.Column="1" Click="ComposePick_Click" VerticalAlignment="Bottom"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon FontSize="14" Glyph="&#xE8E5;" /><TextBlock x:Name="ComposePickLbl" /></StackPanel></Button>
                        </Grid>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ComposeNameBox" Grid.Column="0" Header="Project name · 專案名稱" />
                            <Button x:Name="ComposeUpBtn" Grid.Column="1" Click="ComposeUp_Click" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Bottom"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon FontSize="14" Glyph="&#xE768;" /><TextBlock x:Name="ComposeUpLbl" /></StackPanel></Button>
                            <Button x:Name="ComposeDownBtn" Grid.Column="2" Click="ComposeDown_Click" VerticalAlignment="Bottom"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon FontSize="14" Glyph="&#xE71A;" /><TextBlock x:Name="ComposeDownLbl" /></StackPanel></Button>
                        </Grid>
                        <InfoBar x:Name="ComposeWarnBar" IsClosable="True" IsOpen="False" Severity="Warning" />
                    </StackPanel>

                    <TextBlock x:Name="ComposeLogLbl" Grid.Row="1" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,4,0,0" />
                    <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="10">
                        <TextBox x:Name="ComposeLogBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" FontFamily="Consolas" FontSize="12" BorderThickness="0" Background="Transparent" />
                    </Border>
                </Grid>
            </PivotItem>

        </Pivot>
    </Grid>
</Page>
