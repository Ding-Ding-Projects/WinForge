<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.UnitConvertModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE9CE;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="CategoryLabel" FontWeight="SemiBold" />
                        <ComboBox x:Name="CategoryBox" HorizontalAlignment="Stretch" SelectionChanged="Category_Changed" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="ValueLabel" FontWeight="SemiBold" />
                        <NumberBox x:Name="ValueBox" Value="1" SpinButtonPlacementMode="Compact" ValueChanged="Any_Changed" HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock x:Name="FromLabel" FontWeight="SemiBold" />
                            <ComboBox x:Name="FromBox" HorizontalAlignment="Stretch" SelectionChanged="Any_Changed" />
                        </StackPanel>
                        <FontIcon Grid.Column="1" Glyph="&#xE8AB;" VerticalAlignment="Bottom" Margin="0,0,0,8" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock x:Name="ToLabel" FontWeight="SemiBold" />
                            <ComboBox x:Name="ToBox" HorizontalAlignment="Stretch" SelectionChanged="Any_Changed" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="ResultText" FontWeight="SemiBold" FontSize="22" TextWrapping="Wrap" />
                    <TextBlock x:Name="SummaryText" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource SystemFillColorCriticalBrush}" TextWrapping="Wrap" Visibility="Collapsed" />
                    <Button x:Name="CopyButton" Click="Copy_Click" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                            <TextBlock x:Name="CopyLabel" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="ReferenceTitle" FontWeight="SemiBold" />
                    <TextBlock x:Name="ReferenceList" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
