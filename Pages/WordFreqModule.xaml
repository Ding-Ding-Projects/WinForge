<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.WordFreqModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE8A5;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <TextBlock x:Name="InputLabel" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="140" MaxHeight="240" ScrollViewer.VerticalScrollBarVisibility="Auto" TextChanged="Input_Changed" />

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="ModeLabel" VerticalAlignment="Center" />
                        <ComboBox x:Name="ModeBox" MinWidth="160" SelectionChanged="Options_Changed" SelectedIndex="0" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="MinLenLabel" VerticalAlignment="Center" />
                        <NumberBox x:Name="MinLenBox" Value="1" Minimum="1" Maximum="20" SpinButtonPlacementMode="Inline" MinWidth="130" ValueChanged="MinLen_Changed" />
                    </StackPanel>

                    <CheckBox x:Name="CaseChk" IsChecked="True" Checked="Options_Changed" Unchecked="Options_Changed" />
                    <CheckBox x:Name="PunctChk" IsChecked="True" Checked="Options_Changed" Unchecked="Options_Changed" />
                    <CheckBox x:Name="StopChk" Checked="Options_Changed" Unchecked="Options_Changed" />
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TotalsText" Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Button x:Name="CopyBtn" Grid.Column="1" Click="Copy_Click" />
            </Grid>

            <Border Padding="4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <ListView x:Name="ResultsList" SelectionMode="None" MaxHeight="520">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="6,4,6,4" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="56" />
                                    <ColumnDefinition Width="56" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Rank}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Term}" TextTrimming="CharacterEllipsis" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Rectangle Grid.Column="2" Width="{Binding BarWidth}" Height="12" RadiusX="3" RadiusY="3" HorizontalAlignment="Left" VerticalAlignment="Center" Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                                <TextBlock Grid.Column="3" Text="{Binding Count}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="4" Text="{Binding Percent}" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
