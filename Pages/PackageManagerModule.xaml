<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.PackageManagerModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Style="{StaticResource WinForgePageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="6">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xECAA;" />
            <TextBlock
                x:Name="HeaderBlurb"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />
        </StackPanel>

        <!-- Manager filter -->
        <Border
            Grid.Row="1"
            Padding="14,10,14,10"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel Spacing="6">
                <TextBlock x:Name="ManagersLabel" FontWeight="SemiBold" FontSize="13" />
                <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Auto" VerticalScrollMode="Disabled">
                    <StackPanel x:Name="ManagerFilters" Orientation="Horizontal" Spacing="14" />
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Controls -->
        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="ViewCombo" Grid.Column="0" MinWidth="160" SelectionChanged="View_Changed" />
            <AutoSuggestBox
                x:Name="SearchBox"
                Grid.Column="1"
                QueryIcon="Find"
                QuerySubmitted="Search_Submitted" />
            <Button x:Name="SearchOptionsBtn" Grid.Column="2">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE71C;" />
                    <TextBlock x:Name="SearchOptionsText" />
                </StackPanel>
                <Button.Flyout>
                    <Flyout>
                        <StackPanel Width="300" Spacing="10">
                            <TextBlock x:Name="SearchOptionsTitle" FontWeight="SemiBold" />
                            <TextBlock
                                x:Name="SearchModeLabel"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <RadioButton x:Name="SearchModeBoth" Tag="Both" Checked="SearchMode_Checked" GroupName="PackageSearchMode" />
                            <RadioButton x:Name="SearchModeName" Tag="Name" Checked="SearchMode_Checked" GroupName="PackageSearchMode" />
                            <RadioButton x:Name="SearchModeId" Tag="Id" Checked="SearchMode_Checked" GroupName="PackageSearchMode" />
                            <RadioButton x:Name="SearchModeExact" Tag="Exact" Checked="SearchMode_Checked" GroupName="PackageSearchMode" />
                            <RadioButton x:Name="SearchModeSimilar" Tag="Similar" Checked="SearchMode_Checked" GroupName="PackageSearchMode" />
                            <ToggleSwitch x:Name="SearchCaseToggle" Toggled="SearchOption_Toggled" />
                            <ToggleSwitch x:Name="SearchIgnoreSpecialToggle" Toggled="SearchOption_Toggled" />
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
            <Button x:Name="PrimaryActionBtn" Grid.Column="3" Click="PrimaryAction_Click" />
            <Button x:Name="SecondaryActionBtn" Grid.Column="4" Click="SecondaryAction_Click" />
            <Button x:Name="TerminalBtn" Grid.Column="5" Click="Terminal_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE756;" />
                    <TextBlock x:Name="TerminalBtnText" />
                </StackPanel>
            </Button>
            <ProgressRing x:Name="Busy" Grid.Column="6" Width="22" Height="22" IsActive="False" VerticalAlignment="Center" />
        </Grid>

        <!-- Results -->
        <Grid Grid.Row="3" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock
                x:Name="ResultsHeader"
                Grid.Row="0"
                FontWeight="SemiBold"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <!-- Batch (multi-select) action bar — UniGetUI-style bulk operations -->
            <Border
                x:Name="BatchBar"
                Grid.Row="1"
                Padding="12,8,12,8"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock x:Name="BatchLabel" VerticalAlignment="Center" FontWeight="SemiBold" />
                    <Button x:Name="BatchInstallBtn" Click="BatchInstall_Click" />
                    <Button x:Name="BatchUpdateBtn" Click="BatchUpdate_Click" />
                    <Button x:Name="BatchUninstallBtn" Click="BatchUninstall_Click" />
                    <Button x:Name="BatchExportBtn" Click="BatchExport_Click" />
                    <Button x:Name="BatchClearBtn" Click="BatchClear_Click" />
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ResultsPanel" Spacing="6" />
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
