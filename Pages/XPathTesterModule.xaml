<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.XPathTesterModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE773;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="XmlLabel" FontWeight="SemiBold" />
                        <TextBox x:Name="XmlBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="180"
                                 FontFamily="Consolas" IsSpellCheckEnabled="False"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" TextChanged="Input_Changed" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="XPathLabel" FontWeight="SemiBold" />
                        <TextBox x:Name="XPathBox" FontFamily="Consolas" IsSpellCheckEnabled="False" TextChanged="Input_Changed" />
                    </StackPanel>

                    <TextBlock x:Name="StatusText" FontSize="12" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="ResultsLabel" FontWeight="SemiBold" />
                    <ListView x:Name="ResultsList" MaxHeight="360" SelectionMode="None"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="2" Padding="0,6,0,6">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontFamily="Consolas" />
                                    <TextBlock Text="{Binding Value}" TextWrapping="Wrap"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{Binding Outer}" TextWrapping="Wrap" FontSize="12" FontFamily="Consolas"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock x:Name="EmptyText" FontSize="12"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
