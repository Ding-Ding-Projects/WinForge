<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.RomanNumModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE943;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="Status" IsOpen="False" IsClosable="False" />

            <StackPanel Orientation="Horizontal" Spacing="12">
                <ToggleSwitch x:Name="ExtendedSwitch" Toggled="Extended_Toggled" />
                <TextBlock x:Name="ExtendedNote" VerticalAlignment="Center" FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" MaxWidth="560" />
            </StackPanel>

            <!-- Number -> Roman -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="N2RTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="NumberInput" TextChanged="Number_Changed" InputScope="Number" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="RomanOut" Grid.Column="0" FontSize="24" FontWeight="SemiBold"
                                   IsTextSelectionEnabled="True" TextWrapping="Wrap" VerticalAlignment="Center" />
                        <Button x:Name="CopyRomanBtn" Grid.Column="1" Click="CopyRoman_Click" VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock x:Name="RomanBreakdown" FontSize="12" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Roman -> Number -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="R2NTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBox x:Name="RomanInput" TextChanged="Roman_Changed" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="NumberOut" Grid.Column="0" FontSize="24" FontWeight="SemiBold"
                                   IsTextSelectionEnabled="True" TextWrapping="Wrap" VerticalAlignment="Center" />
                        <Button x:Name="CopyNumberBtn" Grid.Column="1" Click="CopyNumber_Click" VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock x:Name="NumberBreakdown" FontSize="12" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
