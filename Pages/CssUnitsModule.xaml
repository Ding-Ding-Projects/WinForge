<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.CssUnitsModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE943;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <TextBlock x:Name="InputTitle" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBox x:Name="ValueBox" Text="16" MinWidth="180" TextChanged="Input_Changed" />
                        <ComboBox x:Name="UnitBox" MinWidth="110" SelectionChanged="Unit_Changed" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="ContextTitle" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock x:Name="ContextBlurb" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <Grid ColumnSpacing="12" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                            <TextBlock x:Name="RootLabel" FontSize="12" />
                            <NumberBox x:Name="RootBox" Value="16" Minimum="0" SmallChange="1" ValueChanged="Ctx_Changed" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                            <TextBlock x:Name="ElemLabel" FontSize="12" />
                            <NumberBox x:Name="ElemBox" Value="16" Minimum="0" SmallChange="1" ValueChanged="Ctx_Changed" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2">
                            <TextBlock x:Name="VwLabel" FontSize="12" />
                            <NumberBox x:Name="VwBox" Value="1920" Minimum="0" SmallChange="10" ValueChanged="Ctx_Changed" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
                            <TextBlock x:Name="VhLabel" FontSize="12" />
                            <NumberBox x:Name="VhBox" Value="1080" Minimum="0" SmallChange="10" ValueChanged="Ctx_Changed" />
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0" Spacing="2">
                            <TextBlock x:Name="ContainerLabel" FontSize="12" />
                            <NumberBox x:Name="ContainerBox" Value="1000" Minimum="0" SmallChange="10" ValueChanged="Ctx_Changed" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ResultsTitle" Grid.Column="0" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                        <TextBlock x:Name="CopyHint" Grid.Column="1" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                    </Grid>
                    <ListView x:Name="ResultsList" SelectionMode="None" IsItemClickEnabled="True" ItemClick="Result_Click">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="4,6,4,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Unit}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Value}" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Consolas" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
