<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.ManualPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:local="using:WinForge.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Style="{StaticResource WinForgePageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header: title + language toggle  -->
        <controls:ModuleHeader x:Name="Header" Grid.Row="0" Glyph="&#xE82D;">
            <controls:ModuleHeader.ActionContent>
                <Button
                    x:Name="LangToggle"
                    VerticalAlignment="Center"
                    Click="LangToggle_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE8C1;" />
                        <TextBlock x:Name="LangToggleText" />
                    </StackPanel>
                </Button>
            </controls:ModuleHeader.ActionContent>
        </controls:ModuleHeader>

        <!--  Body: TOC (left) + content (right)  -->
        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Table of contents + search  -->
            <Grid Grid.Column="0" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <AutoSuggestBox
                    x:Name="FilterBox"
                    Grid.Row="0"
                    QueryIcon="Find"
                    TextChanged="FilterBox_TextChanged" />
                <ScrollViewer
                    Grid.Row="1"
                    Padding="0,0,8,16"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="TocPanel" Spacing="2" />
                </ScrollViewer>
            </Grid>

            <!--  Content  -->
            <ScrollViewer
                x:Name="ContentScroller"
                Grid.Column="1"
                Padding="4,0,16,16"
                VerticalScrollBarVisibility="Auto">
                <StackPanel
                    x:Name="ContentPanel"
                    MaxWidth="820"
                    HorizontalAlignment="Left"
                    Spacing="14" />
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
