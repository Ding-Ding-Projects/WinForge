<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.TestDiskModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Style="{StaticResource WinForgePageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <controls:ModuleHeader x:Name="Header" Grid.Row="0" Glyph="&#xE7BA;" />

        <!-- Engine / install banner -->
        <InfoBar x:Name="EngineBar" Grid.Row="1" IsClosable="False" IsOpen="False" Severity="Warning">
            <InfoBar.ActionButton>
                <Button x:Name="DownloadBtn" Click="Download_Click" />
            </InfoBar.ActionButton>
        </InfoBar>

        <!-- Configuration card -->
        <Border
            Grid.Row="2"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16">
            <StackPanel Spacing="12">

                <!-- Source row -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="SourceLabel" Grid.Column="0" VerticalAlignment="Center" Width="150" TextWrapping="Wrap" />
                    <ComboBox x:Name="SourceCombo" Grid.Column="1" HorizontalAlignment="Stretch" SelectionChanged="Source_Changed" />
                    <Button x:Name="ImageBtn" Grid.Column="2" Click="PickImage_Click" />
                    <Button x:Name="RefreshDisksBtn" Grid.Column="3" Click="RefreshDisks_Click" />
                </Grid>

                <!-- Output row -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="OutputLabel" Grid.Column="0" VerticalAlignment="Center" Width="150" TextWrapping="Wrap" />
                    <TextBox x:Name="OutputBox" Grid.Column="1" IsReadOnly="True" />
                    <Button x:Name="OutputBtn" Grid.Column="2" Click="PickOutput_Click" />
                </Grid>

                <!-- Same-disk warning -->
                <InfoBar x:Name="SameDiskBar" IsClosable="False" IsOpen="False" Severity="Error" />

                <!-- File-type selection -->
                <Grid ColumnSpacing="8" RowSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="TypesLabel" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <CheckBox x:Name="FreeSpaceCheck" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" />
                    <Button x:Name="SelectAllBtn" Grid.Row="0" Grid.Column="2" Click="SelectAll_Click" />
                    <Button x:Name="SelectNoneBtn" Grid.Row="0" Grid.Column="3" Click="SelectNone_Click" />

                    <Border Grid.Row="1" Grid.ColumnSpan="4"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="6" Padding="8" MaxHeight="200">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalScrollMode="Auto">
                            <ItemsControl x:Name="TypesList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox MinWidth="0" Margin="0,1,0,1"
                                                  IsChecked="{Binding Selected, Mode=TwoWay}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding Token}" FontFamily="Consolas" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Description}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </StackPanel>
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- Action row -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="CarveBtn" Grid.Column="0" Style="{StaticResource AccentButtonStyle}" Click="Carve_Click" />
                    <Button x:Name="ScanBtn" Grid.Column="1" Click="Scan_Click" />
                    <Button x:Name="CancelBtn" Grid.Column="3" Click="Cancel_Click" IsEnabled="False" />
                    <Button x:Name="OpenFolderBtn" Grid.Column="4" Click="OpenFolder_Click" IsEnabled="False" />
                </Grid>

                <!-- Progress -->
                <StackPanel x:Name="ProgressPanel" Spacing="4" Visibility="Collapsed">
                    <ProgressBar x:Name="Progress" IsIndeterminate="True" />
                    <TextBlock x:Name="ProgressText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Live log -->
        <Border
            Grid.Row="3"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Padding="12,8,12,8" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="LogTitle" Grid.Column="0" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                    <Button x:Name="ClearLogBtn" Grid.Column="1" Click="ClearLog_Click" />
                </Grid>
                <ScrollViewer x:Name="LogScroller" Grid.Row="1" Padding="12,0,12,12" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="LogText" FontFamily="Consolas" FontSize="12" IsTextSelectionEnabled="True" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </ScrollViewer>
            </Grid>
        </Border>

        <InfoBar x:Name="ResultBar" Grid.Row="4" IsClosable="True" IsOpen="False" />
    </Grid>
</Page>
