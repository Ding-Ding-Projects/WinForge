<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.NameGenModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE897;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="TypeLabel" FontWeight="SemiBold" />
                        <ComboBox x:Name="TypeBox" MinWidth="240" SelectionChanged="Type_Changed" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="CountLabel" VerticalAlignment="Center" />
                        <NumberBox x:Name="CountBox" Value="10" Minimum="1" Maximum="100" SpinButtonPlacementMode="Inline" MinWidth="140" ValueChanged="Count_Changed" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="RegenBtn" Click="Regen_Click" Style="{ThemeResource AccentButtonStyle}" />
                        <Button x:Name="CopyBtn" Click="Copy_Click" />
                    </StackPanel>

                    <TextBox x:Name="OutputBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                             MinHeight="220" FontFamily="Consolas"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" />

                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
