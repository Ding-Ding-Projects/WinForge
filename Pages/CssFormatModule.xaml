<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinForge.Pages.CssFormatModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:WinForge.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" Spacing="14">
            <controls:ModuleHeader x:Name="Header" Glyph="&#xE943;" />
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Button x:Name="FormatBtn" Click="Format_Click" Style="{ThemeResource AccentButtonStyle}" />
                        <Button x:Name="MinifyBtn" Click="Minify_Click" />
                        <Button x:Name="CopyBtn" Click="Copy_Click" />
                        <Button x:Name="ClearBtn" Click="Clear_Click" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="IndentLabel" VerticalAlignment="Center" />
                        <NumberBox x:Name="IndentBox" Value="2" Minimum="0" Maximum="8" SpinButtonPlacementMode="Inline" MinWidth="130" />
                    </StackPanel>

                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Grid ColumnSpacing="14" RowSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="InputLabel" Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" />
                <TextBlock x:Name="OutputLabel" Grid.Row="0" Grid.Column="1" FontWeight="SemiBold" />

                <TextBox x:Name="InputBox" Grid.Row="1" Grid.Column="0"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         FontFamily="Consolas" MinHeight="340"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto" />

                <TextBox x:Name="OutputBox" Grid.Row="1" Grid.Column="1"
                         AcceptsReturn="True" TextWrapping="NoWrap" IsReadOnly="True"
                         FontFamily="Consolas" MinHeight="340"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto" />
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
