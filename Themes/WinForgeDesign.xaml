<?xml version="1.0" encoding="utf-8" ?>
<!--
    WinForge shared design system · WinForge 共用設計系統
    ============================================================================
    One place to define the page-level visual language so all ~130 module pages
    stay consistent. Change a value here → every migrated page updates.
    所有模組頁面共用嘅版面語言：喺呢度改一次，全部已遷移嘅頁面都會跟住變。

    All brushes referenced here are built-in Fluent ThemeResources, so Light,
    Dark and High-Contrast are all handled by the framework automatically — no
    custom ThemeDictionaries needed.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  ── Spacing / metric tokens · 間距與尺寸代號 ──  -->
    <x:Double x:Key="WinForgeCardCornerRadius">8</x:Double>
    <x:Double x:Key="WinForgeSubtleCornerRadius">6</x:Double>
    <x:Double x:Key="WinForgePillCornerRadius">10</x:Double>
    <Thickness x:Key="WinForgePagePadding">24,16,24,24</Thickness>
    <Thickness x:Key="WinForgeCardPadding">16,14,16,14</Thickness>
    <Thickness x:Key="WinForgeSubtleCardPadding">12</Thickness>
    <x:Double x:Key="WinForgePageContentSpacing">12</x:Double>

    <!--  ── Page root · 頁面根 Grid ──
          Apply to a page's outer Grid:  Style="{StaticResource WinForgePageGridStyle}"  -->
    <Style x:Key="WinForgePageGridStyle" TargetType="Grid">
        <Setter Property="Padding" Value="{StaticResource WinForgePagePadding}" />
        <Setter Property="RowSpacing" Value="{StaticResource WinForgePageContentSpacing}" />
    </Style>

    <!--  ── Card surfaces · 卡片表面 ──
          Primary, layered card. Use for the main content blocks on a page.  -->
    <Style x:Key="WinForgeCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource WinForgeCardCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource WinForgeCardPadding}" />
    </Style>

    <!--  Secondary / nested surface (sits inside a primary card, or for output panes).  -->
    <Style x:Key="WinForgeSubtleCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource WinForgeSubtleCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource WinForgeSubtleCardPadding}" />
    </Style>

    <!--  ── Typography helpers · 字體 ──  -->
    <Style
        x:Key="WinForgeSectionHeaderStyle"
        BasedOn="{StaticResource BodyStrongTextBlockStyle}"
        TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <Style x:Key="WinForgeCaptionStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!--  ── Status pill · 狀態藥丸 ──
          Neutral by default; override Background/Foreground for success/warn/crit.  -->
    <Style x:Key="WinForgeStatusPillStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource WinForgePillCornerRadius}" />
        <Setter Property="Padding" Value="10,2,10,2" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Background" Value="{ThemeResource ControlFillColorSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

</ResourceDictionary>
