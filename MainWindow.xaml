<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="WinForge.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:WinForge"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    Title="WinForge · 視窗調校"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            FontFamily="{StaticResource WinForgeUiFont}"
            Title="WinForge · 視窗調校"
            BackRequested="TitleBar_BackRequested"
            IsBackButtonVisible="False"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="TitleBar_PaneToggleRequested"
            automation:AutomationProperties.Name="WinForge title bar · WinForge 標題列">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
            <TitleBar.Content>
                <Border
                    x:Name="ReactorPill"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="9,3,11,3"
                    CornerRadius="20"
                    Background="#1454E07E"
                    BorderBrush="#4054E07E"
                    BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Ellipse x:Name="ReactorPillDot" Width="6" Height="6" Fill="{StaticResource WinForgeBrandBrush}" />
                        <TextBlock x:Name="ReactorPillText" Text="REACTOR" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource WinForgeBrandBrush}" />
                    </StackPanel>
                </Border>
            </TitleBar.Content>
        </TitleBar>

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            FontFamily="{StaticResource WinForgeUiFont}"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="True"
            SelectionChanged="NavView_SelectionChanged"
            automation:AutomationProperties.AutomationId="ShellNavigationView"
            automation:AutomationProperties.Name="WinForge navigation · WinForge 導航">
            <NavigationView.AutoSuggestBox>
                <AutoSuggestBox
                    x:Name="SearchBox"
                    QueryIcon="Find"
                    PlaceholderText="Search everything · 搜尋全部"
                    MaxSuggestionListHeight="420"
                    TextMemberPath="Title"
                    QuerySubmitted="SearchBox_QuerySubmitted"
                    TextChanged="SearchBox_TextChanged"
                    automation:AutomationProperties.AutomationId="ShellSearchBox"
                    automation:AutomationProperties.Name="Search all WinForge modules · 搜尋全部 WinForge 模組">
                    <AutoSuggestBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Padding="0,4" Spacing="2">
                                <TextBlock
                                    Text="{Binding Title}"
                                    FontWeight="SemiBold"
                                    MaxLines="1"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Text="{Binding Subtitle}"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    MaxLines="1"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </AutoSuggestBox.ItemTemplate>
                </AutoSuggestBox>
            </NavigationView.AutoSuggestBox>
            <NavigationView.MenuItems>
                <NavigationViewItemHeader Content="Suite · 套件" />
