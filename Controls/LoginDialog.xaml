<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="WinForge.Controls.LoginDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    CornerRadius="8"
    mc:Ignorable="d">

    <Grid
        x:Name="RootGrid"
        MinWidth="900"
        MinHeight="680"
        RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Address / status bar -->
        <Grid Grid.Row="0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button
                x:Name="BackButton"
                Grid.Column="0"
                Width="36"
                Padding="0"
                Click="Back_Click"
                ToolTipService.ToolTip="Back · 返回">
                <FontIcon FontSize="14" Glyph="&#xE72B;" />
            </Button>
            <Button
                x:Name="ReloadButton"
                Grid.Column="1"
                Width="36"
                Padding="0"
                Click="Reload_Click"
                ToolTipService.ToolTip="Reload · 重新載入">
                <FontIcon FontSize="14" Glyph="&#xE72C;" />
            </Button>
            <TextBox
                x:Name="AddressBox"
                Grid.Column="2"
                VerticalAlignment="Center"
                IsSpellCheckEnabled="False"
                KeyDown="Address_KeyDown" />
            <ProgressRing
                x:Name="Spinner"
                Grid.Column="3"
                Width="20"
                Height="20"
                IsActive="False" />
        </Grid>

        <InfoBar
            x:Name="ErrorBar"
            Grid.Row="1"
            IsClosable="True"
            IsOpen="False"
            Severity="Error" />

        <Border
            Grid.Row="2"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="6">
            <controls:WebView2
                x:Name="Web"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" />
        </Border>
    </Grid>
</ContentDialog>
