<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="WinForge.Controls.EmbeddedTerminalPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WinForge.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar: connect / disconnect / clear + live status -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
            <Button x:Name="StartBtn" Style="{StaticResource AccentButtonStyle}" Click="Start_Click" />
            <Button x:Name="StopBtn" Click="Stop_Click" IsEnabled="False" />
            <Button x:Name="ClearBtn" Click="Clear_Click" />
            <TextBlock
                x:Name="StatusText"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <controls:TerminalView x:Name="Term" Grid.Row="1" />
    </Grid>
</UserControl>
