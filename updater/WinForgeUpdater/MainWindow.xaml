<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WinForgeUpdater.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WinForge Updater">

    <Grid x:Name="Root" RequestedTheme="Dark" Background="#FF0A0D0B" Padding="28,26,28,24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="13">
            <Border Width="40" Height="40" CornerRadius="11" VerticalAlignment="Center">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF54E07E" Offset="0" />
                        <GradientStop Color="#FF1F5A30" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <FontIcon Glyph="&#xE777;" FontSize="20" Foreground="#FF06210F" />
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Updating WinForge" FontSize="20" FontWeight="SemiBold" Foreground="#FFEDF3ED" />
                <TextBlock x:Name="SubTitle" Text="視窗調校更新中" FontSize="12.5" Foreground="#FF54E07E" />
            </StackPanel>
        </StackPanel>

        <!-- Status line -->
        <TextBlock x:Name="StatusText" Grid.Row="1" FontSize="14" Foreground="#FFEDF3ED" TextWrapping="Wrap"
                   Text="Preparing the update… · 準備更新…" />

        <!-- Progress -->
        <StackPanel Grid.Row="2" Spacing="6">
            <ProgressBar x:Name="Bar" Minimum="0" Maximum="100" Value="0" Height="8" />
            <TextBlock x:Name="DetailText" FontSize="11.5" FontFamily="Consolas" Foreground="#FF95A395" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Log -->
        <Border Grid.Row="3" Background="#FF131814" BorderBrush="#1FFFFFFF" BorderThickness="1" CornerRadius="8" Padding="10,8,10,8">
            <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="LogText" FontFamily="Consolas" FontSize="11" Foreground="#FFBFCBBF" TextWrapping="Wrap" />
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <TextBlock x:Name="TagText" VerticalAlignment="Center" FontSize="11.5" Foreground="#FF6E7A6E" />
            <Button x:Name="CloseBtn" Content="Close · 關閉" Visibility="Collapsed" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
