<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="WinForgeUpdater.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <!-- Reactor-green accent to match WinForge. -->
            <Color x:Key="SystemAccentColor">#FF54E07E</Color>
            <Color x:Key="SystemAccentColorLight1">#FF6BE892</Color>
            <Color x:Key="SystemAccentColorLight2">#FF82EBA4</Color>
            <Color x:Key="SystemAccentColorLight3">#FF9FF0BA</Color>
            <Color x:Key="SystemAccentColorDark1">#FF2FAF57</Color>
            <Color x:Key="SystemAccentColorDark2">#FF279048</Color>
            <Color x:Key="SystemAccentColorDark3">#FF1F7239</Color>
        </ResourceDictionary>
    </Application.Resources>
</Application>
